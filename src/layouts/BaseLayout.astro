---
interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: object | object[];
}

const { title, description, canonical, schema } = Astro.props;

const CONSENTMANAGER_ID = import.meta.env.PUBLIC_CONSENTMANAGER_ID || "";
const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || "";
const schemaItems = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const currentPath = new URL(canonical).pathname;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
        wait_for_update: 500,
      });
      gtag("set", "ads_data_redaction", true);
      gtag("set", "url_passthrough", true);
    </script>

    {
      CONSENTMANAGER_ID ? (
        <script
          type="text/javascript"
          data-cmp-ab="1"
          src={`https://cdn.consentmanager.net/delivery/autoblocking/${CONSENTMANAGER_ID}.js`}
          data-cmp-host="c.delivery.consentmanager.net"
          data-cmp-cdn="cdn.consentmanager.net"
          data-cmp-codesrc="0"
          is:inline
        />
      ) : null
    }

    {
      ADSENSE_ID ? (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_ID}`}
          crossorigin="anonymous"
        />
      ) : null
    }

    {
      schemaItems.map((schemaItem) => (
        <script type="application/ld+json" set:html={JSON.stringify(schemaItem)} />
      ))
    }

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Einschulungsrechner" />

    <slot name="head" />
  </head>

  <body>
    <slot />

    <footer class="base-footer">
      <nav class="base-footer-nav" aria-label="Rechtliches">
        {currentPath !== "/impressum/" ? <a class="base-footer-link" href="/impressum/">Impressum</a> : null}
        {currentPath !== "/datenschutz/" ? <a class="base-footer-link" href="/datenschutz/">Datenschutz</a> : null}
        {CONSENTMANAGER_ID ? (
          <button type="button" class="base-footer-button" data-consentmanager-settings>
            Cookie-Einstellungen
          </button>
        ) : null}
      </nav>
    </footer>

    <script>
      document.addEventListener("click", (event) => {
        const consentTarget = event.target instanceof Element
          ? event.target.closest("[data-consentmanager-settings]")
          : null;

        if (consentTarget) {
          event.preventDefault();
          if (typeof window.__cmp === "function") {
            window.__cmp("showScreen");
          }
          return;
        }

        const backTarget = event.target instanceof Element
          ? event.target.closest("[data-history-back]")
          : null;

        if (!backTarget) return;

        if (window.history.length > 1) {
          event.preventDefault();
          window.history.back();
        }
      });
    </script>
  </body>
</html>

<style is:global>
  .base-footer {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    width: 100% !important;
    box-sizing: border-box !important;
    margin: 38px 0 0 !important;
    padding: 18px 14px !important;
    border-top: 1px solid rgba(42, 35, 21, 0.08) !important;
    text-align: center !important;
  }

  .base-footer-nav {
    display: flex !important;
    flex: 0 1 auto !important;
    flex-wrap: nowrap !important;
    justify-content: center !important;
    align-items: center !important;
    gap: clamp(10px, 2.4vw, 22px) !important;
    width: auto !important;
    max-width: calc(100vw - 20px) !important;
    margin: 0 auto !important;
    white-space: nowrap !important;
  }

  .base-footer-link,
  .base-footer-button {
    display: inline-flex !important;
    flex: 0 0 auto !important;
    align-items: center !important;
    justify-content: center !important;
    color: #816126;
    font: inherit;
    font-size: clamp(0.7rem, 2.8vw, 0.86rem);
    font-weight: 800;
    letter-spacing: 0.005em;
    line-height: 1.15;
    text-align: center;
    text-decoration: none;
    white-space: nowrap !important;
  }

  .base-footer-button {
    width: auto !important;
    height: auto !important;
    min-width: 0 !important;
    min-height: 0 !important;
    padding: 0 !important;
    border: 0 !important;
    border-radius: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
    color: #816126 !important;
    cursor: pointer;
    appearance: none;
  }

  .base-footer-link:hover,
  .base-footer-button:hover {
    color: #172033;
    text-decoration: underline;
  }

  @media (max-width: 520px) {
    .base-footer {
      margin-top: 28px !important;
      padding: 14px 6px !important;
    }

    .base-footer-nav {
      gap: clamp(7px, 2vw, 10px) !important;
      width: auto !important;
      max-width: calc(100vw - 12px) !important;
      margin: 0 auto !important;
    }

    .base-footer-link,
    .base-footer-button {
      font-size: clamp(0.66rem, 2.75vw, 0.78rem);
      letter-spacing: 0;
    }
  }
</style>