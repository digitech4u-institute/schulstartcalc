---
interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: object | object[];
}

const { title, description, canonical, schema } = Astro.props;

const CONSENTMANAGER_ID = import.meta.env.PUBLIC_CONSENTMANAGER_ID || "";
const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || "";
const schemaItems = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const currentPath = new URL(canonical).pathname;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
        wait_for_update: 500,
      });
      gtag("set", "ads_data_redaction", true);
      gtag("set", "url_passthrough", true);
    </script>

    {
      CONSENTMANAGER_ID ? (
        <script
          type="text/javascript"
          data-cmp-ab="1"
          src={`https://cdn.consentmanager.net/delivery/autoblocking/${CONSENTMANAGER_ID}.js`}
          data-cmp-host="c.delivery.consentmanager.net"
          data-cmp-cdn="cdn.consentmanager.net"
          data-cmp-codesrc="0"
          is:inline
        />
      ) : null
    }

    {
      ADSENSE_ID ? (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_ID}`}
          crossorigin="anonymous"
        />
      ) : null
    }

    {
      schemaItems.map((schemaItem) => (
        <script type="application/ld+json" set:html={JSON.stringify(schemaItem)} />
      ))
    }

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Einschulungsrechner" />

    <slot name="head" />
  </head>

  <body>
    <header class="base-header">
      <a class="base-header-brand" href="/" aria-label="Zur Startseite von Einschulungsrechner.de">
        Einschulungsrechner.de
      </a>

      <nav class="base-header-nav" aria-label="Hauptnavigation">
        <a class="base-header-link" href="/#einschulungsrechner">Rechner</a>
        <a class="base-header-link" href="/einschulung/">Ratgeber</a>
        <a class="base-header-link" href="/einschulung-checkliste/">Checkliste</a>
        <a class="base-header-link" href="/einschulung/#bundeslaender">Bundesländer</a>
      </nav>
    </header>

    <slot />

    <footer class="base-footer">
      <p class="base-footer-copyright">
        © 2026 DigiTech4U Institute
      </p>

      <nav class="base-footer-nav" aria-label="Rechtliches">
        {currentPath !== "/impressum/" ? <a class="base-footer-link" href="/impressum/">Impressum</a> : null}
        {currentPath !== "/datenschutz/" ? <a class="base-footer-link" href="/datenschutz/">Datenschutz</a> : null}
        {CONSENTMANAGER_ID ? (
          <button type="button" class="base-footer-button" data-consentmanager-settings>
            Cookie-Einstellungen
          </button>
        ) : null}
      </nav>
    </footer>

    <script>
      document.addEventListener("click", (event) => {
        const consentTarget = event.target instanceof Element
          ? event.target.closest("[data-consentmanager-settings]")
          : null;

        if (consentTarget) {
          event.preventDefault();
          if (typeof window.__cmp === "function") {
            window.__cmp("showScreen");
          }
          return;
        }

        const backTarget = event.target instanceof Element
          ? event.target.closest("[data-history-back]")
          : null;

        if (!backTarget) return;

        if (window.history.length > 1) {
          event.preventDefault();
          window.history.back();
        }
      });

      let lastScrollY = window.scrollY;
      let ticking = false;

      const updateHeaderVisibility = () => {
        const header = document.querySelector(".base-header");
        if (!header) return;

        const currentScrollY = window.scrollY;
        const scrollDelta = currentScrollY - lastScrollY;

        if (currentScrollY < 80) {
          header.classList.remove("base-header-hidden");
        } else if (scrollDelta > 8) {
          header.classList.add("base-header-hidden");
        } else if (scrollDelta < -8) {
          header.classList.remove("base-header-hidden");
        }

        lastScrollY = currentScrollY;
        ticking = false;
      };

      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            window.requestAnimationFrame(updateHeaderVisibility);
            ticking = true;
          }
        },
        { passive: true }
      );
    </script>
  </body>
</html>

<style is:global>
  .base-header {
    position: sticky !important;
    top: 0 !important;
    z-index: 1000 !important;
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    gap: 28px !important;
    width: min(960px, calc(100% - 40px)) !important;
    box-sizing: border-box !important;
    margin: 0 auto !important;
    padding: 14px 22px !important;
    border: 1px solid rgba(129, 97, 38, 0.12) !important;
    border-top: 0 !important;
    border-radius: 0 0 22px 22px !important;
    background:
      linear-gradient(180deg, rgba(255, 252, 246, 0.98) 0%, rgba(247, 238, 222, 0.94) 100%) !important;
    box-shadow: 0 14px 34px rgba(42, 35, 21, 0.08) !important;
    backdrop-filter: blur(14px) !important;
    transform: translateY(0) !important;
    transition: transform 0.22s ease !important;
  }

  .base-header.base-header-hidden {
    transform: translateY(-120%) !important;
  }

  .base-header-brand {
    flex: 0 0 auto !important;
    color: #816126 !important;
    font: inherit;
    font-size: clamp(0.88rem, 2.2vw, 1.02rem);
    font-weight: 850;
    letter-spacing: -0.015em;
    line-height: 1.15;
    text-decoration: none;
    white-space: nowrap !important;
  }

  .base-header-brand:hover {
    color: #172033 !important;
  }

  .base-header-nav {
    display: flex !important;
    flex: 0 1 auto !important;
    flex-wrap: nowrap !important;
    justify-content: flex-end !important;
    align-items: center !important;
    gap: clamp(14px, 2.8vw, 30px) !important;
    width: auto !important;
    max-width: calc(100vw - 20px) !important;
    margin: 0 !important;
    white-space: nowrap !important;
  }

  .base-header-link {
    display: inline-flex !important;
    flex: 0 0 auto !important;
    align-items: center !important;
    justify-content: center !important;
    color: #816126 !important;
    font: inherit;
    font-size: clamp(0.72rem, 2vw, 0.88rem);
    font-weight: 650;
    letter-spacing: 0.002em;
    line-height: 1.15;
    text-align: center;
    text-decoration: none;
    white-space: nowrap !important;
  }

  .base-header-link:hover {
    color: #172033 !important;
    text-decoration: underline;
  }

  :target {
    scroll-margin-top: 96px;
  }

  .base-footer {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    gap: 18px !important;
    width: min(960px, calc(100% - 40px)) !important;
    box-sizing: border-box !important;
    margin: 34px auto 0 !important;
    padding: 16px 0 18px !important;
    border-top: 1px solid rgba(42, 35, 21, 0.07) !important;
    text-align: center !important;
  }

  .base-footer-copyright {
    flex: 0 0 auto !important;
    margin: 0 !important;
    color: rgba(75, 85, 99, 0.78) !important;
    font: inherit;
    font-size: clamp(0.66rem, 2.2vw, 0.78rem);
    font-weight: 500;
    letter-spacing: 0.002em;
    line-height: 1.15;
    white-space: nowrap !important;
  }

  .base-footer-nav {
    display: flex !important;
    flex: 0 1 auto !important;
    flex-wrap: nowrap !important;
    justify-content: flex-end !important;
    align-items: center !important;
    gap: clamp(10px, 2.4vw, 22px) !important;
    width: auto !important;
    max-width: calc(100vw - 20px) !important;
    margin: 0 !important;
    white-space: nowrap !important;
  }

  .base-footer-link,
  .base-footer-button {
    display: inline-flex !important;
    flex: 0 0 auto !important;
    align-items: center !important;
    justify-content: center !important;
    color: rgba(75, 85, 99, 0.82);
    font: inherit;
    font-size: clamp(0.66rem, 2.2vw, 0.78rem);
    font-weight: 550;
    letter-spacing: 0.002em;
    line-height: 1.15;
    text-align: center;
    text-decoration: none;
    white-space: nowrap !important;
  }

  .base-footer-button {
    width: auto !important;
    height: auto !important;
    min-width: 0 !important;
    min-height: 0 !important;
    padding: 0 !important;
    border: 0 !important;
    border-radius: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
    color: rgba(75, 85, 99, 0.82) !important;
    cursor: pointer;
    appearance: none;
  }

  .base-footer-link:hover,
  .base-footer-button:hover {
    color: #172033;
    text-decoration: underline;
  }

  @media (max-width: 520px) {
    .base-header {
      flex-direction: column !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 10px !important;
      width: calc(100% - 28px) !important;
      padding: 12px 16px 11px !important;
      border-radius: 0 0 18px 18px !important;
      text-align: center !important;
    }

    .base-header-nav {
      justify-content: center !important;
      flex-wrap: wrap !important;
      gap: 8px 12px !important;
      width: 100% !important;
      max-width: calc(100vw - 28px) !important;
      margin: 0 auto !important;
      white-space: normal !important;
    }

    .base-header-link {
      font-size: clamp(0.7rem, 3vw, 0.8rem);
      font-weight: 600;
    }
    .base-footer {
      flex-direction: column !important;
      justify-content: center !important;
      gap: 10px !important;
      width: calc(100% - 28px) !important;
      margin-top: 28px !important;
      padding: 14px 0 !important;
    }

    .base-footer-nav {
      justify-content: center !important;
      gap: clamp(7px, 2vw, 10px) !important;
      width: auto !important;
      max-width: calc(100vw - 12px) !important;
      margin: 0 auto !important;
    }

    .base-footer-copyright,
    .base-footer-link,
    .base-footer-button {
      font-size: clamp(0.66rem, 2.75vw, 0.78rem);
      letter-spacing: 0;
    }
  }
</style>