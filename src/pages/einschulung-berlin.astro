---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Berlin 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Berlin in die Schule? Erfahre alles zu Schulstart, Einschulungsfeier, Stichtag 30. September, Kann-Kind-Regelung und Schuljahr.";
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-berlin/" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Wann kommt mein Kind in Berlin in die Schule?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Das hängt vom Geburtsdatum deines Kindes ab. In Berlin werden mit Beginn eines Schuljahres am 1. August alle Kinder schulpflichtig, die das sechste Lebensjahr bereits vollendet haben oder bis zum folgenden 30. September vollenden werden."
            }
          },
          {
            "@type": "Question",
            "name": "Wann ist die Einschulung in Berlin 2026?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In Berlin findet die Einschulungsfeier 2026 in der Regel am Samstag, dem 29. August 2026, statt. Der reguläre Unterricht für Schulanfängerinnen und Schulanfänger beginnt voraussichtlich am Montag, dem 31. August 2026."
            }
          },
          {
            "@type": "Question",
            "name": "Welcher Stichtag gilt für die Einschulung in Berlin?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In Berlin gilt für die reguläre Schulpflicht der 30. September. Kinder, die bis zu diesem Datum sechs Jahre alt werden, werden mit Beginn des Schuljahres am 1. August schulpflichtig."
            }
          },
          {
            "@type": "Question",
            "name": "Kann mein Kind in Berlin früher eingeschult werden?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Kinder, die zwischen dem 1. Oktober und dem 31. März des folgenden Kalenderjahres sechs Jahre alt werden, können auf Antrag der Erziehungsberechtigten vorzeitig aufgenommen werden, wenn kein Sprachförderbedarf besteht. Mit der Aufnahme beginnt die Schulpflicht."
            }
          },
          {
            "@type": "Question",
            "name": "Wann muss ich mein Kind in Berlin an der Grundschule anmelden?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Die Anmeldung erfolgt in Berlin in der Regel an der zuständigen Grundschule. In Berlin finden die Anmeldungen für das folgende Schuljahr meist im Herbst des Vorjahres statt. Die genauen Termine veröffentlicht die zuständige Grundschule, der Bezirk oder die Berliner Senatsverwaltung."
            }
          },
          {
            "@type": "Question",
            "name": "Welche Quelle ist für die Einschulung in Berlin verbindlich?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Diese Seite dient der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule, dem Schulamt oder der Berliner Senatsverwaltung für Bildung, Jugend und Familie."
            }
          }
        ]
      }
    </script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Berlin</p>

        <h1>
          Einschulung in Berlin:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Berlin in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. In
          Berlin gilt der Stichtag 30. September. Die Einschulungsfeier 2026 findet
          in der Regel am Samstag, dem 29. August 2026, statt; der reguläre
          Unterricht beginnt voraussichtlich am Montag, dem 31. August 2026.
        </p>

        <StateEnrollmentCalculator
          stateName="Berlin"
          stateSlug="berlin"
          calculatorKicker="Berlin-Rechner"
          resultKicker="Berlin-Ergebnis"
          headline="Einschulung in Berlin berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Berlin ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts" aria-label="Kurzüberblick Einschulung Berlin">
          <div class="fact-card fact-card-date">
            <span>Einschulungsfeier</span>
            <strong>Samstag, 29.08.2026</strong>
          </div>

          <div class="fact-card fact-card-date">
            <span>Erster Schultag</span>
            <strong>Montag, 31.08.2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. September</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind</strong>
          </div>
        </div>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Berlin?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Berlin. Entscheidend sind
            vor allem der Stichtag 30. September und die Berliner Kann-Kind-Regelung
            für Kinder, die zwischen dem 1. Oktober und dem 31. März des folgenden
            Kalenderjahres sechs Jahre alt werden.
          </p>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. September 2020
            geboren, wird es am 15. September 2026 sechs Jahre alt. Da dieses
            Datum vor dem Stichtag 30. September liegt, ist das Kind in Berlin
            regulär schulpflichtig und voraussichtlich für das Schuljahr 2026/2027
            vorgesehen.
          </p>

          <p>
            Die wichtigsten Termine zur Einschulungsfeier und zum ersten Schultag
            findest du im Terminblock oben. Den konkreten Ablauf legt die zuständige
            Grundschule fest.
          </p>
        </section>

        <section>
          <h2>Wann ist die Einschulung in Berlin 2026?</h2>

          <p>
            In Berlin findet die Einschulungsfeier 2026 in der Regel am Samstag,
            dem 29. August 2026, statt. Der reguläre Unterricht für
            Schulanfängerinnen und Schulanfänger beginnt voraussichtlich am Montag,
            dem 31. August 2026. Den konkreten Ablauf legt die zuständige
            Grundschule fest.
          </p>
        </section>

        <section>
          <h2>Welcher Stichtag gilt für die Einschulung in Berlin?</h2>

          <p>
            In Berlin werden mit Beginn eines Schuljahres am 1. August alle Kinder
            schulpflichtig, die das sechste Lebensjahr bereits vollendet haben oder
            bis zum folgenden 30. September vollenden werden. Für die reguläre
            Einschulung ist daher der 30. September die zentrale Grenze.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind früher eingeschult werden?</h2>

          <p>
            Kinder, die zwischen dem 1. Oktober und dem 31. März des folgenden
            Kalenderjahres sechs Jahre alt werden, können in Berlin auf Antrag der
            Erziehungsberechtigten vorzeitig aufgenommen werden. Voraussetzung ist,
            dass kein Sprachförderbedarf besteht. Mit der Aufnahme in die Schule
            beginnt die Schulpflicht.
          </p>
        </section>

        <section>
          <h2>Was ist bei der Schulanmeldung wichtig?</h2>

          <p>
            Die Anmeldung erfolgt in Berlin in der Regel an der zuständigen
            Grundschule. Für schulpflichtige Kinder ist die Anmeldung verpflichtend.
            In Berlin finden die Anmeldungen für das folgende Schuljahr meist im
            Herbst des Vorjahres statt. Die genauen Termine veröffentlicht die
            zuständige Grundschule, der Bezirk oder die Berliner Senatsverwaltung.
          </p>
        </section>

        <section class="example-box">
          <h2>Beispiel: Geburtsdatum im September</h2>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. September 2020
            geboren, wird es am 15. September 2026 sechs Jahre alt. Da dieses
            Datum vor dem Stichtag 30. September liegt, wird das Kind in Berlin
            voraussichtlich im Schuljahr 2026/2027 regulär eingeschult.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Berlin</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Wann kommt mein Kind in Berlin in die Schule?</h3>
              <p>
                Das hängt vom Geburtsdatum deines Kindes ab. In Berlin werden mit
                Beginn eines Schuljahres am 1. August alle Kinder schulpflichtig,
                die das sechste Lebensjahr bereits vollendet haben oder bis zum
                folgenden 30. September vollenden werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Berlin 2026?</h3>
              <p>
                In Berlin findet die Einschulungsfeier 2026 in der Regel am
                Samstag, dem 29. August 2026, statt. Der reguläre Unterricht für
                Schulanfängerinnen und Schulanfänger beginnt voraussichtlich am
                Montag, dem 31. August 2026.
              </p>
            </article>

            <article class="faq-item">
              <h3>Welcher Stichtag gilt für die Einschulung in Berlin?</h3>
              <p>
                In Berlin gilt für die reguläre Schulpflicht der 30. September.
                Kinder, die bis zu diesem Datum sechs Jahre alt werden, werden mit
                Beginn des Schuljahres am 1. August schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann mein Kind in Berlin früher eingeschult werden?</h3>
              <p>
                Kinder, die zwischen dem 1. Oktober und dem 31. März des folgenden
                Kalenderjahres sechs Jahre alt werden, können auf Antrag der
                Erziehungsberechtigten vorzeitig aufgenommen werden, wenn kein
                Sprachförderbedarf besteht. Mit der Aufnahme beginnt die Schulpflicht.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann muss ich mein Kind in Berlin an der Grundschule anmelden?</h3>
              <p>
                Die Anmeldung erfolgt in Berlin in der Regel an der zuständigen
                Grundschule. In Berlin finden die Anmeldungen für das folgende
                Schuljahr meist im Herbst des Vorjahres statt. Die genauen Termine
                veröffentlicht die zuständige Grundschule, der Bezirk oder die
                Berliner Senatsverwaltung.
              </p>
            </article>

            <article class="faq-item">
              <h3>Welche Quelle ist für die Einschulung in Berlin verbindlich?</h3>
              <p>
                Diese Seite dient der Orientierung. Verbindliche Informationen
                erhältst du bei der zuständigen Grundschule, dem Schulamt oder der
                Berliner Senatsverwaltung für Bildung, Jugend und Familie.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quelle und Hinweis</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Berlin:
          </p>

          <ul class="source-list" aria-label="Offizielle Quellen zur Einschulung in Berlin">
            <li>
              <span>Offizielle Quelle 1</span>
              <a
                class="source-link"
                href="https://www.berlin.de/sen/bildung/schule/bildungswege/grundschule/anmeldung/"
                target="_blank"
                rel="noopener noreferrer"
              >
                Berlin.de: Anmeldung zum Schulanfang
              </a>
            </li>

            <li>
              <span>Offizielle Quelle 2</span>
              <a
                class="source-link"
                href="https://www.berlin.de/ba-steglitz-zehlendorf/politik-und-verwaltung/aemter/gesundheitsamt/kinder-und-jugendgesundheitsdienst/artikel.91465.php"
                target="_blank"
                rel="noopener noreferrer"
              >
                Berlin.de: Einschulung und Einschulungsuntersuchung
              </a>
            </li>

            <li>
              <span>Offizielle Quelle 3</span>
              <a
                class="source-link"
                href="https://www.schulgesetz-berlin.de/berlin/schulgesetz/teil-iv-schulpflicht/sect-42-beginn-und-dauer-der-allgemeinen-schulpflicht.php"
                target="_blank"
                rel="noopener noreferrer"
              >
                Schulgesetz Berlin: Beginn und Dauer der allgemeinen Schulpflicht
              </a>
            </li>
          </ul>

          <p class="source-hint">
            Hinweis: In Berlin werden mit Beginn eines Schuljahres am 1. August
            alle Kinder schulpflichtig, die das sechste Lebensjahr bereits
            vollendet haben oder bis zum folgenden 30. September vollenden werden.
            Kinder, die zwischen dem 1. Oktober und dem 31. März des folgenden
            Kalenderjahres sechs Jahre alt werden, können auf Antrag vorzeitig
            aufgenommen werden, wenn kein Sprachförderbedarf besteht. Bitte prüfe
            verbindliche Details immer bei der zuständigen Grundschule oder
            Schulbehörde.
          </p>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.22rem, 1.55vw, 1.46rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .fact-card-date {
    border-color: rgba(129, 97, 38, 0.16);
    background: rgba(245, 210, 138, 0.12);
  }

  .fact-card-date strong {
    font-size: clamp(1.12rem, 1.36vw, 1.32rem);
    white-space: normal;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 14px;
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }

  .source-list li {
    display: grid;
    gap: 5px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.12);
  }

  .source-list li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-list li > span {
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .source-hint {
    margin-top: 18px;
    color: #465266;
    font-size: 0.96rem;
    font-weight: 500;
    line-height: 1.58;
  }

  .stand {
    display: flex;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
      letter-spacing: -0.05em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .fact-card {
      min-height: 102px;
      padding: 18px 22px;
    }

    .fact-card span {
      font-size: clamp(0.82rem, 3.45vw, 0.96rem);
      letter-spacing: 0.095em;
    }

    .fact-card strong {
      font-size: clamp(1.12rem, 4.9vw, 1.36rem);
      line-height: 1.14;
    }

    .fact-card-date strong {
      white-space: normal;
    }

    section {
      margin-top: 30px;
      padding-top: 28px;
    }

    h2 {
