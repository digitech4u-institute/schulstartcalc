      line-height: 1.1;
    }

    p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .faq-item p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .example-box,
    .source-note,
    .seo-explanation-box {
      padding: 20px;
      border-radius: 20px;
    }
  }

  @media (max-width: 390px) {
    h1 {
      font-size: clamp(1.58rem, 7vw, 1.95rem);
      line-height: 1.07;
      letter-spacing: -0.046em;
    }
  }
</style>