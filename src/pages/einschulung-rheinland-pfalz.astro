---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Rheinland-Pfalz 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Rheinland-Pfalz in die Schule? Alle Informationen zu Stichtag 31. August, Schulanmeldung, Kann-Kind-Regelung, Zurückstellung und Schuljahr.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Rheinland-Pfalz?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Rheinland-Pfalz gilt grundsätzlich der 31. August als Einschulungsstichtag. Kinder, die bis zu diesem Datum im Einschulungsjahr sechs Jahre alt sind, werden mit Beginn des Schuljahres schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Rheinland-Pfalz 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Für das Schuljahr 2026/2027 endet die Sommerferienzeit in Rheinland-Pfalz am Freitag, 7. August 2026. Der erste reguläre Schultag ist damit Montag, 10. August 2026. Den konkreten Einschulungstermin für Erstklässler legt die zuständige Grundschule fest.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind in Rheinland-Pfalz?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind gilt in Rheinland-Pfalz ein Kind, das nach dem regulären Stichtag 31. August sechs Jahre alt wird und deshalb nicht automatisch schulpflichtig ist. Eine vorzeitige Einschulung kann auf Antrag der Eltern geprüft werden, wenn aufgrund der Entwicklung zu erwarten ist, dass das Kind erfolgreich am Unterricht teilnehmen kann.",
      },
    },
    {
      "@type": "Question",
      name: "Wann findet die Schulanmeldung in Rheinland-Pfalz statt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Alle Kinder, die im folgenden Kalenderjahr schulpflichtig werden, werden in Rheinland-Pfalz im Februar von den Eltern an der zuständigen Grundschule angemeldet. Der Schulträger fordert die Eltern zur Anmeldung auf; die Grundschule teilt den konkreten Anmeldetermin mit.",
      },
    },
    {
      "@type": "Question",
      name: "Kann die Einschulung in Rheinland-Pfalz zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eine Zurückstellung ist nur im Ausnahmefall möglich – in der Regel aus gesundheitlichen Gründen. Eltern stellen den Antrag schriftlich bei der zuständigen Grundschule bis spätestens 15. Mai. Die Entscheidung trifft die Schulleitung gemeinsam mit dem Schularzt.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Rheinland-Pfalz verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde in Rheinland-Pfalz.",
      },
    },
  ],
};
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-rheinland-pfalz/" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Rheinland-Pfalz</p>

        <h1>
          Einschulung in<br />
          Rheinland-Pfalz:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Rheinland-Pfalz in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. In
          Rheinland-Pfalz gilt der Stichtag 31. August. Für das Schuljahr 2026/2027
          beginnt der Unterricht nach den Sommerferien voraussichtlich am Montag,
          10. August 2026 – den konkreten Einschulungstermin für Erstklässler
          legt die zuständige Grundschule fest.
        </p>

        <StateEnrollmentCalculator
          stateName="Rheinland-Pfalz"
          stateSlug="rheinland-pfalz"
          calculatorKicker="Rheinland-Pfalz-Rechner"
          resultKicker="Rheinland-Pfalz-Ergebnis"
          headline="Einschulung in Rheinland-Pfalz berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Rheinland-Pfalz ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Rheinland-Pfalz">
          <div class="fact-card fact-card-highlight">
            <span>Nächste Einschulung</span>
            <strong>Termin durch Schule</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag, 10. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>31. August</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>
        </div>

        <section class="example-box">
          <h2>Wie funktioniert der Einschulungsrechner für Rheinland-Pfalz?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Rheinland-Pfalz.
            Entscheidend ist der Stichtag 31. August. Wird dein Kind bis zu diesem
            Datum im Einschulungsjahr sechs Jahre alt, ist es in Rheinland-Pfalz
            regulär schulpflichtig.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. August 2020 geboren, wird es vor dem
            Stichtag 31. August 2026 sechs Jahre alt. Damit ist das Kind
            voraussichtlich für das Schuljahr 2026/2027 regulär schulpflichtig.
          </p>

          <p>
            Wird ein Kind dagegen erst nach dem 31. August sechs Jahre alt, ist es
            nicht automatisch regulär schulpflichtig. Eine frühere Einschulung kann
            auf Antrag der Eltern geprüft werden, wenn aufgrund der Entwicklung zu
            erwarten ist, dass das Kind erfolgreich am Unterricht teilnehmen kann.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind in Rheinland-Pfalz schulpflichtig?</h2>

          <p>
            Schulpflichtig sind in Rheinland-Pfalz alle Kinder, die bis zum
            31. August im Einschulungsjahr sechs Jahre alt sind. Sie besuchen die
            Grundschule mit Beginn des Schuljahres.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Rheinland-Pfalz früher eingeschult werden?</h2>

          <p>
            Jüngere Kinder, die noch nicht schulpflichtig sind, können auf Antrag
            der Eltern in die Grundschule aufgenommen werden. Voraussetzung ist,
            dass aufgrund ihrer Entwicklung zu erwarten ist, dass sie erfolgreich
            am Unterricht teilnehmen können. Über die Aufnahme entscheidet die
            Schulleitung der jeweiligen Grundschule.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Rheinland-Pfalz ab?</h2>

          <p>
            Alle Kinder, die im folgenden Kalenderjahr schulpflichtig werden,
            werden in Rheinland-Pfalz im Februar von den Eltern an der zuständigen
            Grundschule angemeldet. Hierzu erhalten die Eltern durch den Schulträger
            eine Aufforderung zur Anmeldung. Die für den Wohnort zuständige
            Grundschule teilt den konkreten Anmeldetermin mit.
          </p>
        </section>

        <section>
          <h2>Mein Kind ist noch nicht schulreif – was muss ich in Rheinland-Pfalz tun?</h2>

          <p>
            In Rheinland-Pfalz ist eine Zurückstellung vom Schulbesuch nur in
            begründeten Ausnahmefällen möglich – in der Regel aus gesundheitlichen
            Gründen. Eltern stellen einen formlosen schriftlichen Antrag bei der
            zuständigen Grundschule, spätestens bis zum 15. Mai des Einschulungsjahres.
            Die Schulleitung entscheidet gemeinsam mit dem Schularzt und informiert
            die Eltern bis zum 15. Juni schriftlich. Eine Zurückstellung ist nur
            einmal möglich.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Rheinland-Pfalz</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Rheinland-Pfalz?</h3>
              <p>
                In Rheinland-Pfalz gilt grundsätzlich der 31. August als Stichtag
                für die Einschulung.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Rheinland-Pfalz 2026?</h3>
              <p>
                Für das Schuljahr 2026/2027 endet die Sommerferienzeit in Rheinland-Pfalz
                am Freitag, 7. August 2026. Der erste reguläre Schultag ist damit
                Montag, 10. August 2026. Den konkreten Einschulungstermin für
                Erstklässler legt die zuständige Grundschule fest.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind in Rheinland-Pfalz?</h3>
              <p>
                Als Kann-Kind gilt in Rheinland-Pfalz ein Kind, das nach dem regulären
                Stichtag 31. August sechs Jahre alt wird und deshalb nicht automatisch
                schulpflichtig ist. Eine frühere Einschulung kann auf Antrag der
                Eltern geprüft werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung in Rheinland-Pfalz statt?</h3>
              <p>
                Alle Kinder, die im folgenden Kalenderjahr schulpflichtig werden,
                werden im Februar von den Eltern an der zuständigen Grundschule
                angemeldet. Der konkrete Termin wird den Eltern mitgeteilt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann die Einschulung in Rheinland-Pfalz zurückgestellt werden?</h3>
              <p>
                Eine Zurückstellung ist nur im Ausnahmefall möglich – in der Regel
                aus gesundheitlichen Gründen. Eltern stellen den Antrag schriftlich
                bei der zuständigen Grundschule bis spätestens 15. Mai. Die Entscheidung
                trifft die Schulleitung gemeinsam mit dem Schularzt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis verbindlich?</h3>
              <p>
                Nein. Der Rechner und diese Seite dienen der Orientierung.
                Verbindliche Informationen erhältst du bei der zuständigen Schule
                oder Schulbehörde in Rheinland-Pfalz.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Rheinland-Pfalz:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Rheinland-Pfalz">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://bm.rlp.de/schule/bildungswege/grundschule"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Bildung Rheinland-Pfalz: Grundschule
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://bm.rlp.de/service/ferientermine"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Bildung Rheinland-Pfalz: Ferientermine
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://bildung.rlp.de/grundschule/uebergaenge"
                target="_blank"
                rel="noopener noreferrer"
              >
                Bildungsserver Rheinland-Pfalz: Übergang vom Kindergarten zur Grundschule
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Ministerium für Bildung
            Rheinland-Pfalz.
          </p>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  :global(body.has-rheinland-pfalz-calculator-result) .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .stand {
    display: inline-flex;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
      letter-spacing: -0.05em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .fact-card {
      min-height: 102px;
      padding: 18px 22px;
    }

    .fact-card span {
      font-size: clamp(0.82rem, 3.45vw, 0.96rem);
      letter-spacing: 0.095em;
    }

    .fact-card strong {
      font-size: clamp(1.12rem, 4.9vw, 1.36rem);
      line-height: 1.14;
    }

    section {
      margin-top: 30px;
      padding-top: 28px;
    }

    h2 {
      font-size: 1.62rem;
      line-height: 1.1;
    }

    p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .faq-item p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .example-box,
    .source-note {
      padding: 20px;
      border-radius: 20px;
    }

    .source-link {
      width: auto;
      font-size: 1rem;
      line-height: 1.42;
    }
  }

  @media (max-width: 390px) {
    h1 {
      font-size: clamp(1.58rem, 7vw, 1.95rem);
      line-height: 1.07;
      letter-spacing: -0.046em;
    }
  }
</style>
