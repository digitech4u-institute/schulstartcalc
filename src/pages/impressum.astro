---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Impressum";
const pageDescription =
  "Impressum und Anbieterkennzeichnung des Einschulungsrechners Deutschland.";
const canonical = "https://www.einschulungsrechner.de/impressum/";
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <main class="legal-page">
    <a class="back-link" href="/" data-history-back>← Zurück</a>

    <section class="legal-card">
      <p class="legal-kicker">Rechtliches</p>

      <h1>Impressum</h1>

      <h2>Angaben gemäß § 5 ECG (E-Commerce-Gesetz Österreich)</h2>

      <p>
        DigiTech4U Institute<br />
        M. Lanzend. Str. 6-8<br />
        2333 Leopoldsdorf<br />
        Österreich
      </p>

      <h2>Kontakt</h2>

      <p>
        E-Mail: <a href="mailto:info@digitech4u.org">info@digitech4u.org</a>
      </p>

      <h2>Hinweis zur Zielgruppe</h2>

      <p>
        Diese Website richtet sich an Nutzerinnen und Nutzer in Deutschland
        und Österreich. Anbieterin ist eine österreichische Institution. Die
        Inhalte dienen der allgemeinen Orientierung rund um Einschulung,
        Schulpflicht und Schulstart in Deutschland und ersetzen keine
        verbindliche Auskunft durch die zuständige Grundschule oder
        Schulbehörde.
      </p>

      <h2>Verantwortlich für den Inhalt</h2>

      <p>
        DigiTech4U Institute<br />
        M. Lanzend. Str. 6-8<br />
        2333 Leopoldsdorf<br />
        Österreich
      </p>

      <h2>Haftung für Inhalte</h2>

      <p>
        Die Inhalte dieser Website wurden mit größter Sorgfalt recherchiert und
        erstellt. Dennoch können Einschulungstermine, Stichtage, Anmeldefristen
        und schulrechtliche Regelungen je nach Bundesland, Kommune oder Schule
        abweichen oder sich ändern. Der Einschulungsrechner und die begleitenden
        Informationen dienen ausschließlich der unverbindlichen Orientierung.
        Verbindliche Auskünfte erteilen immer die zuständige Grundschule, das
        Schulamt oder die zuständige Schulbehörde.
      </p>

      <h2>Haftung für Links</h2>

      <p>
        Diese Website enthält Links zu externen Websites Dritter. Auf deren
        Inhalte haben wir keinen Einfluss. Für diese fremden Inhalte übernehmen
        wir keine Gewähr. Für die Inhalte der verlinkten Seiten ist stets der
        jeweilige Anbieter oder Betreiber verantwortlich.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.28), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .legal-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 860px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .legal-card {
    max-width: 860px;
    margin: 0 auto;
    padding: clamp(28px, 4vw, 48px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .legal-kicker {
    margin: 0 0 12px;
    color: #816126;
    font-size: 0.86rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 28px;
    color: #172033;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  h2 {
    margin: 28px 0 10px;
    color: #172033;
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  p {
    margin: 0;
    color: #465266;
    font-size: 1rem;
    line-height: 1.7;
  }

  a {
    color: #172033;
    font-weight: 800;
  }

  @media (max-width: 520px) {
    .legal-page {
      padding: 22px 14px 42px;
    }

    .legal-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      font-size: 2.3rem;
    }

    h2 {
      font-size: 1.12rem;
    }

    p {
      font-size: 0.96rem;
      line-height: 1.62;
    }
  }
</style>