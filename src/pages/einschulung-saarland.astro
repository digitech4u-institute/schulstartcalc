---
import BaseLayout from "../layouts/BaseLayout.astro";
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Saarland 2026 & 2027: Termin, Stichtag & Rechner";

const pageDescription =
  "Wann ist die Einschulung im Saarland 2026? Hier findest du Termin, Stichtag 30. Juni, Kann-Kind-Regelung und den kostenlosen Einschulungsrechner.";

const canonical = "https://www.einschulungsrechner.de/einschulung-saarland/";
const dateModified = "2026-06-17";

const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || "";
const STATE_CONTENT_AD_SLOT = import.meta.env.PUBLIC_ADSENSE_STATE_CONTENT_SLOT || "";
const showContentAd = Boolean(ADSENSE_ID && STATE_CONTENT_AD_SLOT);

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  datePublished: "2025-10-01",
  dateModified,
  inLanguage: "de",
  publisher: {
    "@type": "Organization",
    name: "Einschulungsrechner",
    url: "https://www.einschulungsrechner.de/",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt im Saarland?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Im Saarland gilt grundsätzlich der 30. Juni als Einschulungsstichtag. Kinder, die bis zu diesem Datum sechs Jahre alt werden, werden mit Beginn des Schuljahres schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung im Saarland 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Sommerferien im Saarland enden 2026 am Freitag, 7. August 2026. Der erste reguläre Schultag und die voraussichtliche Einschulung sind Montag, 10. August 2026. Einzelne organisatorische Details können je nach Schule abweichen.",
      },
    },
    {
      "@type": "Question",
      name: "Wann beginnt die Grundschule im Saarland 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der erste reguläre Schultag im Schuljahr 2026/2027 ist im Saarland Montag, 10. August 2026. Die voraussichtliche Einschulung fällt ebenfalls auf Montag, 10. August 2026.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind im Saarland?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind gilt im Saarland ein Kind, das noch nicht schulpflichtig ist, aber auf Antrag der Erziehungsberechtigten vorzeitig aufgenommen werden kann. Möglich ist das zu Anfang des Schuljahres, wenn das Kind im laufenden oder im folgenden Kalenderjahr das sechste Lebensjahr vollendet. Die Entscheidung trifft die Schulleitung auf Grundlage einer schul- oder amtsärztlichen Untersuchung und eines Beratungsgesprächs mit den Eltern.",
      },
    },
    {
      "@type": "Question",
      name: "Wann findet die Schulanmeldung im Saarland statt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Schulanmeldung erfolgt im Saarland bei der zuständigen Grundschule, in der Regel im Herbst oder Winter vor dem Einschulungsjahr. Die konkreten Fristen, benötigten Unterlagen und weiteren Schritte gibt die Schule oder die zuständige Schulbehörde bekannt. Zur Vorbereitung der Aufnahme gehört eine Untersuchung durch eine Schul- oder Amtsärztin beziehungsweise einen Schul- oder Amtsarzt.",
      },
    },
    {
      "@type": "Question",
      name: "Kann die Einschulung im Saarland zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eine Zurückstellung ist im Saarland möglich, wenn aufgrund einer medizinischen Indikation durch eine Schul- oder Amtsärztin beziehungsweise einen Schul- oder Amtsarzt eine Einschulung noch nicht angeraten ist. Nach Anhörung der Erziehungsberechtigten entscheidet die Schulleitung über eine Zurückstellung für ein Jahr.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung im Saarland verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde im Saarland.",
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={[faqSchema, webPageSchema]}
>
  <main class="state-page">

      <article class="state-card">
        <p class="state-kicker">Saarland</p>

        <h1>
          <span class="headline-line headline-line-year">Einschulung 2026/2027</span>
          <span class="headline-line headline-line-state">im Saarland:</span>
          <span class="headline-line headline-line-question">Wann kommt mein Kind in die Schule?</span>
        </h1>

        <p class="lead">
          Wann kommt mein Kind im Saarland in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. Im
          Saarland gilt der Stichtag 30. Juni. Für das Schuljahr 2026/2027 ist die
          Einschulung voraussichtlich Montag, 10. August 2026 – das ist zugleich
          der erste reguläre Schultag nach den Sommerferien.
        </p>

        <p class="answer-box">
          Kurzantwort: Die Sommerferien im Saarland enden 2026 am Freitag,
          7. August 2026. Der erste reguläre Schultag und die voraussichtliche
          Einschulung sind Montag, 10. August 2026.
        </p>

        <StateEnrollmentCalculator
          stateName="Saarland"
          stateSlug="saarland"
          calculatorKicker="Saarland-Rechner"
          resultKicker="Saarland-Ergebnis"
          headline="Einschulung im Saarland berechnen"
          intro="Gib das Geburtsdatum ein und erfahre, für welches Schuljahr dein Kind im Saarland voraussichtlich schulpflichtig wird."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Saarland">
          <div class="fact-card fact-card-highlight">
            <span>Einschulung 2026</span>
            <strong>Montag,<br />10. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag,<br />10. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. Juni</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>
        </div>

        {showContentAd ? (
          <aside class="ad-slot ad-slot-after-facts" aria-label="Anzeige">
            <p class="ad-label">Anzeige</p>
            <ins
              class="adsbygoogle"
              style="display:block"
              data-ad-client={ADSENSE_ID}
              data-ad-slot={STATE_CONTENT_AD_SLOT}
              data-ad-format="auto"
              data-full-width-responsive="true"
            ></ins>
          </aside>
        ) : null}

        <section>
          <h2>Wann ist die Einschulung im Saarland 2026?</h2>

          <p>
            Die Sommerferien im Saarland enden 2026 am Freitag, 7. August 2026.
            Der erste reguläre Schultag und die voraussichtliche Einschulung sind
            Montag, 10. August 2026. Einzelne organisatorische Details können je
            nach Schule abweichen.
          </p>
        </section>

        <section>
          <h2>Wie funktioniert der Einschulungsrechner für das Saarland?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln im Saarland. Entscheidend ist
            der Stichtag 30. Juni. Wird dein Kind bis zu diesem Datum sechs Jahre
            alt, ist es im Saarland regulär schulpflichtig.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. Juni 2020 geboren, wird es am
            15. Juni 2026 sechs Jahre alt. Da dieses Datum vor dem Stichtag
            30. Juni liegt, ist das Kind voraussichtlich für das Schuljahr
            2026/2027 regulär schulpflichtig.
          </p>

          <p>
            Wird ein Kind dagegen erst nach dem 30. Juni sechs Jahre alt, ist es
            nicht automatisch regulär schulpflichtig. Eine vorzeitige Einschulung
            kann auf Antrag der Erziehungsberechtigten geprüft werden.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind im Saarland schulpflichtig?</h2>

          <p>
            Im Saarland gilt der 30. Juni als maßgeblicher Stichtag für die
            Schulpflicht. Kinder, die bis zu diesem Datum das sechste Lebensjahr
            vollenden, werden mit Beginn des Schuljahres in diesem Kalenderjahr
            schulpflichtig.
          </p>

          <p>
            Entscheidend ist also, ob der sechste Geburtstag bis einschließlich
            30. Juni erreicht ist. Liegt der Geburtstag nach dem Stichtag, besteht
            keine automatische Schulpflicht für dieses Schuljahr; eine vorzeitige
            Einschulung kann aber als Kann-Kind auf Antrag geprüft werden.
          </p>
        </section>

        <section>
          <h2>Was bedeutet Kann-Kind im Saarland?</h2>

          <p>
            Als Kann-Kind gilt im Saarland ein Kind, das noch nicht schulpflichtig
            ist, aber auf Antrag der Erziehungsberechtigten vorzeitig aufgenommen
            werden kann. Möglich ist das zu Anfang des Schuljahres, wenn das Kind
            im laufenden oder im folgenden Kalenderjahr das sechste Lebensjahr
            vollendet.
          </p>

          <p>
            Die Entscheidung trifft die Schulleitung auf Grundlage einer schul- oder
            amtsärztlichen Untersuchung und eines Beratungsgesprächs mit den
            Erziehungsberechtigten.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind im Saarland früher eingeschult werden?</h2>

          <p>
            Kinder, die noch nicht schulpflichtig sind, können im Saarland auf
            Antrag der Erziehungsberechtigten zu Anfang des Schuljahres vorzeitig
            aufgenommen werden, wenn sie im laufenden oder im folgenden Kalenderjahr
            das sechste Lebensjahr vollenden. Die Entscheidung trifft die
            Schulleitung auf Grundlage einer Untersuchung durch eine Schul- oder
            Amtsärztin beziehungsweise einen Schul- oder Amtsarzt und nach einem
            Beratungsgespräch mit den Erziehungsberechtigten.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung im Saarland ab?</h2>

          <p>
            Die Schulanmeldung erfolgt im Saarland bei der zuständigen Grundschule,
            in der Regel im Herbst oder Winter vor dem Einschulungsjahr. Die
            konkreten Fristen, benötigten Unterlagen und weiteren Schritte gibt
            die Schule oder die zuständige Schulbehörde bekannt. Zur Vorbereitung
            der Aufnahme gehört eine Untersuchung durch eine Schul- oder Amtsärztin
            beziehungsweise einen Schul- oder Amtsarzt; soweit erforderlich, können
            dabei auch fördernde Maßnahmen empfohlen werden.
          </p>

          <ol class="process-list">
            <li>Informationen der zuständigen Grundschule beachten</li>
            <li>Kind an der zuständigen Grundschule anmelden</li>
            <li>Erforderliche Unterlagen und Nachweise bereithalten</li>
            <li>Schul- oder amtsärztliche Untersuchung einplanen</li>
          </ol>
        </section>

        <section class="next-steps-box">
          <h2 class="next-steps-headline">
            <span>Nächste Schritte</span>
            <span>für Eltern</span>
          </h2>

          <p>
            Wenn du jetzt weißt, welches Schuljahr für dein Kind voraussichtlich
            relevant ist, lohnt sich als Nächstes der Blick auf die praktische
            Vorbereitung. In unserer Checkliste findest du eine Schritt-für-Schritt-
            Übersicht zu Unterlagen, Material, Schulweg und Organisation rund um den
            Schulstart.
          </p>

          <div class="next-steps-actions">
            <a class="next-step-button next-step-button-primary" href="/einschulung-checkliste/">
              Zur Einschulungs-Checkliste
            </a>
            <a class="next-step-button next-step-button-secondary" href="/einschulung/">
              Ratgeber zur Einschulung lesen
            </a>
          </div>
        </section>

        <section>
          <h2>Mein Kind ist noch nicht schulreif – was muss ich im Saarland tun?</h2>

          <p>
            Eine Zurückstellung ist im Saarland möglich, wenn aufgrund einer
            medizinischen Indikation durch eine Schul- oder Amtsärztin beziehungsweise
            einen Schul- oder Amtsarzt eine Einschulung noch nicht angeraten ist.
            Nach Anhörung der Erziehungsberechtigten entscheidet die Schulleitung
            über eine Zurückstellung für ein Jahr. Verbindliche Auskunft erhältst
            du bei der zuständigen Grundschule oder Schulbehörde.
          </p>
        </section>

        <section>
          <h2>Einschulung 2027 im Saarland: Kann ich das schon berechnen?</h2>

          <p>
            Ja. Du kannst den Einschulungsrechner auch für die Einschulung 2027 im
            Saarland nutzen. Gib einfach das Geburtsdatum des Kindes ein. Der Rechner
            zeigt dir sämtliche relevanten Daten für das voraussichtliche Schuljahr.
          </p>

          <a class="section-cta-button" href="#saarlandCalculatorForm">
            Einschulung 2027 für das Saarland berechnen
          </a>
        </section>

        <section class="retrospective-box">
          <p class="retrospective-kicker">Rückblick berechnen</p>
          <h2>Wann wurde ich eingeschult?</h2>

          <p>
            Du kannst den Rechner auch rückblickend nutzen. Gib dein Geburtsdatum
            ein und wähle dein damaliges Bundesland aus.
          </p>

          <a class="retrospective-link" href="/#einschulungsrechner">
            Rückblick berechnen
          </a>

          <p>
            Das Ergebnis ist eine Orientierung, weil frühere Einschulung,
            Zurückstellung, Umzug oder frühere Landesregeln abweichen können.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung im Saarland</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt im Saarland?</h3>
              <p>
                Im Saarland gilt grundsätzlich der 30. Juni als Einschulungsstichtag.
                Kinder, die bis zu diesem Datum sechs Jahre alt werden, werden mit
                Beginn des Schuljahres schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung im Saarland 2026?</h3>
              <p>
                Die Sommerferien im Saarland enden 2026 am Freitag,
                7. August 2026. Der erste reguläre Schultag und die voraussichtliche
                Einschulung sind Montag, 10. August 2026. Einzelne organisatorische
                Details können je nach Schule abweichen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann beginnt die Grundschule im Saarland 2026?</h3>
              <p>
                Der erste reguläre Schultag im Schuljahr 2026/2027 ist im Saarland
                Montag, 10. August 2026. Die voraussichtliche Einschulung fällt
                ebenfalls auf Montag, 10. August 2026.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind im Saarland?</h3>
              <p>
                Als Kann-Kind gilt im Saarland ein Kind, das noch nicht schulpflichtig
                ist, aber auf Antrag der Erziehungsberechtigten vorzeitig aufgenommen
                werden kann. Möglich ist das zu Anfang des Schuljahres, wenn das Kind
                im laufenden oder im folgenden Kalenderjahr das sechste Lebensjahr
                vollendet. Die Entscheidung trifft die Schulleitung auf Grundlage
                einer schul- oder amtsärztlichen Untersuchung und eines
                Beratungsgesprächs mit den Eltern.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung im Saarland statt?</h3>
              <p>
                Die Schulanmeldung erfolgt im Saarland bei der zuständigen
                Grundschule, in der Regel im Herbst oder Winter vor dem
                Einschulungsjahr. Die konkreten Fristen, benötigten Unterlagen und
                weiteren Schritte gibt die Schule oder die zuständige Schulbehörde
                bekannt. Zur Vorbereitung der Aufnahme gehört eine Untersuchung
                durch eine Schul- oder Amtsärztin beziehungsweise einen Schul- oder
                Amtsarzt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann die Einschulung im Saarland zurückgestellt werden?</h3>
              <p>
                Eine Zurückstellung ist im Saarland möglich, wenn aufgrund einer
                medizinischen Indikation durch eine Schul- oder Amtsärztin
                beziehungsweise einen Schul- oder Amtsarzt eine Einschulung noch
                nicht angeraten ist. Nach Anhörung der Erziehungsberechtigten
                entscheidet die Schulleitung über eine Zurückstellung für ein Jahr.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung im Saarland verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen
                der Orientierung. Verbindliche Informationen erhältst du bei der
                zuständigen Grundschule oder Schulbehörde im Saarland.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen und fachlich belastbaren Quellen bilden die
            Grundlage dieser Übersicht zur Einschulung im Saarland:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung im Saarland">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://www.saarland.de/mbk/DE/portale/bildungsserver/service/schultermine"
                target="_blank"
                rel="noopener noreferrer"
              >
                Saarland Bildungsserver: Schultermine
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://www.saarland.de/mbk/DE/portale/bildungsserver/service/rechtsvorschriften"
                target="_blank"
                rel="noopener noreferrer"
              >
                Saarland Bildungsserver: Rechtsvorschriften und Schulpflichtgesetz
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://www.kmk.org/fileadmin/Dateien/pdf/Ferienkalender/FER2026_27.pdf"
                target="_blank"
                rel="noopener noreferrer"
              >
                Kultusministerkonferenz: Ferientermine Schuljahr 2026/2027
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Ministerium für Bildung und
            Kultur des Saarlandes.
          </p>

          <p class="stand">Stand der Informationen:<span class="stand-date">Juni 2026</span></p>
        </section>
      </article>
  </main>
</BaseLayout>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }


  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .headline-line {
    display: block;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .answer-box {
    max-width: 760px;
    margin: 20px 0 0;
    padding: 18px 20px;
    border: 1px solid rgba(129, 97, 38, 0.18);
    border-radius: 18px;
    background: rgba(245, 210, 138, 0.14);
    color: #172033;
    font-size: clamp(1.02rem, 1.35vw, 1.12rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  :global(body.has-saarland-calculator-result) .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .ad-slot {
    margin: 30px 0 0;
    padding: 14px 0;
    border-top: 1px solid rgba(42, 35, 21, 0.08);
    border-bottom: 1px solid rgba(42, 35, 21, 0.08);
  }

  .ad-label {
    margin: 0 0 10px;
    color: #8a7960;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
