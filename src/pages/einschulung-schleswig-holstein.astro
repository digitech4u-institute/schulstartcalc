---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Schleswig-Holstein 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Schleswig-Holstein in die Schule? Alle Informationen zu Stichtag 30. Juni, Schulanmeldung, Kann-Kind-Regelung, Zurückstellung und Einschulung 2026.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Schleswig-Holstein?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Schleswig-Holstein gilt grundsätzlich der 30. Juni als Einschulungsstichtag. Kinder, die bis zu diesem Datum im laufenden Kalenderjahr sechs Jahre alt werden, sind schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Schleswig-Holstein 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Für das Schuljahr 2026/2027 endet die Sommerferienzeit in Schleswig-Holstein am Samstag, 15. August 2026. Der erste reguläre Schultag ist damit Montag, 17. August 2026. Die Einschulung an Grundschulen findet nach dem Erlass zu Einschulungsterminen am dritten Schultag nach den Ferien statt – für 2026 also voraussichtlich Mittwoch, 19. August 2026.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind in Schleswig-Holstein?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind gilt in Schleswig-Holstein ein Kind, das nach dem regulären Stichtag 30. Juni sechs Jahre alt wird und deshalb nicht automatisch schulpflichtig ist. Eltern können gegebenenfalls bei der zuständigen Schule einen Antrag auf vorzeitige Einschulung stellen.",
      },
    },
    {
      "@type": "Question",
      name: "Wann findet die Schulanmeldung in Schleswig-Holstein statt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die zuständige Grundschule informiert die Eltern über die Anmeldung und lädt in der Regel zu einem Einschulungsgespräch ein. Bei der Anmeldung werden die Personalien des Kindes und weitere Angaben erfasst, die für den Schulalltag wichtig sind.",
      },
    },
    {
      "@type": "Question",
      name: "Kann die Einschulung in Schleswig-Holstein zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eine Zurückstellung ist in Schleswig-Holstein im Ausnahmefall möglich, wenn Gründe gegen eine Einschulung zum vorgesehenen Zeitpunkt sprechen. Eltern sollten sich dazu frühzeitig an die zuständige Grundschule wenden; verbindlich entscheidet die Schule beziehungsweise die zuständige Schulbehörde.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Schleswig-Holstein verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde in Schleswig-Holstein.",
      },
    },
  ],
};
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-schleswig-holstein/" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Schleswig-Holstein</p>

        <h1>
          Einschulung in<br />
          Schleswig-Holstein:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Schleswig-Holstein in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. In
          Schleswig-Holstein gilt der Stichtag 30. Juni. Für das Schuljahr 2026/2027
          ist die Einschulung an Grundschulen voraussichtlich für Mittwoch,
          19. August 2026 vorgesehen – der erste Schultag ist Montag,
          17. August 2026.
        </p>

        <StateEnrollmentCalculator
          stateName="Schleswig-Holstein"
          stateSlug="schleswig-holstein"
          calculatorKicker="Schleswig-Holstein-Rechner"
          resultKicker="Schleswig-Holstein-Ergebnis"
          headline="Einschulung in Schleswig-Holstein berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Schleswig-Holstein ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Schleswig-Holstein">
          <div class="fact-card fact-card-highlight">
            <span>Nächste Einschulung</span>
            <strong>Mittwoch, 19. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag, 17. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. Juni</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>
        </div>

        <section class="example-box">
          <h2>Wie funktioniert der Einschulungsrechner für Schleswig-Holstein?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Schleswig-Holstein.
            Entscheidend ist der Stichtag 30. Juni. Wird dein Kind bis zu diesem
            Datum im laufenden Kalenderjahr sechs Jahre alt, ist es in Schleswig-Holstein
            regulär schulpflichtig.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. Juni 2020 geboren, wird es vor dem
            Stichtag 30. Juni 2026 sechs Jahre alt. Damit ist das Kind
            voraussichtlich für das Schuljahr 2026/2027 regulär schulpflichtig.
          </p>

          <p>
            Wird ein Kind dagegen erst nach dem 30. Juni sechs Jahre alt, ist es
            nicht automatisch regulär schulpflichtig. Eine frühere Einschulung kann
            auf Antrag der Eltern bei der zuständigen Schule geprüft werden.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind in Schleswig-Holstein schulpflichtig?</h2>

          <p>
            Ein Kind wird in Schleswig-Holstein regulär schulpflichtig, wenn es
            bis zum 30. Juni des laufenden Kalenderjahres sechs Jahre alt wird.
            Die Schulpflicht beginnt dann mit dem Start des neuen Schuljahres.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Schleswig-Holstein früher eingeschult werden?</h2>

          <p>
            Wird ein Kind erst nach dem 30. Juni sechs Jahre alt, ist es nicht
            automatisch schulpflichtig. Eltern können gegebenenfalls bei der
            zuständigen Schule einen Antrag auf vorzeitige Einschulung stellen.
            Die Schule prüft dann, ob eine frühere Aufnahme möglich ist.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Schleswig-Holstein ab?</h2>

          <p>
            Die zuständige Grundschule informiert die Eltern über die Anmeldung und
            lädt in der Regel zu einem Einschulungsgespräch ein. Bei der Anmeldung
            werden die Personalien des Kindes und weitere Angaben erfasst, die für
            den Schulalltag wichtig sind. Zusätzlich gehört die Schuleingangsuntersuchung
            zum Einschulungsverfahren.
          </p>
        </section>

        <section>
          <h2>Mein Kind ist noch nicht schulreif – was muss ich in Schleswig-Holstein tun?</h2>

          <p>
            Wenn du den Eindruck hast, dass dein Kind noch nicht schulreif ist,
            solltest du frühzeitig mit der zuständigen Grundschule sprechen. Eine
            Zurückstellung ist im Ausnahmefall möglich, wenn Gründe gegen eine
            Einschulung zum vorgesehenen Zeitpunkt sprechen. Verbindliche Auskunft
            erhältst du bei der zuständigen Schule oder Schulbehörde.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Schleswig-Holstein</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Schleswig-Holstein?</h3>
              <p>
                In Schleswig-Holstein gilt grundsätzlich der 30. Juni als
                Einschulungsstichtag. Kinder, die bis zu diesem Datum im laufenden
                Kalenderjahr sechs Jahre alt werden, sind schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Schleswig-Holstein 2026?</h3>
              <p>
                Für das Schuljahr 2026/2027 endet die Sommerferienzeit in
                Schleswig-Holstein am Samstag, 15. August 2026. Der erste reguläre
                Schultag ist damit Montag, 17. August 2026. Die Einschulung an
                Grundschulen findet nach dem Erlass zu Einschulungsterminen am
                dritten Schultag nach den Ferien statt – für 2026 also voraussichtlich
                Mittwoch, 19. August 2026.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind in Schleswig-Holstein?</h3>
              <p>
                Als Kann-Kind gilt in Schleswig-Holstein ein Kind, das nach dem
                regulären Stichtag 30. Juni sechs Jahre alt wird und deshalb nicht
                automatisch schulpflichtig ist. Eltern können gegebenenfalls bei der
                zuständigen Schule einen Antrag auf vorzeitige Einschulung stellen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung in Schleswig-Holstein statt?</h3>
              <p>
                Die zuständige Grundschule informiert die Eltern über die Anmeldung
                und lädt in der Regel zu einem Einschulungsgespräch ein. Bei der
                Anmeldung werden die Personalien des Kindes und weitere Angaben
                erfasst, die für den Schulalltag wichtig sind.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann die Einschulung in Schleswig-Holstein zurückgestellt werden?</h3>
              <p>
                Eine Zurückstellung ist in Schleswig-Holstein im Ausnahmefall möglich,
                wenn Gründe gegen eine Einschulung zum vorgesehenen Zeitpunkt sprechen.
                Eltern sollten sich dazu frühzeitig an die zuständige Grundschule
                wenden; verbindlich entscheidet die Schule beziehungsweise die
                zuständige Schulbehörde.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Schleswig-Holstein verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen
                der Orientierung. Verbindliche Informationen erhältst du bei der
                zuständigen Grundschule oder Schulbehörde in Schleswig-Holstein.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Schleswig-Holstein:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Schleswig-Holstein">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://www.schleswig-holstein.de/DE/fachinhalte/S/schulsystem/einschulung"
                target="_blank"
                rel="noopener noreferrer"
              >
                Land Schleswig-Holstein: Einschulung
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://www.schleswig-holstein.de/DE/landesregierung/themen/bildung-hochschulen/ferientermine"
                target="_blank"
                rel="noopener noreferrer"
              >
                Land Schleswig-Holstein: Ferientermine
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://www.schleswig-holstein.de/DE/fachinhalte/S/schulrecht/Downloads/Erlasse/Downloads/Einschulungstermine_allgemein_bildende_Schulen.pdf?__blob=publicationFile&v=2"
                target="_blank"
                rel="noopener noreferrer"
              >
                Land Schleswig-Holstein: Einschulungstermine an allgemein bildenden Schulen
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Land Schleswig-Holstein.
          </p>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  :global(body.has-schleswig-holstein-calculator-result) .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .stand {
    display: inline-flex;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
      letter-spacing: -0.05em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .fact-card {
      min-height: 102px;
      padding: 18px 22px;
    }

    .fact-card span {
      font-size: clamp(0.82rem, 3.45vw, 0.96rem);
      letter-spacing: 0.095em;
    }

    .fact-card strong {
      font-size: clamp(1.12rem, 4.9vw, 1.36rem);
      line-height: 1.14;
    }

    section {
      margin-top: 30px;
      padding-top: 28px;
    }

    h2 {
      font-size: 1.62rem;
      line-height: 1.1;
    }

    p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .faq-item p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .example-box,
    .source-note {
      padding: 20px;
      border-radius: 20px;
    }

    .source-link {
      width: auto;
      font-size: 1rem;
      line-height: 1.42;
    }
  }

  @media (max-width: 390px) {
    h1 {
      font-size: clamp(1.58rem, 7vw, 1.95rem);
      line-height: 1.07;
      letter-spacing: -0.046em;
    }
  }
</style>