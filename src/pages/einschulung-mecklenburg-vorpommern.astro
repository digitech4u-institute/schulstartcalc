---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Mecklenburg-Vorpommern 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Mecklenburg-Vorpommern in die Schule? Alle Informationen zu Stichtag 30. Juni, Schulanmeldung, Kann-Kind-Regelung, Zurückstellung und Einschulung 2026.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Mecklenburg-Vorpommern?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Mecklenburg-Vorpommern gilt grundsätzlich der 30. Juni als Einschulungsstichtag. Kinder, die bis zu diesem Datum sechs Jahre alt werden, werden mit dem 1. August desselben Jahres schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Mecklenburg-Vorpommern 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Sommerferien in Mecklenburg-Vorpommern enden im Schuljahr 2026/2027 am Samstag, 22. August 2026. Die Einschulung findet voraussichtlich ebenfalls an diesem Tag statt; der erste reguläre Schultag ist Montag, 24. August 2026.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind in Mecklenburg-Vorpommern?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind gilt in Mecklenburg-Vorpommern ein Kind, das nach dem regulären Stichtag 30. Juni sechs Jahre alt wird und deshalb nicht automatisch schulpflichtig ist. Kinder, die bis zum 30. Juni des darauffolgenden Jahres sechs Jahre alt werden, können auf Antrag der Erziehungsberechtigten vorzeitig eingeschult werden, wenn sie für den Schulbesuch hinreichend entwickelt sind.",
      },
    },
    {
      "@type": "Question",
      name: "Wann findet die Schulanmeldung in Mecklenburg-Vorpommern statt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Schulanmeldung erfolgt in Mecklenburg-Vorpommern bei der zuständigen Grundschule. Die konkreten Termine, benötigten Unterlagen und weiteren Schritte gibt die Schule oder der Schulträger bekannt. Zum Einschulungsverfahren gehört in der Regel auch die schulärztliche Untersuchung.",
      },
    },
    {
      "@type": "Question",
      name: "Kann die Einschulung in Mecklenburg-Vorpommern zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eine Zurückstellung ist in Mecklenburg-Vorpommern auf Antrag der Erziehungsberechtigten nur aus erheblichen gesundheitlichen Gründen möglich, wenn ein erfolgreicher Schulbesuch noch nicht zu erwarten ist. Die Entscheidung trifft die Schulleitung im Einvernehmen mit dem Schularzt.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Mecklenburg-Vorpommern verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde in Mecklenburg-Vorpommern.",
      },
    },
  ],
};
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-mecklenburg-vorpommern/" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Mecklenburg-Vorpommern</p>

        <h1>
          Einschulung in<br />
          Mecklenburg-Vorpommern:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Mecklenburg-Vorpommern in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. In
          Mecklenburg-Vorpommern gilt der Stichtag 30. Juni. Für das Schuljahr
          2026/2027 fällt die Einschulung voraussichtlich auf Samstag,
          22. August 2026 – der erste Schultag ist Montag, 24. August 2026.
        </p>

        <StateEnrollmentCalculator
          stateName="Mecklenburg-Vorpommern"
          stateSlug="mecklenburg-vorpommern"
          calculatorKicker="Mecklenburg-Vorpommern-Rechner"
          resultKicker="Mecklenburg-Vorpommern-Ergebnis"
          headline="Einschulung in Mecklenburg-Vorpommern berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Mecklenburg-Vorpommern ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Mecklenburg-Vorpommern">
          <div class="fact-card fact-card-highlight">
            <span>Nächste Einschulung</span>
            <strong>Samstag, 22. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag, 24. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. Juni</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>
        </div>

        <section class="example-box">
          <h2>Wie funktioniert der Einschulungsrechner für Mecklenburg-Vorpommern?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Mecklenburg-Vorpommern.
            Entscheidend ist der Stichtag 30. Juni. Wird dein Kind bis zu diesem
            Datum sechs Jahre alt, ist es in Mecklenburg-Vorpommern regulär
            schulpflichtig.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. Juni 2020 geboren, wird es am
            15. Juni 2026 sechs Jahre alt. Da dieses Datum vor dem Stichtag
            30. Juni liegt, ist das Kind voraussichtlich für das Schuljahr
            2026/2027 regulär schulpflichtig.
          </p>

          <p>
            Wird ein Kind dagegen erst nach dem 30. Juni sechs Jahre alt, ist es
            nicht automatisch regulär schulpflichtig. Eine vorzeitige Einschulung
            kann auf Antrag der Erziehungsberechtigten geprüft werden.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind in Mecklenburg-Vorpommern schulpflichtig?</h2>

          <p>
            In Mecklenburg-Vorpommern gilt der 30. Juni als maßgeblicher Stichtag
            für die Schulpflicht. Kinder, die spätestens an diesem Tag sechs Jahre
            alt sind, werden mit dem 1. August desselben Jahres schulpflichtig.
          </p>

          <p>
            Entscheidend ist also, ob der sechste Geburtstag bis einschließlich
            30. Juni erreicht ist. Liegt der Geburtstag nach dem Stichtag, besteht
            keine automatische Schulpflicht für dieses Schuljahr; eine vorzeitige
            Einschulung kann aber als Kann-Kind auf Antrag geprüft werden.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Mecklenburg-Vorpommern früher eingeschult werden?</h2>

          <p>
            Kinder, die bis zum 30. Juni des darauffolgenden Jahres sechs Jahre alt
            werden, können auf Antrag der Erziehungsberechtigten mit Beginn des
            Schuljahres vorzeitig eingeschult werden. Voraussetzung ist, dass das
            Kind für den Schulbesuch körperlich, geistig und verhaltensmäßig
            hinreichend entwickelt ist.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Mecklenburg-Vorpommern ab?</h2>

          <p>
            Die Schulanmeldung erfolgt in Mecklenburg-Vorpommern bei der zuständigen
            Grundschule. Die konkreten Termine, benötigten Unterlagen und weiteren
            Schritte gibt die Schule oder der Schulträger bekannt. Zum
            Einschulungsverfahren gehört in der Regel auch die schulärztliche
            Untersuchung.
          </p>
        </section>

        <section>
          <h2>Mein Kind ist noch nicht schulreif – was muss ich in Mecklenburg-Vorpommern tun?</h2>

          <p>
            Eine Zurückstellung kann in Mecklenburg-Vorpommern auf Antrag der
            Erziehungsberechtigten nur aus erheblichen gesundheitlichen Gründen
            erfolgen, wenn ein erfolgreicher Schulbesuch noch nicht zu erwarten ist.
            Die Entscheidung trifft die Schulleitung im Einvernehmen mit dem
            Schularzt. Verbindliche Auskunft erhältst du bei der zuständigen
            Grundschule oder Schulbehörde.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Mecklenburg-Vorpommern</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Mecklenburg-Vorpommern?</h3>
              <p>
                In Mecklenburg-Vorpommern gilt grundsätzlich der 30. Juni als
                Einschulungsstichtag. Kinder, die bis zu diesem Datum sechs Jahre
                alt werden, werden mit dem 1. August desselben Jahres schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Mecklenburg-Vorpommern 2026?</h3>
              <p>
                Die Sommerferien in Mecklenburg-Vorpommern enden im Schuljahr
                2026/2027 am Samstag, 22. August 2026. Die Einschulung findet
                voraussichtlich ebenfalls an diesem Tag statt; der erste reguläre
                Schultag ist Montag, 24. August 2026.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind in Mecklenburg-Vorpommern?</h3>
              <p>
                Als Kann-Kind gilt in Mecklenburg-Vorpommern ein Kind, das nach dem
                regulären Stichtag 30. Juni sechs Jahre alt wird und deshalb nicht
                automatisch schulpflichtig ist. Kinder, die bis zum 30. Juni des
                darauffolgenden Jahres sechs Jahre alt werden, können auf Antrag der
                Erziehungsberechtigten vorzeitig eingeschult werden, wenn sie für
                den Schulbesuch hinreichend entwickelt sind.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung in Mecklenburg-Vorpommern statt?</h3>
              <p>
                Die Schulanmeldung erfolgt in Mecklenburg-Vorpommern bei der
                zuständigen Grundschule. Die konkreten Termine, benötigten Unterlagen
                und weiteren Schritte gibt die Schule oder der Schulträger bekannt.
                Zum Einschulungsverfahren gehört in der Regel auch die schulärztliche
                Untersuchung.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann die Einschulung in Mecklenburg-Vorpommern zurückgestellt werden?</h3>
              <p>
                Eine Zurückstellung ist in Mecklenburg-Vorpommern auf Antrag der
                Erziehungsberechtigten nur aus erheblichen gesundheitlichen Gründen
                möglich, wenn ein erfolgreicher Schulbesuch noch nicht zu erwarten
                ist. Die Entscheidung trifft die Schulleitung im Einvernehmen mit
                dem Schularzt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Mecklenburg-Vorpommern verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen
                der Orientierung. Verbindliche Informationen erhältst du bei der
                zuständigen Grundschule oder Schulbehörde in Mecklenburg-Vorpommern.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Mecklenburg-Vorpommern:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Mecklenburg-Vorpommern">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://www.regierung-mv.de/Landesregierung/bm/Schule/Unterricht/Einschulung/"
                target="_blank"
                rel="noopener noreferrer"
              >
                Regierungsportal Mecklenburg-Vorpommern: Einschulung
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://www.landesrecht-mv.de/bsmv/document/jlr-SchulGMV2010V29P43"
                target="_blank"
                rel="noopener noreferrer"
              >
                Landesrecht Mecklenburg-Vorpommern: § 43 Beginn der Schulpflicht
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://www.kmk.org/fileadmin/Dateien/pdf/Ferienkalender/FER2025_26.pdf"
                target="_blank"
                rel="noopener noreferrer"
              >
                Kultusministerkonferenz: Ferientermine Schuljahr 2025/2026
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Land Mecklenburg-Vorpommern.
          </p>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  :global(body.has-mecklenburg-vorpommern-calculator-result) .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

