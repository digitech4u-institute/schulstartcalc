---
import BaseLayout from "../layouts/BaseLayout.astro";
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Hamburg 2026: Termin, Stichtag & Rechner";

const pageDescription =
  "Wann ist die Einschulung in Hamburg 2026? Hier findest du Termin, Stichtag 30. Juni, Kann-Kind-Regelung und den kostenlosen Einschulungsrechner.";

const canonical = "https://www.einschulungsrechner.de/einschulung-hamburg/";
const dateModified = "2026-05-27";

const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || "";
const STATE_CONTENT_AD_SLOT = import.meta.env.PUBLIC_ADSENSE_STATE_CONTENT_SLOT || "";
const showContentAd = Boolean(ADSENSE_ID && STATE_CONTENT_AD_SLOT);

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  datePublished: "2025-10-01",
  dateModified,
  inLanguage: "de",
  publisher: {
    "@type": "Organization",
    name: "Einschulungsrechner",
    url: "https://www.einschulungsrechner.de/",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Hamburg?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Hamburg werden Kinder am 1. August schulpflichtig, wenn sie vor dem 1. Juli desselben Kalenderjahres das sechste Lebensjahr vollendet haben. Praktisch betrifft das Kinder, die bis einschließlich 30. Juni sechs Jahre alt werden. Hamburg hat keinen Einschulungskorridor; eine vorzeitige Einschulung kann auf Antrag geprüft werden.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Hamburg 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Sommerferien in Hamburg enden 2026 am Mittwoch, 19. August 2026. Der erste Schultag ist Donnerstag, 20. August 2026. Die Einschulungsfeier der ersten Klassen legt die jeweilige Grundschule individuell fest. Häufig starten Erstklässlerinnen und Erstklässler am Montag oder Dienstag nach dem ersten Schultag. Verbindliche Informationen erhältst du bei der zuständigen Grundschule.",
      },
    },
    {
      "@type": "Question",
      name: "Wann beginnt die Grundschule in Hamburg 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der erste Schultag im Schuljahr 2026/2027 ist in Hamburg Donnerstag, 20. August 2026. Die Einschulung der ersten Klassen wird von der jeweiligen Grundschule festgelegt. Verbindliche Informationen erhältst du bei der zuständigen Grundschule.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind in Hamburg?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind werden Kinder bezeichnet, die nach dem regulären Stichtag sechs Jahre alt werden und nicht automatisch schulpflichtig sind. In Hamburg betrifft das Kinder, die nach dem 30. Juni sechs Jahre alt werden. Eine vorzeitige Einschulung kann auf Antrag der Sorgeberechtigten geprüft werden.",
      },
    },
    {
      "@type": "Question",
      name: "Kann mein Kind in Hamburg früher eingeschult werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Kinder, die nach dem 30. Juni sechs Jahre alt werden, sind in Hamburg nicht automatisch regulär schulpflichtig. Eine vorzeitige Einschulung kann auf Antrag der Sorgeberechtigten geprüft werden. Die Schule berücksichtigt dabei, ob das Kind geistig, seelisch, körperlich und sprachlich ausreichend entwickelt ist.",
      },
    },
    {
      "@type": "Question",
      name: "Was passiert, wenn mein Kind in Hamburg noch nicht schulfähig ist?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Wenn Zweifel an der Schulfähigkeit bestehen, solltest du frühzeitig Kontakt mit der zuständigen Grundschule aufnehmen. Die Schule prüft den Entwicklungsstand und informiert über das weitere Verfahren. Verbindliche Auskunft erhältst du bei der zuständigen Grundschule oder beim Schulinformationszentrum Hamburg.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Hamburg verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindlich sind die Auskünfte der zuständigen Grundschule, der Schulbehörde oder des Schulinformationszentrums Hamburg – insbesondere bei Fragen zur Schulanmeldung, vorzeitigen Einschulung oder individuellen Entscheidungen.",
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={[faqSchema, webPageSchema]}
>
  <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Hamburg</p>

        <h1>
          Einschulung Hamburg 2026:<br />
          Wann kommt mein Kind in die Schule?
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Hamburg in die Schule? Gib das Geburtsdatum ein
          und berechne das voraussichtliche Schuljahr. In Hamburg gilt der Stichtag
          30. Juni. Für das Schuljahr 2026/2027 ist der erste Schultag Donnerstag,
          20. August 2026. Die Einschulung wird von der jeweiligen Grundschule festgelegt.
        </p>

        <p class="answer-box">
          Kurzantwort: Der erste Schultag in Hamburg 2026 ist Donnerstag,
          20. August 2026. Die Einschulung wird schulabhängig von der jeweiligen
          Grundschule festgelegt. Schulpflichtig werden Kinder, die bis zum
          30. Juni 2026 sechs Jahre alt werden.
        </p>

        <StateEnrollmentCalculator
          stateName="Hamburg"
          stateSlug="hamburg"
          calculatorKicker="Hamburg-Rechner"
          resultKicker="Hamburg-Ergebnis"
          headline="Einschulung in Hamburg berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Hamburg ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Hamburg">
          <div class="fact-card fact-card-highlight">
            <span>Einschulung 2026</span>
            <strong>schulabhängig,<br />ab 24. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Donnerstag,<br />20. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. Juni</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>
        </div>

        {showContentAd ? (
          <aside class="ad-slot ad-slot-after-facts" aria-label="Anzeige">
            <p class="ad-label">Anzeige</p>
            <ins
              class="adsbygoogle"
              style="display:block"
              data-ad-client={ADSENSE_ID}
              data-ad-slot={STATE_CONTENT_AD_SLOT}
              data-ad-format="auto"
              data-full-width-responsive="true"
            ></ins>
          </aside>
        ) : null}

        <section>
          <h2>Wann ist die Einschulung in Hamburg 2026?</h2>

          <p>
            Die Sommerferien in Hamburg enden 2026 am Mittwoch, 19. August 2026.
            Der erste Schultag ist Donnerstag, 20. August 2026. Die Einschulung
            der ersten Klassen wird von der jeweiligen Grundschule festgelegt –
            häufig am Montag oder Dienstag nach dem ersten Schultag. Verbindliche
            Informationen erhältst du bei der zuständigen Grundschule.
          </p>
        </section>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Hamburg?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Hamburg. Entscheidend ist
            der Stichtag 30. Juni. Wird dein Kind bis zu diesem Datum sechs Jahre
            alt, ist es in Hamburg regulär schulpflichtig.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. Juni 2020 geboren, wird es am
            15. Juni 2026 sechs Jahre alt. Da dieses Datum vor dem 1. Juli liegt,
            ist das Kind voraussichtlich für das Schuljahr 2026/2027 regulär
            schulpflichtig.
          </p>

          <p>
            Wird ein Kind dagegen am 1. Juli 2020 oder später geboren, ist es in
            Hamburg nicht automatisch regulär schulpflichtig. Eine vorzeitige
            Einschulung kann auf Antrag der Sorgeberechtigten geprüft werden.
          </p>
        </section>

        <section>
          <h2>Welcher Einschulungsstichtag gilt in Hamburg?</h2>

          <p>
            Ein Kind wird in Hamburg regulär schulpflichtig, wenn es vor dem
            1. Juli des jeweiligen Kalenderjahres das sechste Lebensjahr vollendet
            hat. Praktisch betrifft das Kinder, die bis zum 30. Juni sechs Jahre
            alt werden. Die Schulpflicht beginnt dann am 1. August desselben Jahres.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Hamburg früher eingeschult werden?</h2>

          <p>
            Hamburg hat keinen Einschulungskorridor wie Bayern. Kinder, die nach
            dem 30. Juni sechs Jahre alt werden, sind nicht automatisch regulär
            schulpflichtig. Eine vorzeitige Einschulung kann aber auf Antrag der
            Sorgeberechtigten geprüft werden. Diese Kinder werden auch als
            Kann-Kinder bezeichnet.
          </p>
        </section>

        <section>
          <h2>Wie läuft die vorzeitige Einschulung in Hamburg ab?</h2>

          <p>
            Wenn dein Kind nach dem 30. Juni sechs Jahre alt wird, kannst du eine
            vorzeitige Einschulung bei der zuständigen Grundschule prüfen lassen.
            Dabei wird berücksichtigt, ob dein Kind geistig, seelisch, körperlich
            und sprachlich ausreichend entwickelt ist, um erfolgreich am Unterricht
            teilzunehmen.
          </p>

          <p>
            Nimm frühzeitig Kontakt mit der zuständigen Grundschule auf. Bei
            allgemeinen Fragen unterstützt auch das Schulinformationszentrum
            Hamburg unter der Telefonnummer 040 428 99 22 11.
          </p>
        </section>

        <section class="example-box">
          <h2>Beispiel: Geburtsdatum nach dem Stichtag</h2>

          <p>
            Wird ein Kind am 1. Juli 2020 geboren, vollendet es am 1. Juli 2026
            das sechste Lebensjahr. Damit liegt der Geburtstag nach dem Hamburger
            Stichtag 30. Juni. Das Kind ist für das Schuljahr 2026/2027 nicht
            automatisch regulär schulpflichtig; eine vorzeitige Einschulung kann
            auf Antrag der Sorgeberechtigten geprüft werden.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Hamburg</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Hamburg?</h3>
              <p>
                In Hamburg werden Kinder am 1. August schulpflichtig, wenn sie vor
                dem 1. Juli desselben Kalenderjahres das sechste Lebensjahr
                vollendet haben. Praktisch betrifft das Kinder, die bis einschließlich
                30. Juni sechs Jahre alt werden. Hamburg hat keinen Einschulungskorridor;
                eine vorzeitige Einschulung kann auf Antrag geprüft werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Hamburg 2026?</h3>
              <p>
                Die Sommerferien in Hamburg enden 2026 am Mittwoch, 19. August 2026.
                Der erste Schultag ist Donnerstag, 20. August 2026. Die
                Einschulungsfeier der ersten Klassen legt die jeweilige Grundschule
                individuell fest. Häufig starten Erstklässlerinnen und Erstklässler
                am Montag oder Dienstag nach dem ersten Schultag. Verbindliche
                Informationen erhältst du bei der zuständigen Grundschule.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann beginnt die Grundschule in Hamburg 2026?</h3>
              <p>
                Der erste Schultag im Schuljahr 2026/2027 ist in Hamburg Donnerstag,
                20. August 2026. Die Einschulung der ersten Klassen wird von der
                jeweiligen Grundschule festgelegt. Verbindliche Informationen erhältst
                du bei der zuständigen Grundschule.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind in Hamburg?</h3>
              <p>
                Als Kann-Kind werden Kinder bezeichnet, die nach dem regulären
                Stichtag sechs Jahre alt werden und nicht automatisch schulpflichtig
                sind. In Hamburg betrifft das Kinder, die nach dem 30. Juni sechs
                Jahre alt werden. Eine vorzeitige Einschulung kann auf Antrag der
                Sorgeberechtigten geprüft werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann mein Kind in Hamburg früher eingeschult werden?</h3>
              <p>
                Kinder, die nach dem 30. Juni sechs Jahre alt werden, sind in
                Hamburg nicht automatisch regulär schulpflichtig. Eine vorzeitige
                Einschulung kann auf Antrag der Sorgeberechtigten geprüft werden.
                Die Schule berücksichtigt dabei, ob das Kind geistig, seelisch,
                körperlich und sprachlich ausreichend entwickelt ist.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was passiert, wenn mein Kind in Hamburg noch nicht schulfähig ist?</h3>
              <p>
                Wenn Zweifel an der Schulfähigkeit bestehen, solltest du frühzeitig
                Kontakt mit der zuständigen Grundschule aufnehmen. Die Schule prüft
                den Entwicklungsstand und informiert über das weitere Verfahren.
                Verbindliche Auskunft erhältst du bei der zuständigen Grundschule
                oder beim Schulinformationszentrum Hamburg.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Hamburg verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen der
                Orientierung. Verbindlich sind die Auskünfte der zuständigen Grundschule,
                der Schulbehörde oder des Schulinformationszentrums Hamburg – insbesondere
                bei Fragen zur Schulanmeldung, vorzeitigen Einschulung oder individuellen
                Entscheidungen.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Hamburg:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Hamburg">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://www.hamburg.de/service/info/11330100/"
                target="_blank"
                rel="noopener noreferrer"
              >
                hamburg.de: Schulinformationszentrum – Einschulung
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://www.hamburg.de/leben-in-hamburg/ferien-feiertage-termine-378818"
                target="_blank"
                rel="noopener noreferrer"
              >
                hamburg.de: Schulferien und Feiertage in Hamburg 2026
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://www.landesrecht-hamburg.de/bsha/document/jlr-SchulGHArahmen/part/X"
                target="_blank"
                rel="noopener noreferrer"
              >
                Hamburgisches Schulgesetz: § 38 – Beginn der Schulpflicht
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Schulinformationszentrum Hamburg.
          </p>

          <p class="stand">Stand der Informationen:<span class="stand-date">Mai 2026</span></p>
        </section>
      </article>
  </main>
</BaseLayout>

<style is:global>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .answer-box {
    max-width: 760px;
    margin: 20px 0 0;
    padding: 18px 20px;
    border: 1px solid rgba(129, 97, 38, 0.18);
    border-radius: 18px;
    background: rgba(245, 210, 138, 0.14);
    color: #172033;
    font-size: clamp(1.02rem, 1.35vw, 1.12rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  body.has-hamburg-calculator-result .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .ad-slot {
    margin: 30px 0 0;
    padding: 14px 0;
    border-top: 1px solid rgba(42, 35, 21, 0.08);
    border-bottom: 1px solid rgba(42, 35, 21, 0.08);
  }

  .ad-label {
    margin: 0 0 10px;
    color: #8a7960;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .stand {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    width: fit-content;
    margin-top: 16px;
