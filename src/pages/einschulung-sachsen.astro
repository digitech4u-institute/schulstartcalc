---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Sachsen 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Sachsen in die Schule? Alle Informationen zu Stichtag 30. Juni, Schulanmeldung, Kann-Kind-Regelung, Zurückstellung und Schuleinführung 2026.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Sachsen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Sachsen gilt grundsätzlich der 30. Juni als Einschulungsstichtag. Kinder, die bis zu diesem Datum sechs Jahre alt werden, werden mit Beginn des Schuljahres schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann findet die Schulanmeldung in Sachsen statt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Schulanmeldung findet in Sachsen in der Regel im Zeitraum vom 1. August bis zum 15. September im Jahr vor der Einschulung statt. Ort und Zeit geben die Städte und Gemeinden im Mai bekannt.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Schuleinführung in Sachsen 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Für Sachsen ist die Schuleinführung im Schuljahr 2026/2027 offiziell für Samstag, den 15. August 2026, genannt. Der erste Schultag ist Montag, der 17. August 2026. Einzelne organisatorische Details können je nach Schule abweichen.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind in Sachsen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind gilt in Sachsen ein Kind, das nach dem regulären Stichtag 30. Juni sechs Jahre alt wird und deshalb nicht automatisch schulpflichtig ist. Eine frühere Einschulung kann auf Antrag der Eltern geprüft werden, wenn das Kind den erforderlichen Entwicklungsstand für den Schulbesuch besitzt.",
      },
    },
    {
      "@type": "Question",
      name: "Kann mein Kind in Sachsen vom Schulbesuch zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eine Zurückstellung ist in Sachsen im Ausnahmefall möglich, wenn ein Kind bei Beginn der Schulpflicht geistig oder körperlich nicht genügend entwickelt ist, um mit Erfolg am Unterricht teilzunehmen. Die Entscheidung trifft die Schulleitung.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Sachsen verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde in Sachsen.",
      },
    },
  ],
};
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-sachsen/" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Sachsen</p>

        <h1>
          Einschulung in Sachsen:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Sachsen in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr.
          In Sachsen gilt der Stichtag 30. Juni. Für das Schuljahr 2026/2027
          ist die Schuleinführung für Samstag, den 15. August 2026 vorgesehen –
          der erste Schultag ist Montag, der 17. August 2026.
        </p>

        <StateEnrollmentCalculator
          stateName="Sachsen"
          stateSlug="sachsen"
          calculatorKicker="Sachsen-Rechner"
          resultKicker="Sachsen-Ergebnis"
          headline="Einschulung in Sachsen berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Sachsen ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Sachsen">
          <div class="fact-card fact-card-highlight">
            <span>Nächste Einschulung</span>
            <strong>Samstag, 15.08.2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag, 17.08.2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. Juni</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>
        </div>

        <section class="example-box">
          <h2>Wie funktioniert der Einschulungsrechner für Sachsen?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Sachsen. Entscheidend ist
            der Stichtag 30. Juni. Wird dein Kind bis zu diesem Datum sechs Jahre
            alt, ist es in Sachsen regulär schulpflichtig.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. Juni 2020 geboren, wird es vor dem
            Stichtag 30. Juni 2026 sechs Jahre alt. Damit ist das Kind
            voraussichtlich für das Schuljahr 2026/2027 regulär schulpflichtig.
          </p>

          <p>
            Wird ein Kind dagegen erst nach dem 30. Juni sechs Jahre alt, ist es
            nicht automatisch regulär schulpflichtig. Eine frühere Einschulung kann
            auf Antrag der Eltern geprüft werden, wenn das Kind den erforderlichen
            Entwicklungsstand für den Schulbesuch besitzt.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind in Sachsen schulpflichtig?</h2>

          <p>
            Ein Kind wird in Sachsen regulär schulpflichtig, wenn es bis zum
            30. Juni des jeweiligen Kalenderjahres sechs Jahre alt wird. Die
            Schulpflicht beginnt dann mit dem Start des neuen Schuljahres.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind nach dem 30. Juni früher eingeschult werden?</h2>

          <p>
            Maßgeblich für die reguläre Schulpflicht ist in Sachsen der 30. Juni.
            Kinder, die nach diesem Stichtag sechs Jahre alt werden, sind nicht
            automatisch schulpflichtig. Eine frühere Einschulung kann aber auf
            Antrag der Eltern geprüft werden, wenn das Kind den erforderlichen
            geistigen und körperlichen Entwicklungsstand für den Schulbesuch besitzt.
          </p>
        </section>


        <section>
          <h2>Wie läuft die vorzeitige Einschulung in Sachsen ab?</h2>

          <p>
            Die vorzeitige Einschulung ist keine automatische Schulpflicht, sondern
            erfolgt auf Antrag der Eltern. Die Schule prüft, ob das Kind den für
            den Schulbesuch erforderlichen geistigen und körperlichen Entwicklungsstand
            besitzt. Entscheidend ist also nicht nur das Geburtsdatum, sondern die
            individuelle Schulbereitschaft des Kindes.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Anmeldung zur Schule in Sachsen ab?</h2>

          <p>
            Die Schulanmeldung findet in Sachsen in der Regel im Zeitraum vom
            1. August bis zum 15. September im Jahr vor der Einschulung statt –
            also nicht erst im Einschulungsjahr selbst. Ort und Zeit der Anmeldung
            geben die Städte und Gemeinden in Abstimmung mit den Schulleitungen
            der Grundschulen im Mai bekannt. Angemeldet werden müssen Kinder, die
            bis zum 30. Juni des folgenden Kalenderjahres sechs Jahre alt werden.
          </p>
        </section>

        <section>
          <h2>Kann die Einschulung zurückgestellt werden?</h2>

          <p>
            Eine Zurückstellung ist in Sachsen eine Ausnahme. Sie kommt in Betracht,
            wenn ein schulpflichtiges Kind bei Beginn der Schulpflicht geistig oder
            körperlich nicht genügend entwickelt ist, um mit Erfolg am Unterricht
            teilzunehmen. Die Entscheidung trifft die Schulleitung; zugleich werden
            geeignete Fördermaßnahmen vereinbart. Bei Hinweisen auf sonderpädagogischen
            Förderbedarf gelten gesonderte Prüf- und Beratungswege.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Sachsen</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Sachsen?</h3>
              <p>
                In Sachsen gilt grundsätzlich der 30. Juni als Stichtag für die
                Einschulung.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind in Sachsen?</h3>
              <p>
                Als Kann-Kind gilt in Sachsen ein Kind, das nach dem regulären
                Stichtag 30. Juni sechs Jahre alt wird und deshalb nicht automatisch
                schulpflichtig ist. Eine frühere Einschulung kann auf Antrag der
                Eltern geprüft werden, wenn das Kind den erforderlichen
                Entwicklungsstand für den Schulbesuch besitzt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung in Sachsen statt?</h3>
              <p>
                Die Schulanmeldung findet in Sachsen in der Regel im Zeitraum vom
                1. August bis zum 15. September im Jahr vor der Einschulung statt.
                Ort und Zeit geben die Städte und Gemeinden im Mai bekannt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist der Einschulungstag in Sachsen 2026?</h3>
              <p>
                Für Sachsen ist die Schuleinführung im Schuljahr 2026/2027
                offiziell für Samstag, den 15. August 2026, genannt. Der erste
                Schultag ist Montag, der 17. August 2026. Einzelne organisatorische
                Details können je nach Schule abweichen.
              </p>
            </article>


            <article class="faq-item">
              <h3>Kann mein Kind vom Schulbesuch zurückgestellt werden?</h3>
              <p>
                Eine Zurückstellung ist im Ausnahmefall möglich, wenn das Kind bei
                Beginn der Schulpflicht geistig oder körperlich nicht genügend
                entwickelt ist, um mit Erfolg am Unterricht teilzunehmen. Die
                Entscheidung trifft die Schulleitung.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis verbindlich?</h3>
              <p>
                Nein. Der Rechner und diese Seite dienen der Orientierung.
                Verbindliche Informationen erhältst du bei der zuständigen Schule
                oder Schulbehörde in Sachsen.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Sachsen:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Sachsen">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://www.schule.sachsen.de/aufnahme-in-die-schule-4012.html"
                target="_blank"
                rel="noopener noreferrer"
              >
                sachsen.de: Aufnahme in die Schule
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://www.schule.sachsen.de/schuljahrestermine-4793.html"
                target="_blank"
                rel="noopener noreferrer"
              >
                sachsen.de: Schuljahrestermine und Schuleinführung
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://www.recht.sachsen.de/vorschrift/4192.27"
                target="_blank"
                rel="noopener noreferrer"
              >
                recht.sachsen.de: Sächsisches Schulgesetz § 27
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, beim Landesamt für Schule und Bildung oder beim Sächsischen
            Staatsministerium für Kultus.
          </p>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .stand {
    display: inline-flex;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
      letter-spacing: -0.05em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .fact-card {
      min-height: 102px;
      padding: 18px 22px;
    }

    .fact-card span {
      font-size: clamp(0.82rem, 3.45vw, 0.96rem);
      letter-spacing: 0.095em;
    }

    .fact-card strong {
      font-size: clamp(1.12rem, 4.9vw, 1.36rem);
      line-height: 1.14;
    }

    section {
      margin-top: 30px;
      padding-top: 28px;
    }

    h2 {
      font-size: 1.62rem;
      line-height: 1.1;
    }

    p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .faq-item p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .example-box,
    .source-note {
      padding: 20px;
      border-radius: 20px;
    }

    .source-link {
      width: auto;
      font-size: 1rem;
      line-height: 1.42;
    }
  }

  @media (max-width: 390px) {
    h1 {
      font-size: clamp(1.58rem, 7vw, 1.95rem);
      line-height: 1.07;
      letter-spacing: -0.046em;
    }
  }
</style>
