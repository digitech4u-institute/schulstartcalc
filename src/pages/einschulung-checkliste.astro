

---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle =
  "Einschulung Checkliste 2026 – Was braucht mein Kind zur Einschulung?";

const pageDescription =
  "Was braucht mein Kind zur Einschulung? Checkliste für Schulranzen, Schultüte, Unterlagen und Schulanmeldung – Schritt für Schritt zum Schulstart 2026.";

const canonical = "https://www.einschulungsrechner.de/einschulung-checkliste/";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Was gehört auf eine Einschulungs-Checkliste?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Auf eine Einschulungs-Checkliste gehören unter anderem Schulanmeldung, wichtige Unterlagen, schulärztliche Untersuchung, Schulranzen, Materialliste, Schulweg, Betreuung, Schultüte und die emotionale Vorbereitung des Kindes.",
      },
    },
    {
      "@type": "Question",
      name: "Was braucht mein Kind zur Einschulung?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Zur Einschulung braucht dein Kind einen Schulranzen, Schreibzeug wie Bleistift, Buntstifte und Füller, eine Federmappe, Hefte, einen Sportbeutel und geeignetes Sportzeug. Dazu kommen schulspezifische Unterlagen wie Impfnachweis, Anmeldeformular und weitere Vorgaben der Schule.",
      },
    },
    {
      "@type": "Question",
      name: "Was kommt in eine Schultüte?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In eine Schultüte kommen klassisch Schreibzeug wie Buntstifte oder Füller, ein Kinderbuch, eine kleine Süßigkeit und etwas Persönliches wie ein kleines Spielzeug, ein Glücksbringer oder ein Foto. Die Schultüte ist ein Geschenk für den ersten Schultag.",
      },
    },
    {
      "@type": "Question",
      name: "Wann sollte man mit der Vorbereitung auf die Einschulung beginnen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Viele organisatorische Punkte beginnen mehrere Monate vor dem Schulstart. Sinnvoll ist es, nach dem Einschulungsergebnis frühzeitig die zuständige Schule, Anmeldefristen und benötigte Unterlagen zu prüfen.",
      },
    },
    {
      "@type": "Question",
      name: "Welche Unterlagen braucht man für die Schulanmeldung?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Typische Unterlagen sind Geburtsurkunde oder Ausweisdokument des Kindes, Nachweis der Sorgeberechtigung, Meldebestätigung, Impf- oder Masernschutznachweis und gegebenenfalls weitere Unterlagen der zuständigen Schule. Die genauen Anforderungen unterscheiden sich je nach Bundesland und Schule.",
      },
    },
    {
      "@type": "Question",
      name: "Sind Einschulungs-Checklisten verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Die Checkliste dient der Orientierung. Verbindliche Informationen zu Fristen, Unterlagen und Abläufen erhalten Eltern bei der zuständigen Grundschule oder Schulbehörde.",
      },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} schema={faqSchema}>
  <main class="guide-page">
      <a class="back-link" href="/einschulung/">← Zurück zum Einschulungs-Ratgeber</a>

      <article class="guide-card">
        <p class="guide-kicker">Checkliste</p>

        <h1>
          Einschulung Checkliste:<br />
          Was braucht mein Kind zum Schulstart?
        </h1>

        <p class="lead">
          Schulranzen, Schultüte, Schulanmeldung, Unterlagen – rund um den
          Schulstart gibt es viel zu bedenken. Diese Checkliste hilft dir,
          nichts Wichtiges zu vergessen: von der Anmeldung an der Grundschule
          bis zur ersten Schultasche. Schritt für Schritt, damit der Schulstart
          2026 entspannt gelingt.
        </p>

        <div class="phase-grid" aria-label="Kurzüberblick Einschulungs-Checkliste">
          <div class="phase-card">
            <span>1</span>
            <strong>Orientieren</strong>
            <p>Schuljahr, Bundesland und Stichtag einordnen.</p>
          </div>

          <div class="phase-card">
            <span>2</span>
            <strong>Organisieren</strong>
            <p>Anmeldung, Unterlagen und Fristen prüfen.</p>
          </div>

          <div class="phase-card">
            <span>3</span>
            <strong>Vorbereiten</strong>
            <p>Ausstattung, Schulweg und Alltag planen.</p>
          </div>
        </div>

        <section class="highlight-section">
          <h2>Erster Schritt: Einschulung berechnen</h2>

          <p>
            Du bist noch unsicher, welches Schuljahr für dein Kind relevant ist?
            Dann starte zuerst mit dem Einschulungsrechner und prüfe Geburtsdatum
            und Bundesland.
          </p>

          <a class="cta-link" href="/">Jetzt Einschulung berechnen</a>
        </section>

        <section>
          <h2>Die wichtigste Checkliste im Überblick</h2>

          <div class="checklist-box">
            <label><input type="checkbox" /> Einschulungsjahr mit dem Rechner prüfen</label>
            <label><input type="checkbox" /> Bundeslandseite und Stichtag lesen</label>
            <label><input type="checkbox" /> Zuständige Grundschule ermitteln</label>
            <label><input type="checkbox" /> Zeitraum für die Schulanmeldung prüfen</label>
            <label><input type="checkbox" /> Benötigte Unterlagen sammeln</label>
            <label><input type="checkbox" /> Schulärztliche Untersuchung beachten</label>
            <label><input type="checkbox" /> Betreuung nach Schulschluss klären</label>
            <label><input type="checkbox" /> Schulweg gemeinsam üben</label>
            <label><input type="checkbox" /> Schulranzen und Ausstattung besorgen</label>
            <label><input type="checkbox" /> Schultüte und erster Schultag planen</label>
          </div>
        </section>

        <section>
          <h2>12 bis 6 Monate vor der Einschulung</h2>

          <p>
            In dieser Phase geht es vor allem um Orientierung. Prüfe, welches
            Schuljahr voraussichtlich relevant ist, welche Regel in deinem
            Bundesland gilt und welche Grundschule zuständig sein könnte.
          </p>

          <div class="next-steps">
            <article>
              <h3>Schuljahr prüfen</h3>
              <p>
                Nutze den Rechner und lies die passende Bundeslandseite, damit du
                Stichtag und mögliche Sonderregeln verstehst.
              </p>
            </article>

            <article>
              <h3>Schule ermitteln</h3>
              <p>
                Informiere dich, welche Grundschule für deinen Wohnort zuständig
                ist und ob es besondere Informationsveranstaltungen gibt.
              </p>
            </article>

            <article>
              <h3>Fristen notieren</h3>
              <p>
                Trage dir Anmeldezeiträume, Untersuchungstermine und wichtige
                Schultermine frühzeitig in den Kalender ein.
              </p>
            </article>
          </div>
        </section>

        <section>
          <h2>6 bis 3 Monate vor der Einschulung</h2>

          <p>
            Jetzt wird es konkreter: Anmeldung, Unterlagen, Betreuung und erste
            praktische Fragen rücken in den Mittelpunkt. Die genauen Abläufe
            unterscheiden sich je nach Bundesland, Gemeinde und Schule.
          </p>

          <div class="checklist-box compact">
            <label><input type="checkbox" /> Einladung oder Informationen der Schule prüfen</label>
            <label><input type="checkbox" /> Anmeldeunterlagen vorbereiten</label>
            <label><input type="checkbox" /> Betreuung, Hort oder Nachmittagsangebot klären</label>
            <label><input type="checkbox" /> Fragen zu Kann-Kind oder Zurückstellung rechtzeitig ansprechen</label>
          </div>
        </section>

        <section>
          <h2>Welche Unterlagen können wichtig sein?</h2>

          <p>
            Die Anforderungen können sich unterscheiden. Häufig werden aber
            bestimmte Nachweise benötigt. Verbindlich ist immer die Information
            der zuständigen Schule oder Behörde.
          </p>

          <div class="info-list">
            <article>
              <h3>Persönliche Unterlagen</h3>
              <p>Geburtsurkunde, Ausweis oder Meldebestätigung des Kindes.</p>
            </article>

            <article>
              <h3>Nachweise der Eltern</h3>
              <p>Angaben zu Erziehungsberechtigten, Sorgeberechtigung oder Wohnsitz.</p>
            </article>

            <article>
              <h3>Gesundheitliche Nachweise</h3>
              <p>Je nach Vorgabe Impf- oder Masernschutznachweis und schulärztliche Untersuchung.</p>
            </article>
          </div>
        </section>

        <section>
          <h2>3 bis 1 Monat vor dem Schulstart</h2>

          <p>
            In dieser Phase geht es um die praktische Vorbereitung: Schulranzen,
            Materialliste, Schulweg, Tagesrhythmus und die emotionale Einstimmung
            auf den neuen Lebensabschnitt.
          </p>

          <div class="next-steps">
            <article>
              <h3>Ausstattung besorgen</h3>
              <p>
                Schulranzen, Federmappe, Brotdose, Trinkflasche und Materialien
                nach der Liste der Schule vorbereiten.
              </p>
            </article>

            <article>
              <h3>Schulweg üben</h3>
              <p>
                Gehe den Schulweg mehrfach gemeinsam ab und besprecht gefährliche
                Stellen, Ampeln und sichere Übergänge.
              </p>
            </article>

            <article>
              <h3>Alltag vorbereiten</h3>
              <p>
                Übt Morgenroutine, Schlafenszeiten, Pausenbrot und selbstständiges
                Packen kleiner Dinge.
              </p>
            </article>
          </div>

          <div class="checklist-hint-box">
            <p class="checklist-hint-kicker">Kauftipp</p>
            <h3 class="checklist-hint-title">Worauf du beim Schulranzen achten solltest</h3>
            <p>
              Ein guter Schulranzen für Erstklässler erfüllt die Norm
              <strong>DIN 58124</strong>: ergonomisch geformte Rückenplatte,
              breit verstellbare Träger, Reflektoren rundum und ein Leergewicht
              unter 1,2 kg. Verzichte auf schwere Metallverschlüsse –
              Kinder der ersten Klasse müssen den Ranzen selbst öffnen können.
            </p>
          </div>

          <div class="checklist-hint-box">
            <p class="checklist-hint-kicker">Materialien</p>
            <h3 class="checklist-hint-title">Welche Materialien Erstklässler wirklich brauchen</h3>
            <p>
              Viele Schulen geben eine <strong>Materialliste</strong> bei der
              Anmeldung aus – frag dort nach, bevor du kaufst. Grundsätzlich
              empfehlenswert für den Start: <strong>Dreikant-Bleistifte</strong>,
              ein weicher Radierer ohne Hülle, dicke Buntstifte, eine stabile
              Federmappe und ein Trinkfläschchen für den Schulrucksack.
            </p>
          </div>
        </section>

        <section>
          <h2>Letzte Woche vor der Einschulung</h2>

          <p>
            Kurz vor dem ersten Schultag sollte möglichst Ruhe einkehren. Jetzt
            geht es nicht mehr darum, alles perfekt zu machen, sondern dem Kind
            Sicherheit, Vorfreude und Orientierung zu geben.
          </p>

          <div class="checklist-box compact">
            <label><input type="checkbox" /> Schulranzen gemeinsam packen</label>
            <label><input type="checkbox" /> Kleidung für den ersten Schultag bereitlegen</label>
            <label><input type="checkbox" /> Schultüte vorbereiten</label>
            <label><input type="checkbox" /> Ablauf des ersten Tages besprechen</label>
            <label><input type="checkbox" /> Früh genug schlafen gehen</label>
          </div>

          <div class="checklist-hint-box">
            <p class="checklist-hint-kicker">Ideen &amp; Tipps</p>
            <h3 class="checklist-hint-title">Was in eine gute Schultüte kommt</h3>
            <p>
              Klassisch und bewährt: <strong>Schreibzeug</strong> wie Buntstifte
              mit dicken Minen oder ein Dreikant-Bleistift, ein
              <strong>Kinderbuch</strong>, eine kleine Süßigkeit und etwas
              Persönliches – zum Beispiel ein Mini-Spielzeug, eine Postkarte
              oder ein Foto. Die Schultüte ist kein Pflichtprogramm, aber ein
              starkes Ritual für den ersten Schultag.
            </p>
          </div>
        </section>

        <section class="highlight-section">
          <h2>Was braucht mein Kind zur Einschulung?</h2>

          <p>
            Viele Dinge hängen von der Materialliste der Schule ab. Typisch sind
            Schulranzen, Federmappe, Stifte, Hefte, Brotdose, Trinkflasche,
            Hausschuhe oder Turnsachen. Kaufe größere Dinge möglichst erst, wenn
            klar ist, was die Schule tatsächlich vorgibt.
          </p>
        </section>

        <section class="project-note">
          <h2>Ein kostenloses Orientierungsangebot</h2>

          <p>
            einschulungsrechner.de ist ein kostenloses Orientierungsangebot von
            DigiTech4U für Eltern rund um Einschulung und Schulstart. Ziel ist es,
            Eltern eine verständliche und datensparsame Orientierung zu bieten.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulungs-Checkliste</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Was braucht mein Kind zur Einschulung?</h3>
              <p>
                Zur Einschulung braucht dein Kind einen Schulranzen, Schreibzeug
                wie Bleistift, Buntstifte und Füller, eine Federmappe, Hefte,
                einen Sportbeutel und geeignetes Sportzeug. Dazu kommen
                schulspezifische Unterlagen wie Impfnachweis, Anmeldeformular
                und weitere Vorgaben der Schule.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was kommt in eine Schultüte?</h3>
              <p>
                In eine Schultüte kommen klassisch Schreibzeug wie Buntstifte
                oder Füller, ein Kinderbuch, eine kleine Süßigkeit und etwas
                Persönliches wie ein kleines Spielzeug, ein Glücksbringer oder
                ein Foto. Die Schultüte ist ein Geschenk für den ersten Schultag.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann sollte ich mit der Einschulungsvorbereitung beginnen?</h3>
              <p>
                Sinnvoll ist es, mehrere Monate vorher mit Orientierung,
                Schulanmeldung und Unterlagen zu beginnen. Praktische Dinge wie
                Ausstattung und Schulweg folgen meist näher am Schulstart.
              </p>
            </article>

            <article class="faq-item">
              <h3>Brauche ich sofort einen Schulranzen?</h3>
              <p>
                Nicht unbedingt sofort. Wichtig ist, die Vorgaben der Schule und
                die körperliche Passform zu beachten. Viele Eltern kaufen den
                Schulranzen einige Monate vor dem Schulstart.
              </p>
            </article>

            <article class="faq-item">
              <h3>Sind Einschulungs-Checklisten verbindlich?</h3>
              <p>
                Nein. Sie dient der Orientierung. Verbindliche Informationen zu
                Fristen, Unterlagen und Abläufen erhältst du bei der zuständigen
                Grundschule oder Schulbehörde.
              </p>
            </article>
          </div>
        </section>
      </article>
  </main>
</BaseLayout>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .guide-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .guide-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .guide-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  h1 {
    max-width: 920px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.2rem, 4.35vw, 3.72rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  .lead {
    max-width: 780px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.7vw, 1.24rem);
    line-height: 1.65;
  }

  .phase-grid,
  .next-steps,
  .info-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .phase-card,
  .next-steps article,
  .info-list article,
  .faq-item {
    padding: 22px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .phase-card span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    margin-bottom: 16px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.12);
    color: #816126;
    font-weight: 950;
  }

  .phase-card strong {
    display: block;
    color: #172033;
    font-size: 1.2rem;
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  .highlight-section,
  .project-note {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .checklist-hint-box {
    display: grid;
    gap: 10px;
    margin: 28px 0 0;
    padding: 20px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 14px;
    background: #f5f2eb;
  }

  .checklist-hint-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .checklist-hint-title {
    margin: 0;
    color: #172033;
    font-size: 1.15rem;
    font-weight: 850;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .checklist-hint-box p:last-child {
    margin: 0;
    color: #3a3530;
    font-size: 0.97rem;
    line-height: 1.6;
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.65rem, 2.6vw, 2.25rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.05em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: 1.08rem;
    font-weight: 900;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: 1.03rem;
    line-height: 1.7;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 20px;
    min-height: 54px;
    padding: 0 22px;
    border-radius: 16px;
    background: #172033;
    color: #fff;
    font-weight: 850;
    text-decoration: none;
  }

  .cta-link:hover {
    background: #2a3550;
  }

  .checklist-box {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .checklist-box label {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 18px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.72);
    color: #172033;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .checklist-box.compact label {
    font-weight: 760;
  }

  input[type="checkbox"] {
    width: 20px;
    height: 20px;
    margin-top: 1px;
    accent-color: #172033;
    flex: 0 0 auto;
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .next-steps p,
  .info-list p,
  .faq-item p,
  .phase-card p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1.02rem, 1.5vw, 1.12rem);
    line-height: 1.62;
  }

  @media (max-width: 760px) {
    h1 {
      max-width: 100%;
      font-size: clamp(1.92rem, 6.25vw, 2.28rem);
      line-height: 1.06;
      letter-spacing: -0.058em;
    }

    .phase-grid,
    .next-steps,
    .info-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .guide-page {
      padding: 22px 14px 42px;
    }

    .guide-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      font-size: clamp(1.78rem, 5.85vw, 2.08rem);
      line-height: 1.07;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    section {
      margin-top: 30px;
      padding-top: 28px;
    }

    .highlight-section,
    .project-note {
      padding: 20px;
      border-radius: 20px;
    }

    h2 {
      font-size: 1.55rem;
      line-height: 1.12;
    }

    p {
      font-size: 0.96rem;
      line-height: 1.62;
    }

    .cta-link {
      width: 100%;
    }
  }
</style>