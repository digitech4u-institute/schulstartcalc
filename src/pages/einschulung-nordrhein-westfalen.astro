---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung NRW 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Nordrhein-Westfalen in die Schule? Erfahre alles zu Schulstart, erstem Schultag, Einschulung, Stichtag 30. September und Schulpflicht.";
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-nordrhein-westfalen/" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Wann kommt mein Kind in Nordrhein-Westfalen in die Schule?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Das hängt vom Geburtsdatum deines Kindes ab. In Nordrhein-Westfalen gilt der 30. September als Stichtag. Kinder, die bis einschließlich 30. September sechs Jahre alt werden, sind in Nordrhein-Westfalen ab dem 1. August desselben Kalenderjahres regulär schulpflichtig."
            }
          },
          {
            "@type": "Question",
            "name": "Wann ist der erste Schultag in Nordrhein-Westfalen 2026?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Der letzte Ferientag in Nordrhein-Westfalen ist 2026 Dienstag, der 1. September. Daraus ergibt sich voraussichtlich Mittwoch, der 2. September 2026, als allgemeiner erster Schultag nach den Sommerferien."
            }
          },
          {
            "@type": "Question",
            "name": "Wann ist die Einschulung in Nordrhein-Westfalen 2026?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In Nordrhein-Westfalen erfolgt die Einschulung in der Regel spätestens am zweiten Schultag nach den Sommerferien. Für 2026 ergibt sich daraus voraussichtlich Donnerstag, der 3. September 2026; organisatorische Abweichungen einzelner Grundschulen sind möglich."
            }
          },
          {
            "@type": "Question",
            "name": "Kann mein Kind in Nordrhein-Westfalen früher eingeschult werden?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Kinder, die nach dem Stichtag sechs Jahre alt werden, können auf Antrag der Eltern vorzeitig eingeschult werden. Die Schulleitung entscheidet nach Beratung mit den Eltern über die Aufnahme."
            }
          },
          {
            "@type": "Question",
            "name": "Wann muss ich mein Kind in Nordrhein-Westfalen an der Grundschule anmelden?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Kinder, die im folgenden Jahr schulpflichtig werden, müssen in Nordrhein-Westfalen bis spätestens 15. November an einer Grundschule angemeldet werden. Die Anmeldung erfolgt an der zuständigen oder gewählten Grundschule zu den vom Schulträger festgelegten Terminen."
            }
          },
          {
            "@type": "Question",
            "name": "Welche Quelle ist für die Einschulung in Nordrhein-Westfalen verbindlich?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Diese Seite dient der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule, der Schulbehörde oder beim Ministerium für Schule und Bildung des Landes Nordrhein-Westfalen."
            }
          }
        ]
      }
    </script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Nordrhein-Westfalen</p>

        <h1>
          Einschulung in<br />
          Nordrhein-Westfalen:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Nordrhein-Westfalen in die Schule? Der
          Einschulungsrechner zeigt dir anhand des Geburtsdatums das
          voraussichtliche Schuljahr. In Nordrhein-Westfalen gilt der Stichtag
          30. September. Der letzte Ferientag ist 2026 Dienstag, der
          1. September. Daraus ergibt sich voraussichtlich Mittwoch, der
          2. September 2026, als allgemeiner erster Schultag.
        </p>

        <StateEnrollmentCalculator
          stateName="Nordrhein-Westfalen"
          stateSlug="nordrhein-westfalen"
          calculatorKicker="Nordrhein-Westfalen-Rechner"
          resultKicker="Nordrhein-Westfalen-Ergebnis"
          headline="Einschulung in Nordrhein-Westfalen berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Nordrhein-Westfalen ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts" aria-label="Kurzüberblick Einschulung Nordrhein-Westfalen">
          <div class="fact-card fact-card-date">
            <span>Erster Schultag</span>
            <strong>Mittwoch, 02.09.2026</strong>
          </div>

          <div class="fact-card fact-card-date">
            <span>Spätester Einschulungstermin</span>
            <strong>Donnerstag, 03.09.2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. September</strong>
          </div>

          <div class="fact-card">
            <span>Schulpflicht</span>
            <strong>ab 1. August</strong>
          </div>
        </div>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Nordrhein-Westfalen?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Nordrhein-Westfalen.
            Entscheidend sind vor allem der Stichtag 30. September und der Beginn
            der Schulpflicht am 1. August desselben Kalenderjahres.
          </p>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. September 2020
            geboren, wird es am 15. September 2026 sechs Jahre alt. Da dieses
            Datum vor dem Stichtag 30. September liegt, ist das Kind in
            Nordrhein-Westfalen regulär schulpflichtig und voraussichtlich für das
            Schuljahr 2026/2027 vorgesehen.
          </p>

          <p>
            Die wichtigsten Termine zum allgemeinen Schulstart und zur Einschulung
            findest du im Terminblock oben. Der konkrete Einschulungstermin kann
            je nach Grundschule organisatorisch abweichen.
          </p>
        </section>

        <section>
          <h2>Wann ist die Einschulung in Nordrhein-Westfalen 2026?</h2>

          <p>
            In Nordrhein-Westfalen erfolgt die Einschulung in der Regel spätestens
            am zweiten Schultag nach den Sommerferien. Für 2026 ergibt sich daraus
            voraussichtlich Donnerstag, der 3. September 2026; organisatorische
            Abweichungen einzelner Grundschulen sind möglich.
          </p>
        </section>

        <section>
          <h2>Welcher Stichtag gilt für die Einschulung in Nordrhein-Westfalen?</h2>

          <p>
            In Nordrhein-Westfalen gilt der 30. September als Stichtag für die
            Einschulung. Kinder, die bis einschließlich 30. September sechs Jahre
            alt werden, sind in Nordrhein-Westfalen ab dem 1. August desselben
            Kalenderjahres regulär schulpflichtig.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind früher eingeschult werden?</h2>

          <p>
            Kinder, die erst nach dem Stichtag sechs Jahre alt werden, können auf
            Antrag der Eltern vorzeitig eingeschult werden. Die Schulleitung
            entscheidet nach Beratung mit den Eltern über die Aufnahme des Kindes.
          </p>
        </section>

        <section>
          <h2>Kann die Einschulung zurückgestellt werden?</h2>

          <p>
            Ob ein schulpflichtiges Kind tatsächlich eingeschult wird oder ob im
            Einzelfall eine andere Entscheidung getroffen wird, klärst du mit der
            zuständigen Grundschule oder Schulbehörde. Der Rechner dient nur der
            ersten Orientierung.
          </p>
        </section>

        <section class="example-box">
          <h2>Beispiel: Geburtsdatum im September</h2>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. September 2020
            geboren, wird es am 15. September 2026 sechs Jahre alt. Da dieses
            Datum vor dem Stichtag 30. September liegt, wird das Kind in
            Nordrhein-Westfalen voraussichtlich im Schuljahr 2026/2027 eingeschult.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Nordrhein-Westfalen</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Wann kommt mein Kind in Nordrhein-Westfalen in die Schule?</h3>
              <p>
                Das hängt vom Geburtsdatum deines Kindes ab. In Nordrhein-Westfalen
                gilt der 30. September als Stichtag. Kinder, die bis einschließlich
                30. September sechs Jahre alt werden, sind in Nordrhein-Westfalen ab
                dem 1. August desselben Kalenderjahres regulär schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist der erste Schultag in Nordrhein-Westfalen 2026?</h3>
              <p>
                Der letzte Ferientag in Nordrhein-Westfalen ist 2026 Dienstag, der
                1. September. Daraus ergibt sich voraussichtlich Mittwoch, der
                2. September 2026, als allgemeiner erster Schultag nach den
                Sommerferien.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Nordrhein-Westfalen 2026?</h3>
              <p>
                In Nordrhein-Westfalen erfolgt die Einschulung in der Regel
                spätestens am zweiten Schultag nach den Sommerferien. Für 2026
                ergibt sich daraus voraussichtlich Donnerstag, der 3. September
                2026; organisatorische Abweichungen einzelner Grundschulen sind
                möglich.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann mein Kind in Nordrhein-Westfalen früher eingeschult werden?</h3>
              <p>
                Kinder, die nach dem Stichtag sechs Jahre alt werden, können auf
                Antrag der Eltern vorzeitig eingeschult werden. Die Schulleitung
                entscheidet nach Beratung mit den Eltern über die Aufnahme.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann muss ich mein Kind in Nordrhein-Westfalen an der Grundschule anmelden?</h3>
              <p>
                Kinder, die im folgenden Jahr schulpflichtig werden, müssen in
                Nordrhein-Westfalen bis spätestens 15. November an einer
                Grundschule angemeldet werden. Die Anmeldung erfolgt an der
                zuständigen oder gewählten Grundschule zu den vom Schulträger
                festgelegten Terminen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Welche Quelle ist für die Einschulung in Nordrhein-Westfalen verbindlich?</h3>
              <p>
                Diese Seite dient der Orientierung. Verbindliche Informationen
                erhältst du bei der zuständigen Grundschule, der Schulbehörde oder
                beim Ministerium für Schule und Bildung des Landes Nordrhein-Westfalen.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quelle und Hinweis</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Nordrhein-Westfalen:
          </p>

          <ul class="source-list" aria-label="Offizielle Quellen zur Einschulung in Nordrhein-Westfalen">
            <li>
              <span>Offizielle Quelle 1</span>
              <a
                class="source-link"
                href="https://www.schulministerium.nrw/wann-wird-mein-kind-schulpflichtig"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Schule und Bildung NRW: Wann wird mein Kind schulpflichtig?
              </a>
            </li>

            <li>
              <span>Offizielle Quelle 2</span>
              <a
                class="source-link"
                href="https://www.schulministerium.nrw/themen/schulsystem/schulformen/grundschule/anmeldung-zur-grundschule"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Schule und Bildung NRW: Anmeldung zur Grundschule
              </a>
            </li>

            <li>
              <span>Offizielle Quelle 3</span>
              <a
                class="source-link"
                href="https://www.schulministerium.nrw/service/ferienordnung-fuer-nordrhein-westfalen-fuer-die-schuljahre-bis-202930"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Schule und Bildung NRW: Ferienordnung bis 2029/30
              </a>
            </li>
          </ul>

          <p class="source-hint">
            Hinweis: Die amtliche Stichtagslogik in Nordrhein-Westfalen knüpft daran
            an, ob ein Kind bis zum Beginn des 30. September sechs Jahre alt wird.
            Bitte prüfe verbindliche Details immer bei der zuständigen Grundschule
            oder Schulbehörde.
          </p>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.22rem, 1.55vw, 1.46rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .fact-card-date {
    border-color: rgba(129, 97, 38, 0.16);
    background: rgba(245, 210, 138, 0.12);
  }

  .fact-card-date strong {
    font-size: clamp(1.12rem, 1.36vw, 1.32rem);
    white-space: normal;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 14px;
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }

  .source-list li {
    display: grid;
    gap: 5px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.12);
  }

  .source-list li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-list li > span {
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .source-hint {
    margin-top: 18px;
    color: #465266;
    font-size: 0.96rem;
    font-weight: 500;
    line-height: 1.58;
  }

  .stand {
    display: inline-flex;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
      letter-spacing: -0.05em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .fact-card {
      min-height: 102px;
      padding: 18px 22px;
    }

    .fact-card span {
      font-size: clamp(0.82rem, 3.45vw, 0.96rem);
      letter-spacing: 0.095em;
    }

    .fact-card strong {
      font-size: clamp(1.12rem, 4.9vw, 1.36rem);
      line-height: 1.14;
    }

    section {
      margin-top: 30px;
      padding-top: 28px;
    }

    h2 {
      font-size: 1.62rem;
      line-height: 1.1;
    }

    p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .faq-item p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .example-box,
    .source-note,
    .seo-explanation-box {
      padding: 20px;
      border-radius: 20px;
    }
  }

  @media (max-width: 390px) {
    h1 {
      font-size: clamp(1.58rem, 7vw, 1.95rem);
      line-height: 1.07;
      letter-spacing: -0.046em;
    }
  }
</style>