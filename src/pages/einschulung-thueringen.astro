---
import BaseLayout from "../layouts/BaseLayout.astro";
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Schuleinführung Thüringen 2026: Termin, Stichtag & Rechner";

const pageDescription =
  "Wann ist die Schuleinführung in Thüringen 2026? Hier findest du Termin, Stichtag 1. August, Kann-Kind-Regelung und den kostenlosen Einschulungsrechner.";

const canonical = "https://www.einschulungsrechner.de/einschulung-thueringen/";
const dateModified = "2026-05-27";

const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || "";
const STATE_CONTENT_AD_SLOT = import.meta.env.PUBLIC_ADSENSE_STATE_CONTENT_SLOT || "";
const showContentAd = Boolean(ADSENSE_ID && STATE_CONTENT_AD_SLOT);

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  datePublished: "2025-10-01",
  dateModified,
  inLanguage: "de",
  publisher: {
    "@type": "Organization",
    name: "Einschulungsrechner",
    url: "https://www.einschulungsrechner.de/",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Thüringen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Thüringen gilt der 1. August als maßgeblicher Stichtag für die Schulpflicht. Kinder, die bis zu diesem Datum sechs Jahre alt sind, werden mit Beginn des Schuljahres schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Schuleinführung in Thüringen 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Für das Schuljahr 2026/2027 enden die Sommerferien in Thüringen am Freitag, 14. August 2026. Die Schuleinführung ist voraussichtlich für Montag, 17. August 2026 vorgesehen. Dieser Tag ist zugleich der erste Schultag. Den konkreten Ablauf legt die zuständige Grundschule fest.",
      },
    },
    {
      "@type": "Question",
      name: "Wann beginnt die Grundschule in Thüringen 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der erste Schultag im Schuljahr 2026/2027 ist in Thüringen Montag, 17. August 2026. Die Schuleinführung ist voraussichtlich ebenfalls für Montag, 17. August 2026 vorgesehen. Den konkreten Ablauf legt die zuständige Grundschule fest.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind in Thüringen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind gilt in Thüringen ein Kind, das noch nicht regulär schulpflichtig ist, aber am 30. Juni mindestens fünf Jahre alt ist. Auf Antrag der Eltern kann es am 1. August desselben Jahres vorzeitig in die Schule aufgenommen werden. Die Entscheidung trifft die Schulleitung im Benehmen mit dem Schularzt.",
      },
    },
    {
      "@type": "Question",
      name: "Wann findet die Schulanmeldung in Thüringen statt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Schulanmeldung findet in Thüringen in der Regel im Januar oder Februar statt. Die zuständige Grundschule informiert die Eltern über den konkreten Termin und die erforderlichen Unterlagen.",
      },
    },
    {
      "@type": "Question",
      name: "Kann die Einschulung in Thüringen zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eltern können in Thüringen einen Antrag auf Zurückstellung ihres schulpflichtigen Kindes für ein Schuljahr stellen. Voraussetzung sind die schulärztliche Untersuchung und eine Beratung durch die Schule. Die Entscheidung trifft die Schulleitung; eine Zurückstellung ist nur einmal möglich.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Thüringen verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde in Thüringen.",
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={[faqSchema, webPageSchema]}
>
  <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Thüringen</p>

        <h1>
          Schuleinführung Thüringen 2026:<br />
          Wann kommt mein Kind in die Schule?
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Thüringen in die Schule? Gib das Geburtsdatum ein
          und berechne das voraussichtliche Schuljahr. In Thüringen gilt der
          Stichtag 1. August. Für das Schuljahr 2026/2027 ist die Schuleinführung
          voraussichtlich für Montag, 17. August 2026 vorgesehen – dieser Tag ist
          zugleich der erste Schultag.
        </p>

        <p class="answer-box">
          Kurzantwort: Die Schuleinführung in Thüringen 2026 ist voraussichtlich
          für Montag, 17. August 2026 vorgesehen. Dieser Tag ist zugleich der erste
          Schultag. Schulpflichtig werden Kinder, die bis zum 1. August 2026 sechs
          Jahre alt sind.
        </p>

        <StateEnrollmentCalculator
          stateName="Thüringen"
          stateSlug="thueringen"
          calculatorKicker="Thüringen-Rechner"
          resultKicker="Thüringen-Ergebnis"
          headline="Einschulung in Thüringen berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Thüringen ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Thüringen">
          <div class="fact-card fact-card-highlight">
            <span>Schuleinführung 2026</span>
            <strong>Montag,<br />17. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag,<br />17. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>1. August</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>
        </div>

        {showContentAd ? (
          <aside class="ad-slot ad-slot-after-facts" aria-label="Anzeige">
            <p class="ad-label">Anzeige</p>
            <ins
              class="adsbygoogle"
              style="display:block"
              data-ad-client={ADSENSE_ID}
              data-ad-slot={STATE_CONTENT_AD_SLOT}
              data-ad-format="auto"
              data-full-width-responsive="true"
            ></ins>
          </aside>
        ) : null}

        <section>
          <h2>Wann ist die Schuleinführung in Thüringen 2026?</h2>

          <p>
            Die Sommerferien in Thüringen enden 2026 am Freitag, 14. August 2026.
            Die Schuleinführung ist voraussichtlich für Montag, 17. August 2026
            vorgesehen. Dieser Tag ist zugleich der erste Schultag. Den konkreten
            Ablauf legt die zuständige Grundschule fest.
          </p>
        </section>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Thüringen?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Thüringen. Entscheidend
            ist der Stichtag 1. August. Ist dein Kind am 1. August sechs Jahre
            alt, beginnt die Vollzeitschulpflicht am 1. August desselben Jahres.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind in Thüringen schulpflichtig?</h2>

          <p>
            In Thüringen gilt der 1. August als maßgeblicher Stichtag für die
            Schulpflicht. Kinder, die spätestens an diesem Tag sechs Jahre alt
            sind, werden mit Beginn des Schuljahres schulpflichtig.
          </p>

          <p>
            Entscheidend ist also nicht nur das Geburtsjahr, sondern ob der
            sechste Geburtstag bis einschließlich 1. August erreicht ist. Liegt
            der Geburtstag nach dem Stichtag, besteht keine automatische
            Schulpflicht für dieses Schuljahr; eine vorzeitige Einschulung kann
            aber als Kann-Kind auf Antrag geprüft werden.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Thüringen früher eingeschult werden?</h2>

          <p>
            Ein Kind, das noch nicht regulär schulpflichtig ist, kann auf Antrag
            der Eltern am 1. August desselben Jahres vorzeitig in die Schule
            aufgenommen werden, wenn es am 30. Juni mindestens fünf Jahre alt ist.
            Die Entscheidung trifft die Schulleitung im Benehmen mit dem Schularzt.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Thüringen ab?</h2>

          <p>
            Die Schulanmeldung erfolgt in Thüringen üblicherweise im Januar oder
            Februar des Jahres, in dem das Kind schulpflichtig wird. Die zuständige
            Grundschule oder der Schulträger informiert die Eltern rechtzeitig über
            den konkreten Termin und die benötigten Unterlagen. Zum Einschulungsverfahren
            gehört in der Regel auch die schulärztliche Untersuchung.
          </p>
        </section>

        <section>
          <h2>Mein Kind ist noch nicht schulreif – was muss ich in Thüringen tun?</h2>

          <p>
            In Thüringen können Eltern einen Antrag auf Zurückstellung ihres
            schulpflichtigen Kindes für ein Schuljahr stellen. Der Antrag setzt die
            schulärztliche Untersuchung und eine Beratung durch die Schule voraus.
            Die Entscheidung trifft die Schulleitung. Eine Zurückstellung ist nur
            einmal möglich. Verbindliche Auskunft erhältst du bei der zuständigen
            Grundschule oder Schulbehörde.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Thüringen</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Thüringen?</h3>
              <p>
                In Thüringen gilt der 1. August als maßgeblicher Stichtag für die
                Schulpflicht. Kinder, die bis zu diesem Datum sechs Jahre alt sind,
                werden mit Beginn des Schuljahres schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Schuleinführung in Thüringen 2026?</h3>
              <p>
                Für das Schuljahr 2026/2027 enden die Sommerferien in Thüringen
                am Freitag, 14. August 2026. Die Schuleinführung ist voraussichtlich
                für Montag, 17. August 2026 vorgesehen. Dieser Tag ist zugleich der
                erste Schultag. Den konkreten Ablauf legt die zuständige Grundschule fest.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann beginnt die Grundschule in Thüringen 2026?</h3>
              <p>
                Der erste Schultag im Schuljahr 2026/2027 ist in Thüringen Montag,
                17. August 2026. Die Schuleinführung ist voraussichtlich ebenfalls
                für Montag, 17. August 2026 vorgesehen. Den konkreten Ablauf legt
                die zuständige Grundschule fest.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind in Thüringen?</h3>
              <p>
                Als Kann-Kind gilt in Thüringen ein Kind, das noch nicht regulär
                schulpflichtig ist, aber am 30. Juni mindestens fünf Jahre alt ist.
                Auf Antrag der Eltern kann es am 1. August desselben Jahres
                vorzeitig in die Schule aufgenommen werden. Die Entscheidung trifft
                die Schulleitung im Benehmen mit dem Schularzt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung in Thüringen statt?</h3>
              <p>
                Die Schulanmeldung findet in Thüringen in der Regel im Januar oder
                Februar statt. Die zuständige Grundschule informiert die Eltern über
                den konkreten Termin und die erforderlichen Unterlagen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann die Einschulung in Thüringen zurückgestellt werden?</h3>
              <p>
                Eltern können in Thüringen einen Antrag auf Zurückstellung ihres
                schulpflichtigen Kindes für ein Schuljahr stellen. Voraussetzung
                sind die schulärztliche Untersuchung und eine Beratung durch die
                Schule. Die Entscheidung trifft die Schulleitung; eine Zurückstellung
                ist nur einmal möglich.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Thüringen verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen
                der Orientierung. Verbindliche Informationen erhältst du bei der
                zuständigen Grundschule oder Schulbehörde in Thüringen.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Thüringen:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Thüringen">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://bildung.thueringen.de/fileadmin/ministerium/publikationen/thueringer_schulgesetz.pdf"
                target="_blank"
                rel="noopener noreferrer"
              >
                Thüringer Ministerium für Bildung: Thüringer Schulgesetz
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://bildung.thueringen.de/schule/schulwesen/ferien"
                target="_blank"
                rel="noopener noreferrer"
              >
                Thüringer Ministerium für Bildung: Ferien in Thüringen
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://stadt.weimar.de/de/leistung/leistung/1336/einschulung.html"
                target="_blank"
                rel="noopener noreferrer"
              >
                Stadt Weimar: Einschulung nach Thüringer Schulgesetz
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Thüringer Ministerium für
            Bildung, Wissenschaft und Kultur.
          </p>

          <p class="stand">Stand der Informationen:<span class="stand-date">Mai 2026</span></p>
        </section>
      </article>
  </main>
</BaseLayout>

<style is:global>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .answer-box {
    max-width: 760px;
    margin: 20px 0 0;
    padding: 18px 20px;
    border: 1px solid rgba(129, 97, 38, 0.18);
    border-radius: 18px;
    background: rgba(245, 210, 138, 0.14);
    color: #172033;
    font-size: clamp(1.02rem, 1.35vw, 1.12rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  body.has-thueringen-calculator-result .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .ad-slot {
    margin: 30px 0 0;
    padding: 14px 0;
    border-top: 1px solid rgba(42, 35, 21, 0.08);
    border-bottom: 1px solid rgba(42, 35, 21, 0.08);
  }

  .ad-label {
    margin: 0 0 10px;
    color: #8a7960;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .stand {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  .stand-date {
    display: inline;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
      letter-spacing: -0.05em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .answer-box {
      padding: 16px 18px;
      font-size: 1rem;
      line-height: 1.5;
    }

    .fact-card {
      min-height: 102px;
      padding: 18px 22px;
