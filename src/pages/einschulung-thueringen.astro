---
import BaseLayout from "../layouts/BaseLayout.astro";
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Schuleinführung Thüringen 2026 & 2027: Termin, Stichtag & Rechner";

const pageDescription =
  "Schuleinführung Thüringen 2026: Termin 17. August, erster Schultag 17. August. Stichtag 1. August. Jetzt kostenlos berechnen.";

const canonical = "https://www.einschulungsrechner.de/einschulung-thueringen/";
const dateModified = "2026-06-16";

const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || "";
const STATE_CONTENT_AD_SLOT = import.meta.env.PUBLIC_ADSENSE_STATE_CONTENT_SLOT || "";
const showContentAd = Boolean(ADSENSE_ID && STATE_CONTENT_AD_SLOT);

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  datePublished: "2025-10-01",
  dateModified,
  inLanguage: "de",
  publisher: {
    "@type": "Organization",
    name: "Einschulungsrechner",
    url: "https://www.einschulungsrechner.de/",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Thüringen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Thüringen gilt der 1. August als maßgeblicher Stichtag für die Schulpflicht. Kinder, die am 1. August sechs Jahre alt sind, werden mit Beginn des Schuljahres schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Schuleinführung in Thüringen 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Für das Schuljahr 2026/2027 ist der erste Unterrichtstag in Thüringen Montag, 17. August 2026. Die Schuleinführungsfeiern finden nach offizieller Ferienübersicht ebenfalls an diesem Tag statt. Den konkreten Ablauf legt die zuständige Grundschule fest.",
      },
    },
    {
      "@type": "Question",
      name: "Wann beginnt die Grundschule in Thüringen 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der erste Unterrichtstag im Schuljahr 2026/2027 ist in Thüringen Montag, 17. August 2026. Die Schuleinführungsfeiern sind laut offizieller Ferienübersicht ebenfalls für Montag, 17. August 2026 vorgesehen.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind in Thüringen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind gilt in Thüringen ein Kind, das noch nicht regulär schulpflichtig ist, aber am 30. Juni mindestens fünf Jahre alt ist. Auf Antrag der Eltern kann es am 1. August desselben Jahres vorzeitig in die Schule aufgenommen werden. Die Entscheidung trifft die Schulleitung im Benehmen mit dem Schularzt.",
      },
    },
    {
      "@type": "Question",
      name: "Wann findet die Schulanmeldung in Thüringen statt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Anmeldung zur Einschulung erfolgt in Thüringen bereits im Kalenderjahr vor der Einschulung im Zeitraum vom 2. bis 10. Mai. Die zuständige Grundschule oder der Schulträger informiert über den konkreten Ablauf und die erforderlichen Unterlagen.",
      },
    },
    {
      "@type": "Question",
      name: "Kann die Einschulung in Thüringen zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eltern können in Thüringen einen Antrag auf Zurückstellung ihres schulpflichtigen Kindes für ein Schuljahr stellen. Voraussetzung sind die schulärztliche Untersuchung und eine Beratung durch die Schule. Die Entscheidung trifft die Schulleitung; eine Zurückstellung ist nur einmal möglich.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Thüringen verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde in Thüringen.",
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={[faqSchema, webPageSchema]}
>
  <main class="state-page">

      <article class="state-card">
        <p class="state-kicker">Thüringen</p>

        <h1>
          <span class="headline-line headline-line-year">Schuleinführung 2026/2027</span>
          <span class="headline-line headline-line-state">in Thüringen:</span>
          <span class="headline-line headline-line-question">Wann kommt mein Kind in die Schule?</span>
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Thüringen in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. In
          Thüringen gilt der Stichtag 1. August. Für das Schuljahr 2026/2027 ist der
          erste Unterrichtstag Montag, 17. August 2026 – die Schuleinführungsfeiern
          finden laut offizieller Ferienübersicht ebenfalls an diesem Tag statt.
        </p>

        <p class="answer-box">
          Kurzantwort: Die Schuleinführung in Thüringen 2026 ist für Montag,
          17. August 2026 vorgesehen. Dieser Tag ist auch der erste Unterrichtstag.
          Schulpflichtig werden Kinder, die am 1. August 2026 sechs Jahre alt sind.
        </p>

        <StateEnrollmentCalculator
          stateName="Thüringen"
          stateSlug="thueringen"
          calculatorKicker="Thüringen-Rechner"
          resultKicker="Thüringen-Ergebnis"
          headline="Einschulung in Thüringen berechnen"
          intro="Gib das Geburtsdatum ein und erfahre, für welches Schuljahr dein Kind in Thüringen voraussichtlich schulpflichtig wird."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Thüringen">
          <div class="fact-card fact-card-highlight">
            <span>Schuleinführung 2026</span>
            <strong>Montag,<br />17. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag,<br />17. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>1. August</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>

          <div class="fact-card">
            <span>Anmeldung</span>
            <strong>2.–10. Mai<br />des Vorjahres</strong>
          </div>
        </div>

        {showContentAd ? (
          <aside class="ad-slot ad-slot-after-facts" aria-label="Anzeige">
            <p class="ad-label">Anzeige</p>
            <ins
              class="adsbygoogle"
              style="display:block"
              data-ad-client={ADSENSE_ID}
              data-ad-slot={STATE_CONTENT_AD_SLOT}
              data-ad-format="auto"
              data-full-width-responsive="true"
            ></ins>
          </aside>
        ) : null}

        <section>
          <h2>Wann ist die Schuleinführung in Thüringen 2026?</h2>

          <p>
            Der erste Unterrichtstag im Schuljahr 2026/2027 ist in Thüringen Montag,
            17. August 2026. Die Schuleinführungsfeiern sind laut offizieller
            Ferienübersicht ebenfalls für Montag, 17. August 2026 vorgesehen.
          </p>

          <p>
            Den konkreten Ablauf, die Uhrzeit und organisatorische Hinweise legt die
            zuständige Grundschule fest. Für die persönliche Planung solltest du
            deshalb immer auch die Mitteilung deiner Schule oder Kommune beachten.
          </p>
        </section>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Thüringen?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Thüringen. Entscheidend ist
            der Stichtag 1. August. Ist dein Kind an diesem Tag sechs Jahre alt,
            beginnt die Vollzeitschulpflicht mit Beginn des Schuljahres.
          </p>

          <p>
            Beispiel: Wird ein Kind am 20. Juli 2020 geboren, ist es am 1. August
            2026 bereits sechs Jahre alt. Damit ist es in Thüringen regulär
            schulpflichtig und voraussichtlich für das Schuljahr 2026/2027 vorgesehen.
          </p>

          <p>
            Wird ein Kind dagegen nach dem 1. August 2020 geboren, fällt es nicht
            mehr unter die reguläre Schulpflicht für das Schuljahr 2026/2027. Eine
            vorzeitige Einschulung kann als Kann-Kind auf Antrag geprüft werden,
            wenn das Kind am 30. Juni mindestens fünf Jahre alt ist.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind in Thüringen schulpflichtig?</h2>

          <p>
            In Thüringen gilt der 1. August als maßgeblicher Stichtag für die
            Schulpflicht. Kinder, die am 1. August sechs Jahre alt sind, werden mit
            Beginn des Schuljahres schulpflichtig.
          </p>

          <p>
            Entscheidend ist also nicht nur das Geburtsjahr, sondern ob der sechste
            Geburtstag bis zum Stichtag erreicht ist. Liegt der Geburtstag nach dem
            1. August, besteht keine automatische Schulpflicht für dieses Schuljahr;
            eine vorzeitige Einschulung kann aber als Kann-Kind auf Antrag geprüft
            werden.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Thüringen früher eingeschult werden?</h2>

          <p>
            Ein Kind, das noch nicht regulär schulpflichtig ist, kann in Thüringen
            auf Antrag der Eltern am 1. August desselben Jahres vorzeitig in die
            Schule aufgenommen werden, wenn es am 30. Juni mindestens fünf Jahre alt
            ist. Die Entscheidung trifft die Schulleitung im Benehmen mit dem
            Schularzt.
          </p>

          <p>
            Wenn du eine frühere Einschulung prüfen lassen möchtest, solltest du
            frühzeitig Kontakt mit der zuständigen Grundschule aufnehmen. Dort erfährst
            du, welche Unterlagen benötigt werden und wie der Antrag im konkreten
            Einzelfall abläuft.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Thüringen ab?</h2>

          <p>
            Die Anmeldung zur Einschulung erfolgt in Thüringen bereits im Kalenderjahr
            vor der Einschulung im Zeitraum vom 2. bis 10. Mai. Die zuständige
            Grundschule oder der Schulträger informiert über den konkreten Ablauf und
            die erforderlichen Unterlagen.
          </p>

          <ol class="process-list">
            <li>Hinweise von Grundschule oder Schulträger beachten</li>
            <li>Kind im Zeitraum vom 2. bis 10. Mai des Vorjahres anmelden</li>
            <li>Erforderliche Unterlagen bereithalten</li>
            <li>Schulärztliche Untersuchung im weiteren Verfahren einplanen</li>
          </ol>
        </section>

        <section>
          <h2>Mein Kind ist noch nicht schulreif – was muss ich in Thüringen tun?</h2>

          <p>
            In Thüringen können Eltern einen Antrag auf Zurückstellung ihres
            schulpflichtigen Kindes für ein Schuljahr stellen. Voraussetzung sind die
            schulärztliche Untersuchung und eine Beratung durch die Schule.
          </p>

          <p>
            Die Entscheidung trifft die Schulleitung. Eine Zurückstellung ist nur
            einmal möglich. Verbindliche Auskunft erhältst du bei der zuständigen
            Grundschule oder Schulbehörde.
          </p>
        </section>

        <section>
          <h2>Schuleinführung Thüringen 2027: Kann ich das schon berechnen?</h2>

          <p>
            Ja. Du kannst den Einschulungsrechner auch für die Schuleinführung in
            Thüringen 2027 nutzen. Gib einfach das Geburtsdatum deines Kindes ein
            und wähle Thüringen aus. Der Rechner zeigt dir, welches Schuljahr
            voraussichtlich relevant ist.
          </p>
        </section>

        <section class="next-steps-box">
          <h2>Nächste Schritte für Eltern</h2>

          <p>
            Wenn du jetzt weißt, welches Schuljahr für dein Kind voraussichtlich
            relevant ist, lohnt sich als Nächstes der Blick auf die praktische
            Vorbereitung. In unserer Checkliste findest du eine Schritt-für-Schritt-
            Übersicht zu Unterlagen, Material, Schulweg und Organisation rund um den
            Schulstart.
          </p>

          <div class="next-steps-actions">
            <a class="next-step-button next-step-button-primary" href="/einschulung-checkliste/">
              Zur Einschulungs-Checkliste
            </a>
            <a class="next-step-button next-step-button-secondary" href="/einschulung/">
              Ratgeber zur Einschulung lesen
            </a>
          </div>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Thüringen</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Thüringen?</h3>
              <p>
                In Thüringen gilt der 1. August als maßgeblicher Stichtag für die
                Schulpflicht. Kinder, die am 1. August sechs Jahre alt sind, werden
                mit Beginn des Schuljahres schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Schuleinführung in Thüringen 2026?</h3>
              <p>
                Für das Schuljahr 2026/2027 ist der erste Unterrichtstag in Thüringen
                Montag, 17. August 2026. Die Schuleinführungsfeiern finden nach
                offizieller Ferienübersicht ebenfalls an diesem Tag statt. Den
                konkreten Ablauf legt die zuständige Grundschule fest.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann beginnt die Grundschule in Thüringen 2026?</h3>
              <p>
                Der erste Unterrichtstag im Schuljahr 2026/2027 ist in Thüringen
                Montag, 17. August 2026. Die Schuleinführungsfeiern sind laut
                offizieller Ferienübersicht ebenfalls für Montag, 17. August 2026
                vorgesehen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind in Thüringen?</h3>
              <p>
                Als Kann-Kind gilt in Thüringen ein Kind, das noch nicht regulär
                schulpflichtig ist, aber am 30. Juni mindestens fünf Jahre alt ist.
                Auf Antrag der Eltern kann es am 1. August desselben Jahres
                vorzeitig in die Schule aufgenommen werden. Die Entscheidung trifft
                die Schulleitung im Benehmen mit dem Schularzt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung in Thüringen statt?</h3>
              <p>
                Die Anmeldung zur Einschulung erfolgt in Thüringen bereits im
                Kalenderjahr vor der Einschulung im Zeitraum vom 2. bis 10. Mai.
                Die zuständige Grundschule oder der Schulträger informiert über den
                konkreten Ablauf und die erforderlichen Unterlagen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann die Einschulung in Thüringen zurückgestellt werden?</h3>
              <p>
                Eltern können in Thüringen einen Antrag auf Zurückstellung ihres
                schulpflichtigen Kindes für ein Schuljahr stellen. Voraussetzung
                sind die schulärztliche Untersuchung und eine Beratung durch die
                Schule. Die Entscheidung trifft die Schulleitung; eine Zurückstellung
                ist nur einmal möglich.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Thüringen verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen
                der Orientierung. Verbindliche Informationen erhältst du bei der
                zuständigen Grundschule oder Schulbehörde in Thüringen.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Thüringen:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Thüringen">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://bildung.thueringen.de/fileadmin/ministerium/publikationen/thueringer_schulgesetz.pdf"
                target="_blank"
                rel="noopener noreferrer"
              >
                Thüringer Ministerium für Bildung: Thüringer Schulgesetz
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://bildung.thueringen.de/schule/schulwesen/ferien"
                target="_blank"
                rel="noopener noreferrer"
              >
                Thüringer Ministerium für Bildung: Ferien in Thüringen
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://stadt.weimar.de/de/leistung/leistung/1336/einschulung.html"
                target="_blank"
                rel="noopener noreferrer"
              >
                Stadt Weimar: Einschulung nach Thüringer Schulgesetz
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Thüringer Ministerium für
            Bildung, Wissenschaft und Kultur.
          </p>

          <p class="stand">Stand der Informationen:<span class="stand-date">Juni 2026</span></p>
        </section>
      </article>
  </main>
</BaseLayout>

<style is:global>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }


  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .headline-line {
    display: block;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .answer-box {
    max-width: 760px;
    margin: 20px 0 0;
    padding: 18px 20px;
    border: 1px solid rgba(129, 97, 38, 0.18);
    border-radius: 18px;
    background: rgba(245, 210, 138, 0.14);
    color: #172033;
    font-size: clamp(1.02rem, 1.35vw, 1.12rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  body.has-thueringen-calculator-result .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .ad-slot {
    margin: 30px 0 0;
    padding: 14px 0;
    border-top: 1px solid rgba(42, 35, 21, 0.08);
    border-bottom: 1px solid rgba(42, 35, 21, 0.08);
  }

  .ad-label {
    margin: 0 0 10px;
    color: #8a7960;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box,
  .next-steps-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }
  .process-list {
    display: grid;
    gap: 10px;
    margin: 18px 0 0;
    padding-left: 1.25rem;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 600;
    line-height: 1.62;
