

---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle =
  "Einschulung in Deutschland: Schulpflicht, Stichtag und Anmeldung einfach erklärt";

const pageDescription =
  "Ratgeber zur Einschulung in Deutschland: Schulpflicht, Stichtag, Kann-Kind, Zurückstellung, Schulanmeldung und nächste Schritte verständlich erklärt.";

const canonical = "https://www.einschulungsrechner.de/einschulung/";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wann ist mein Kind schulpflichtig?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dein Kind wird schulpflichtig, wenn es bis zum Einschulungsstichtag seines Bundeslands sechs Jahre alt wird. Der genaue Stichtag hängt vom Bundesland ab."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist der Einschulungsstichtag?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Der Einschulungsstichtag entscheidet, ob ein Kind in diesem oder erst im nächsten Schuljahr eingeschult wird. Die Stichtage unterscheiden sich je nach Bundesland."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist ein Kann-Kind?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ein Kann-Kind hat den regulären Stichtag noch nicht erreicht, kann aber auf Antrag der Eltern früher eingeschult werden. Die Schule prüft die Schulreife und entscheidet."
      }
    },
    {
      "@type": "Question",
      "name": "Was bedeutet Zurückstellung?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Zurückstellung bedeutet, dass ein eigentlich schulpflichtiges Kind auf Antrag ein Jahr später eingeschult wird. Die Entscheidung trifft die zuständige Schule oder Schulbehörde."
      }
    },
    {
      "@type": "Question",
      "name": "Wann findet die Schulanmeldung statt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Schulanmeldung findet je nach Bundesland und Schule meist zwischen Oktober und Februar vor dem geplanten Schuljahr statt. Verbindliche Fristen nennt die zuständige Grundschule."
      }
    },
    {
      "@type": "Question",
      "name": "Ist der Einschulungsrechner verbindlich?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. Der Einschulungsrechner dient der Orientierung. Verbindliche Auskünfte geben die zuständige Grundschule, das Schulamt oder die Bildungsbehörde."
      }
    }
  ]
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  <main class="guide-page">

      <article class="guide-card">
        <p class="guide-kicker">Ratgeber</p>

        <h1>Einschulung in Deutschland – einfach erklärt für Eltern</h1>

        <p class="lead">
          Wann ist mein Kind schulpflichtig? Was passiert,
          wenn der Geburtstag knapp am Stichtag liegt?
        </p>

        <p class="lead">
          Hier findest du klare Antworten zur Einschulung in Deutschland –
          ohne Behördensprache und mit den wichtigsten nächsten Schritten.
        </p>

        <div class="journey-box" aria-label="Schulstart-Journey">
          <div class="journey-step">
            <span>1</span>
            <strong>Stichtag prüfen</strong>
            <p>Geburtsdatum und Bundesland einordnen.</p>
          </div>

          <div class="journey-step">
            <span>2</span>
            <strong>Regel verstehen</strong>
            <p>Schulpflicht, Kann-Kind oder Zurückstellung klären.</p>
          </div>

          <div class="journey-step">
            <span>3</span>
            <strong>Nächsten Schritt planen</strong>
            <p>Schulanmeldung, Untersuchung und Vorbereitung angehen.</p>
          </div>
        </div>

        <section class="highlight-section">
          <h2>Der schnellste Einstieg: Einschulung berechnen</h2>

          <p>
            Gib Geburtsdatum und Bundesland ein. Der Rechner zeigt dir sofort,
            wann dein Kind voraussichtlich in die Schule kommt.
          </p>

          <a class="cta-link" href="/">Jetzt Einschulung berechnen</a>
        </section>

        <section>
          <h2>Was bedeutet Schulpflicht?</h2>

          <p>
            Dein Kind muss in die Schule, sobald es das gesetzlich festgelegte
            Einschulungsalter erreicht.
          </p>

          <p>
            In Deutschland beginnt die Schulpflicht mit der Grundschule.
            Der genaue Zeitpunkt hängt aber vom Bundesland ab.
          </p>

          <p>
            Entscheidend ist fast immer der Einschulungsstichtag:
            Wird dein Kind bis zu diesem Datum sechs Jahre alt,
            gilt es regulär als schulpflichtig.
          </p>
        </section>

        <section>
          <h2>Was ist der Einschulungsstichtag?</h2>

          <p>
            Der Einschulungsstichtag entscheidet, ob dein Kind in diesem
            oder erst im nächsten Schuljahr eingeschult wird.
          </p>

          <p>
            Die Stichtage sind nicht überall gleich. Je nach Bundesland
            liegen sie zwischen Ende Juni und Ende September.
          </p>

          <p>
            Das bedeutet: Dasselbe Geburtsdatum kann in einem Bundesland
            zur Einschulung führen – in einem anderen aber erst ein Jahr später.
          </p>

          <p>Typische Beispiele:</p>

          <ul>
            <li><strong>30. Juni:</strong> zum Beispiel Sachsen oder Hamburg</li>
            <li><strong>30. September:</strong> zum Beispiel Niedersachsen, Hessen oder Nordrhein-Westfalen</li>
            <li><strong>Sonderfall Bayern:</strong> Einschulungskorridor für Kinder vom 1. Juli bis 30. September</li>
          </ul>
        </section>

        <section id="bundeslaender">
          <h2>Einschulung nach Bundesland</h2>

          <p>
            Jedes Bundesland hat eigene Regeln zur Einschulung.
            Wähle dein Bundesland aus und lies die wichtigsten Informationen direkt nach.
          </p>

          <div class="state-grid" aria-label="Bundeslandseiten zur Einschulung">
            <a href="/einschulung-baden-wuerttemberg/">Baden-Württemberg</a>
            <a href="/einschulung-bayern/">Bayern</a>
            <a href="/einschulung-berlin/">Berlin</a>
            <a href="/einschulung-brandenburg/">Brandenburg</a>
            <a href="/einschulung-bremen/">Bremen</a>
            <a href="/einschulung-hamburg/">Hamburg</a>
            <a href="/einschulung-hessen/">Hessen</a>
            <a href="/einschulung-mecklenburg-vorpommern/">Mecklenburg-Vorpommern</a>
            <a href="/einschulung-niedersachsen/">Niedersachsen</a>
            <a href="/einschulung-nordrhein-westfalen/">Nordrhein-Westfalen</a>
            <a href="/einschulung-rheinland-pfalz/">Rheinland-Pfalz</a>
            <a href="/einschulung-saarland/">Saarland</a>
            <a href="/einschulung-sachsen/">Sachsen</a>
            <a href="/einschulung-sachsen-anhalt/">Sachsen-Anhalt</a>
            <a href="/einschulung-schleswig-holstein/">Schleswig-Holstein</a>
            <a href="/einschulung-thueringen/">Thüringen</a>
          </div>

          <p class="state-rule-hint">
            Hinweis: In Brandenburg ist politisch eine Verlegung des Stichtags auf
            den 30. Juni geplant. Solange diese Änderung nicht gesetzlich umgesetzt
            ist, bleibt für die Orientierung der aktuell geltende Stichtag relevant.
          </p>
        </section>

        <section>
          <h2>Was ist ein Kann-Kind?</h2>

          <p>
            Ein Kann-Kind hat den regulären Stichtag noch nicht erreicht,
            kann aber auf Antrag der Eltern früher eingeschult werden.
          </p>

          <p>
            Die Schule prüft dann, ob dein Kind bereit für den Schulalltag ist –
            zum Beispiel sprachlich, körperlich und sozial.
          </p>

          <p>
            Wichtig: Der Antrag allein reicht nicht aus.
            Die Entscheidung trifft die zuständige Schule oder Schulbehörde.
          </p>
        </section>

        <section>
          <h2>Was bedeutet Zurückstellung?</h2>

          <p>
            Zurückstellung bedeutet: Dein Kind ist eigentlich schulpflichtig,
            startet aber auf Antrag ein Jahr später in die Schule.
          </p>

          <p>
            Das kann sinnvoll sein, wenn dein Kind noch nicht schulreif wirkt
            oder die Schule eine spätere Einschulung empfiehlt.
          </p>

          <p>
            Sprich das Thema frühzeitig mit Kindergarten und Grundschule an.
            In vielen Bundesländern gelten feste Fristen.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung ab?</h2>

          <p>
            Die Schulanmeldung ist der formelle Schritt vor der Einschulung.
            Sie findet je nach Bundesland und Schule meist zwischen Oktober und Februar statt.
          </p>

          <p>Diese Unterlagen brauchst du häufig:</p>

          <ul>
            <li>Geburtsurkunde des Kindes</li>
            <li>Personalausweis eines Elternteils</li>
            <li>Nachweis über die Masernimpfung</li>
            <li>ggf. Einladung oder Nachweis zur Schuleingangsuntersuchung</li>
          </ul>

          <p>
            Die zuständige Grundschule sagt dir verbindlich,
            welche Unterlagen und Fristen bei euch gelten.
          </p>
        </section>

        <section>
          <h2>Was müssen Eltern nach dem Ergebnis tun?</h2>

          <p>
            Wenn du das voraussichtliche Schuljahr kennst,
            kannst du die nächsten Schritte gezielt planen.
          </p>

          <a class="guide-inline-link" href="/einschulung-checkliste/">Zur Einschulungs-Checkliste</a>

          <div class="next-steps">
            <article>
              <h3>1. Ergebnis einordnen</h3>
              <p>
                Prüfe, ob dein Kind regulär schulpflichtig wird oder ob eine
                Sonderregelung relevant sein könnte.
              </p>
            </article>

            <article>
              <h3>2. Bundeslandseite lesen</h3>
              <p>
                Lies die Informationen für dein Bundesland und prüfe die dort
                verlinkten offiziellen Quellen.
              </p>
            </article>

            <article>
              <h3>3. Schule kontaktieren</h3>
              <p>
                Bei Unsicherheit ist die zuständige Grundschule der wichtigste
                nächste Ansprechpartner.
              </p>
            </article>
          </div>
        </section>

        <section class="project-note">
          <h2>Ein ehrenamtliches Orientierungsprojekt</h2>

          <p>
            Einschulungsrechner.de ist ein ehrenamtliches Informationsangebot
            des <strong>DigiTech4U Institute</strong>.
          </p>

          <p>
            Ziel ist es, Eltern eine kostenlose, verständliche und datensparsame
            Orientierung rund um Einschulung und Schulstart zu bieten.
          </p>

          <p>
            Das Angebot ersetzt keine verbindliche Auskunft der zuständigen Schule
            oder Behörde. Es hilft dir, schneller die richtigen Fragen zu stellen.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Wann ist mein Kind schulpflichtig?</h3>
              <p>
                Dein Kind wird schulpflichtig, wenn es bis zum Einschulungsstichtag
                seines Bundeslands sechs Jahre alt wird.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was ist der Einschulungsstichtag?</h3>
              <p>
                Der Stichtag entscheidet, ob dein Kind in diesem oder erst im
                nächsten Schuljahr eingeschult wird.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was ist ein Kann-Kind?</h3>
              <p>
                Ein Kann-Kind hat den regulären Stichtag noch nicht erreicht,
                kann aber auf Antrag der Eltern früher eingeschult werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Zurückstellung?</h3>
              <p>
                Zurückstellung bedeutet, dass ein eigentlich schulpflichtiges Kind
                auf Antrag ein Jahr später eingeschult wird.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung statt?</h3>
              <p>
                Die Schulanmeldung findet je nach Bundesland und Schule meist
                zwischen Oktober und Februar vor dem geplanten Schuljahr statt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist der Einschulungsrechner verbindlich?</h3>
              <p>
                Nein. Der Rechner dient der Orientierung. Verbindliche Informationen
                bekommst du bei der zuständigen Grundschule oder Schulbehörde.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweis</h2>

          <p>
            Diese Ratgeberseite wird redaktionell gepflegt und basiert auf
            offiziellen Informationen der Bundesländer, Schulbehörden,
            Kultusministerien und der Kultusministerkonferenz.
          </p>

          <p>
            Stand der Informationen: Mai 2026. Verbindliche Auskünfte erteilt
            immer die zuständige Grundschule oder Schulbehörde.
          </p>
        </section>

        <div class="content-note">
          <h2>Wichtig: Orientierung statt verbindliche Auskunft</h2>
      
          <p>
            Dieser Ratgeber dient als verständliche Orientierung für Eltern.
            Verbindliche Informationen erhältst du bei der zuständigen Schule,
            beim Schulamt oder bei der Bildungsbehörde deines Bundeslands.
          </p>
        </div>
      </article>

  </main>
</BaseLayout>

<style>

  * {
    box-sizing: border-box;
  }


  :global(body) {
    margin: 0;
    color: #172033;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .guide-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
    color: #172033;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
  }

  .guide-page :where(h1, h2, h3, p, a, li, strong, span) {
    font-family: inherit;
  }


  .guide-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .guide-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  h1 {
    max-width: 840px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.35rem, 5vw, 4.25rem);
    font-weight: 950;
    line-height: 1.01;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  .headline-question {
    display: inline-block;
    max-width: 780px;
    text-wrap: balance;
  }


  .lead {
    max-width: 780px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.7vw, 1.24rem);
    line-height: 1.65;
  }

  .journey-box {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .journey-step {
    padding: 22px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .journey-step span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    margin-bottom: 16px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.12);
    color: #816126;
    font-weight: 950;
  }

  .journey-step strong {
    display: block;
    color: #172033;
    font-size: 1.2rem;
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .journey-step p {
    margin-top: 10px;
    font-size: 0.96rem;
    line-height: 1.55;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  .highlight-section,
  .project-note {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.65rem, 2.6vw, 2.25rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.05em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: 1.08rem;
    font-weight: 900;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: 1.03rem;
    line-height: 1.7;
  }

  .lead + .lead {
    margin-top: 12px;
  }

  .guide-card ul {
    margin: 14px 0 0;
    padding-left: 1.25rem;
    color: #465266;
  }

  .guide-card li {
    font-size: 1rem;
    line-height: 1.62;
  }

  .guide-card li + li {
    margin-top: 8px;
  }

  .source-note {
    padding: 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.68);
  }

  .source-note p {
    font-size: 0.94rem;
    line-height: 1.58;
  }

  .content-note {
    max-width: none;
    margin-top: 38px;
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .content-note h2 {
    font-size: clamp(1.45rem, 2.2vw, 1.9rem) !important;
    line-height: 1.14 !important;
    letter-spacing: -0.04em !important;
  }

  .content-note p {
    max-width: 64rem;
    font-size: 0.94rem !important;
    line-height: 1.58 !important;
  }



  .cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 20px;
    min-height: 54px;
    padding: 0 22px;
    border-radius: 16px;
    background: #172033;
    color: #fff;
    font-weight: 850;
    text-decoration: none;
  }

  .cta-link:hover {
    background: #2a3550;
  }

  .guide-inline-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 20px;
    min-height: 52px;
    padding: 0 20px;
    border-radius: 16px;
    background: #172033;
    color: #fff;
    font-weight: 850;
    line-height: 1.2;
    text-decoration: none;
  }

  .guide-inline-link:hover {
    background: #2a3550;
  }

  .state-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 22px;
  }

  .state-grid a {
    display: flex;
    align-items: center;
    min-height: 52px;
    padding: 12px 14px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.72);
    color: #172033;
    font-weight: 850;
    line-height: 1.25;
    text-decoration: none;
  }

  .state-grid a:hover {
    border-color: rgba(129, 97, 38, 0.25);
    background: rgba(255, 255, 255, 0.9);
    text-decoration: underline;
  }

  .state-rule-notes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 22px;
  }

  .state-rule-notes article {
    padding: 18px;
    border: 1px solid rgba(129, 97, 38, 0.14);
    border-radius: 18px;
    background: rgba(245, 210, 138, 0.12);
  }

  .state-rule-notes span {
    display: block;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .state-rule-notes strong {
    display: block;
    margin-top: 8px;
    color: #172033;
    font-size: 1.08rem;
    font-weight: 950;
    line-height: 1.16;
    letter-spacing: -0.025em;
  }

  .state-rule-notes p {
    margin-top: 10px;
    color: #465266;
    font-size: 0.96rem;
    line-height: 1.58;
  }

  .state-rule-hint {
    margin-top: 16px;
    padding: 14px 16px;
    border-radius: 16px;
    background: rgba(70, 82, 102, 0.06);
    color: #5b6576;
    font-size: 0.94rem;
    line-height: 1.56;
  }

  .next-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 22px;
  }

  .next-steps article,
  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .next-steps p,
  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1.02rem, 1.5vw, 1.12rem);
    line-height: 1.62;
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }


  @media (max-width: 760px) {
    h1 {
      max-width: 100%;
      font-size: clamp(2.2rem, 7.8vw, 2.85rem);
      line-height: 1.045;
      letter-spacing: -0.06em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
