---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Hessen 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Hessen in die Schule? Erfahre alles zu Schulstart, Einschulung, Stichtag 30. Juni, Schulpflicht ab 1. August und Schuljahr.";
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-hessen/" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Wann kommt mein Kind in Hessen in die Schule?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Das hängt vom Geburtsdatum deines Kindes ab. In Hessen gilt der 30. Juni als Stichtag. Kinder, die bis zu diesem Datum das sechste Lebensjahr vollenden, werden zum 1. August desselben Kalenderjahres schulpflichtig. Nach offizieller Formulierung betrifft das Kinder, die bis einschließlich 1. Juli geboren sind."
            }
          },
          {
            "@type": "Question",
            "name": "Wann ist der erste Schultag in Hessen 2026?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Die Sommerferien in Hessen enden 2026 am 7. August. Daraus ergibt sich voraussichtlich Montag, der 10. August 2026, als allgemeiner erster Schultag nach den Sommerferien."
            }
          },
          {
            "@type": "Question",
            "name": "Wann ist die Einschulung in Hessen 2026?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Der konkrete Einschulungstermin in Hessen wird von der zuständigen Grundschule bekanntgegeben. Als Orientierung gilt für 2026 Montag, der 10. August 2026, weil an diesem Tag voraussichtlich der allgemeine erste Schultag nach den Sommerferien ist."
            }
          },
          {
            "@type": "Question",
            "name": "Kann mein Kind in Hessen früher eingeschult werden?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Kinder, die nach dem 30. Juni das sechste Lebensjahr vollenden, können auf Antrag der Eltern vorzeitig eingeschult werden. Der schriftliche Antrag wird bei der zuständigen Grundschule gestellt; die Entscheidung trifft die Schulleitung. Bei Kindern, die erst nach dem 31. Dezember das sechste Lebensjahr vollenden, kann zusätzlich eine schulpsychologische Überprüfung angeordnet werden."
            }
          },
          {
            "@type": "Question",
            "name": "Wann muss ich mein Kind in Hessen an der Grundschule anmelden?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Die Anmeldung erfolgt in Hessen in der Regel im März oder April des Jahres, das dem Beginn der Schulpflicht vorausgeht. Die zuständige Grundschule lädt die Eltern schriftlich ein und informiert über Termin, Unterlagen und Ablauf. Eltern sollten daher die Post der Schule im Herbst oder Winter des Vorjahres beachten."
            }
          },
          {
            "@type": "Question",
            "name": "Welche Quelle ist für die Einschulung in Hessen verbindlich?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Diese Seite dient der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule, dem Staatlichen Schulamt oder beim Hessischen Ministerium für Kultus, Bildung und Chancen."
            }
          }
        ]
      }
    </script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Hessen</p>

        <h1>
          Einschulung in Hessen:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Hessen in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. In
          Hessen gilt der Stichtag 30. Juni. Die Sommerferien enden 2026 am
          7. August; daraus ergibt sich voraussichtlich Montag, der 10. August
          2026, als allgemeiner erster Schultag.
        </p>

        <StateEnrollmentCalculator
          stateName="Hessen"
          stateSlug="hessen"
          calculatorKicker="Hessen-Rechner"
          resultKicker="Hessen-Ergebnis"
          headline="Einschulung in Hessen berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Hessen ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts" aria-label="Kurzüberblick Einschulung Hessen">
          <div class="fact-card fact-card-date">
            <span>Erster Schultag</span>
            <strong>Montag, 10.08.2026</strong>
          </div>

          <div class="fact-card fact-card-date">
            <span>Einschulung</span>
            <strong>Montag, 10.08.2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. Juni</strong>
          </div>

          <div class="fact-card">
            <span>Schulpflicht</span>
            <strong>ab 1. August</strong>
          </div>
        </div>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Hessen?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Hessen. Entscheidend sind
            vor allem der Stichtag 30. Juni und der Beginn der Schulpflicht am
            1. August desselben Kalenderjahres.
          </p>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. Juni 2020
            geboren, vollendet es im Juni 2026 das sechste Lebensjahr. Damit ist
            es in Hessen regulär schulpflichtig und voraussichtlich für das
            Schuljahr 2026/2027 vorgesehen.
          </p>

          <p>
            Die wichtigsten Termine zum allgemeinen Schulstart und zur Einschulung
            findest du im Terminblock oben. Der konkrete Einschulungstermin wird
            von der zuständigen Grundschule festgelegt und kann organisatorisch
            abweichen.
          </p>
        </section>

        <section>
          <h2>Wann ist die Einschulung in Hessen 2026?</h2>

          <p>
            Der konkrete Einschulungstermin in Hessen wird von der zuständigen
            Grundschule bekanntgegeben. Als Orientierung gilt für 2026 Montag,
            der 10. August 2026, weil an diesem Tag voraussichtlich der allgemeine
            erste Schultag nach den Sommerferien ist.
          </p>
        </section>

        <section>
          <h2>Welcher Stichtag gilt für die Einschulung in Hessen?</h2>

          <p>
            In Hessen gilt der 30. Juni als Stichtag für die Einschulung. Kinder,
            die bis zu diesem Datum das sechste Lebensjahr vollenden, werden zum
            1. August desselben Kalenderjahres regulär schulpflichtig. Nach
            offizieller Formulierung betrifft das Kinder, die bis einschließlich
            1. Juli geboren sind.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind früher eingeschult werden?</h2>

          <p>
            Kinder, die nach dem 30. Juni das sechste Lebensjahr vollenden, können
            auf Antrag der Eltern vorzeitig eingeschult werden. Der schriftliche
            Antrag wird bei der zuständigen Grundschule gestellt. Die Entscheidung
            trifft die Schulleitung mit Hilfe eines schulärztlichen Gutachtens und
            nach Absprache mit dem pädagogischen Fachpersonal der Kindertagesstätte.
            Bei Kindern, die erst nach dem 31. Dezember das sechste Lebensjahr
            vollenden, kann zusätzlich eine schulpsychologische Überprüfung
            angeordnet werden.
          </p>
        </section>

        <section>
          <h2>Wann muss ich mein Kind in Hessen anmelden?</h2>

          <p>
            Die Anmeldung erfolgt in Hessen in der Regel im März oder April des
            Jahres, das dem Beginn der Schulpflicht vorausgeht. Die zuständige
            Grundschule lädt die Eltern schriftlich ein und informiert über Termin,
            Unterlagen und Ablauf. Eltern sollten daher die Post der Schule im
            Herbst oder Winter des Vorjahres beachten. Bei der Anmeldung können
            auch die deutschen Sprachkenntnisse des Kindes festgestellt werden.
          </p>
        </section>

        <section class="example-box">
          <h2>Beispiel: Geburtsdatum im Juni</h2>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. Juni 2020
            geboren, vollendet es im Juni 2026 das sechste Lebensjahr. Da dieses
            Datum vor dem Stichtag 30. Juni liegt, wird das Kind in Hessen
            voraussichtlich im Schuljahr 2026/2027 eingeschult.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Hessen</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Wann kommt mein Kind in Hessen in die Schule?</h3>
              <p>
                Das hängt vom Geburtsdatum deines Kindes ab. In Hessen gilt der
                30. Juni als Stichtag. Kinder, die bis zu diesem Datum das sechste
                Lebensjahr vollenden, werden zum 1. August desselben Kalenderjahres
                schulpflichtig. Nach offizieller Formulierung betrifft das Kinder,
                die bis einschließlich 1. Juli geboren sind.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist der erste Schultag in Hessen 2026?</h3>
              <p>
                Die Sommerferien in Hessen enden 2026 am 7. August. Daraus ergibt
                sich voraussichtlich Montag, der 10. August 2026, als allgemeiner
                erster Schultag nach den Sommerferien.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Hessen 2026?</h3>
              <p>
                Der konkrete Einschulungstermin in Hessen wird von der zuständigen
                Grundschule bekanntgegeben. Als Orientierung gilt für 2026 Montag,
                der 10. August 2026, weil an diesem Tag voraussichtlich der
                allgemeine erste Schultag nach den Sommerferien ist.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann mein Kind in Hessen früher eingeschult werden?</h3>
              <p>
                Kinder, die nach dem 30. Juni das sechste Lebensjahr vollenden,
                können auf Antrag der Eltern vorzeitig eingeschult werden. Der
                schriftliche Antrag wird bei der zuständigen Grundschule gestellt;
                die Entscheidung trifft die Schulleitung. Bei Kindern, die erst
                nach dem 31. Dezember das sechste Lebensjahr vollenden, kann
                zusätzlich eine schulpsychologische Überprüfung angeordnet werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann muss ich mein Kind in Hessen an der Grundschule anmelden?</h3>
              <p>
                Die Anmeldung erfolgt in Hessen in der Regel im März oder April des
                Jahres, das dem Beginn der Schulpflicht vorausgeht. Die zuständige
                Grundschule lädt die Eltern schriftlich ein und informiert über
                Termin, Unterlagen und Ablauf. Eltern sollten daher die Post der
                Schule im Herbst oder Winter des Vorjahres beachten.
              </p>
            </article>

            <article class="faq-item">
              <h3>Welche Quelle ist für die Einschulung in Hessen verbindlich?</h3>
              <p>
                Diese Seite dient der Orientierung. Verbindliche Informationen
                erhältst du bei der zuständigen Grundschule, dem Staatlichen
                Schulamt oder beim Hessischen Ministerium für Kultus, Bildung und
                Chancen.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quelle und Hinweis</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Hessen:
          </p>

          <ul class="source-list" aria-label="Offizielle Quellen zur Einschulung in Hessen">
            <li>
              <span>Offizielle Quelle 1</span>
              <a
                class="source-link"
                href="https://kultus.hessen.de/schulsystem/schulformen-und-bildungsgaenge/grundschule/grundschule"
                target="_blank"
                rel="noopener noreferrer"
              >
                Hessisches Ministerium für Kultus, Bildung und Chancen: Einschulung
              </a>
            </li>

            <li>
              <span>Offizielle Quelle 2</span>
              <a
                class="source-link"
                href="https://kultus.hessen.de/schulsystem/ferien/ferientermine"
                target="_blank"
                rel="noopener noreferrer"
              >
                Hessisches Ministerium für Kultus, Bildung und Chancen: Ferientermine
              </a>
            </li>
          </ul>

          <p class="source-hint">
            Hinweis: In Hessen beginnt die Schulpflicht für Kinder, die bis zum
            30. Juni das sechste Lebensjahr vollenden, am 1. August desselben
            Kalenderjahres. Nach offizieller Formulierung betrifft das Kinder, die
            bis einschließlich 1. Juli geboren sind. Bitte prüfe verbindliche
            Details immer bei der zuständigen Grundschule oder Schulbehörde.
          </p>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.22rem, 1.55vw, 1.46rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .fact-card-date {
    border-color: rgba(129, 97, 38, 0.16);
    background: rgba(245, 210, 138, 0.12);
  }

  .fact-card-date strong {
    font-size: clamp(1.12rem, 1.36vw, 1.32rem);
    white-space: normal;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 14px;
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }

  .source-list li {
    display: grid;
    gap: 5px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.12);
  }

  .source-list li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-list li > span {
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .source-hint {
    margin-top: 18px;
    color: #465266;
    font-size: 0.96rem;
    font-weight: 500;
    line-height: 1.58;
  }

  .stand {
    display: flex;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
      letter-spacing: -0.05em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .fact-card {
      min-height: 102px;
      padding: 18px 22px;
    }

    .fact-card span {
      font-size: clamp(0.82rem, 3.45vw, 0.96rem);
      letter-spacing: 0.095em;
    }

    .fact-card strong {
      font-size: clamp(1.12rem, 4.9vw, 1.36rem);
      line-height: 1.14;
    }

    .fact-card-date strong {
