---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Brandenburg 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Brandenburg in die Schule? Erfahre alles zu Schulstart 2026, Einschulungsstichtag, Kann-Kind-Regel, Zurückstellung und voraussichtlichem Schuljahr.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Brandenburg?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Brandenburg gilt derzeit der 30. September als Einschulungsstichtag. Kinder, die bis zu diesem Datum das sechste Lebensjahr vollenden, werden am 1. August desselben Kalenderjahres schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Brandenburg 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der erste Schultag im Schuljahr 2026/2027 ist in Brandenburg Montag, 24. August 2026. Die Einschulungsfeiern werden in der Regel am Samstag vor dem ersten Schultag durchgeführt, also voraussichtlich am Samstag, 22. August 2026. Den konkreten Ablauf legt die zuständige Grundschule fest.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind in Brandenburg?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind werden Kinder bezeichnet, die nach dem regulären Stichtag sechs Jahre alt werden und nicht automatisch schulpflichtig sind. In Brandenburg betrifft das vor allem Kinder, die zwischen dem 1. Oktober und dem 31. Dezember sechs Jahre alt werden. Eine vorzeitige Einschulung kann auf Antrag der Eltern geprüft werden.",
      },
    },
    {
      "@type": "Question",
      name: "Kann mein Kind in Brandenburg früher eingeschult werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Kinder, die zwischen dem 1. Oktober und dem 31. Dezember sechs Jahre alt werden, können auf Antrag der Eltern vorzeitig aufgenommen werden. Darüber hinaus kann in begründeten Ausnahmefällen auch eine vorzeitige Aufnahme für Kinder geprüft werden, die erst nach dem 31. Dezember – aber noch vor dem 1. August des Folgejahres – das sechste Lebensjahr vollenden.",
      },
    },
    {
      "@type": "Question",
      name: "Wann findet die Schulanmeldung in Brandenburg statt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Anmeldung erfolgt in Brandenburg bei der zuständigen Grundschule. Für das Schuljahr 2026/2027 musste die Anmeldung nach Angaben des MBJS bis zum 27. Februar 2026 erfolgen. Die Frist für das Schuljahr 2027/2028 wird vom MBJS rechtzeitig bekanntgegeben.",
      },
    },
    {
      "@type": "Question",
      name: "Kann die Einschulung in Brandenburg zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Schulpflichtige Kinder können in Brandenburg im Ausnahmefall auf Antrag der Eltern für ein Schuljahr zurückgestellt werden, wenn zu erwarten ist, dass sie noch nicht mit Erfolg am Unterricht teilnehmen können. Die Entscheidung trifft die Schulleitung nach schulärztlicher Untersuchung und Beratung durch die Schule.",
      },
    },
    {
      "@type": "Question",
      name: "Ändert sich der Einschulungsstichtag in Brandenburg?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Im Koalitionsvertrag Brandenburgs 2024–2029 ist vorgesehen, den Einschulungsstichtag künftig auf den 30. Juni zu verlegen. Stand Mai 2026 ist diese Änderung noch nicht gesetzlich umgesetzt. Bis dahin gilt weiterhin der 30. September. Verbindliche Auskunft erteilt das Ministerium für Bildung, Jugend und Sport Brandenburg.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Brandenburg verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule, der Schulbehörde oder beim Ministerium für Bildung, Jugend und Sport Brandenburg.",
      },
    },
  ],
};
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-brandenburg/" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Brandenburg</p>

        <h1>
          Einschulung in Brandenburg:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Brandenburg in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. In
          Brandenburg gilt derzeit der Stichtag 30. September. Für das Schuljahr
          2026/2027 ist die Einschulungsfeier voraussichtlich für Samstag,
          22. August 2026 vorgesehen – der erste Schultag ist Montag,
          24. August 2026.
        </p>

        <StateEnrollmentCalculator
          stateName="Brandenburg"
          stateSlug="brandenburg"
          calculatorKicker="Brandenburg-Rechner"
          resultKicker="Brandenburg-Ergebnis"
          headline="Einschulung in Brandenburg berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Brandenburg ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Brandenburg">
          <div class="fact-card fact-card-highlight">
            <span>Nächste Einschulung</span>
            <strong>Samstag, 22. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag, 24. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. September</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>
        </div>

        <section class="example-box">
          <h2>Wie funktioniert der Einschulungsrechner für Brandenburg?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Brandenburg. Entscheidend
            ist der Stichtag 30. September. Wird dein Kind bis zu diesem
            Datum sechs Jahre alt, ist es in Brandenburg regulär schulpflichtig.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. September 2020 geboren, wird es am
            15. September 2026 sechs Jahre alt. Da dieses Datum vor dem Stichtag
            30. September liegt, ist das Kind voraussichtlich für das Schuljahr
            2026/2027 regulär schulpflichtig.
          </p>

          <p>
            Wird ein Kind dagegen zwischen dem 1. Oktober und dem 31. Dezember
            sechs Jahre alt, ist es nicht automatisch regulär schulpflichtig. Eine
            vorzeitige Einschulung kann auf Antrag der Eltern geprüft werden.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind in Brandenburg schulpflichtig?</h2>

          <p>
            Ein Kind wird in Brandenburg regulär schulpflichtig, wenn es bis zum
            30. September des jeweiligen Kalenderjahres das sechste Lebensjahr
            vollendet. Die Schulpflicht beginnt dann am 1. August desselben Jahres.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Brandenburg früher eingeschult werden?</h2>

          <p>
            Kinder, die zwischen dem 1. Oktober und dem 31. Dezember sechs Jahre
            alt werden, können auf Antrag der Eltern vorzeitig aufgenommen werden.
            Diese Kinder werden häufig als Kann-Kinder bezeichnet.
          </p>

          <p>
            Darüber hinaus kann in begründeten Ausnahmefällen auch eine vorzeitige
            Aufnahme für Kinder geprüft werden, die erst nach dem 31. Dezember —
            aber noch vor dem 1. August des Folgejahres — das sechste Lebensjahr
            vollenden.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Brandenburg ab?</h2>

          <p>
            Die Anmeldung erfolgt bei der zuständigen Grundschule. Für das Schuljahr
            2026/2027 musste die Anmeldung nach Angaben des MBJS bis zum 27. Februar
            2026 erfolgen. Die Frist für das Schuljahr 2027/2028 wird vom MBJS
            rechtzeitig bekanntgegeben. Im Anschluss finden unter anderem die
            schulärztliche Untersuchung und das Schulaufnahmegespräch statt.
          </p>

          <p>
            Über die Aufnahme entscheidet die Schulleitung. Die Entscheidung wird
            den Eltern in der Regel schriftlich mitgeteilt.
          </p>
        </section>

        <section>
          <h2>Mein Kind ist noch nicht schulreif – was muss ich in Brandenburg tun?</h2>

          <p>
            Schulpflichtige Kinder können in Brandenburg im Ausnahmefall auf Antrag
            der Eltern für ein Schuljahr zurückgestellt werden, wenn zu erwarten
            ist, dass sie noch nicht mit Erfolg am Unterricht teilnehmen können.
            Die Entscheidung trifft die Schulleitung nach schulärztlicher
            Untersuchung und Beratung durch die Schule.
          </p>
        </section>

        <section class="example-box">
          <h2>Hinweis zur geplanten Stichtagsänderung</h2>

          <p>
            Im Koalitionsvertrag Brandenburgs 2024–2029 ist vorgesehen, den
            Einschulungsstichtag künftig auf den 30. Juni zu verlegen. Stand Mai
            2026 ist diese Änderung noch nicht gesetzlich umgesetzt. Bis dahin gilt
            weiterhin der 30. September. Diese Seite wird angepasst, sobald eine
            gesetzliche Änderung verbindlich in Kraft ist.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Brandenburg</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Brandenburg?</h3>
              <p>
                In Brandenburg gilt derzeit der 30. September als Einschulungsstichtag.
                Kinder, die bis zu diesem Datum das sechste Lebensjahr vollenden,
                werden am 1. August desselben Kalenderjahres schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Brandenburg 2026?</h3>
              <p>
                Der erste Schultag im Schuljahr 2026/2027 ist in Brandenburg
                Montag, 24. August 2026. Die Einschulungsfeiern werden in der Regel
                am Samstag vor dem ersten Schultag durchgeführt, also voraussichtlich
                am Samstag, 22. August 2026. Den konkreten Ablauf legt die zuständige
                Grundschule fest.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind in Brandenburg?</h3>
              <p>
                Als Kann-Kind werden Kinder bezeichnet, die nach dem regulären
                Stichtag sechs Jahre alt werden und nicht automatisch schulpflichtig
                sind. In Brandenburg betrifft das vor allem Kinder mit Geburtstag
                zwischen dem 1. Oktober und dem 31. Dezember. Eine vorzeitige
                Einschulung kann auf Antrag der Eltern geprüft werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann mein Kind in Brandenburg früher eingeschult werden?</h3>
              <p>
                Kinder, die zwischen dem 1. Oktober und dem 31. Dezember sechs
                Jahre alt werden, können auf Antrag der Eltern vorzeitig aufgenommen
                werden. Darüber hinaus kann in begründeten Ausnahmefällen auch eine
                vorzeitige Aufnahme für Kinder geprüft werden, die erst nach dem
                31. Dezember – aber noch vor dem 1. August des Folgejahres – das
                sechste Lebensjahr vollenden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung in Brandenburg statt?</h3>
              <p>
                Die Anmeldung erfolgt in Brandenburg bei der zuständigen Grundschule.
                Für das Schuljahr 2026/2027 musste die Anmeldung nach Angaben des
                MBJS bis zum 27. Februar 2026 erfolgen. Die Frist für das Schuljahr
                2027/2028 wird vom MBJS rechtzeitig bekanntgegeben.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann die Einschulung in Brandenburg zurückgestellt werden?</h3>
              <p>
                Schulpflichtige Kinder können in Brandenburg im Ausnahmefall auf
                Antrag der Eltern für ein Schuljahr zurückgestellt werden, wenn zu
                erwarten ist, dass sie noch nicht mit Erfolg am Unterricht teilnehmen
                können. Die Entscheidung trifft die Schulleitung nach schulärztlicher
                Untersuchung und Beratung durch die Schule.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ändert sich der Einschulungsstichtag in Brandenburg?</h3>
              <p>
                Im Koalitionsvertrag Brandenburgs 2024–2029 ist vorgesehen, den
                Einschulungsstichtag künftig auf den 30. Juni zu verlegen. Stand
                Mai 2026 ist diese Änderung noch nicht gesetzlich umgesetzt. Bis
                dahin gilt weiterhin der 30. September. Verbindliche Auskunft
                erteilt das Ministerium für Bildung, Jugend und Sport Brandenburg.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Brandenburg verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen der
                Orientierung. Verbindliche Informationen erhältst du bei der zuständigen
                Grundschule, der Schulbehörde oder beim Ministerium für Bildung,
                Jugend und Sport Brandenburg.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Brandenburg:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Brandenburg">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://mbjs.brandenburg.de/bildung/weitere-themen/anmeldung-an-schulen.html"
                target="_blank"
                rel="noopener noreferrer"
