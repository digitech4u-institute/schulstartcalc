---
import BaseLayout from "../layouts/BaseLayout.astro";
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Sachsen-Anhalt 2026: Termin, Stichtag & Rechner";

const pageDescription =
  "Wann ist die Einschulung in Sachsen-Anhalt 2026? Hier findest du Termin, Stichtag 30. Juni, Kann-Kind-Regelung und den kostenlosen Einschulungsrechner.";

const canonical = "https://www.einschulungsrechner.de/einschulung-sachsen-anhalt/";
const dateModified = "2026-05-27";

const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || "";
const STATE_CONTENT_AD_SLOT = import.meta.env.PUBLIC_ADSENSE_STATE_CONTENT_SLOT || "";
const showContentAd = Boolean(ADSENSE_ID && STATE_CONTENT_AD_SLOT);

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  datePublished: "2025-10-01",
  dateModified,
  inLanguage: "de",
  publisher: {
    "@type": "Organization",
    name: "Einschulungsrechner",
    url: "https://www.einschulungsrechner.de/",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Sachsen-Anhalt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Sachsen-Anhalt gilt grundsätzlich der 30. Juni als Einschulungsstichtag. Kinder, die bis zu diesem Datum das sechste Lebensjahr vollenden, werden mit Beginn des folgenden Schuljahres schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Sachsen-Anhalt 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Für das Schuljahr 2026/2027 enden die Sommerferien in Sachsen-Anhalt am Freitag, 14. August 2026. Die Einschulung der Erstklässler fällt voraussichtlich auf Samstag, 15. August 2026, der erste reguläre Schultag auf Montag, 17. August 2026. Einzelne organisatorische Details können je nach Schule abweichen.",
      },
    },
    {
      "@type": "Question",
      name: "Wann beginnt die Grundschule in Sachsen-Anhalt 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der erste reguläre Schultag im Schuljahr 2026/2027 ist in Sachsen-Anhalt Montag, 17. August 2026. Die Einschulung ist voraussichtlich für Samstag, 15. August 2026 vorgesehen. Den konkreten Ablauf legt die zuständige Grundschule fest.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Kann-Kind in Sachsen-Anhalt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Kann-Kind gilt in Sachsen-Anhalt ein Kind, das noch nicht regulär schulpflichtig ist, aber bis zum 30. Juni das fünfte Lebensjahr vollendet. Eine vorzeitige Einschulung kann auf Antrag der Erziehungsberechtigten geprüft werden, wenn das Kind die erforderlichen körperlichen und geistigen Voraussetzungen besitzt und sozial ausreichend entwickelt ist.",
      },
    },
    {
      "@type": "Question",
      name: "Wann findet die Schulanmeldung in Sachsen-Anhalt statt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Schulanmeldung erfolgt in Sachsen-Anhalt in der Regel bis zum 1. März des Vorjahres über das Serviceportal Schule Sachsen-Anhalt. Die zuständige Grundschule, der Schulträger oder das Serviceportal informieren über den konkreten Termin und die erforderlichen Unterlagen.",
      },
    },
    {
      "@type": "Question",
      name: "Kann die Einschulung in Sachsen-Anhalt zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eltern können in Sachsen-Anhalt einen Antrag auf Zurückstellung ihres schulpflichtigen Kindes stellen. Die Entscheidung trifft die zuständige Schulbehörde nach amtsärztlicher Untersuchung.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Sachsen-Anhalt verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde in Sachsen-Anhalt.",
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={[faqSchema, webPageSchema]}
>
  <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Sachsen-Anhalt</p>

        <h1>
          Einschulung Sachsen-Anhalt 2026:<br />
          Wann kommt mein Kind in die Schule?
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Sachsen-Anhalt in die Schule? Gib das Geburtsdatum
          ein und berechne das voraussichtliche Schuljahr. In Sachsen-Anhalt gilt
          der Stichtag 30. Juni. Für das Schuljahr 2026/2027 ist die Einschulung
          voraussichtlich für Samstag, 15. August 2026 vorgesehen – der erste
          Schultag ist Montag, 17. August 2026.
        </p>

        <p class="answer-box">
          Kurzantwort: Die Einschulung in Sachsen-Anhalt 2026 ist voraussichtlich
          für Samstag, 15. August 2026 vorgesehen. Der erste Schultag ist Montag,
          17. August 2026. Schulpflichtig werden Kinder, die bis zum 30. Juni 2026
          sechs Jahre alt werden.
        </p>

        <StateEnrollmentCalculator
          stateName="Sachsen-Anhalt"
          stateSlug="sachsen-anhalt"
          calculatorKicker="Sachsen-Anhalt-Rechner"
          resultKicker="Sachsen-Anhalt-Ergebnis"
          headline="Einschulung in Sachsen-Anhalt berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Sachsen-Anhalt ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Sachsen-Anhalt">
          <div class="fact-card fact-card-highlight">
            <span>Einschulung 2026</span>
            <strong>Samstag,<br />15. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag,<br />17. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. Juni</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Kann-Kind auf Antrag</strong>
          </div>
        </div>

        {showContentAd ? (
          <aside class="ad-slot ad-slot-after-facts" aria-label="Anzeige">
            <p class="ad-label">Anzeige</p>
            <ins
              class="adsbygoogle"
              style="display:block"
              data-ad-client={ADSENSE_ID}
              data-ad-slot={STATE_CONTENT_AD_SLOT}
              data-ad-format="auto"
              data-full-width-responsive="true"
            ></ins>
          </aside>
        ) : null}

        <section>
          <h2>Wann ist die Einschulung in Sachsen-Anhalt 2026?</h2>

          <p>
            Die Sommerferien in Sachsen-Anhalt enden 2026 am Freitag,
            14. August 2026. Die Einschulung ist voraussichtlich für Samstag,
            15. August 2026 vorgesehen. Der erste Schultag ist Montag,
            17. August 2026. Den konkreten Ablauf legt die zuständige Grundschule fest.
          </p>
        </section>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Sachsen-Anhalt?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Sachsen-Anhalt. Entscheidend
            ist der Stichtag 30. Juni. Wird dein Kind bis zu diesem Datum sechs Jahre
            alt, ist es in Sachsen-Anhalt regulär schulpflichtig.
          </p>

        </section>

        <section>
          <h2>Wann ist ein Kind in Sachsen-Anhalt schulpflichtig?</h2>

          <p>
            In Sachsen-Anhalt gilt der 30. Juni als maßgeblicher Stichtag für die
            Schulpflicht. Kinder, die bis zu diesem Datum das sechste Lebensjahr
            vollenden, werden mit Beginn des folgenden Schuljahres schulpflichtig.
          </p>

          <p>
            Entscheidend ist also, ob der sechste Geburtstag bis einschließlich
            30. Juni erreicht ist. Liegt der Geburtstag nach dem Stichtag, besteht
            keine automatische Schulpflicht für dieses Schuljahr; eine vorzeitige
            Einschulung kann aber als Kann-Kind auf Antrag geprüft werden.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Sachsen-Anhalt früher eingeschult werden?</h2>

          <p>
            Kinder, die bis zum 30. Juni das fünfte Lebensjahr vollenden, können
            auf Antrag der Erziehungsberechtigten mit Beginn des Schuljahres
            vorzeitig in die Schule aufgenommen werden. Voraussetzung ist, dass das
            Kind die für den Schulbesuch erforderlichen körperlichen und geistigen
            Voraussetzungen besitzt und in seinem sozialen Verhalten ausreichend
            entwickelt ist.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Sachsen-Anhalt ab?</h2>

          <p>
            Die Schulanmeldung erfolgt in Sachsen-Anhalt in der Regel bis zum
            1. März des Vorjahres über das Serviceportal Schule Sachsen-Anhalt.
            Die zuständige Grundschule, der Schulträger oder das Serviceportal
            informieren über den konkreten Termin und die erforderlichen Unterlagen.
            Vor der Aufnahme in die Schule ist außerdem eine amtsärztliche
            Untersuchung vorgesehen.
          </p>
        </section>

        <section>
          <h2>Mein Kind ist noch nicht schulreif – was muss ich in Sachsen-Anhalt tun?</h2>

          <p>
            Wenn du unsicher bist, ob dein Kind schon schulbereit ist, sprich
            frühzeitig mit der zuständigen Grundschule. Eltern können in
            Sachsen-Anhalt einen Antrag auf Zurückstellung ihres schulpflichtigen
            Kindes stellen. Die Entscheidung trifft die zuständige Schulbehörde
            nach amtsärztlicher Untersuchung. Verbindliche Auskunft erhältst du
            bei der zuständigen Grundschule oder Schulbehörde.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Sachsen-Anhalt</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Sachsen-Anhalt?</h3>
              <p>
                In Sachsen-Anhalt gilt grundsätzlich der 30. Juni als
                Einschulungsstichtag. Kinder, die bis zu diesem Datum das sechste
                Lebensjahr vollenden, werden mit Beginn des folgenden Schuljahres
                schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Sachsen-Anhalt 2026?</h3>
              <p>
                Für das Schuljahr 2026/2027 enden die Sommerferien in Sachsen-Anhalt
                am Freitag, 14. August 2026. Die Einschulung der Erstklässler fällt
                voraussichtlich auf Samstag, 15. August 2026, der erste reguläre
                Schultag auf Montag, 17. August 2026. Einzelne organisatorische
                Details können je nach Schule abweichen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann beginnt die Grundschule in Sachsen-Anhalt 2026?</h3>
              <p>
                Der erste reguläre Schultag im Schuljahr 2026/2027 ist in
                Sachsen-Anhalt Montag, 17. August 2026. Die Einschulung ist
                voraussichtlich für Samstag, 15. August 2026 vorgesehen. Den
                konkreten Ablauf legt die zuständige Grundschule fest.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Kann-Kind in Sachsen-Anhalt?</h3>
              <p>
                Als Kann-Kind gilt in Sachsen-Anhalt ein Kind, das noch nicht
                regulär schulpflichtig ist, aber bis zum 30. Juni das fünfte
                Lebensjahr vollendet. Eine vorzeitige Einschulung kann auf Antrag
                der Erziehungsberechtigten geprüft werden, wenn das Kind die
                erforderlichen körperlichen und geistigen Voraussetzungen besitzt
                und sozial ausreichend entwickelt ist.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann findet die Schulanmeldung in Sachsen-Anhalt statt?</h3>
              <p>
                Die Schulanmeldung erfolgt in Sachsen-Anhalt in der Regel bis zum
                1. März des Vorjahres über das Serviceportal Schule Sachsen-Anhalt.
                Die zuständige Grundschule, der Schulträger oder das Serviceportal
                informieren über den konkreten Termin und die erforderlichen
                Unterlagen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann die Einschulung in Sachsen-Anhalt zurückgestellt werden?</h3>
              <p>
                Eltern können in Sachsen-Anhalt einen Antrag auf Zurückstellung
                ihres schulpflichtigen Kindes stellen. Die Entscheidung trifft die
                zuständige Schulbehörde nach amtsärztlicher Untersuchung.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Sachsen-Anhalt verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen
                der Orientierung. Verbindliche Informationen erhältst du bei der
                zuständigen Grundschule oder Schulbehörde in Sachsen-Anhalt.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Sachsen-Anhalt:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Sachsen-Anhalt">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://mb.sachsen-anhalt.de/fileadmin/Bibliothek/Landesjournal/Bildung_und_Wissenschaft/Publikationen/schulgesetz.pdf"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Bildung Sachsen-Anhalt: Schulgesetz des Landes Sachsen-Anhalt
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://www.kmk.org/fileadmin/Dateien/pdf/Ferienkalender/FER2025_26.pdf"
                target="_blank"
                rel="noopener noreferrer"
              >
                Kultusministerkonferenz: Ferientermine Schuljahr 2025/2026
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://presse.sachsen-anhalt.de/bildungsministerium/2026/01/23/einschulung-zum-schuljahr-2027-2028-kinder-bis-zum-1-maerz-2026-ueber-das-serviceportal-schule-anmelden"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Bildung Sachsen-Anhalt: Schulanmeldung über das Serviceportal Schule
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Ministerium für Bildung
            Sachsen-Anhalt.
          </p>

          <p class="stand">Stand der Informationen:<span class="stand-date">Mai 2026</span></p>
        </section>
      </article>
  </main>
</BaseLayout>

<style is:global>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .answer-box {
    max-width: 760px;
    margin: 20px 0 0;
    padding: 18px 20px;
    border: 1px solid rgba(129, 97, 38, 0.18);
    border-radius: 18px;
    background: rgba(245, 210, 138, 0.14);
    color: #172033;
    font-size: clamp(1.02rem, 1.35vw, 1.12rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  body.has-sachsen-anhalt-calculator-result .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .ad-slot {
    margin: 30px 0 0;
    padding: 14px 0;
    border-top: 1px solid rgba(42, 35, 21, 0.08);
    border-bottom: 1px solid rgba(42, 35, 21, 0.08);
  }

  .ad-label {
    margin: 0 0 10px;
    color: #8a7960;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .stand {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  .stand-date {
    display: inline;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
