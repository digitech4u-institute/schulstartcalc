    <script define:vars={{ calculatorStateRules, calculatorEnrollmentDatesBySchoolYear, currentSchoolYear }}>
      const stateRules = calculatorStateRules;
      const stateEnrollmentDatesBySchoolYear = calculatorEnrollmentDatesBySchoolYear;
      const referenceSchoolYear = currentSchoolYear;

      function parseDateInput(value) {
        const [year, month, day] = value.split("-").map(Number);
        return new Date(year, month - 1, day);
      }

      function createDateFromMMDD(year, mmdd) {
        const [month, day] = mmdd.split("-").map(Number);
        return new Date(year, month - 1, day);
      }

      function formatDate(date) {
        return new Intl.DateTimeFormat("de-DE", {
          day: "2-digit",
          month: "long",
          year: "numeric",
        }).format(date);
      }

      function calculateEnrollment(birthdateValue, stateKey) {
        const stateRule = stateRules[stateKey];

        if (!birthdateValue || !stateRule) {
          return {
            status: "missing_input",
            title: "Bitte Geburtsdatum und Bundesland auswählen",
            text: "Sobald beide Angaben vorhanden sind, berechnen wir das voraussichtliche Einschulungsjahr.",
          };
        }

        const birthDate = parseDateInput(birthdateValue);
        const sixthBirthdayYear = birthDate.getFullYear() + 6;

        const sixthBirthday = new Date(
          sixthBirthdayYear,
          birthDate.getMonth(),
          birthDate.getDate()
        );

        const cutoffDate = createDateFromMMDD(sixthBirthdayYear, stateRule.cutoff);

        if (stateRule.type === "brandenburg_optional") {
          const birthMonth = birthDate.getMonth() + 1;

          if (birthMonth <= 7) {
            return buildSpecialResult(
              stateRule,
              sixthBirthdayYear,
              cutoffDate,
              sixthBirthday
            );
          }
        }

        if (stateRule.type === "berlin_optional") {
          const birthMonth = birthDate.getMonth() + 1;

          if (birthMonth >= 10) {
            return buildSpecialResult(
              stateRule,
              sixthBirthdayYear,
              createDateFromMMDD(sixthBirthdayYear, stateRule.cutoff),
              sixthBirthday
            );
          }

          if (birthMonth <= 3) {
            const optionalEnrollmentYear = sixthBirthdayYear - 1;

            return buildSpecialResult(
              stateRule,
              optionalEnrollmentYear,
              createDateFromMMDD(optionalEnrollmentYear, stateRule.cutoff),
              sixthBirthday
            );
          }
        }

        if (stateRule.specialWindow) {
          const specialFrom = createDateFromMMDD(
            sixthBirthdayYear,
            stateRule.specialWindow.from
          );

          const specialTo = createDateFromMMDD(
            sixthBirthdayYear,
            stateRule.specialWindow.to
          );

          if (sixthBirthday >= specialFrom && sixthBirthday <= specialTo) {
            return buildSpecialResult(
              stateRule,
              sixthBirthdayYear,
              cutoffDate,
              sixthBirthday
            );
          }
        }

        if (sixthBirthday <= cutoffDate) {
          return {
            status: "regular",
            title: `Dein Kind wird voraussichtlich im Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1} eingeschult.`,
            shortText: `In ${stateRule.name} gilt der ${stateRule.label}. Da dein Kind bis zu diesem Stichtag sechs Jahre alt wird, fällt es voraussichtlich in das Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1}.`,
            whyText: `In ${stateRule.name} gilt der ${stateRule.label}. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt und erreicht damit den Stichtag.`,
            nextStep: `Informiere dich rechtzeitig bei der zuständigen Grundschule über Anmeldung, Fristen und den konkreten Einschulungstermin.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${sixthBirthdayYear}/${sixthBirthdayYear + 1}`,
              statusLabel: "Regulär schulpflichtig",
            },
          };
        }

        const nextEnrollmentYear = sixthBirthdayYear + 1;

        const earlyEnrollmentText = stateRule.type === "standard_with_optional"
          ? ` In ${stateRule.name} kann für Kinder nach dem Stichtag eine vorzeitige Einschulung auf Antrag geprüft werden.`
          : "";

        return {
          status: "next_year",
          title: `Dein Kind wird voraussichtlich im Schuljahr ${nextEnrollmentYear}/${nextEnrollmentYear + 1} eingeschult.`,
          shortText: `In ${stateRule.name} gilt der ${stateRule.label}. Da dein Kind erst nach diesem Stichtag sechs Jahre alt wird, fällt es voraussichtlich in das Schuljahr ${nextEnrollmentYear}/${nextEnrollmentYear + 1}.${earlyEnrollmentText}`,
          whyText: `In ${stateRule.name} gilt der ${stateRule.label}. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt und erreicht den Stichtag in diesem Jahr voraussichtlich nicht.${earlyEnrollmentText}`,
          nextStep: stateRule.type === "standard_with_optional"
            ? `Wenn du eine Einschulung schon im Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1} prüfen möchtest, informiere dich frühzeitig bei der zuständigen Grundschule über Antrag, Voraussetzungen und Fristen.`
            : `Wenn du über eine frühere Einschulung nachdenkst, informiere dich bei der zuständigen Grundschule über die Voraussetzungen.`,
          meta: {
            state: stateRule.name,
            cutoff: formatDate(createDateFromMMDD(nextEnrollmentYear, stateRule.cutoff)),
            schoolYear: `${nextEnrollmentYear}/${nextEnrollmentYear + 1}`,
            statusLabel: "Regulär schulpflichtig",
          },
        };
      }

      function buildSpecialResult(stateRule, enrollmentYear, cutoffDate, sixthBirthday) {
        if (stateRule.type === "corridor") {
          return {
            status: "corridor",
            title: `Dein Kind liegt im Einschulungskorridor.`,
            shortText: `Dein Kind fällt in Bayern in den Einschulungskorridor, weil es zwischen dem 1. Juli und dem 30. September sechs Jahre alt wird.`,
            whyText: `In Bayern fallen Kinder, die zwischen dem 1. Juli und dem 30. September sechs Jahre alt werden, in den Einschulungskorridor. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt.`,
            nextStep: `Prüfe die Fristen bei der zuständigen Grundschule. Unter bestimmten Voraussetzungen kann eine spätere Einschulung geklärt werden.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${enrollmentYear}/${enrollmentYear + 1}`,
              statusLabel: "Einschulungskorridor",
            },
          };
        }

        if (stateRule.type === "karenzzeit") {
          return {
            status: "karenzzeit",
            title: `Dein Kind fällt in die Karenzzeit.`,
            shortText: `In Bremen gilt der 30. Juni als regulärer Stichtag. Da dein Kind zwischen dem 1. Juli und dem 30. September sechs Jahre alt wird, fällt es in die Karenzzeit.`,
            whyText: `Kinder, die zwischen dem 1. Juli und dem 30. September sechs Jahre alt werden, gelten in Bremen als Karenzzeitkinder. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt.`,
            nextStep: `Prüfe mit der zuständigen Grundschule, ob die Einschulung im aktuellen oder im nächsten Jahr sinnvoll ist.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${enrollmentYear}/${enrollmentYear + 1}`,
              statusLabel: "Karenzzeit",
            },
          };
        }

        if (stateRule.type === "flexible_window") {
          return {
            status: "flexible",
            title: `<span class="result-headline-muted">Dein Kind fällt in Niedersachsen in den</span><span class="result-headline-accent">flexiblen Einschulungszeitraum</span><span class="result-headline-muted">Eine Einschulung zum</span><span class="result-headline-accent">Schuljahr ${enrollmentYear}/${enrollmentYear + 1}</span><span class="result-headline-muted">ist grundsätzlich möglich.</span>`,
            shortText: `In Niedersachsen gilt der 30. September als Stichtag. Da dein Kind zwischen dem 1. Juli und dem 30. September sechs Jahre alt wird, ist es grundsätzlich schulpflichtig; zugleich gibt es eine besondere Flexibilisierung.`,
            whyText: `Für Kinder, die zwischen dem 1. Juli und dem 30. September sechs Jahre alt werden, gibt es in Niedersachsen eine besondere Regelung. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt.`,
            nextStep: `Informiere dich bei der zuständigen Grundschule, ob eine Verschiebung des Einschulungstermins in Frage kommt.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${enrollmentYear}/${enrollmentYear + 1}`,
              statusLabel: "Flexibler Einschulungszeitraum",
            },
          };
        }

        if (stateRule.type === "berlin_optional") {
          return {
            status: "optional",
            title: `Dein Kind ist in Berlin ein Kann-Kind.`,
            shortText: `In Berlin kann für dieses Geburtsdatum eine vorzeitige Einschulung auf Antrag geprüft werden.`,
            whyText: `Kinder, die zwischen dem 1. Oktober und dem 31. März des folgenden Kalenderjahres sechs Jahre alt werden, können in Berlin auf Antrag vorzeitig eingeschult werden, wenn kein Sprachförderbedarf besteht. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt.`,
            nextStep: `Sprich frühzeitig mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung beantragen möchtest.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${enrollmentYear}/${enrollmentYear + 1}`,
              statusLabel: "Kann-Kind",
            },
          };
        }

        if (stateRule.type === "brandenburg_optional") {
          const birthMonth = sixthBirthday.getMonth() + 1;
          const exceptionYear = enrollmentYear - 1;

          if (birthMonth <= 7) {
            return {
              status: "brandenburg_exception",
              title: `<span class="result-headline-muted">Dein Kind kann in ${stateRule.name} für das</span><span class="result-headline-accent">Schuljahr ${exceptionYear}/${exceptionYear + 1}</span><span class="result-headline-muted">nur im</span><span class="result-headline-accent">Ausnahmefall</span><span class="result-headline-muted">aufgenommen werden.</span>`,
              shortText: `Dein Kind wird erst nach dem 31. Dezember und vor dem 1. August des Folgejahres sechs Jahre alt. In Brandenburg kann eine Aufnahme in diesem Schuljahr nur in begründeten Ausnahmefällen geprüft werden.`,
              whyText: `Dein Kind wird erst nach dem 31. Dezember und vor dem 1. August des Folgejahres sechs Jahre alt. In Brandenburg kann eine Aufnahme in diesem Schuljahr nur in begründeten Ausnahmefällen geprüft werden.`,
              nextStep: `Für diesen Sonderfall solltest du dich direkt an die zuständige Grundschule wenden.`,
              meta: {
                state: stateRule.name,
                cutoff: formatDate(cutoffDate),
                schoolYear: `${exceptionYear}/${exceptionYear + 1}`,
                statusLabel: "Aufnahme im Ausnahmefall möglich",
              },
            };
          }

          return {
            status: "brandenburg_optional",
            title: `Dein Kind ist in Brandenburg ein Kann-Kind.`,
            shortText: `Dein Kind wird nach dem regulären Stichtag, aber bis zum 31. Dezember sechs Jahre alt. In Brandenburg kann eine vorzeitige Einschulung für das Schuljahr ${enrollmentYear}/${enrollmentYear + 1} auf Antrag geprüft werden.`,
            whyText: `Dein Kind wird nach dem regulären Stichtag, aber bis zum 31. Dezember sechs Jahre alt. In Brandenburg kann eine vorzeitige Einschulung für das Schuljahr ${enrollmentYear}/${enrollmentYear + 1} auf Antrag geprüft werden.`,
            nextStep: `Sprich frühzeitig mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung für dieses Schuljahr prüfen lassen möchtest.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${enrollmentYear}/${enrollmentYear + 1}`,
              statusLabel: "Kann-Kind auf Antrag",
            },
          };
        }
		if (stateRule.type === "registration_window") {
  return {
    status: "registration_window",
    title: `Dein Kind liegt im erweiterten Anmeldezeitraum.`,
    shortText: `In Sachsen gilt der 30. Juni als regulärer Stichtag. Kinder, die bis zum 30. September sechs Jahre alt werden, können durch Anmeldung der Eltern ebenfalls schulpflichtig werden.`,
    whyText: `In Sachsen gilt der 30. Juni als regulärer Stichtag. Kinder, die bis zum 30. September sechs Jahre alt werden, können durch Anmeldung der Eltern ebenfalls schulpflichtig werden.`,
    nextStep: `Informiere dich bei der zuständigen Grundschule, ob und wie die Anmeldung für eine Einschulung in diesem Schuljahr möglich ist.`,
    meta: {
      state: stateRule.name,
      cutoff: formatDate(cutoffDate),
      schoolYear: `${enrollmentYear}/${enrollmentYear + 1}`,
      statusLabel: "Anmeldung möglich",
    },
  };
}
}
  function renderResult(result) {
    const resultBox = document.getElementById("resultBox");

    if (!resultBox) return;

    resultBox.classList.remove("result-box-empty");

    if (result.status === "missing_input") {
      resultBox.classList.add("result-box-empty");

      resultBox.innerHTML = `
        <p class="result-kicker">Bitte prüfen</p>

        <div class="result-empty-content">
          <h2 class="result-heading">${result.title}</h2>
          <p class="result-body">${result.text}</p>
        </div>
      `;
      return;
    }

    const selectedStateKey = stateSelect?.value || "";
    const selectedBirthdate = buildBirthdateValueFromFields().value;
    const resultSchoolYearStart = Number(result.meta.schoolYear.split("/")[0]);
    const referenceSchoolYearStart = Number(referenceSchoolYear.split("/")[0]);
    const currentActiveSchoolYearStart = referenceSchoolYearStart - 1;
    const isActiveSchoolYear = resultSchoolYearStart === currentActiveSchoolYearStart;
    const isPastSchoolYear = resultSchoolYearStart < currentActiveSchoolYearStart;
    const isFutureSchoolYear = resultSchoolYearStart > referenceSchoolYearStart;
    let resultPreline = isPastSchoolYear || isActiveSchoolYear
      ? "Das berechnete"
      : "Dein Kind wird voraussichtlich im";
    let resultHighlightText = `Schuljahr ${result.meta.schoolYear}`;
    let resultHighlightClass = "result-schoolyear";
    let resultPostline = isPastSchoolYear
      ? "liegt bereits in der Vergangenheit."
      : isActiveSchoolYear
        ? `ist in ${result.meta.state} das laufende Schuljahr.`
        : "eingeschult.";
    const resultSectionTitle = isPastSchoolYear || isActiveSchoolYear ? "Einordnung" : "Warum?";
    let resultSectionText = isPastSchoolYear
      ? `Das berechnete Schuljahr ${result.meta.schoolYear} liegt bereits in der Vergangenheit. Das Ergebnis dient daher nur noch der zeitlichen Einordnung.`
      : isActiveSchoolYear
        ? `Für ${result.meta.state} fällt dieses Geburtsdatum in das Schuljahr ${result.meta.schoolYear}; die Einschulung hat in diesem Schuljahr in der Regel bereits stattgefunden.`
        : result.shortText;
    const nextStepTitle = isPastSchoolYear || isActiveSchoolYear ? "Rückwirkende Fragen" : "Dein nächster Schritt";
    let nextStepText = isPastSchoolYear
      ? "Wende dich bei rückwirkenden Fragen, Nachweisen oder verbindlichen Auskünften direkt an die zuständige Grundschule."
      : isActiveSchoolYear
        ? "Wende dich bei aktuellen oder rückwirkenden Fragen, Nachweisen oder verbindlichen Auskünften direkt an die zuständige Grundschule."
        : result.nextStep;
    const resultNoteText = isPastSchoolYear
      ? "Das Ergebnis ist keine aktuelle Einschulungsempfehlung mehr, sondern dient nur noch der zeitlichen Einordnung. Bitte wende dich bei rückwirkenden Fragen direkt an die zuständige Grundschule."
      : isActiveSchoolYear
        ? "Das Ergebnis bezieht sich auf das laufende Schuljahr und dient nur der Orientierung. Für aktuelle oder rückwirkende Fragen ist die zuständige Grundschule maßgeblich."
        : "Dieser Rechner dient der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Schule oder Schulbehörde.";
    const selectedEnrollmentDates = selectedStateKey
      ? stateEnrollmentDatesBySchoolYear?.[result.meta.schoolYear]?.[selectedStateKey]
      : null;
    const hasEnrollmentDates = Boolean(
      selectedEnrollmentDates?.enrollment && selectedEnrollmentDates?.firstSchoolDay,
    );
    const formatDateFactValue = (value) => value.replace(", ", ",<br />");
    const stripWeekday = (value) => value.replace(/^[^,]+,\s*/, "");
    const formatHeadlineDateRange = (value) => value.replace(/(\d+\.)–(\d+\.)/, "$1 oder $2");
    const enrollmentQualifierText = selectedEnrollmentDates?.enrollmentQualifier
      ? ` (${selectedEnrollmentDates.enrollmentQualifier})`
      : "";
    const enrollmentDateText = selectedEnrollmentDates?.enrollment
      ? `${formatDateFactValue(selectedEnrollmentDates.enrollment)}${enrollmentQualifierText}`
      : "";
    const firstSchoolDayText = selectedEnrollmentDates?.firstSchoolDay
      ? formatDateFactValue(selectedEnrollmentDates.firstSchoolDay)
      : "";

    if (!isPastSchoolYear && !isActiveSchoolYear && isFutureSchoolYear && !hasEnrollmentDates) {
      resultSectionText = `Dein Kind wird im Jahr ${resultSchoolYearStart} sechs Jahre alt. Nach den Regeln in ${result.meta.state} fällt es voraussichtlich in das Schuljahr ${result.meta.schoolYear}.`;
      nextStepText = `Notiere dir das voraussichtliche Schuljahr ${result.meta.schoolYear} und prüfe die Schulanmeldung, Fristen und Termine rechtzeitig bei der zuständigen Grundschule. Konkrete Einschulungstermine werden je nach Bundesland und Schule später festgelegt.`;
    }

    const nonDefinitiveResultStatuses = new Set([
      "corridor",
      "karenzzeit",
      "flexible",
      "optional",
      "brandenburg_optional",
      "brandenburg_exception",
      "registration_window",
    ]);
    const isNonDefinitiveResult = nonDefinitiveResultStatuses.has(result.status);

    if (!isPastSchoolYear && !isActiveSchoolYear && isNonDefinitiveResult) {
      resultPreline = "";
      resultHighlightText = result.title;
      resultHighlightClass = "result-schoolyear result-schoolyear-range";
      resultPostline = "";
    }

    if (!isPastSchoolYear && !isActiveSchoolYear && !isNonDefinitiveResult && hasEnrollmentDates && selectedEnrollmentDates?.enrollment) {
      const isDateRange = selectedEnrollmentDates.enrollment.includes("–");
      const hasEnrollmentQualifier = Boolean(selectedEnrollmentDates.enrollmentQualifier);
      const headlineDate = isDateRange || hasEnrollmentQualifier
        ? selectedEnrollmentDates.enrollment
        : stripWeekday(selectedEnrollmentDates.enrollment);
      const plainHeadlineDate = formatHeadlineDateRange(headlineDate);

      if (hasEnrollmentQualifier || isDateRange) {
        resultPreline = `Die Einschulung deines Kindes findet in ${result.meta.state}<br />im Schuljahr ${result.meta.schoolYear} voraussichtlich am`;
        resultHighlightText = isDateRange
          ? plainHeadlineDate
          : formatDateFactValue(plainHeadlineDate);
        resultHighlightClass = "result-schoolyear result-schoolyear-range";
        resultPostline = `statt${enrollmentQualifierText}.`;
        resultSectionText = `Dein Kind ist in ${result.meta.state} für das Schuljahr ${result.meta.schoolYear} regulär schulpflichtig. Der konkrete Einschulungstermin liegt in diesem Schuljahr schulabhängig voraussichtlich am ${plainHeadlineDate}.`;
        nextStepText = `Prüfe den genauen Einschulungstermin direkt bei der zuständigen Grundschule.`;
      } else {
        resultPreline = `Dein Kind wird in ${result.meta.state} voraussichtlich am`;
        resultHighlightText = formatDateFactValue(selectedEnrollmentDates.enrollment);
        resultPostline = `für das Schuljahr ${result.meta.schoolYear} eingeschult.`;
      }
    }
    const dateFactsHtml = hasEnrollmentDates
      ? `
        <div class="result-fact result-fact-highlight">
          <span class="result-fact-label">Nächste Einschulung</span>
          <span class="result-fact-value">${enrollmentDateText}</span>
        </div>

        <div class="result-fact result-fact-highlight">
          <span class="result-fact-label">Erster Schultag</span>
          <span class="result-fact-value">${firstSchoolDayText}</span>
        </div>
      `
      : "";
    const stateDetailUrl = selectedStateKey
      ? `/einschulung-${selectedStateKey}/${selectedBirthdate ? `?geburtsdatum=${selectedBirthdate}` : ""}`
      : "";
    const stateDetailLink = stateDetailUrl
      ? `
      <a class="result-detail-link" href="${stateDetailUrl}">
        Mehr Details zur Einschulung in ${result.meta.state}
      </a>
      `
      : "";
    const checklistCta = !isPastSchoolYear && !isActiveSchoolYear
      ? `
      <a class="result-checklist-cta" href="/einschulung-checkliste/">
        <span class="result-checklist-cta-title">Jetzt den Schulstart vorbereiten</span>
        <span class="result-checklist-cta-text">Mit der Checkliste behältst du Anmeldung, Schulranzen, Schultüte und wichtige Fristen im Blick.</span>
