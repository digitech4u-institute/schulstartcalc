	  function renderResult(result) {
  const resultBox = document.getElementById("resultBox");

  if (!resultBox) return;

  resultBox.classList.remove("result-box-empty");

  if (result.status === "missing_input") {
    resultBox.classList.add("result-box-empty");

    resultBox.innerHTML = `
      <p class="result-kicker">Bitte prüfen</p>

      <div class="result-empty-content">
        <h2 class="result-heading">${result.title}</h2>
        <p class="result-body">${result.text}</p>
      </div>
    `;
    return;
  }

  resultBox.innerHTML = `
    <p class="result-kicker">Dein Ergebnis</p>

    <div class="result-summary">
      <p class="result-preline">Dein Kind wird voraussichtlich im</p>
      <p class="result-schoolyear">Schuljahr ${result.meta.schoolYear}</p>
      <p class="result-postline">eingeschult.</p>
    </div>

    <div class="result-facts" aria-label="Einschulungsdetails">
      <div class="result-fact">
        <span class="result-fact-label">Bundesland</span>
        <span class="result-fact-value">${result.meta.state}</span>
      </div>

      <div class="result-fact">
        <span class="result-fact-label">Stichtag</span>
        <span class="result-fact-value">${result.meta.cutoff}</span>
      </div>

      <div class="result-fact">
        <span class="result-fact-label">Status</span>
        <span class="result-fact-value">${result.meta.statusLabel}</span>
      </div>

      <div class="result-fact">
        <span class="result-fact-label">Schuljahr</span>
        <span class="result-fact-value">${result.meta.schoolYear}</span>
      </div>
    </div>

    <div class="result-section">
      <h3>Warum?</h3>
      <p>${result.shortText}</p>
    </div>

    <div class="result-section">
      <h3>Dein nächster Schritt</h3>
      <p>${result.nextStep}</p>
    </div>

    <p class="result-note">
      Dieser Rechner dient der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Schule oder Schulbehörde.
    </p>
  `;
}
      const birthDayInput = document.getElementById("calcDay");
      const birthMonthInput = document.getElementById("calcMonth");
      const birthYearInput = document.getElementById("calcYear");
      const dateError = document.getElementById("dateError");
      const stateSelect = document.getElementById("state");
      const calculateButton = document.getElementById("calculateButton");

      function onlyDigits(value) {
        return value.replace(/\D/g, "");
      }

      function setDateError(message) {
        if (!dateError) return;
        dateError.textContent = message || "";
      }

      function pad2(value) {
        return value.toString().padStart(2, "0");
      }

      function focusInput(input) {
        if (!input) return;
        input.focus();
      }

      function isRealDate(day, month, year) {
        const date = new Date(year, month - 1, day);

        return (
          date.getFullYear() === year &&
          date.getMonth() === month - 1 &&
          date.getDate() === day
        );
      }

      function buildBirthdateValueFromFields() {
        const dayValue = onlyDigits(birthDayInput?.value || "");
        const monthValue = onlyDigits(birthMonthInput?.value || "");
        const yearValue = onlyDigits(birthYearInput?.value || "");

        if (!dayValue || !monthValue || !yearValue) {
          return {
            value: "",
            error: "Bitte gib Tag, Monat und Jahr des Geburtsdatums ein.",
          };
        }

        const day = Number(dayValue);
        const month = Number(monthValue);
        const year = Number(yearValue);
        const currentYear = new Date().getFullYear();

        if (day < 1 || day > 31) {
          return {
            value: "",
            error: "Bitte prüfe den Tag. Der Wert muss zwischen 1 und 31 liegen.",
          };
        }

        if (month < 1 || month > 12) {
          return {
            value: "",
            error: "Bitte prüfe den Monat. Der Wert muss zwischen 1 und 12 liegen.",
          };
        }

        if (yearValue.length !== 4) {
          return {
            value: "",
            error: "Bitte gib das Geburtsjahr vierstellig ein, zum Beispiel 2020.",
          };
        }

        if (year > currentYear) {
          return {
            value: "",
            error: "Das Geburtsjahr liegt in der Zukunft. Bitte prüfe deine Eingabe.",
          };
        }

        if (year < currentYear - 12) {
          return {
            value: "",
            error:
              "Das Geburtsdatum wirkt für einen Einschulungsrechner ungewöhnlich. Bitte prüfe deine Eingabe.",
          };
        }

        if (!isRealDate(day, month, year)) {
          return {
            value: "",
            error: "Dieses Datum gibt es nicht. Bitte prüfe Tag und Monat.",
          };
        }

        return {
          value: `${year}-${pad2(month)}-${pad2(day)}`,
          error: "",
        };
      }

      function updateCalculateButtonState() {
        if (!calculateButton) return;

        const birthdateResult = buildBirthdateValueFromFields();
        const hasValidDate = Boolean(birthdateResult.value);
        const hasState = Boolean(stateSelect?.value);

        if (hasValidDate && hasState) {
          calculateButton.classList.add("is-ready");
        } else {
          calculateButton.classList.remove("is-ready");
        }
      }

      function normalizeDateFieldOnBlur(input, maxValue) {
        if (!input) return;

        const value = onlyDigits(input.value);
        if (!value) return;

        const numberValue = Number(value);

        if (numberValue >= 1 && numberValue <= maxValue) {
          input.value = pad2(numberValue);
        }
      }

      birthDayInput?.addEventListener("input", () => {
        setDateError("");

        birthDayInput.value = onlyDigits(birthDayInput.value).slice(0, 2);

        const day = Number(birthDayInput.value);

        if (birthDayInput.value.length === 2) {
          if (day < 1 || day > 31) {
            setDateError("Bitte prüfe den Tag. Der Wert darf höchstens 31 sein.");
            updateCalculateButtonState();
            return;
          }

          focusInput(birthMonthInput);
        }

        updateCalculateButtonState();
      });

      birthDayInput?.addEventListener("blur", () => {
        normalizeDateFieldOnBlur(birthDayInput, 31);
        updateCalculateButtonState();
      });

      birthMonthInput?.addEventListener("input", () => {
        setDateError("");

        birthMonthInput.value = onlyDigits(birthMonthInput.value).slice(0, 2);

        const value = birthMonthInput.value;

        if (value.length === 2) {
          const month = Number(value);

          if (month >= 1 && month <= 12) {
            focusInput(birthYearInput);
            updateCalculateButtonState();
            return;
          }

          const firstDigit = Number(value[0]);
          const secondDigit = value[1];

          const shouldUseSmartSpillover =
            firstDigit >= 1 && firstDigit <= 9 && secondDigit === "2";

          if (shouldUseSmartSpillover) {
            birthMonthInput.value = pad2(firstDigit);

            if (birthYearInput) {
              birthYearInput.value = secondDigit;
              focusInput(birthYearInput);
            }

            updateCalculateButtonState();
            return;
          }

          setDateError("Bitte prüfe den Monat. Der Wert darf höchstens 12 sein.");
        }

        updateCalculateButtonState();
      });

      birthMonthInput?.addEventListener("blur", () => {
        normalizeDateFieldOnBlur(birthMonthInput, 12);
        updateCalculateButtonState();
      });

      birthYearInput?.addEventListener("input", () => {
        setDateError("");

        birthYearInput.value = onlyDigits(birthYearInput.value).slice(0, 4);

        if (birthYearInput.value.length === 4) {
          const { error } = buildBirthdateValueFromFields();

          if (error) {
            setDateError(error);
            updateCalculateButtonState();
            return;
          }

          setDateError("");
          focusInput(stateSelect);
        }

        updateCalculateButtonState();
      });

      birthYearInput?.addEventListener("blur", () => {
        updateCalculateButtonState();
      });

      stateSelect?.addEventListener("change", () => {
        updateCalculateButtonState();
      });

      calculateButton?.addEventListener("click", () => {
        const birthdateResult = buildBirthdateValueFromFields();

        if (birthdateResult.error) {
          setDateError(birthdateResult.error);

          renderResult({
            status: "missing_input",
            title: "Bitte Geburtsdatum prüfen",
            text: birthdateResult.error,
          });

          updateCalculateButtonState();
          return;
        }

        setDateError("");

        const result = calculateEnrollment(
          birthdateResult.value,
          stateSelect?.value
        );

        renderResult(result);
        updateCalculateButtonState();
      });

      updateCalculateButtonState();
    </script>
  </body>
</html>

