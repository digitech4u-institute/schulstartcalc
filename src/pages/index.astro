---
const pageTitle =
  "Einschulungsrechner Deutschland: Wann kommt mein Kind in die Schule?";

const pageDescription =
  "Berechne mit Geburtsdatum und Bundesland das voraussichtliche Einschulungsjahr deines Kindes. Inklusive Stichtag, Schuljahr und Orientierung je Bundesland.";

  const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
	  {
		"@type": "Question",
		"name": "Wann kommt mein Kind in die Schule?",
		"acceptedAnswer": {
		  "@type": "Answer",
		  "text": "Das hängt vom Geburtsdatum deines Kindes und vom Einschulungsstichtag deines Bundeslands ab. Der Einschulungsrechner zeigt dir eine erste Orientierung zum voraussichtlichen Schuljahr."
		}
	  },
	  {
		"@type": "Question",
		"name": "Wodurch unterscheidet sich der Einschulungsstichtag vom Einschulungstermin?",
		"acceptedAnswer": {
		  "@type": "Answer",
		  "text": "Der Einschulungsstichtag entscheidet, ob ein Kind in einem bestimmten Jahr schulpflichtig wird. Der Einschulungstermin ist der konkrete Tag, an dem das Kind tatsächlich eingeschult wird oder die Schule beginnt."
		}
	  },
	  {
		"@type": "Question",
		"name": "Sind die Einschulungsstichtage jedes Jahr gleich?",
		"acceptedAnswer": {
		  "@type": "Answer",
		  "text": "Die Stichtage rotieren nicht jährlich. Sie sind je Bundesland fest geregelt, können aber durch gesetzliche Änderungen angepasst werden. Der konkrete Einschulungstermin kann sich dagegen jedes Jahr ändern."
		}
	  },
	  {
		"@type": "Question",
		"name": "Was bedeutet Kann-Kind?",
		"acceptedAnswer": {
		  "@type": "Answer",
		  "text": "Ein Kann-Kind ist ein Kind, das den regulären Einschulungsstichtag noch nicht erreicht, aber unter bestimmten Voraussetzungen vorzeitig eingeschult werden kann."
		}
	  },
	  {
		"@type": "Question",
		"name": "Kann mein Kind früher eingeschult werden?",
		"acceptedAnswer": {
		  "@type": "Answer",
		  "text": "In vielen Bundesländern ist eine frühere Einschulung möglich, wenn das Kind die erforderliche Entwicklung mitbringt. Die Entscheidung trifft in der Regel die zuständige Schule oder Schulbehörde."
		}
	  },
	  {
		"@type": "Question",
		"name": "Kann mein Kind später eingeschult werden?",
		"acceptedAnswer": {
		  "@type": "Answer",
		  "text": "Eine spätere Einschulung oder Zurückstellung kann je nach Bundesland und individueller Situation möglich sein. Verbindliche Informationen erhältst du bei der zuständigen Schule oder Schulbehörde."
		}
	  },
	  {
		"@type": "Question",
		"name": "Sind die Regeln in allen Bundesländern gleich?",
		"acceptedAnswer": {
		  "@type": "Answer",
		  "text": "Nein. Die Einschulungsregeln unterscheiden sich je nach Bundesland. Deshalb berücksichtigt der Rechner das Bundesland, das du auswählst."
		}
	  },
	  {
		"@type": "Question",
		"name": "Ist das Ergebnis des Einschulungsrechners verbindlich?",
		"acceptedAnswer": {
		  "@type": "Answer",
		  "text": "Nein. Der Rechner dient der Orientierung. Verbindliche Auskünfte erhältst du bei der zuständigen Schule, beim Schulamt oder bei der Bildungsbehörde deines Bundeslands."
		}
	  }
	]
  };

const webApplicationSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Einschulungsrechner Deutschland",
  "description": pageDescription,
  "applicationCategory": "EducationalApplication",
  "operatingSystem": "All",
  "inLanguage": "de-DE",
  "isAccessibleForFree": true,
  "browserRequirements": "Requires JavaScript",
  "featureList": [
    "Berechnung des voraussichtlichen Einschulungsjahres",
    "Berücksichtigung des Bundeslands",
    "Anzeige des Einschulungsstichtags",
    "Einordnung möglicher Sonderfälle",
    "Berechnung direkt im Browser ohne Speicherung der Eingaben"
  ],
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
};
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/" />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
	<script type="application/ld+json" set:html={JSON.stringify(webApplicationSchema)}></script>
</head>

  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Einschulungsrechner Deutschland 🇩🇪</p>

        <h1>Wann kommt mein Kind in die Schule?</h1>

        <p class="lead">
          Gib Geburtsdatum und Bundesland ein – du erhältst sofort eine verständliche
          Orientierung zum voraussichtlichen Schuljahr, zum Stichtag und zu möglichen
          Grenzfällen.
        </p>

        <div class="calculator-card">
          <form
            class="calculator-form"
            autocomplete="off"
            data-lpignore="true"
            data-1p-ignore="true"
            data-form-type="other"
          >
            <div class="form-group form-group-centered">
              <span class="form-label form-label-large">Geburtsdatum des Kindes</span>

              <div class="date-input-group" aria-label="Geburtsdatum des Kindes">
                <div class="date-field">
                  <input
                    id="calcDay"
                    name="calc_part_a"
                    type="tel"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    maxlength="2"
                    placeholder="TT"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="off"
                    spellcheck="false"
                    data-lpignore="true"
                    data-1p-ignore="true"
                    data-form-type="other"
                    aria-label="Tag des Datums"
                  />
                  <span>Tag</span>
                </div>

                <div class="date-field">
                  <input
                    id="calcMonth"
                    name="calc_part_b"
                    type="tel"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    maxlength="2"
                    placeholder="MM"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="off"
                    spellcheck="false"
                    data-lpignore="true"
                    data-1p-ignore="true"
                    data-form-type="other"
                    aria-label="Monat des Datums"
                  />
                  <span>Monat</span>
                </div>

                <div class="date-field date-field-year">
                  <input
                    id="calcYear"
                    name="calc_part_c"
                    type="tel"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    maxlength="4"
                    placeholder="JJJJ"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="off"
                    spellcheck="false"
                    data-lpignore="true"
                    data-1p-ignore="true"
                    data-form-type="other"
                    aria-label="Jahr des Datums"
                  />
                  <span>Jahr</span>
                </div>
              </div>

              <p id="dateError" class="field-error" aria-live="polite"></p>
            </div>

            <label class="state-label">
              <span class="form-label form-label-large">Bundesland</span>
              <select id="state" name="state">
                <option value="">Bitte auswählen</option>
                <option value="baden-wuerttemberg">Baden-Württemberg</option>
                <option value="bayern">Bayern</option>
                <option value="berlin">Berlin</option>
                <option value="brandenburg">Brandenburg</option>
                <option value="bremen">Bremen</option>
                <option value="hamburg">Hamburg</option>
                <option value="hessen">Hessen</option>
                <option value="mecklenburg-vorpommern">Mecklenburg-Vorpommern</option>
                <option value="niedersachsen">Niedersachsen</option>
                <option value="nordrhein-westfalen">Nordrhein-Westfalen</option>
                <option value="rheinland-pfalz">Rheinland-Pfalz</option>
                <option value="saarland">Saarland</option>
                <option value="sachsen">Sachsen</option>
                <option value="sachsen-anhalt">Sachsen-Anhalt</option>
                <option value="schleswig-holstein">Schleswig-Holstein</option>
                <option value="thueringen">Thüringen</option>
              </select>
            </label>

            <div class="form-actions">
              <button id="calculateButton" type="button">Einschulung berechnen</button>

              <p class="privacy-note">
                🔒 Deine Eingaben werden nicht gespeichert.<br />
                Die Berechnung erfolgt direkt in deinem Browser.
              </p>
            </div>
          </form>

          <div id="resultBox" class="result-box result-box-empty">
			<p class="result-kicker">Dein Ergebnis</p>
		  
			<div class="result-empty-content">
			  <h2 class="result-heading">erscheint hier</h2>
			  <p class="result-body">
				Sobald du Geburtsdatum und Bundesland ausgewählt hast, zeigen wir dir eine
				erste Orientierung zum voraussichtlichen Schulstart.
			  </p>
			</div>
		  </div>
		</div>
      </section>

	  <section class="content-section">
		<div class="content-intro">
		  <p class="content-kicker">Einfach erklärt</p>
	  
		  <h2>Wie funktioniert der Einschulungsrechner?</h2>
	  
		  <p>
			Der Einschulungsrechner nutzt das Geburtsdatum deines Kindes und das
			ausgewählte Bundesland. Daraus wird berechnet, in welchem Schuljahr dein
			Kind voraussichtlich eingeschult wird und welcher Stichtag dabei eine
			Rolle spielt.
		  </p>
		</div>
	  
		<div class="content-grid">
		  <article class="info-card">
			<h3>1. Geburtsdatum eingeben</h3>
			<p>
			  Gib Tag, Monat und Jahr der Geburt deines Kindes ein. Der Rechner
			  ermittelt daraus, wann dein Kind sechs Jahre alt wird.
			</p>
		  </article>
	  
		  <article class="info-card">
			<h3>2. Bundesland auswählen</h3>
			<p>
			  Die Einschulungsregeln unterscheiden sich je nach Bundesland. Deshalb
			  berücksichtigt der Rechner den jeweiligen Einschulungsstichtag.
			</p>
		  </article>
	  
		  <article class="info-card">
			<h3>3. Ergebnis erhalten</h3>
			<p>
			  Du erhältst eine erste Orientierung zum voraussichtlichen Schuljahr,
			  zum Stichtag, zum Status und zum nächsten sinnvollen Schritt.
			</p>
		  </article>
		</div>
	  
		<div class="content-block">
		  <h2>Was ist ein Einschulungsstichtag?</h2>
	  
		  <p>
			Der Einschulungsstichtag ist das Datum, bis zu dem ein Kind in einem
			Bundesland sechs Jahre alt sein muss, um regulär schulpflichtig zu werden.
			Liegt der sechste Geburtstag nach diesem Datum, beginnt die Schulpflicht
			meist erst im folgenden Schuljahr.
		  </p>
		</div>
	  
		<div class="content-block">
			<p class="content-kicker">Übersicht</p>
		  
			<h2>Einschulungsstichtage nach Bundesland</h2>
		  
			<p>
			  Die folgende Übersicht zeigt die im Rechner berücksichtigten Stichtage und
			  Besonderheiten der einzelnen Bundesländer.
			</p>
		  
			<div class="table-wrap" aria-label="Einschulungsstichtage nach Bundesland">
			  <table class="state-table">
				<thead>
				  <tr>
					<th>Bundesland</th>
					<th>Stichtag</th>
					<th>Besonderheit</th>
				  </tr>
				</thead>
		  
				<tbody>
				  <tr>
					<td>Baden-Württemberg</td>
					<td>30. Juni</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Bayern</td>
					<td>30. September</td>
					<td>Einschulungskorridor vom 1. Juli bis 30. September</td>
				  </tr>
				  <tr>
					<td>Berlin</td>
					<td>30. September</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Brandenburg</td>
					<td>30. September</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Bremen</td>
					<td>30. Juni</td>
					<td>Karenzzeit vom 1. Juli bis 30. September</td>
				  </tr>
				  <tr>
					<td>Hamburg</td>
					<td>1. Juli</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Hessen</td>
					<td>30. Juni</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Mecklenburg-Vorpommern</td>
					<td>30. Juni</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Niedersachsen</td>
					<td>30. September</td>
					<td>Flexibler Einschulungszeitraum vom 1. Juli bis 30. September</td>
				  </tr>
				  <tr>
					<td>Nordrhein-Westfalen</td>
					<td>30. September</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Rheinland-Pfalz</td>
					<td>31. August</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Saarland</td>
					<td>30. Juni</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Sachsen</td>
					<td>30. Juni</td>
					<td>Anmeldung bis 30. September möglich</td>
				  </tr>
				  <tr>
					<td>Sachsen-Anhalt</td>
					<td>30. Juni</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Schleswig-Holstein</td>
					<td>30. Juni</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				  <tr>
					<td>Thüringen</td>
					<td>1. August</td>
					<td>Regulärer Stichtag</td>
				  </tr>
				</tbody>
			  </table>
			</div>
		  </div>
		  <div class="content-block">
			<p class="content-kicker">Begriffe einfach erklärt</p>
		  
			<h2>Wichtige Begriffe rund um die Einschulung</h2>
		  
			<p>
			  Rund um die Einschulung tauchen viele Begriffe auf, die leicht verwechselt
			  werden. Hier findest du die wichtigsten Erklärungen kurz und verständlich.
			</p>
		  
			<div class="terms-grid">
			  <article class="term-card">
				<h3>Muss-Kind</h3>
				<p>
				  Ein Muss-Kind ist ein Kind, das den Einschulungsstichtag erreicht und
				  dadurch regulär schulpflichtig wird.
				</p>
			  </article>
		  
			  <article class="term-card">
				<h3>Kann-Kind</h3>
				<p>
				  Ein Kann-Kind ist ein Kind, das noch nicht regulär schulpflichtig ist,
				  aber unter bestimmten Voraussetzungen vorzeitig eingeschult werden kann.
				</p>
			  </article>
		  
			  <article class="term-card">
				<h3>Korridorkind</h3>
				<p>
				  Ein Korridorkind ist ein Kind, das in Bayern zwischen dem 1. Juli und
				  dem 30. September sechs Jahre alt wird und damit in den
				  Einschulungskorridor fällt.
				</p>
			  </article>
		  
			  <article class="term-card">
				<h3>Karenzzeit</h3>
				<p>
				  Die Karenzzeit bezeichnet in Bremen den Zeitraum vom 1. Juli bis zum
				  30. September, in dem Eltern unter bestimmten Voraussetzungen über den
				  Einschulungszeitpunkt mitentscheiden können.
				</p>
			  </article>
		  
			  <article class="term-card">
				<h3>Flexibler Einschulungszeitraum</h3>
				<p>
				  In Niedersachsen gibt es für Kinder, die zwischen dem 1. Juli und dem
				  30. September sechs Jahre alt werden, eine besondere Flexibilisierung
				  beim Schulstart.
				</p>
			  </article>
		  
			  <article class="term-card">
				<h3>Stichtag oder Einschulungstermin?</h3>
				<p>
				  Der Einschulungsstichtag entscheidet, ob ein Kind schulpflichtig wird.
				  Der Einschulungstermin ist der konkrete Tag, an dem das Kind tatsächlich
				  eingeschult wird.
				</p>
			  </article>
			</div>
		  </div>

		  <div class="content-block faq-block">
			<p class="content-kicker">Häufige Fragen</p>
		  
			<h2>FAQ zur Einschulung</h2>
		  
			<p>
			  Hier findest du Antworten auf häufige Fragen rund um Einschulungsstichtag,
			  Schuljahr, Kann-Kind, spätere Einschulung und die Aussagekraft des Rechners.
			</p>
		  
			<div class="faq-list">
			  <article class="faq-item">
				<h3>Wann kommt mein Kind in die Schule?</h3>
				<p>
				  Das hängt vom Geburtsdatum deines Kindes und vom Einschulungsstichtag
				  deines Bundeslands ab. Der Rechner zeigt dir eine erste Orientierung zum
				  voraussichtlichen Schuljahr.
				</p>
			  </article>
		  
			  <article class="faq-item">
				<h3>Wodurch unterscheidet sich der Einschulungsstichtag vom Einschulungstermin?</h3>
				<p>
				  Der Einschulungsstichtag entscheidet, ob ein Kind in einem bestimmten Jahr
				  schulpflichtig wird. Der Einschulungstermin ist der konkrete Tag, an dem
				  das Kind tatsächlich eingeschult wird oder die Schule beginnt.
				</p>
			  </article>
		  
			  <article class="faq-item">
				<h3>Sind die Einschulungsstichtage jedes Jahr gleich?</h3>
				<p>
				  Die Stichtage rotieren nicht jährlich. Sie sind je Bundesland fest geregelt,
				  können aber durch gesetzliche Änderungen angepasst werden. Der konkrete
				  Einschulungstermin kann sich dagegen jedes Jahr ändern.
				</p>
			  </article>
		  
			  <article class="faq-item">
				<h3>Was bedeutet Kann-Kind?</h3>
				<p>
				  Ein Kann-Kind ist ein Kind, das den regulären Einschulungsstichtag noch
				  nicht erreicht, aber unter bestimmten Voraussetzungen vorzeitig eingeschult
				  werden kann.
				</p>
			  </article>
		  
			  <article class="faq-item">
				<h3>Kann mein Kind früher eingeschult werden?</h3>
				<p>
				  In vielen Bundesländern ist eine frühere Einschulung möglich, wenn das Kind
				  die erforderliche Entwicklung mitbringt. Die Entscheidung trifft in der
				  Regel die zuständige Schule oder Schulbehörde.
				</p>
			  </article>
		  
			  <article class="faq-item">
				<h3>Kann mein Kind später eingeschult werden?</h3>
				<p>
				  Eine spätere Einschulung oder Zurückstellung kann je nach Bundesland und
				  individueller Situation möglich sein. Verbindliche Informationen erhältst
				  du bei der zuständigen Schule oder Schulbehörde.
				</p>
			  </article>
		  
			  <article class="faq-item">
				<h3>Sind die Regeln in allen Bundesländern gleich?</h3>
				<p>
				  Nein. Die Einschulungsregeln unterscheiden sich je nach Bundesland. Deshalb
				  berücksichtigt der Rechner das Bundesland, das du auswählst.
				</p>
			  </article>
		  
			  <article class="faq-item">
				<h3>Ist das Ergebnis des Einschulungsrechners verbindlich?</h3>
				<p>
				  Nein. Der Rechner dient der Orientierung. Verbindliche Auskünfte erhältst
				  du bei der zuständigen Schule, beim Schulamt oder bei der Bildungsbehörde
				  deines Bundeslands.
				</p>
			  </article>
			</div>
		  </div>

		<div class="content-block sources-block">
		  <p class="content-kicker">Quellen & Aktualität</p>

		  <h2>Quellen und Stand der Informationen</h2>

		  <p>
			Die Berechnung basiert auf öffentlich zugänglichen Informationen zu
			Einschulungsstichtagen und Schulpflichtregelungen in den deutschen
			Bundesländern. Da sich gesetzliche Regelungen ändern können, solltest du
			das Ergebnis immer zusätzlich bei der zuständigen Schule, dem Schulamt oder
			der Bildungsbehörde deines Bundeslands prüfen.
		  </p>

		  <p class="sources-date">Stand der Informationen: Mai 2026</p>

		  <ul class="sources-list">
			<li>
			  <a href="https://www.test.de/Special-Einschulung-Was-wichtig-ist-fuer-einen-guten-Start-1243089-1243091/" target="_blank" rel="noopener noreferrer">
				Stiftung Warentest: Einschulung, Schulpflicht und Stichtagsregelung
			  </a>
			</li>
			<li>
			  <a href="https://www.kmk.org/fileadmin/Dateien/pdf/PresseUndAktuelles/Beschluesse_Veroeffentlichungen/schulanf.pdf" target="_blank" rel="noopener noreferrer">
				Kultusministerkonferenz: Empfehlungen zum Schulanfang
			  </a>
			</li>
			<li>
			  <a href="https://km.baden-wuerttemberg.de/de/schule/grundschule/einschulungsstichtag" target="_blank" rel="noopener noreferrer">
				Ministerium für Kultus, Jugend und Sport Baden-Württemberg: Einschulungsstichtag
			  </a>
			</li>
			<li>
			  <a href="https://www.mk.niedersachsen.de/startseite/schule/unsere_schulen/allgemein_bildende_schulen/grundschule/vor_der_einschulung/vor-der-schule-149343.html" target="_blank" rel="noopener noreferrer">
				Niedersächsisches Kultusministerium: Vor der Einschulung
			  </a>
			</li>
		  </ul>
		</div>

		<div class="content-block content-note">
		  <h2>Wichtig: Orientierung statt verbindliche Auskunft</h2>
	  
		  <p>
			Dieser Rechner dient als verständliche Orientierung für Eltern. Verbindliche
			Informationen erhältst du bei der zuständigen Schule, beim Schulamt oder
			bei der Bildungsbehörde deines Bundeslands.
		  </p>
		</div>
	  </section>

	  <footer class="site-footer">
		<a href="/impressum/">Impressum</a>
		<span aria-hidden="true">·</span>
		<a href="/datenschutz/">Datenschutz</a>
	  </footer>
