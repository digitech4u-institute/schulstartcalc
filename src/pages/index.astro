    <script define:vars={{ calculatorStateRules, calculatorEnrollmentDatesBySchoolYear, calculatorFactSheetFacts, currentSchoolYear }}>
      const stateRules = calculatorStateRules;
      const stateEnrollmentDatesBySchoolYear = calculatorEnrollmentDatesBySchoolYear;
      const stateFactSheetFacts = calculatorFactSheetFacts;
      const referenceSchoolYear = currentSchoolYear;

      function parseDateInput(value) {
        const [year, month, day] = value.split("-").map(Number);
        return new Date(year, month - 1, day);
      }

      function createDateFromMMDD(year, mmdd) {
        const [month, day] = mmdd.split("-").map(Number);
        return new Date(year, month - 1, day);
      }

      function formatDate(date) {
        return new Intl.DateTimeFormat("de-DE", {
          day: "2-digit",
          month: "long",
          year: "numeric",
        }).format(date);
      }

      function calculateEnrollment(birthdateValue, stateKey) {
        const stateRule = stateRules[stateKey];

        if (!birthdateValue || !stateRule) {
          return {
            status: "missing_input",
            title: "Bitte Geburtsdatum und Bundesland auswählen",
            text: "Sobald beide Angaben vorhanden sind, berechnen wir das voraussichtliche Einschulungsjahr.",
          };
        }

        const birthDate = parseDateInput(birthdateValue);
        const sixthBirthdayYear = birthDate.getFullYear() + 6;

        const sixthBirthday = new Date(
          sixthBirthdayYear,
          birthDate.getMonth(),
          birthDate.getDate()
        );

        const cutoffDate = createDateFromMMDD(sixthBirthdayYear, stateRule.cutoff);

        if (stateRule.type === "brandenburg_optional") {
          const birthMonth = birthDate.getMonth() + 1;

          if (birthMonth <= 7) {
            return buildSpecialResult(
              stateRule,
              sixthBirthdayYear,
              cutoffDate,
              sixthBirthday
            );
          }
        }

        if (stateRule.type === "berlin_optional") {
          const birthMonth = birthDate.getMonth() + 1;

          if (birthMonth >= 10) {
            return buildSpecialResult(
              stateRule,
              sixthBirthdayYear,
              createDateFromMMDD(sixthBirthdayYear, stateRule.cutoff),
              sixthBirthday
            );
          }

          if (birthMonth <= 3) {
            const optionalEnrollmentYear = sixthBirthdayYear - 1;

            return buildSpecialResult(
              stateRule,
              optionalEnrollmentYear,
              createDateFromMMDD(optionalEnrollmentYear, stateRule.cutoff),
              sixthBirthday
            );
          }
        }

        if (stateRule.specialWindow) {
          const specialFrom = createDateFromMMDD(
            sixthBirthdayYear,
            stateRule.specialWindow.from
          );

          const specialTo = createDateFromMMDD(
            sixthBirthdayYear,
            stateRule.specialWindow.to
          );

          if (sixthBirthday >= specialFrom && sixthBirthday <= specialTo) {
            return buildSpecialResult(
              stateRule,
              sixthBirthdayYear,
              cutoffDate,
              sixthBirthday
            );
          }
        }

        if (sixthBirthday <= cutoffDate) {
          return {
            status: "regular",
            title: `Dein Kind wird voraussichtlich im Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1} eingeschult.`,
            shortText: `In ${stateRule.name} gilt der ${stateRule.label}. Da dein Kind bis zu diesem Stichtag sechs Jahre alt wird, fällt es voraussichtlich in das Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1}.`,
            whyText: `In ${stateRule.name} gilt der ${stateRule.label}. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt und erreicht damit den Stichtag.`,
            nextStep: `Informiere dich rechtzeitig bei der zuständigen Grundschule über Anmeldung, Fristen und den konkreten Einschulungstermin.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${sixthBirthdayYear}/${sixthBirthdayYear + 1}`,
              statusLabel: "Regulär schulpflichtig",
            },
          };
        }

        const nextEnrollmentYear = sixthBirthdayYear + 1;

        if (stateRule.type === "standard_with_optional") {
          return {
            status: "optional",
            title: `Dein Kind ist in ${stateRule.name} ein Kann-Kind.`,
            shortText: `In ${stateRule.name} gilt der ${stateRule.label}. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt und erreicht den Stichtag für das Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1} knapp nicht. Eine vorzeitige Einschulung kann auf Antrag geprüft werden. Regulär schulpflichtig wird dein Kind voraussichtlich im Schuljahr ${nextEnrollmentYear}/${nextEnrollmentYear + 1}.`,
            whyText: `Dein Kind wird nach dem Stichtag sechs Jahre alt. Deshalb ist es für das Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1} nicht automatisch regulär schulpflichtig, kann aber als Kann-Kind beziehungsweise auf Antrag vorzeitig eingeschult werden.`,
            nextStep: `Wenn du eine Einschulung schon im Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1} prüfen möchtest, informiere dich frühzeitig bei der zuständigen Grundschule über Antrag, Voraussetzungen und Fristen.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${sixthBirthdayYear}/${sixthBirthdayYear + 1}`,
              regularSchoolYear: `${nextEnrollmentYear}/${nextEnrollmentYear + 1}`,
              statusLabel: "Kann-Kind auf Antrag",
            },
          };
        }

        return {
          status: "next_year",
          title: `Dein Kind wird voraussichtlich im Schuljahr ${nextEnrollmentYear}/${nextEnrollmentYear + 1} eingeschult.`,
          shortText: `In ${stateRule.name} gilt der ${stateRule.label}. Da dein Kind erst nach diesem Stichtag sechs Jahre alt wird, fällt es voraussichtlich in das Schuljahr ${nextEnrollmentYear}/${nextEnrollmentYear + 1}.`,
          whyText: `In ${stateRule.name} gilt der ${stateRule.label}. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt und erreicht den Stichtag in diesem Jahr voraussichtlich nicht.`,
          nextStep: `Wenn du über eine frühere Einschulung nachdenkst, informiere dich bei der zuständigen Grundschule über die Voraussetzungen.`,
          meta: {
            state: stateRule.name,
            cutoff: formatDate(createDateFromMMDD(nextEnrollmentYear, stateRule.cutoff)),
            schoolYear: `${nextEnrollmentYear}/${nextEnrollmentYear + 1}`,
            statusLabel: "Regulär schulpflichtig",
          },
        };
      }

      function buildSpecialResult(stateRule, enrollmentYear, cutoffDate, sixthBirthday) {
        if (stateRule.type === "corridor") {
          return {
            status: "corridor",
            title: `Dein Kind liegt im Einschulungskorridor.`,
            shortText: `Dein Kind fällt in Bayern in den Einschulungskorridor, weil es zwischen dem 1. Juli und dem 30. September sechs Jahre alt wird.`,
            whyText: `In Bayern fallen Kinder, die zwischen dem 1. Juli und dem 30. September sechs Jahre alt werden, in den Einschulungskorridor. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt.`,
            nextStep: `Prüfe die Fristen bei der zuständigen Grundschule. Unter bestimmten Voraussetzungen kann eine spätere Einschulung geklärt werden.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${enrollmentYear}/${enrollmentYear + 1}`,
              statusLabel: "Einschulungskorridor",
            },
          };
        }

        if (stateRule.type === "karenzzeit") {
          return {
            status: "karenzzeit",
            title: `Dein Kind fällt in die Karenzzeit.`,
            shortText: `In Bremen gilt der 30. Juni als regulärer Stichtag. Da dein Kind zwischen dem 1. Juli und dem 30. September sechs Jahre alt wird, fällt es in die Karenzzeit.`,
            whyText: `Kinder, die zwischen dem 1. Juli und dem 30. September sechs Jahre alt werden, gelten in Bremen als Karenzzeitkinder. Dein Kind wird am ${formatDate(sixthBirthday)} sechs Jahre alt.`,
            nextStep: `Prüfe mit der zuständigen Grundschule, ob die Einschulung im aktuellen oder im nächsten Jahr sinnvoll ist.`,
            meta: {
              state: stateRule.name,
              cutoff: formatDate(cutoffDate),
              schoolYear: `${enrollmentYear}/${enrollmentYear + 1}`,
              statusLabel: "Karenzzeit",
            },
          };
        }

        if (stateRule.type === "flexible_window") {
          return {
            status: "flexible",
