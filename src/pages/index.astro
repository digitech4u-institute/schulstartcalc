---
import BaseLayout from "../layouts/BaseLayout.astro";
import { germanStates } from "../data/states";
import { enrollmentRules } from "../data/enrollmentRules";
import { enrollmentDatesBySchoolYear } from "../data/enrollmentDatesBySchoolYear";
import { stateFactSheets } from "../data/stateFactSheet";

const pageTitle =
  "Einschulungsrechner Deutschland 2026/2027 – Stichtag & Schuljahr berechnen";

const pageDescription =
  "Berechne das voraussichtliche Schuljahr deines Kindes nach Bundesland. Einschulungsrechner für Deutschland mit Stichtag, Schulpflicht, Kann-Kind-Regeln und Bundesländer-Links.";

const canonical = "https://www.einschulungsrechner.de/";

const currentSchoolYear = "2026/2027";
const currentEnrollmentDates = enrollmentDatesBySchoolYear[currentSchoolYear];

const cutoffOverrides: Record<string, { cutoff: string; cutoffLabel: string }> = {
  hamburg: {
    cutoff: "07-01",
    cutoffLabel: "1. Juli",
  },
  hessen: {
    cutoff: "07-01",
    cutoffLabel: "1. Juli",
  },
};

const summerHolidayPeriods2026: Record<string, { from: string; to: string }> = {
  "baden-wuerttemberg": {
    from: "Donnerstag, 30. Juli",
    to: "Samstag, 12. September",
  },
  bayern: {
    from: "Montag, 3. August",
    to: "Montag, 14. September",
  },
  berlin: {
    from: "Donnerstag, 9. Juli",
    to: "Samstag, 22. August",
  },
  brandenburg: {
    from: "Donnerstag, 9. Juli",
    to: "Samstag, 22. August",
  },
  bremen: {
    from: "Donnerstag, 2. Juli",
    to: "Mittwoch, 12. August",
  },
  hamburg: {
    from: "Donnerstag, 9. Juli",
    to: "Mittwoch, 19. August",
  },
  hessen: {
    from: "Montag, 29. Juni",
    to: "Freitag, 7. August",
  },
  "mecklenburg-vorpommern": {
    from: "Montag, 13. Juli",
    to: "Samstag, 22. August",
  },
  niedersachsen: {
    from: "Donnerstag, 2. Juli",
    to: "Mittwoch, 12. August",
  },
  "nordrhein-westfalen": {
    from: "Montag, 20. Juli",
    to: "Dienstag, 1. September",
  },
  "rheinland-pfalz": {
    from: "Montag, 29. Juni",
    to: "Freitag, 7. August",
  },
  saarland: {
    from: "Montag, 29. Juni",
    to: "Freitag, 7. August",
  },
  sachsen: {
    from: "Samstag, 4. Juli",
    to: "Freitag, 14. August",
  },
  "sachsen-anhalt": {
    from: "Samstag, 4. Juli",
    to: "Freitag, 14. August",
  },
  "schleswig-holstein": {
    from: "Samstag, 4. Juli",
    to: "Samstag, 15. August",
  },
  thueringen: {
    from: "Samstag, 4. Juli",
    to: "Freitag, 14. August",
  },
};

const stateOverviewRows = germanStates.map((state) => {
  const rule = enrollmentRules[state.slug];
  const cutoffOverride = cutoffOverrides[state.slug];
  const dates = currentEnrollmentDates[state.slug];

  return {
    slug: state.slug,
    name: state.name,
    url: state.url,
    summerHolidays: summerHolidayPeriods2026[state.slug],
    enrollment: dates.enrollment,
    enrollmentQualifier: dates.enrollmentQualifier,
    firstSchoolDay: dates.firstSchoolDay,
    cutoffLabel:
      state.slug === "brandenburg"
        ? `${rule.cutoffLabel} *`
        : cutoffOverride?.cutoffLabel ?? rule.cutoffLabel,
    specialRuleLabel: rule.specialRuleLabel,
    note: dates.note,
  };
});

const calculatorStateRules = Object.fromEntries(
  germanStates.map((state) => {
    const rule = enrollmentRules[state.slug];
    const cutoffOverride = cutoffOverrides[state.slug];

    return [
      state.slug,
      {
        name: state.name,
        cutoff: cutoffOverride?.cutoff ?? rule.cutoff,
        type:
          rule.type === "optional" ? "standard_with_optional" : rule.type,
        specialWindow: rule.specialWindow,
        label: `Stichtag ${cutoffOverride?.cutoffLabel ?? rule.cutoffLabel}`,
      },
    ];
  }),
);

const calculatorEnrollmentDatesBySchoolYear = Object.fromEntries(
  Object.entries(enrollmentDatesBySchoolYear).map(([schoolYear, datesByState]) => [
    schoolYear,
    Object.fromEntries(
      germanStates.map((state) => {
        const dates = datesByState[state.slug];

        return [
          state.slug,
          {
            enrollment: dates.enrollment,
            enrollmentQualifier: dates.enrollmentQualifier,
            firstSchoolDay: dates.firstSchoolDay,
            note: dates.note,
            hasConfirmedDate: dates.hasConfirmedDate,
            sourceStatus: dates.sourceStatus,
          },
        ];
      }),
    ),
  ]),
);

const calculatorFactSheetFacts = {
  saarland: {
    "2027/2028": {
      enrollmentLabel:
        stateFactSheets.saarland.schoolYears["2027/2028"].enrollmentLabel,
      firstSchoolDayLabel:
        stateFactSheets.saarland.schoolYears["2027/2028"].firstSchoolDayLabel,
      summerHolidays:
        stateFactSheets.saarland.schoolYears["2027/2028"].summerHolidays,
      note: stateFactSheets.saarland.schoolYears["2027/2028"].note,
      registration:
        stateFactSheets.saarland.schoolYears["2027/2028"].registration,
    },
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wann kommt mein Kind in die Schule?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Das hängt von Geburtsdatum und Bundesland ab. Wird dein Kind bis zum Einschulungsstichtag deines Bundeslands sechs Jahre alt, kommt es in diesem Schuljahr in die Schule. Der Rechner zeigt dir das voraussichtliche Ergebnis sofort."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist der Unterschied zwischen Stichtag und Einschulungstermin?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Der Stichtag entscheidet, ob dein Kind in diesem Jahr schulpflichtig wird. Das ist ein gesetzlich festgelegtes Datum. Der Einschulungstermin ist der tatsächliche erste Schultag – oft ein Samstag kurz nach den Sommerferien. Die beiden Daten liegen meist Wochen auseinander."
      }
    },
    {
      "@type": "Question",
      "name": "Was bedeutet Kann-Kind?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dein Kind hat den Stichtag noch nicht erreicht, kann aber auf deinen Antrag früher eingeschult werden. Die Schule prüft die Schulreife deines Kindes und entscheidet dann. Den Antrag stellst du meist bis Februar des Jahres vor der gewünschten Einschulung."
      }
    },
    {
      "@type": "Question",
      "name": "Kann mein Kind später eingeschult werden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja. Das nennt sich Zurückstellung und ist in allen Bundesländern möglich. Du beantragst sie bei der zuständigen Grundschule, wenn du oder die Schule dein Kind noch nicht schulreif sehen. Wichtig ist, die Fristen frühzeitig zu prüfen."
      }
    },
    {
      "@type": "Question",
      "name": "Ist das Ergebnis des Rechners verbindlich?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. Der Rechner zeigt dir eine Orientierung. Verbindliche Auskunft zu Terminen, Anmeldung und Fristen bekommst du bei der zuständigen Grundschule oder dem Schulamt deines Wohnorts."
      }
    },
    {
      "@type": "Question",
      "name": "Was tun, wenn mein Kind noch nicht schulreif wirkt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sprich das frühzeitig mit der Kindergartenleitung und der Grundschule an. Viele Schulen bieten vor der Einschulung ein Beratungsgespräch an. Du kannst auch eine Zurückstellung beantragen – aber nur, solange die Frist noch nicht abgelaufen ist."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist eine Schuleingangsuntersuchung?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Eine ärztliche Untersuchung, die in den meisten Bundesländern vor der Einschulung verpflichtend ist. Das Gesundheitsamt lädt euch automatisch ein. Geprüft werden Sehen, Hören, Sprache und motorische Entwicklung deines Kindes."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist der Unterschied zwischen Schulanmeldung und Einschulung?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Schulanmeldung ist der formelle Schritt vorab – meist zwischen Oktober und Februar. Die Einschulung selbst ist der erste Schultag, oft mit einer kleinen Feier in der Schule. Ohne Anmeldung gibt es keine Einschulung."
      }
    }
  ]
};

const webApplicationSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Einschulungsrechner Deutschland",
  "description": pageDescription,
  "applicationCategory": "EducationalApplication",
  "operatingSystem": "All",
  "inLanguage": "de-DE",
  "isAccessibleForFree": true,
  "browserRequirements": "Requires JavaScript",
  "featureList": [
    "Berechnung des voraussichtlichen Einschulungsjahres",
    "Berücksichtigung des Bundeslands",
    "Anzeige des Einschulungsstichtags",
    "Einordnung möglicher Sonderfälle",
    "Berechnung direkt im Browser ohne Speicherung der Eingaben"
  ],
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={[faqSchema, webApplicationSchema]}
>
  <main class="page">
      <section class="hero">
        <p class="eyebrow">Einschulungsrechner Deutschland 🇩🇪</p>

        <h1 class="hero-title">
          <span>Wann kommt mein Kind in die Schule?</span>
          <span class="hero-title-subline">Einschulungsrechner für alle 16 Bundesländer</span>
        </h1>

        <p class="lead">
          Gib Geburtsdatum und Bundesland ein – du siehst sofort,
          wann dein Kind voraussichtlich in die Schule kommt.
        </p>

        <p class="lead">
          In Deutschland wird ein Kind schulpflichtig, wenn es bis zum
          Einschulungsstichtag seines Bundeslands sechs Jahre alt wird.
          Der Stichtag ist je nach Bundesland unterschiedlich –
          er reicht von Ende Juni bis Ende September.
        </p>

        <p class="lead">
          Das bedeutet: Dasselbe Geburtsdatum kann je nach Wohnort
          zu einem anderen Schuljahr führen. Für Kinder mit Geburtstag
          knapp am Stichtag gibt es außerdem besondere Regelungen –
          zum Beispiel die Möglichkeit einer früheren Einschulung.
        </p>

        <div id="einschulungsrechner" class="calculator-card">
          <form
            class="calculator-form"
            autocomplete="off"
            data-lpignore="true"
            data-1p-ignore="true"
            data-form-type="other"
          >
            <div class="form-group form-group-centered">
              <span class="form-label form-label-large">Geburtsdatum des Kindes</span>

              <div class="date-input-group" aria-label="Geburtsdatum des Kindes">
                <div class="date-field">
                  <input
                    id="calcDay"
                    name="calc_part_a"
                    type="tel"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    maxlength="2"
                    placeholder="TT"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="off"
                    spellcheck="false"
                    data-lpignore="true"
                    data-1p-ignore="true"
                    data-form-type="other"
                    aria-label="Tag des Datums"
                  />
                  <span>Tag</span>
                </div>

                <div class="date-field">
                  <input
                    id="calcMonth"
                    name="calc_part_b"
                    type="tel"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    maxlength="2"
                    placeholder="MM"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="off"
                    spellcheck="false"
                    data-lpignore="true"
                    data-1p-ignore="true"
                    data-form-type="other"
                    aria-label="Monat des Datums"
                  />
                  <span>Monat</span>
                </div>

                <div class="date-field date-field-year">
                  <input
                    id="calcYear"
                    name="calc_part_c"
                    type="tel"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    maxlength="4"
                    placeholder="JJJJ"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="off"
                    spellcheck="false"
                    data-lpignore="true"
                    data-1p-ignore="true"
                    data-form-type="other"
                    aria-label="Jahr des Datums"
                  />
                  <span>Jahr</span>
                </div>
              </div>

              <p id="dateError" class="field-error" aria-live="polite"></p>
            </div>

            <label class="state-label">
              <span class="form-label form-label-large">Bundesland</span>
              <select id="state" name="state">
                <option value="">Bitte auswählen</option>
                {germanStates.map((state) => (
                  <option value={state.slug}>{state.name}</option>
                ))}
              </select>
            </label>

            <div class="form-actions">
              <button id="calculateButton" type="button">Einschulung berechnen</button>

              <p class="privacy-note">
                🔒 Deine Eingaben werden nicht gespeichert.<br />
                Die Berechnung erfolgt direkt in deinem Browser.
              </p>
            </div>
          </form>

          <div id="resultBox" class="result-box result-box-empty">
			<p class="result-kicker">Dein Ergebnis</p>
		  
			<div class="result-empty-content">
			  <h2 class="result-heading">erscheint hier</h2>
			  <p class="result-body">
				Sobald du Geburtsdatum und Bundesland ausgewählt hast, zeigen wir dir eine
				erste Orientierung zum voraussichtlichen Schulstart.
			  </p>
			</div>
		  </div>
		</div>
      </section>

	  <section class="content-section">
		<div class="content-intro">
		  <p class="content-kicker">Einfach erklärt</p>
	  
		  <h2>Wie funktioniert der Einschulungsrechner?</h2>
	  
		  <p>
			Der Rechner prüft Geburtsdatum, Bundesland und Stichtag. So bekommst
			du eine schnelle Orientierung – ohne Speicherung deiner Eingaben.
		  </p>
		</div>

		<div class="content-grid">
		  <article class="info-card">
			<h3>Was der Rechner kann</h3>
			<p>
			  Er zeigt dir das voraussichtliche Schuljahr, den Stichtag und –
			  soweit hinterlegt – den nächsten Einschulungstermin.
			</p>
		  </article>
	  
		  <article class="info-card">
			<h3>Was der Rechner nicht kann</h3>
			<p>
			  Er ersetzt keine verbindliche Auskunft der Schule und bewertet
			  nicht, ob dein Kind schon schulreif ist.
			</p>
		  </article>
	  
		  <article class="info-card">
			<h3>Wie wir Daten prüfen</h3>
			<p>
			  Die Angaben basieren auf offiziellen Quellen der Bundesländer.
			  Details findest du auf den jeweiligen Bundeslandseiten.
			</p>
		  </article>
		</div>

		<div class="guide-teaser-grid" aria-label="Ratgeber und Checkliste zur Einschulung">
		  <article class="guide-teaser">
			<p class="content-kicker">Ratgeber</p>
			<h3 class="guide-teaser-title">Einschulung<br />einfach erklärt</h3>
			<p>
			  Du möchtest nicht nur das Schuljahr berechnen, sondern auch verstehen,
			  was Stichtag, Schulpflicht, Kann-Kind, Zurückstellung und Schulanmeldung
			  bedeuten? Unser Ratgeber führt dich Schritt für Schritt durch die wichtigsten Fragen.
			</p>
			<a class="guide-teaser-link" href="/einschulung/">Zum Einschulungs-Ratgeber</a>
		  </article>

		  <article class="guide-teaser guide-teaser-primary">
			<p class="content-kicker">Checkliste</p>
			<h3 class="guide-teaser-title">Schulstart<br />Schritt-für-Schritt<br />vorbereiten</h3>
			<p>
			  Schulranzen, Schultüte, Anmeldung und erste Vorbereitung – die Checkliste
			  hilft dir, an alles Wichtige rund um die Einschulung zu denken. Schritt
			  für Schritt, damit nichts Wichtiges vergessen wird.
			</p>
			<a class="guide-teaser-link" href="/einschulung-checkliste/">Zur Einschulungs-Checkliste</a>
		  </article>
		</div>

    <div class="content-block retrospective-block">
      <p class="content-kicker">Rückblick</p>

      <h2>Wann wurde ich eingeschult?</h2>

      <p>
        Du kannst den Rechner auch rückblickend nutzen. Gib dein Geburtsdatum
        und dein damaliges Bundesland ein. Das Ergebnis ist eine Orientierung,
        weil frühere Einschulung, Zurückstellung oder Umzug abweichen können.
      </p>

      <a class="retrospective-link" href="#einschulungsrechner">
        Rückblick berechnen
      </a>
    </div>
	  
		<div class="content-block">
		  <h2>Was ist ein Einschulungsstichtag?</h2>
	  
		  <p>
			Der Einschulungsstichtag entscheidet, ob dein Kind
			in diesem oder erst im nächsten Schuljahr eingeschult wird.
		  </p>

		  <p>
			Wird dein Kind bis zu diesem Datum sechs Jahre alt,
			ist es schulpflichtig. Ist der sechste Geburtstag danach,
			beginnt die Schule regulär erst ein Jahr später.
		  </p>

		  <p>
			Wichtig: Jedes Bundesland hat seinen eigenen Stichtag.
			Die meisten liegen am 30. September – Sachsen zum Beispiel
			schon am 30. Juni, Bayern hat ein eigenes Korridorsystem.
		  </p>

		  <p>
			Wenn du umziehst, lohnt sich daher ein kurzer Check:
			Der Stichtag am neuen Wohnort kann sich vom alten
			deutlich unterscheiden.
		  </p>
		</div>
	  
		<div class="content-block state-overview-block">
			<p class="content-kicker">Übersicht 2026</p>
		  
			<h2>Wann ist die Einschulung 2026? Alle Bundesländer im Überblick</h2>
		  
			<p>
			  Die Einschulung 2026 in Deutschland findet je nach Bundesland zu
			  unterschiedlichen Terminen statt. Entscheidend sind das Ende der
			  Sommerferien, der erste Schultag, der Einschulungstermin und der jeweilige
			  Stichtag. Die Tabelle zeigt dir alle 16 Bundesländer auf einen Blick.
			</p>

			<aside class="state-table-cta-card" aria-label="Einschulungsrechner nutzen">
			  <div>
			    <h3>Du möchtest es für dein Kind genau wissen?</h3>
			    <p>
			      Jede Familie startet mit einer anderen Situation: Geburtsdatum,
			      Bundesland und Stichtag entscheiden gemeinsam über das voraussichtliche
			      Schuljahr. Mit dem Einschulungsrechner bekommst du eine schnelle erste
			      Orientierung für dein Kind.
			    </p>
			  </div>

			  <a class="state-table-cta-button" href="#einschulungsrechner">
			    Zum Einschulungsrechner
			  </a>
			</aside>
		  
			<div class="table-wrap" aria-label="Einschulung 2026 und erster Schultag nach Bundesland">
			  <table class="state-table">
				<thead>
				  <tr>
					<th>Bundesland</th>
					<th>Sommerferien 2026</th>
					<th>Einschulung 2026</th>
					<th>1. Schultag 2026</th>
					<th>Stichtag</th>
					<th>Sonderregel</th>
					<th>Hinweis</th>
				  </tr>
				</thead>
		  
				<tbody>
				  {stateOverviewRows.map((row) => (
					<tr>
					  <td><a class="state-table-link" href={row.url}>{row.name}</a></td>
					  <td>
						<span class="table-date-range">
						  <span>{row.summerHolidays.from} –</span>
						  <span>{row.summerHolidays.to}</span>
						</span>
					  </td>
					  <td>
						{row.enrollment}
						{row.enrollmentQualifier && (
						  <span class="table-subnote">({row.enrollmentQualifier})</span>
						)}
					  </td>
					  <td>{row.firstSchoolDay}</td>
					  <td>{row.cutoffLabel}</td>
					  <td>{row.specialRuleLabel}</td>
					  <td>{row.note}</td>
					</tr>
				  ))}
				</tbody>
			  </table>
			</div>

			<div class="state-mobile-cards" aria-label="Einschulung 2026 nach Bundesland als Kartenansicht">
			  {stateOverviewRows.map((row) => (
				<details class="state-mobile-card state-mobile-accordion">
				  <summary class="state-mobile-summary">
				    <span>{row.name}</span>
				    <span class="state-mobile-toggle" aria-hidden="true">+</span>
				  </summary>

				  <dl class="state-mobile-facts">
					<div>
					  <dt>Sommerferien 2026</dt>
					  <dd>
						<span class="table-date-range">
						  <span>{row.summerHolidays.from} –</span>
						  <span>{row.summerHolidays.to}</span>
						</span>
					  </dd>
					</div>

					<div>
					  <dt>Einschulung 2026</dt>
					  <dd>
						{row.enrollment}
						{row.enrollmentQualifier && (
						  <span class="state-mobile-subnote">({row.enrollmentQualifier})</span>
						)}
					  </dd>
					</div>

					<div>
					  <dt>1. Schultag 2026</dt>
					  <dd>{row.firstSchoolDay}</dd>
					</div>

					<div>
					  <dt>Stichtag</dt>
					  <dd>{row.cutoffLabel}</dd>
					</div>

					<div>
					  <dt>Sonderregel</dt>
					  <dd>{row.specialRuleLabel}</dd>
					</div>

					<div>
					  <dt>Hinweis</dt>
					  <dd>{row.note}</dd>
					</div>
				  </dl>

				  <a class="state-mobile-detail-button" href={row.url}>
				    Einschulung in {row.name} →
				  </a>
				</details>
			  ))}
			</div>

			<p class="state-table-hint">
			  * Hinweis Sommerferien: Bei den Sommerferien ist jeweils der erste und letzte Ferientag angegeben.<br /><br />
			  * Hinweis Brandenburg: Stand Juni 2026 plant Brandenburg eine Verlegung des Stichtags auf den
			  30. Juni. Bis zur gesetzlichen Umsetzung gilt der 30. September. Alle
			  Termine dienen der Orientierung; verbindlich sind die Angaben der
			  zuständigen Schule oder Schulbehörde.
			</p>

			<div class="state-table-aftertext">
			  <p>
				In den meisten Bundesländern findet die Einschulung
				in der ersten Woche nach den Sommerferien statt.
			  </p>

			  <p>
				Kinder in Sachsen oder Thüringen starten damit oft
				mehrere Wochen früher als Kinder in Bayern oder
				Baden-Württemberg.
			  </p>

			  <p>
				Besonders bei Geburtstagen im Juli, August oder September
				lohnt sich ein genauer Blick – hier können wenige Tage
				Unterschied ein ganzes Schuljahr ausmachen.
			  </p>
			</div>
		  </div>

		  <div class="content-block checklist-mini-block">
			<p class="content-kicker">Nächster Schritt</p>
			<h2>Was braucht dein Kind jetzt konkret?</h2>
			<p>
			  Wenn du das voraussichtliche Schuljahr kennst, beginnt die praktische
			  Vorbereitung: Anmeldung, Schulranzen, Schultüte, Unterlagen und wichtige
			  Termine. Die Checkliste hilft dir, Schritt für Schritt den Überblick zu behalten.
			</p>
			<a class="checklist-mini-link" href="/einschulung-checkliste/">Zur Einschulungs-Checkliste</a>
		  </div>

		  <div class="content-block">
			<p class="content-kicker">Begriffe einfach erklärt</p>
		  
			<h2>Wichtige Begriffe rund um die Einschulung</h2>
		  
			<p>
			  Rund um die Einschulung tauchen viele Begriffe auf, die leicht verwechselt
			  werden. Hier findest du die wichtigsten Erklärungen kurz und verständlich.
			</p>
		  
			<div class="terms-grid">
			  <article class="term-card">
				<h3>Muss-Kind</h3>
				<p>
				  Dein Kind hat den Stichtag erreicht und wird
				  automatisch schulpflichtig. Die Einschulung ist
				  gesetzlich verpflichtend.
				</p>
				<p>
				  Möchtest du die Einschulung verschieben lassen,
				  musst du eine Zurückstellung bei der Schule beantragen.
				  Das ist möglich, aber nicht automatisch.
				</p>
			  </article>

			  <article class="term-card">
				<h3>Kann-Kind</h3>
				<p>
				  Dein Kind hat den Stichtag noch nicht erreicht,
				  könnte aber auf deinen Antrag hin früher eingeschult werden.
				</p>
				<p>
				  Die Schule prüft dann, ob dein Kind bereit ist –
				  sprachlich, körperlich und sozial. Die Entscheidung
				  liegt bei der Schule, nicht allein bei dir als Elternteil.
				</p>
			  </article>

			  <article class="term-card">
				<h3>Zurückstellung</h3>
				<p>
				  Dein Kind ist eigentlich schulpflichtig, wird aber
				  auf Antrag für ein weiteres Jahr zurückgestellt.
				</p>
				<p>
				  Das passiert, wenn die Schule oder die Eltern
				  die Schulreife noch nicht als gegeben sehen.
				  Sprich das Thema frühzeitig mit der Schule an –
				  Fristen gelten meist bis zum Frühjahr.
				</p>
			  </article>

			  <article class="term-card">
				<h3>Korridorkind</h3>
				<p>
				  Nur in Bayern: Kinder, die zwischen dem 1. Juli
				  und 30. September sechs werden, fallen in den
				  sogenannten Einschulungskorridor.
				</p>
				<p>
				  Sie sind nicht automatisch schulpflichtig, können aber
				  eingeschult werden. Eltern klären das gemeinsam mit
				  der Grundschule.
				</p>
			  </article>

			  <article class="term-card">
				<h3>Karenzzeit</h3>
				<p>
				  Nur in Bremen: Kinder mit Geburtstag zwischen
				  1. Juli und 30. September gelten als Karenzzeitkinder.
				</p>
				<p>
				  Eltern können hier unter bestimmten Voraussetzungen
				  mitentscheiden, ob ihr Kind dieses Jahr oder erst
				  nächstes Jahr eingeschult wird.
				</p>
			  </article>

			  <article class="term-card">
				<h3>Flexibler Einschulungszeitraum</h3>
				<p>
				  Nur in Niedersachsen: Kinder mit Geburtstag
				  zwischen 1. Juli und 30. September sind grundsätzlich
				  schulpflichtig – können aber unter Umständen
				  ein Jahr später starten.
				</p>
				<p>
				  Die Entscheidung triffst du in Absprache mit
				  der zuständigen Grundschule bis zum 1. Mai.
				</p>
			  </article>

			  <article class="term-card">
				<h3>Stichtag oder Einschulungstermin?</h3>
				<p>
				  Der <strong>Stichtag</strong> sagt: Wird dein Kind
				  in diesem Jahr schulpflichtig?
				</p>
				<p>
				  Der <strong>Einschulungstermin</strong> ist der
				  konkrete erste Schultag – meist ein Samstag
				  kurz nach den Sommerferien. Beides ist nicht dasselbe.
				</p>
			  </article>
			</div>
		  </div>

		  <div class="content-block faq-block">
			<p class="content-kicker">Häufige Fragen</p>
		  
			<h2>FAQ zur Einschulung</h2>
		  
			<p>
			  Hier findest du Antworten auf häufige Fragen rund um Einschulungsstichtag,
			  Schuljahr, Kann-Kind, spätere Einschulung und die Aussagekraft des Rechners.
			</p>
		  
      <div class="faq-list">
        <article class="faq-item">
          <h3>Wann kommt mein Kind in die Schule?</h3>
          <p>Das hängt von Geburtsdatum und Bundesland ab.</p>
          <p>
            Wird dein Kind bis zum Einschulungsstichtag
            deines Bundeslands sechs Jahre alt, kommt es
            in diesem Schuljahr in die Schule. Der Rechner
            oben zeigt dir das voraussichtliche Ergebnis sofort.
          </p>
        </article>

        <article class="faq-item">
          <h3>Was ist der Unterschied zwischen Stichtag und Einschulungstermin?</h3>
          <p>
            Der Stichtag entscheidet, ob dein Kind in diesem
            Jahr schulpflichtig wird. Das ist ein gesetzlich
            festgelegtes Datum.
          </p>
          <p>
            Der Einschulungstermin ist der tatsächliche erste
            Schultag – oft ein Samstag kurz nach den Sommerferien.
            Die beiden Daten liegen meist Wochen auseinander.
          </p>
        </article>

        <article class="faq-item">
          <h3>Was bedeutet Kann-Kind?</h3>
          <p>
            Dein Kind hat den Stichtag noch nicht erreicht,
            kann aber auf deinen Antrag früher eingeschult werden.
          </p>
          <p>
            Die Schule prüft die Schulreife deines Kindes und
            entscheidet dann. Den Antrag stellst du meist
            bis Februar des Jahres vor der gewünschten Einschulung.
          </p>
        </article>

        <article class="faq-item">
          <h3>Kann mein Kind später eingeschult werden?</h3>
          <p>
            Ja – das nennt sich Zurückstellung und ist in
            allen Bundesländern möglich.
          </p>
          <p>
            Du beantragst sie bei der zuständigen Grundschule,
            wenn du oder die Schule das Kind noch nicht schulreif sehen.
            Wichtig: Die Fristen liegen meist im Frühjahr.
            Sprich das Thema frühzeitig an.
          </p>
        </article>

        <article class="faq-item">
          <h3>Ist das Ergebnis des Rechners verbindlich?</h3>
          <p>Nein – der Rechner zeigt dir eine Orientierung.</p>
          <p>
            Verbindliche Auskunft zu Terminen, Anmeldung und
            Fristen bekommst du bei der zuständigen Grundschule
            oder dem Schulamt deines Wohnorts.
          </p>
        </article>

        <article class="faq-item">
          <h3>Was tun, wenn mein Kind noch nicht schulreif wirkt?</h3>
          <p>
            Sprich das frühzeitig mit der Kindergartenleitung
            und der Grundschule an.
          </p>
          <p>
            Viele Schulen bieten vor der Einschulung ein
            Beratungsgespräch an. Du kannst auch eine
            Zurückstellung beantragen – aber nur, solange
            die Frist noch nicht abgelaufen ist.
          </p>
        </article>

        <article class="faq-item">
          <h3>Was ist eine Schuleingangsuntersuchung?</h3>
          <p>
            Eine ärztliche Untersuchung, die in den meisten
            Bundesländern vor der Einschulung verpflichtend ist.
          </p>
          <p>
            Das Gesundheitsamt lädt euch automatisch ein.
            Geprüft werden Sehen, Hören, Sprache und
            motorische Entwicklung deines Kindes.
          </p>
        </article>

        <article class="faq-item">
          <h3>Was ist der Unterschied zwischen Schulanmeldung und Einschulung?</h3>
          <p>
            Die Schulanmeldung ist der formelle Schritt vorab –
            meist zwischen Oktober und Februar.
          </p>
          <p>
            Die Einschulung selbst ist der erste Schultag,
            oft mit einer kleinen Feier in der Schule.
            Ohne Anmeldung gibt es keine Einschulung.
          </p>
        </article>
      </div>
		  </div>

		<div class="content-block editorial-note-block">
		  <p class="content-kicker">Über diesen Rechner</p>

		  <h2>Wie wir arbeiten</h2>

		  <p>
			Einschulungsrechner.de ist ein ehrenamtliches Informationsangebot
			des DigiTech4U Institute – einer gemeinnützigen
			Organisation (NPO) aus Österreich, die digitale Bildungsprojekte
      entwickelt und betreibt.
		  </p>

		  <p>
			Die Idee entstand aus einer einfachen Frage:
			Warum ist es für Eltern so schwer, den passenden Einschulungszeitpunkt
			schnell und verständlich zu finden?
		  </p>

		  <p>
			Die Einschulungsregeln in Deutschland sind je nach Bundesland unterschiedlich,
			über viele offizielle Seiten verteilt und ändern sich teilweise von Jahr zu Jahr.
			Wir bereiten diese Informationen so auf, dass Eltern schneller Orientierung finden.
		  </p>

		  <h3>So recherchieren wir</h3>

		  <p>
			Für alle 16 Bundesländer prüfen wir offizielle Quellen:
			Kultusministerien, Schulbehörden, Schulportale, Ferienkalender
			und Veröffentlichungen der Kultusministerkonferenz.
		  </p>

		  <p>
			Dabei achten wir besonders auf drei Punkte:
		  </p>

		  <ul>
			<li>Welcher Einschulungsstichtag gilt im Bundesland?</li>
			<li>Gibt es Sonderregeln wie Korridor, Karenzzeit oder Kann-Kind-Regelung?</li>
			<li>Sind Einschulungstermin und erster Schultag für das aktuelle Schuljahr bestätigt?</li>
		  </ul>

		  <h3>Wann wir aktualisieren</h3>

		  <p>
			Die Daten werden mindestens einmal jährlich geprüft –
			in der Regel im Frühjahr vor dem nächsten Schuljahr.
		  </p>

		  <p>
			Wenn sich Stichtage, Termine oder Sonderregelungen ändern,
			aktualisieren wir die betroffenen Seiten zusätzlich und kennzeichnen
			wichtige Hinweise transparent.
		  </p>

		  <h3>Was dieser Rechner leisten kann</h3>

		  <p>
			Der Rechner gibt dir eine schnelle, verständliche Orientierung
			zum voraussichtlichen Schuljahr deines Kindes.
		  </p>

		  <p>
			Er ersetzt aber keine offizielle Auskunft. Für verbindliche Informationen
			zu Anmeldung, Fristen, Schulreife oder Zurückstellung ist immer
			die zuständige Grundschule oder Schulbehörde die richtige Anlaufstelle.
		  </p>
		</div>

