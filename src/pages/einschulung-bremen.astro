---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Bremen 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Bremen in die Schule? Alle Informationen zu Stichtag 30. Juni, Karenzzeit, vorzeitiger Einschulung, Zurückstellung und Einschulung 2026.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Bremen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Bremen gilt grundsätzlich der 30. Juni als Einschulungsstichtag. Kinder, die bis zu diesem Datum sechs Jahre alt werden, werden zum 1. August schulpflichtig und müssen zur Schule angemeldet werden.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Bremen 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Für das Schuljahr 2026/2027 enden die Sommerferien in Bremen am Mittwoch, 12. August 2026. Der erste reguläre Schultag ist Donnerstag, 13. August 2026. Die Einschulungsfeier für Erstklässler ist offiziell für Samstag, 15. August 2026 festgelegt.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Karenzzeit in Bremen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Als Karenzzeitkinder gelten in Bremen Kinder, die zwischen dem 1. Juli und dem 31. Dezember sechs Jahre alt werden. Sie können innerhalb der Anmeldefrist für die Einschulung angemeldet werden; die Anmeldung ist verbindlich.",
      },
    },
    {
      "@type": "Question",
      name: "Kann mein Kind in Bremen vorzeitig eingeschult werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Kinder, die zwischen dem 1. Oktober eines Jahres und dem 31. Januar des Folgejahres sechs Jahre alt werden, können in Bremen auf Antrag vorzeitig schulpflichtig werden. Die zuständige Grundschule prüft den Antrag; maßgeblich sind unter anderem die Schulreife und die schulärztliche Einschätzung. Kinder mit Geburtstag zwischen Oktober und Dezember gehören zugleich zur Karenzzeit.",
      },
    },
    {
      "@type": "Question",
      name: "Kann die Einschulung in Bremen zurückgestellt werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eine Zurückstellung ist in Bremen für ein Jahr möglich, wenn aufgrund des Entwicklungsstands zu erwarten ist, dass das Kind noch nicht erfolgreich im ersten Schuljahr mitarbeiten kann. Eltern stellen den Antrag bei der zuständigen Grundschule; verbindlich entscheidet die zuständige Stelle.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Bremen verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde in Bremen.",
      },
    },
  ],
};

---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-bremen/" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Bremen</p>

        <h1>
          Einschulung in Bremen:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Bremen in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. In
          Bremen gilt der Stichtag 30. Juni. Für das Schuljahr 2026/2027 ist der
          erste reguläre Schultag Donnerstag, 13. August 2026 – die Einschulungsfeier
          für Erstklässler ist offiziell für Samstag, 15. August 2026 festgelegt.
        </p>

        <StateEnrollmentCalculator
          stateName="Bremen"
          stateSlug="bremen"
          calculatorKicker="Bremen-Rechner"
          resultKicker="Bremen-Ergebnis"
          headline="Einschulung in Bremen berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Bremen ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Bremen">
          <div class="fact-card fact-card-highlight">
            <span>Nächste Einschulung</span>
            <strong>Samstag, 15. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Donnerstag, 13. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. Juni</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Karenzzeit bis 31. Dezember</strong>
          </div>
        </div>

        <section class="example-box">
          <h2>Wie funktioniert der Einschulungsrechner für Bremen?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Bremen. Entscheidend ist
            zunächst der Stichtag 30. Juni. Wird dein Kind bis zu diesem Datum
            sechs Jahre alt, wird es in Bremen zum 1. August schulpflichtig.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. Juni 2020 geboren, wird es am
            15. Juni 2026 sechs Jahre alt. Da dieses Datum vor dem Stichtag
            30. Juni liegt, ist das Kind voraussichtlich für das Schuljahr
            2026/2027 regulär schulpflichtig.
          </p>

          <p>
            Wird ein Kind zwischen dem 1. Juli und dem 31. Dezember sechs Jahre
            alt, gilt es in Bremen als Karenzzeitkind. Wird ein Kind zwischen dem
            1. Oktober und dem 31. Januar des Folgejahres sechs Jahre alt, kommt
            eine vorzeitige Einschulung auf Antrag in Betracht. Kinder mit Geburtstag
            zwischen Oktober und Dezember liegen damit in einem Überschneidungsbereich,
            der über die zuständige Grundschule geklärt wird.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind in Bremen schulpflichtig?</h2>

          <p>
            In Bremen gilt der 30. Juni als maßgeblicher Stichtag für die reguläre
            Schulpflicht. Kinder, die bis zu diesem Datum sechs Jahre alt werden,
            werden zum 1. August desselben Jahres schulpflichtig und müssen zur
            Schule angemeldet werden.
          </p>

          <p>
            Für Kinder nach dem Stichtag gelten besondere Regeln: Kinder mit
            Geburtstag vom 1. Juli bis 31. Dezember sind Karenzzeitkinder. Kinder,
            die vom 1. Oktober bis 31. Januar des Folgejahres sechs Jahre alt
            werden, können auf Antrag vorzeitig schulpflichtig werden. Für Kinder
            mit Geburtstag von Oktober bis Dezember überschneiden sich diese
            Regelungen in der Praxis; die zuständige Grundschule hilft bei der
            konkreten Einordnung.
          </p>
        </section>

        <section>
          <h2>Was bedeutet Karenzzeit in Bremen?</h2>

          <p>
            Die Karenzzeit betrifft Kinder, die zwischen dem 1. Juli und dem
            31. Dezember sechs Jahre alt werden. Diese Kinder können innerhalb der
            Anmeldefrist für die Einschulung angemeldet werden. Wichtig für Eltern:
            Die Anmeldung eines Karenzzeitkindes ist verbindlich.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Bremen früher eingeschult werden?</h2>

          <p>
            Kinder, die zwischen dem 1. Oktober eines Jahres und dem 31. Januar des
            Folgejahres sechs Jahre alt werden, können in Bremen auf Antrag
            vorzeitig schulpflichtig werden. Die Anmeldung erfolgt bei der
            zuständigen Grundschule während der Anmeldezeit. Die Schule prüft, ob
            das Kind bereits schulreif ist; dabei spielt auch die schulärztliche
            Einschätzung eine wichtige Rolle. Kinder mit Geburtstag zwischen Oktober
            und Dezember gehören zugleich zur Karenzzeit.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Bremen ab?</h2>

          <p>
            Die Anmeldung erfolgt in Bremen bei der zuständigen Grundschule. Die
            Zuordnung richtet sich grundsätzlich nach dem von der Stadtgemeinde
            Bremen festgelegten Einzugsbezirk. Eltern erhalten rechtzeitig
            Informationen zur Anmeldung, zu den erforderlichen Unterlagen und zu
            möglichen weiteren Schritten.
          </p>

          <p>
            Zur Vorbereitung des Schulstarts gehören auch schulische und
            gesundheitliche Einschätzungen. Wenn du unsicher bist, welche Regelung
            für dein Kind gilt, ist die zuständige Grundschule die wichtigste erste
            Anlaufstelle.
          </p>
        </section>

        <section>
          <h2>Mein Kind ist noch nicht schulreif – was muss ich in Bremen tun?</h2>

          <p>
            Eine Zurückstellung vom Schulbesuch ist in Bremen für ein Jahr möglich,
            wenn aufgrund des Entwicklungsstands zu erwarten ist, dass das Kind noch
            nicht erfolgreich im ersten Schuljahr der Grundschule oder einer
            Förderschule mitarbeiten kann. Eltern stellen den Antrag bei der
            zuständigen Grundschule. Verbindliche Auskunft erhältst du bei der
            zuständigen Grundschule oder Schulbehörde.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Bremen</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Bremen?</h3>
              <p>
                In Bremen gilt grundsätzlich der 30. Juni als Einschulungsstichtag.
                Kinder, die bis zu diesem Datum sechs Jahre alt werden, werden zum
                1. August schulpflichtig und müssen zur Schule angemeldet werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Bremen 2026?</h3>
              <p>
                Für das Schuljahr 2026/2027 enden die Sommerferien in Bremen am
                Mittwoch, 12. August 2026. Der erste reguläre Schultag ist
                Donnerstag, 13. August 2026. Die Einschulungsfeier für Erstklässler
                ist offiziell für Samstag, 15. August 2026 festgelegt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Karenzzeit in Bremen?</h3>
              <p>
                Als Karenzzeitkinder gelten in Bremen Kinder, die zwischen dem
                1. Juli und dem 31. Dezember sechs Jahre alt werden. Sie können
                innerhalb der Anmeldefrist für die Einschulung angemeldet werden;
                die Anmeldung ist verbindlich.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann mein Kind in Bremen vorzeitig eingeschult werden?</h3>
              <p>
                Kinder, die zwischen dem 1. Oktober eines Jahres und dem 31. Januar
                des Folgejahres sechs Jahre alt werden, können in Bremen auf Antrag
                vorzeitig schulpflichtig werden. Die zuständige Grundschule prüft
                den Antrag; maßgeblich sind unter anderem die Schulreife und die
                schulärztliche Einschätzung. Kinder mit Geburtstag zwischen Oktober
                und Dezember gehören zugleich zur Karenzzeit.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann die Einschulung in Bremen zurückgestellt werden?</h3>
              <p>
                Eine Zurückstellung ist in Bremen für ein Jahr möglich, wenn aufgrund
                des Entwicklungsstands zu erwarten ist, dass das Kind noch nicht
                erfolgreich im ersten Schuljahr mitarbeiten kann. Eltern stellen den
                Antrag bei der zuständigen Grundschule; verbindlich entscheidet die
                zuständige Stelle.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Bremen verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen
                der Orientierung. Verbindliche Informationen erhältst du bei der
                zuständigen Grundschule oder Schulbehörde in Bremen.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Bremen:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Bremen">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://www.service.bremen.de/dienstleistungen/aufnahme-an-einer-grundschule-anmelden-185040"
                target="_blank"
                rel="noopener noreferrer"
              >
                Service Bremen: Aufnahme an einer Grundschule anmelden
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://www.service.bremen.de/dienstleistungen/vorzeitige-aufnahme-in-die-grundschule-beantragen-185044"
                target="_blank"
                rel="noopener noreferrer"
              >
                Service Bremen: Vorzeitige Aufnahme in die Grundschule beantragen
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://www.service.bremen.de/dienstleistungen/zurueckstellung-vom-schulbesuch-beantragen-185042"
                target="_blank"
                rel="noopener noreferrer"
              >
                Service Bremen: Zurückstellung vom Schulbesuch beantragen
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 4</p>
              <a
                class="source-link"
                href="https://www.kmk.org/fileadmin/Dateien/pdf/Ferienkalender/FER2026_27.pdf"
                target="_blank"
                rel="noopener noreferrer"
              >
                Kultusministerkonferenz: Ferientermine Schuljahr 2026/2027
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder bei der Senatorin für Kinder und
            Bildung Bremen.
          </p>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  :global(body.has-bremen-calculator-result) .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .stand {
    display: inline-flex;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  @media (max-width: 720px) {
