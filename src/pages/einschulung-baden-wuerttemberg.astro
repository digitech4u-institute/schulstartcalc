  }

  .source-list li > span {
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .source-hint {
    margin-top: 18px;
