  .source-link {
    display: inline-flex;
    width: fit-content;
    margin-top: 18px;
    padding: 12px 14px;
    border: 1px solid rgba(129, 97, 38, 0.18);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.58);
    color: #172033;
    font-size: 0.96rem;
    font-weight: 850;
