---
import BaseLayout from "../layouts/BaseLayout.astro";
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Baden-Württemberg 2026: Termin, Stichtag & Rechner";

const pageDescription =
  "Wann ist die Einschulung in Baden-Württemberg 2026? Hier findest du Termin, Stichtag 30. Juni, Stichtagsflexibilisierung und den kostenlosen Einschulungsrechner.";

const canonical = "https://www.einschulungsrechner.de/einschulung-baden-wuerttemberg/";
const dateModified = "2026-05-28";

const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || "";
const STATE_CONTENT_AD_SLOT = import.meta.env.PUBLIC_ADSENSE_STATE_CONTENT_SLOT || "";
const showContentAd = Boolean(ADSENSE_ID && STATE_CONTENT_AD_SLOT);

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  datePublished: "2025-10-01",
  dateModified,
  inLanguage: "de",
  publisher: {
    "@type": "Organization",
    name: "Einschulungsrechner",
    url: "https://www.einschulungsrechner.de/",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Baden-Württemberg?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Baden-Württemberg gilt der 30. Juni als Stichtag für die Einschulung. Kinder, die bis zu diesem Datum sechs Jahre alt werden, sind mit Beginn des neuen Schuljahres regulär schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Baden-Württemberg 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Sommerferien in Baden-Württemberg enden 2026 am Samstag, 12. September 2026. Der erste Schultag ist Montag, 14. September 2026. Die Einschulung der ersten Klassen wird von der zuständigen Grundschule festgelegt. Verbindliche Informationen erhältst du daher direkt bei der Schule.",
      },
    },
    {
      "@type": "Question",
      name: "Wann beginnt die Grundschule in Baden-Württemberg 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der erste Schultag im Schuljahr 2026/2027 ist in Baden-Württemberg Montag, 14. September 2026. Die Einschulung der ersten Klassen wird schulabhängig festgelegt.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Stichtagsflexibilisierung in Baden-Württemberg?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Durch die Stichtagsflexibilisierung können Eltern ihre Kinder, die nach dem 30. Juni geboren sind und bis zum 30. Juni des folgenden Kalenderjahres sechs Jahre alt werden, an der zuständigen Grundschule anmelden. Mit der Anmeldung wird die Schulpflicht ausgelöst.",
      },
    },
    {
      "@type": "Question",
      name: "Kann mein Kind in Baden-Württemberg früher eingeschult werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja. Eine frühere Einschulung kann möglich sein, wenn dein Kind nach dem Stichtag geboren ist und die Voraussetzungen für den Schulbesuch erfüllt. Die Entscheidung trifft die Schulleitung. Bestehen Zweifel am Entwicklungsstand, kann ein Gutachten des Gesundheitsamts einbezogen werden.",
      },
    },
    {
      "@type": "Question",
      name: "Wie läuft die Schulanmeldung in Baden-Württemberg ab?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die zuständige Grundschule informiert die Eltern über Anmeldung, Termine, Unterlagen und den weiteren Ablauf. Bei Fragen zur Stichtagsflexibilisierung, vorzeitigen Einschulung oder individuellen Entscheidungen solltest du frühzeitig Kontakt mit der zuständigen Grundschule aufnehmen.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Baden-Württemberg verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule, der Schulbehörde oder beim Ministerium für Kultus, Jugend und Sport Baden-Württemberg.",
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={[faqSchema, webPageSchema]}
>
  <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Baden-Württemberg</p>

        <h1>
          Einschulung Baden-Württemberg 2026:<br />
          Wann kommt mein Kind in die Schule?
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Baden-Württemberg in die Schule? Gib das Geburtsdatum
          ein und berechne das voraussichtliche Schuljahr. In Baden-Württemberg gilt
          der Stichtag 30. Juni. Für das Schuljahr 2026/2027 ist der erste Schultag
          Montag, 14. September 2026. Die Einschulung wird schulabhängig festgelegt.
        </p>

        <p class="answer-box">
          Kurzantwort: Die Sommerferien in Baden-Württemberg enden 2026 am Samstag,
          12. September 2026. Der erste Schultag ist Montag, 14. September 2026.
          Die Einschulung der ersten Klassen wird von der zuständigen Grundschule
          festgelegt.
        </p>

        <StateEnrollmentCalculator
          stateName="Baden-Württemberg"
          stateSlug="baden-wuerttemberg"
          calculatorKicker="Baden-Württemberg-Rechner"
          resultKicker="Baden-Württemberg-Ergebnis"
          headline="Einschulung in Baden-Württemberg berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Baden-Württemberg ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Baden-Württemberg">
          <div class="fact-card fact-card-highlight">
            <span>Einschulung 2026</span>
            <strong>schulabhängig,<br />ab 14. September 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Montag,<br />14. September 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. Juni</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Stichtagsflexibilisierung</strong>
          </div>
        </div>

        {showContentAd ? (
          <aside class="ad-slot ad-slot-after-facts" aria-label="Anzeige">
            <p class="ad-label">Anzeige</p>
            <ins
              class="adsbygoogle"
              style="display:block"
              data-ad-client={ADSENSE_ID}
              data-ad-slot={STATE_CONTENT_AD_SLOT}
              data-ad-format="auto"
              data-full-width-responsive="true"
            ></ins>
          </aside>
        ) : null}

        <section>
          <h2>Wann ist die Einschulung in Baden-Württemberg 2026?</h2>

          <p>
            Die Sommerferien in Baden-Württemberg enden 2026 am Samstag,
            12. September 2026. Der erste Schultag ist Montag,
            14. September 2026. Die Einschulung der ersten Klassen wird von der
            zuständigen Grundschule festgelegt. Verbindliche Informationen erhältst
            du daher direkt bei der Schule.
          </p>
        </section>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Baden-Württemberg?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und gleicht
            es mit den Regeln zur Einschulung in Baden-Württemberg ab. Entscheidend
            sind vor allem der Stichtag 30. Juni und die Stichtagsflexibilisierung.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. Juni 2020 geboren, wird es vor dem
            Stichtag 30. Juni 2026 sechs Jahre alt. Damit ist das Kind in
            Baden-Württemberg voraussichtlich für das Schuljahr 2026/2027 regulär
            schulpflichtig.
          </p>
        </section>

        <section>
          <h2>Welcher Einschulungsstichtag gilt in Baden-Württemberg?</h2>

          <p>
            In Baden-Württemberg gilt der 30. Juni als Stichtag für die Einschulung.
            Kinder, die bis zu diesem Datum sechs Jahre alt werden, sind mit Beginn
            des neuen Schuljahres regulär schulpflichtig.
          </p>
        </section>

        <section>
          <h2>Was bedeutet Stichtagsflexibilisierung in Baden-Württemberg?</h2>

          <p>
            Durch die Stichtagsflexibilisierung können Eltern ihre Kinder, die nach
            dem 30. Juni geboren sind und bis zum 30. Juni des folgenden Kalenderjahres
            sechs Jahre alt werden, an der zuständigen Grundschule anmelden. Mit der
            Anmeldung wird die Schulpflicht ausgelöst.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Baden-Württemberg früher eingeschult werden?</h2>

          <p>
            Ja. Eine frühere Einschulung kann möglich sein, wenn dein Kind nach dem
            Stichtag geboren ist und die Voraussetzungen für den Schulbesuch erfüllt.
            Die Entscheidung trifft die Schulleitung. Bestehen Zweifel am
            Entwicklungsstand, kann ein Gutachten des Gesundheitsamts einbezogen
            werden.
          </p>
        </section>

        <section class="example-box">
          <h2>Beispiel: Geburtsdatum im Juni</h2>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. Juni 2020 geboren,
            wird es am 15. Juni 2026 sechs Jahre alt. Da dieses Datum vor dem
            Stichtag 30. Juni liegt, wird das Kind in Baden-Württemberg
            voraussichtlich im Schuljahr 2026/2027 regulär eingeschult.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Baden-Württemberg</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Baden-Württemberg?</h3>
              <p>
                In Baden-Württemberg gilt der 30. Juni als Stichtag für die
                Einschulung. Kinder, die bis zu diesem Datum sechs Jahre alt werden,
                sind mit Beginn des neuen Schuljahres regulär schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Baden-Württemberg 2026?</h3>
              <p>
                Die Sommerferien in Baden-Württemberg enden 2026 am Samstag,
                12. September 2026. Der erste Schultag ist Montag,
                14. September 2026. Die Einschulung der ersten Klassen wird von der
                zuständigen Grundschule festgelegt. Verbindliche Informationen
                erhältst du daher direkt bei der Schule.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann beginnt die Grundschule in Baden-Württemberg 2026?</h3>
              <p>
                Der erste Schultag im Schuljahr 2026/2027 ist in Baden-Württemberg
                Montag, 14. September 2026. Die Einschulung der ersten Klassen wird
                schulabhängig festgelegt.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Stichtagsflexibilisierung in Baden-Württemberg?</h3>
              <p>
                Durch die Stichtagsflexibilisierung können Eltern ihre Kinder, die nach
                dem 30. Juni geboren sind und bis zum 30. Juni des folgenden
                Kalenderjahres sechs Jahre alt werden, an der zuständigen Grundschule
                anmelden. Mit der Anmeldung wird die Schulpflicht ausgelöst.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann mein Kind in Baden-Württemberg früher eingeschult werden?</h3>
              <p>
                Ja. Eine frühere Einschulung kann möglich sein, wenn dein Kind nach
                dem Stichtag geboren ist und die Voraussetzungen für den Schulbesuch
                erfüllt. Die Entscheidung trifft die Schulleitung. Bestehen Zweifel
                am Entwicklungsstand, kann ein Gutachten des Gesundheitsamts
                einbezogen werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wie läuft die Schulanmeldung in Baden-Württemberg ab?</h3>
              <p>
                Die zuständige Grundschule informiert die Eltern über Anmeldung,
                Termine, Unterlagen und den weiteren Ablauf. Bei Fragen zur
                Stichtagsflexibilisierung, vorzeitigen Einschulung oder individuellen
                Entscheidungen solltest du frühzeitig Kontakt mit der zuständigen
                Grundschule aufnehmen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Baden-Württemberg verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen der
                Orientierung. Verbindliche Informationen erhältst du bei der zuständigen
                Grundschule, der Schulbehörde oder beim Ministerium für Kultus,
                Jugend und Sport Baden-Württemberg.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Baden-Württemberg:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Baden-Württemberg">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://km.baden-wuerttemberg.de/de/schule/grundschule/einschulungsstichtag"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Kultus, Jugend und Sport Baden-Württemberg: Einschulungsstichtag
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://km.baden-wuerttemberg.de/de/service/ferien"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Kultus, Jugend und Sport Baden-Württemberg: Ferien
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://km.baden-wuerttemberg.de/de/schule/grundschule/schulanfang"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ministerium für Kultus, Jugend und Sport Baden-Württemberg: Schulanfang
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Ministerium für Kultus, Jugend
            und Sport Baden-Württemberg.
          </p>

          <p class="stand">Stand der Informationen:<span class="stand-date">Mai 2026</span></p>
        </section>
      </article>
  </main>
</BaseLayout>

<style is:global>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .answer-box {
    max-width: 760px;
    margin: 20px 0 0;
    padding: 18px 20px;
    border: 1px solid rgba(129, 97, 38, 0.18);
    border-radius: 18px;
    background: rgba(245, 210, 138, 0.14);
    color: #172033;
    font-size: clamp(1.02rem, 1.35vw, 1.12rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  body.has-baden-wuerttemberg-calculator-result .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .ad-slot {
    margin: 30px 0 0;
    padding: 14px 0;
    border-top: 1px solid rgba(42, 35, 21, 0.08);
    border-bottom: 1px solid rgba(42, 35, 21, 0.08);
  }

  .ad-label {
    margin: 0 0 10px;
    color: #8a7960;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .stand {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  .stand-date {
    display: inline;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
