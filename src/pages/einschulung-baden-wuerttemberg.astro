      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.22rem, 1.55vw, 1.46rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .fact-card-date {
    border-color: rgba(129, 97, 38, 0.16);
    background: rgba(245, 210, 138, 0.12);
  }

  .fact-card-date strong {
    font-size: clamp(1.12rem, 1.36vw, 1.32rem);
    white-space: normal;
  }

  .fact-card-no-wrap strong {
    white-space: nowrap;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
