---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Bayern 2026: Schulstart, Stichtag und Einschulungskorridor";

const pageDescription =
  "Wann ist die Einschulung in Bayern? Erfahre alles zu Schulstart, erstem Schultag, Einschulungstermin, Stichtag 30. September und Einschulungskorridor.";
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-bayern/" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Welcher Einschulungsstichtag gilt in Bayern?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In Bayern gilt grundsätzlich der 30. September als Stichtag für die Einschulung. Kinder, die bis zu diesem Datum sechs Jahre alt werden, sind schulpflichtig."
            }
          },
          {
            "@type": "Question",
            "name": "Was ist der Einschulungskorridor in Bayern?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Der Einschulungskorridor betrifft Kinder, die zwischen dem 1. Juli und dem 30. September sechs Jahre alt werden. Für diese Kinder kann der Beginn der Schulpflicht um ein Jahr nach hinten verschoben werden."
            }
          },
          {
            "@type": "Question",
            "name": "Ist das Ergebnis zur Einschulung in Bayern verbindlich?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule oder Schulbehörde in Bayern."
            }
          },
          {
            "@type": "Question",
            "name": "Wann ist die Einschulung in Bayern 2026?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Für Schulanfängerinnen und Schulanfänger in Bayern nennt das Bayerische Kultusministerium den 16. September 2026. Der konkrete Einschulungstermin kann je nach Grundschule organisatorisch abweichen."
            }
          },
          {
            "@type": "Question",
            "name": "Wann ist der erste Schultag in Bayern 2026?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Der allgemeine Schulstart nach den Sommerferien in Bayern ist voraussichtlich Dienstag, der 15. September 2026. Für Schulanfängerinnen und Schulanfänger nennt das Bayerische Kultusministerium den 16. September 2026."
            }
          }
        ]
      }
    </script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Bayern</p>

        <h1>
          Einschulung in Bayern:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann ist die Einschulung in Bayern? Für Schulanfängerinnen und
          Schulanfänger nennt das Bayerische Kultusministerium den 16. September 2026.
          Der allgemeine Schulstart nach den Sommerferien ist voraussichtlich am
          15. September 2026. Für die Schulpflicht gilt der Stichtag 30. September.
        </p>

        <StateEnrollmentCalculator
          stateName="Bayern"
          stateSlug="bayern"
          calculatorKicker="Bayern-Rechner"
          resultKicker="Bayern-Ergebnis"
          headline="Einschulung in Bayern berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Bayern ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts" aria-label="Kurzüberblick Einschulung Bayern">
          <div class="fact-card fact-card-date">
            <span>Nächste Einschulung</span>
            <strong>Mittwoch, 16.09.2026</strong>
          </div>

          <div class="fact-card fact-card-date">
            <span>Erster Schultag</span>
            <strong>Dienstag, 15.09.2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. September</strong>
          </div>

          <div class="fact-card fact-card-no-wrap">
            <span>Sonderregel</span>
            <strong>Einschulungskorridor</strong>
          </div>
        </div>

        <section>
          <h2>Wann ist die Einschulung in Bayern 2026?</h2>

          <p>
            Die nächste Einschulung in Bayern für Schulanfängerinnen und
            Schulanfänger ist nach aktueller Darstellung des Bayerischen
            Kultusministeriums am 16. September 2026. Der allgemeine Schulstart
            nach den Sommerferien ist voraussichtlich Dienstag, der 15. September
            2026. Die konkrete Einschulungsfeier kann je nach Grundschule
            organisatorisch abweichen.
          </p>
        </section>

        <section>
          <h2>Wann ist ein Kind in Bayern schulpflichtig?</h2>

          <p>
            Ein Kind wird in Bayern grundsätzlich schulpflichtig, wenn es bis zum
            30. September des jeweiligen Kalenderjahres sechs Jahre alt wird. Die
            Schulpflicht beginnt dann mit dem Start des neuen Schuljahres.
          </p>
        </section>

        <section>
          <h2>Was bedeutet Einschulungskorridor in Bayern?</h2>

          <p>
            Der Einschulungskorridor betrifft Kinder, die zwischen dem 1. Juli und
            dem 30. September sechs Jahre alt werden. Für diese Kinder ist die
            Einschulung grundsätzlich vorgesehen. Der Beginn der Schulpflicht kann
            aber um ein Jahr nach hinten verschoben werden.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind früher eingeschult werden?</h2>

          <p>
            Kinder, die erst nach dem 30. September sechs Jahre alt werden, können
            unter bestimmten Voraussetzungen vorzeitig eingeschult werden. Die
            Entscheidung hängt vom Entwicklungsstand des Kindes und der Einschätzung
            der zuständigen Schule ab.
          </p>
        </section>

        <section class="example-box">
          <h2>Beispiel: Geburtsdatum im August</h2>

          <p>
            Wird ein Kind am 15. August 2020 geboren, wird es am 15. August 2026
            sechs Jahre alt. Da dieses Datum zwischen dem 1. Juli und dem
            30. September liegt, fällt das Kind in Bayern in den Einschulungskorridor
            für das Schuljahr 2026/2027.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Bayern</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Wann ist die Einschulung in Bayern 2026?</h3>
              <p>
                Für Schulanfängerinnen und Schulanfänger in Bayern nennt das
                Bayerische Kultusministerium den 16. September 2026. Der konkrete
                Einschulungstermin kann je nach Grundschule organisatorisch abweichen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist der Schulstart in Bayern 2026?</h3>
              <p>
                Der allgemeine Schulstart nach den Sommerferien ist voraussichtlich
                Dienstag, der 15. September 2026. Für Schulanfängerinnen und
                Schulanfänger ist besonders der Einschulungstermin am 16. September
                relevant.
              </p>
            </article>

            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Bayern?</h3>
              <p>
                In Bayern gilt grundsätzlich der 30. September als Stichtag für die
                Einschulung.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was ist der Einschulungskorridor?</h3>
              <p>
                Der Einschulungskorridor betrifft Kinder, die zwischen dem 1. Juli
                und dem 30. September sechs Jahre alt werden. Für diese Kinder kann
                der Beginn der Schulpflicht um ein Jahr verschoben werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis verbindlich?</h3>
              <p>
                Nein. Der Rechner und diese Seite dienen der Orientierung.
                Verbindliche Informationen erhältst du bei der zuständigen Schule
                oder Schulbehörde in Bayern.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist der erste Schultag in Bayern 2026?</h3>
              <p>
                Der allgemeine erste Schultag nach den Sommerferien ist
                voraussichtlich Dienstag, der 15. September 2026. Für
                Schulanfängerinnen und Schulanfänger nennt das Bayerische
                Kultusministerium den 16. September 2026.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quelle und Hinweis</h2>

          <p>
            Grundlage dieser Übersicht sind öffentlich zugängliche Informationen
            zur Einschulung in Bayern. Bitte prüfe verbindliche Details immer bei
            der zuständigen Grundschule oder beim Bayerischen Staatsministerium für
            Unterricht und Kultus.
          </p>

          <a
            class="source-link"
            href="https://www.km.bayern.de/lernen/schularten/grundschule/einschulung-und-schulwegsicherheit"
            target="_blank"
            rel="noopener noreferrer"
          >
            km.bayern.de: Einschulung und Schulwegsicherheit
          </a>

          <a
            class="source-link"
            href="https://www.km.bayern.de/ministerium/termine/ferientermine.html"
            target="_blank"
            rel="noopener noreferrer"
          >
            km.bayern.de: Ferien und Feiertage
          </a>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.22rem, 1.55vw, 1.46rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .fact-card-date {
    border-color: rgba(129, 97, 38, 0.16);
    background: rgba(245, 210, 138, 0.12);
  }

  .fact-card-date strong {
    font-size: clamp(1.22rem, 1.65vw, 1.56rem);
    white-space: nowrap;
  }

  .fact-card-no-wrap strong {
    white-space: nowrap;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-link {
    display: inline-flex;
    width: fit-content;
    margin-top: 18px;
    padding: 12px 14px;
    border: 1px solid rgba(129, 97, 38, 0.18);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.58);
    color: #172033;
    font-size: 0.96rem;
    font-weight: 850;
    line-height: 1.35;
    text-decoration: none;
  }

  .source-link:hover {
    border-color: rgba(129, 97, 38, 0.32);
    background: rgba(255, 255, 255, 0.82);
    text-decoration: underline;
  }

  .stand {
    display: inline-flex;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  .desktop-break {
    display: inline;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }

    .desktop-break {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
      letter-spacing: -0.05em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .fact-card {
      min-height: 102px;
      padding: 18px 22px;
    }

    .fact-card span {
      font-size: clamp(0.82rem, 3.45vw, 0.96rem);
      letter-spacing: 0.095em;
    }

    .fact-card strong {
      font-size: clamp(1.12rem, 4.9vw, 1.36rem);
      line-height: 1.14;
    }

    .fact-card-date strong {
      white-space: normal;
    }

    .fact-card-no-wrap strong {
      white-space: normal;
    }

    section {
      margin-top: 30px;
      padding-top: 28px;
    }

    h2 {
      font-size: 1.62rem;
      line-height: 1.1;
    }

    p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .faq-item p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .example-box,
    .source-note {
      padding: 20px;
      border-radius: 20px;
    }

    .source-link {
      width: 100%;
    }
  }

  @media (max-width: 390px) {
    h1 {
      font-size: clamp(1.58rem, 7vw, 1.95rem);
      line-height: 1.07;
      letter-spacing: -0.046em;
    }
  }
</style>