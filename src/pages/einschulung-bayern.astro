---
import BaseLayout from "../layouts/BaseLayout.astro";
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Bayern 2026: Termin, Stichtag & Rechner";

const pageDescription =
  "Wann ist die Einschulung in Bayern 2026? Hier findest du Termin, Stichtag 30. September, Einschulungskorridor und den kostenlosen Einschulungsrechner.";

const dateModified = "2026-05-26";

const canonical = "https://www.einschulungsrechner.de/einschulung-bayern/";

const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || "";
const STATE_CONTENT_AD_SLOT = import.meta.env.PUBLIC_ADSENSE_STATE_CONTENT_SLOT || "";
const showContentAd = Boolean(ADSENSE_ID && STATE_CONTENT_AD_SLOT);

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  datePublished: "2025-10-01",
  dateModified,
  inLanguage: "de",
  publisher: {
    "@type": "Organization",
    name: "Einschulungsrechner",
    url: "https://www.einschulungsrechner.de/",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Bayern?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Bayern gilt der 30. September als Einschulungsstichtag. Wird ein Kind bis zu diesem Datum sechs Jahre alt, ist es in der Regel mit Beginn des neuen Schuljahres schulpflichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Bayern 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Für Schulanfängerinnen und Schulanfänger nennt das Bayerische Kultusministerium Mittwoch, 16. September 2026. Der allgemeine erste Schultag nach den Sommerferien ist voraussichtlich Dienstag, 15. September 2026. Die konkrete Organisation kann je nach Grundschule abweichen.",
      },
    },
    {
      "@type": "Question",
      name: "Wann beginnt die Grundschule in Bayern 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der allgemeine erste Schultag nach den Sommerferien ist in Bayern im Schuljahr 2026/2027 voraussichtlich Dienstag, 15. September 2026. Die Einschulung für Schulanfängerinnen und Schulanfänger ist für Mittwoch, 16. September 2026 vorgesehen. Die konkrete Organisation kann je nach Grundschule abweichen.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet der Einschulungskorridor in Bayern?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der Einschulungskorridor betrifft Kinder, die zwischen dem 1. Juli und dem 30. September sechs Jahre alt werden. Für diese Kinder ist die Einschulung grundsätzlich vorgesehen. Eltern können den Schulbeginn nach Beratung und Empfehlung durch die Schule unter bestimmten Voraussetzungen um ein Jahr verschieben.",
      },
    },
    {
      "@type": "Question",
      name: "Kann mein Kind in Bayern früher eingeschult werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Kinder, die erst nach dem 30. September sechs Jahre alt werden, können unter bestimmten Voraussetzungen vorzeitig eingeschult werden. Den Antrag stellst du bei der Schulanmeldung an der zuständigen Grundschule; über die Aufnahme entscheidet die Schule nach Einschätzung des Entwicklungsstands deines Kindes.",
      },
    },
    {
      "@type": "Question",
      name: "Wie läuft die Schulanmeldung in Bayern ab?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Anmeldung erfolgt an der zuständigen Grundschule, die dich über Termine, Unterlagen und mögliche Beratungstermine informiert. Wenn du eine vorzeitige Einschulung wünschst, stellst du den Antrag spätestens bei der Schulanmeldung; verbindliche Fristen erfährst du direkt bei der Schule.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Bayern verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule, der Schulbehörde oder beim Bayerischen Staatsministerium für Unterricht und Kultus.",
      },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} schema={[faqSchema, webPageSchema]}>
  <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Bayern</p>

        <h1>
          Einschulung Bayern 2026:<br />
          Wann kommt mein Kind in die Schule?
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Bayern in die Schule? Gib das Geburtsdatum ein und
          berechne das voraussichtliche Schuljahr. In Bayern gilt der Stichtag
          30. September. Für das Schuljahr 2026/2027 ist die Einschulung für
          Mittwoch, 16. September 2026 vorgesehen – der erste Schultag ist
          Dienstag, 15. September 2026.
        </p>

        <p class="answer-box">
          Kurzantwort: Die Einschulung in Bayern 2026 ist für Mittwoch,
          16. September 2026 vorgesehen. Schulpflichtig werden Kinder, die bis zum
          30. September 2026 sechs Jahre alt werden. Für Kinder mit Geburtstag zwischen
          1. Juli und 30. September gilt der Einschulungskorridor.
        </p>

        <StateEnrollmentCalculator
          stateName="Bayern"
          stateSlug="bayern"
          calculatorKicker="Bayern-Rechner"
          resultKicker="Bayern-Ergebnis"
          headline="Einschulung in Bayern berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Bayern ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Bayern">
          <div class="fact-card fact-card-highlight">
            <span>Einschulung 2026</span>
            <strong>Mittwoch,<br />16. September 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Dienstag,<br />15. September 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. September</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Einschulungskorridor</strong>
          </div>
        </div>

        {showContentAd ? (
          <aside class="ad-slot ad-slot-after-facts" aria-label="Anzeige">
            <p class="ad-label">Anzeige</p>
            <ins
              class="adsbygoogle"
              style="display:block"
              data-ad-client={ADSENSE_ID}
              data-ad-slot={STATE_CONTENT_AD_SLOT}
              data-ad-format="auto"
              data-full-width-responsive="true"
            ></ins>
          </aside>
        ) : null}

        <section>
          <h2>Wann ist die Einschulung in Bayern 2026?</h2>

          <p>
            Die nächste Einschulung in Bayern für Schulanfängerinnen und
            Schulanfänger ist nach aktueller Darstellung des Bayerischen
            Kultusministeriums Mittwoch, 16. September 2026. Der allgemeine
            erste Schultag nach den Sommerferien ist voraussichtlich Dienstag,
            15. September 2026. Die konkrete Organisation der Einschulung kann
            je nach Grundschule abweichen.
          </p>
        </section>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Bayern?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Bayern. Entscheidend sind
            vor allem der Stichtag 30. September und der Einschulungskorridor
            zwischen dem 1. Juli und dem 30. September.
          </p>

          <p>
            Beispiel: Wird ein Kind am 15. August 2020 geboren, wird es am
            15. August 2026 sechs Jahre alt. Da dieses Datum im bayerischen
            Einschulungskorridor liegt, ist das Kind grundsätzlich für das
            Schuljahr 2026/2027 vorgesehen. Eltern können den Schulbeginn unter
            bestimmten Voraussetzungen aber um ein Jahr verschieben.
          </p>

          <p>
            Die wichtigsten Termine zur Einschulung und zum allgemeinen Schulstart
            findest du im Terminblock oben. Der konkrete Ablauf kann je nach
            Grundschule organisatorisch abweichen.
          </p>
        </section>

        <section>
          <h2>Welcher Einschulungsstichtag gilt in Bayern?</h2>

          <p>
            In Bayern gilt der 30. September als Stichtag für die Einschulung.
            Wird ein Kind bis dahin sechs Jahre alt, ist es regulär schulpflichtig.
            Die Schulpflicht beginnt dann mit dem Start des neuen Schuljahres.
          </p>
        </section>

        <section>
          <h2>Was bedeutet der Einschulungskorridor in Bayern?</h2>

          <p>
            Der Einschulungskorridor betrifft Kinder, die zwischen dem 1. Juli und
            dem 30. September sechs Jahre alt werden. Für diese Kinder ist die
            Einschulung grundsätzlich vorgesehen. Der Beginn der Schulpflicht kann
            aber um ein Jahr nach hinten verschoben werden.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Bayern früher eingeschult werden?</h2>

          <p>
            Kinder, die erst nach dem 30. September sechs Jahre alt werden,
            können unter bestimmten Voraussetzungen vorzeitig eingeschult
            werden. Den Antrag stellst du bei der Schulanmeldung an der
            zuständigen Grundschule; über die Aufnahme entscheidet die Schule
            nach Einschätzung des Entwicklungsstands deines Kindes.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Bayern ab?</h2>

          <p>
            Die Anmeldung erfolgt an der zuständigen Grundschule, die dich über
            Termine, Unterlagen und mögliche Beratungstermine informiert. Wenn
            du eine vorzeitige Einschulung wünschst, stellst du den Antrag
            spätestens bei der Schulanmeldung; verbindliche Fristen erfährst du
            direkt bei der Schule.
          </p>
        </section>

        <section class="example-box">
          <h2>Beispiel: Geburtsdatum im August</h2>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. August 2020
            geboren, wird es am 15. August 2026 sechs Jahre alt. Da dieses Datum
            zwischen dem 1. Juli und dem 30. September liegt, fällt das Kind in
            Bayern in den Einschulungskorridor für das Schuljahr 2026/2027.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Bayern</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Bayern?</h3>
              <p>
                In Bayern gilt der 30. September als Einschulungsstichtag. Wird ein
                Kind bis zu diesem Datum sechs Jahre alt, ist es in der Regel mit
                Beginn des neuen Schuljahres schulpflichtig.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Bayern 2026?</h3>
              <p>
                Für Schulanfängerinnen und Schulanfänger nennt das Bayerische
                Kultusministerium Mittwoch, 16. September 2026. Der allgemeine
                erste Schultag nach den Sommerferien ist voraussichtlich Dienstag,
                15. September 2026. Die konkrete Organisation kann je nach
                Grundschule abweichen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann beginnt die Grundschule in Bayern 2026?</h3>
              <p>
                Der allgemeine erste Schultag nach den Sommerferien ist in Bayern im
                Schuljahr 2026/2027 voraussichtlich Dienstag, 15. September 2026.
                Die Einschulung für Schulanfängerinnen und Schulanfänger ist für
                Mittwoch, 16. September 2026 vorgesehen. Die konkrete Organisation
                kann je nach Grundschule abweichen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet der Einschulungskorridor in Bayern?</h3>
              <p>
                Der Einschulungskorridor betrifft Kinder, die zwischen dem 1. Juli
                und dem 30. September sechs Jahre alt werden. Für diese Kinder ist
                die Einschulung grundsätzlich vorgesehen. Eltern können den
                Schulbeginn nach Beratung und Empfehlung durch die Schule unter
                bestimmten Voraussetzungen um ein Jahr verschieben.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann mein Kind in Bayern früher eingeschult werden?</h3>
              <p>
                Kinder, die erst nach dem 30. September sechs Jahre alt werden,
                können unter bestimmten Voraussetzungen vorzeitig eingeschult
                werden. Den Antrag stellst du bei der Schulanmeldung an der
                zuständigen Grundschule; über die Aufnahme entscheidet die Schule
                nach Einschätzung des Entwicklungsstands deines Kindes.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wie läuft die Schulanmeldung in Bayern ab?</h3>
              <p>
                Die Anmeldung erfolgt an der zuständigen Grundschule, die dich über
                Termine, Unterlagen und mögliche Beratungstermine informiert. Wenn
                du eine vorzeitige Einschulung wünschst, stellst du den Antrag
                spätestens bei der Schulanmeldung; verbindliche Fristen erfährst du
                direkt bei der Schule.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Bayern verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen der
                Orientierung. Verbindliche Informationen erhältst du bei der zuständigen
                Grundschule, der Schulbehörde oder beim Bayerischen Staatsministerium
                für Unterricht und Kultus.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Bayern:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Bayern">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://www.km.bayern.de/lernen/schularten/grundschule/einschulung-und-schulwegsicherheit"
                target="_blank"
                rel="noopener noreferrer"
              >
                Bayerisches Staatsministerium für Unterricht und Kultus: Einschulung und Schulwegsicherheit
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://www.km.bayern.de/ministerium/termine/ferientermine.html"
                target="_blank"
                rel="noopener noreferrer"
              >
                Bayerisches Staatsministerium für Unterricht und Kultus: Ferien und Feiertage
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://www.bayernportal.de/dokumente/leistung/13885875650"
                target="_blank"
                rel="noopener noreferrer"
              >
                BayernPortal: Grundschule, Anmeldung und Schulpflicht
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Bayerischen Staatsministerium
            für Unterricht und Kultus.
          </p>

          <p class="stand">Stand der Informationen:<span class="stand-date">Mai 2026</span></p>
        </section>
      </article>
  </main>
</BaseLayout>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .answer-box {
    max-width: 760px;
    margin: 20px 0 0;
    padding: 18px 20px;
    border: 1px solid rgba(129, 97, 38, 0.18);
    border-radius: 18px;
    background: rgba(245, 210, 138, 0.14);
    color: #172033;
    font-size: clamp(1.02rem, 1.35vw, 1.12rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  :global(body.has-bayern-calculator-result) .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  .ad-slot {
    margin: 30px 0 0;
    padding: 14px 0;
    border-top: 1px solid rgba(42, 35, 21, 0.08);
    border-bottom: 1px solid rgba(42, 35, 21, 0.08);
  }

  .ad-label {
    margin: 0 0 10px;
    color: #8a7960;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }


  .stand {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  .stand-date {
    display: inline;
  }

  .desktop-break {
    display: inline;
  }

  @media (max-width: 720px) {
    .quick-facts {
