  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.34rem, 2vw, 1.72rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.65rem, 2.6vw, 2.25rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.05em;
  }

  h3 {
    margin: 0;
    color: #172033;
