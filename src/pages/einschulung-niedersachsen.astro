---
import StateEnrollmentCalculator from "../components/StateEnrollmentCalculator.astro";

const pageTitle =
  "Einschulung Niedersachsen 2026: Schulstart, Stichtag und Schuljahr";

const pageDescription =
  "Wann kommt mein Kind in Niedersachsen in die Schule? Erfahre alles zu Schulstart, Einschulung, Stichtag 30. September, Flexibilisierung und Schuljahr.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Welcher Einschulungsstichtag gilt in Niedersachsen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Niedersachsen gilt der 30. September als Einschulungsstichtag. Kinder, die bis zu diesem Datum sechs Jahre alt werden, sind mit Beginn des neuen Schuljahres schulpflichtig. Nach offizieller Auslegung zählen dazu auch Kinder, die am 1. Oktober ihren sechsten Geburtstag haben.",
      },
    },
    {
      "@type": "Question",
      name: "Wann ist die Einschulung in Niedersachsen 2026?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In Niedersachsen findet die Einschulung laut Ferienordnung am Sonnabend nach dem ersten Schultag statt – für 2026 also voraussichtlich Samstag, 15. August 2026. Der erste reguläre Schultag nach den Sommerferien ist voraussichtlich Donnerstag, 13. August 2026.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Flexibilisierung in Niedersachsen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eltern von Kindern, die zwischen dem 1. Juli und dem 30. September sechs Jahre alt werden, können den Schulbesuch durch schriftliche Erklärung gegenüber der Schule um ein Jahr hinausschieben. Die Erklärung soll in der Regel bis zum 1. Mai abgegeben werden.",
      },
    },
    {
      "@type": "Question",
      name: "Kann mein Kind in Niedersachsen früher eingeschult werden?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Jüngere Kinder können auf Antrag der Erziehungsberechtigten eingeschult werden, wenn ihr Entwicklungsstand eine erfolgreiche Mitarbeit im ersten Schuljahrgang erwarten lässt. Die Entscheidung trifft die Schulleiterin oder der Schulleiter.",
      },
    },
    {
      "@type": "Question",
      name: "Wie läuft die Schulanmeldung in Niedersachsen ab?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die zuständige Grundschule beziehungsweise der Schulträger informiert die Eltern über Anmeldung, Fristen und erforderliche Unterlagen. Verbindliche Details erhältst du bei der zuständigen Grundschule oder Schulbehörde in Niedersachsen.",
      },
    },
    {
      "@type": "Question",
      name: "Ist das Ergebnis zur Einschulung in Niedersachsen verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Der Einschulungsrechner und diese Informationsseite dienen der Orientierung. Verbindliche Informationen erhältst du bei der zuständigen Grundschule, der Schulbehörde oder beim Niedersächsischen Kultusministerium.",
      },
    },
  ],
};
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.einschulungsrechner.de/einschulung-niedersachsen/" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </head>

  <body>
    <main class="state-page">
      <a class="back-link" href="/">← Zur Startseite</a>

      <article class="state-card">
        <p class="state-kicker">Niedersachsen</p>

        <h1>
          Einschulung in<br />
          Niedersachsen:<br />
          Schulstart, Stichtag und Schuljahr
        </h1>

        <p class="lead">
          Wann kommt mein Kind in Niedersachsen in die Schule? Der Einschulungsrechner
          zeigt dir anhand des Geburtsdatums das voraussichtliche Schuljahr. In
          Niedersachsen gilt der Stichtag 30. September. Für das Schuljahr
          2026/2027 ist die Einschulung voraussichtlich für Samstag,
          15. August 2026 vorgesehen – der erste Schultag ist Donnerstag,
          13. August 2026.
        </p>

        <StateEnrollmentCalculator
          stateName="Niedersachsen"
          stateSlug="niedersachsen"
          calculatorKicker="Niedersachsen-Rechner"
          resultKicker="Niedersachsen-Ergebnis"
          headline="Einschulung in Niedersachsen berechnen"
          intro="Gib das Geburtsdatum deines Kindes ein. Niedersachsen ist hier bereits vorausgewählt. Wenn du von der Startseite kommst, übernehmen wir das Geburtsdatum automatisch aus dem Link."
        />

        <div class="quick-facts quick-facts-master" aria-label="Kurzüberblick Einschulung Niedersachsen">
          <div class="fact-card fact-card-highlight">
            <span>Nächste Einschulung</span>
            <strong>Samstag, 15. August 2026</strong>
          </div>

          <div class="fact-card fact-card-highlight">
            <span>Erster Schultag</span>
            <strong>Donnerstag, 13. August 2026</strong>
          </div>

          <div class="fact-card">
            <span>Stichtag</span>
            <strong>30. September</strong>
          </div>

          <div class="fact-card">
            <span>Sonderregel</span>
            <strong>Flexibilisierung</strong>
          </div>
        </div>

        <section class="seo-explanation-box">
          <h2>Wie funktioniert der Einschulungsrechner für Niedersachsen?</h2>

          <p>
            Der Einschulungsrechner prüft das Geburtsdatum deines Kindes und
            vergleicht es mit den Einschulungsregeln in Niedersachsen. Entscheidend
            sind vor allem der Stichtag 30. September und die Flexibilisierung für
            Kinder, die zwischen dem 1. Juli und dem 30. September sechs Jahre alt
            werden.
          </p>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. August 2020
            geboren, wird es am 15. August 2026 sechs Jahre alt. Da dieses Datum
            im flexiblen Einschulungszeitraum liegt, ist das Kind grundsätzlich
            für das Schuljahr 2026/2027 vorgesehen; Eltern können den Schulbesuch
            aber durch schriftliche Erklärung um ein Jahr hinausschieben.
          </p>

          <p>
            Die wichtigsten Termine zum allgemeinen Schulstart und zur Einschulung
            findest du im Terminblock oben. Der konkrete Einschulungstermin wird
            von der zuständigen Grundschule festgelegt und kann organisatorisch
            abweichen.
          </p>
        </section>

        <section>
          <h2>Wann ist die Einschulung in Niedersachsen 2026?</h2>

          <p>
            In Niedersachsen findet die Einschulung laut Ferienordnung am Sonnabend
            nach dem ersten Schultag statt – für 2026 also voraussichtlich Samstag,
            15. August 2026. Der allgemeine erste Schultag nach den Sommerferien
            ist voraussichtlich Donnerstag, 13. August 2026. Den konkreten Ablauf
            legt die zuständige Grundschule fest.
          </p>
        </section>

        <section>
          <h2>Welcher Einschulungsstichtag gilt in Niedersachsen?</h2>

          <p>
            In Niedersachsen gilt der 30. September als Stichtag für die
            Einschulung. Kinder, die bis zu diesem Datum sechs Jahre alt werden,
            sind mit Beginn des neuen Schuljahres regulär schulpflichtig. Nach
            offizieller Auslegung zählen dazu auch Kinder, die am 1. Oktober ihren
            sechsten Geburtstag haben.
          </p>
        </section>

        <section>
          <h2>Was bedeutet Flexibilisierung in Niedersachsen?</h2>

          <p>
            Die Flexibilisierung betrifft Kinder, die zwischen dem 1. Juli und dem
            30. September sechs Jahre alt werden. Eltern können den Schulbesuch
            ihres Kindes durch schriftliche Erklärung gegenüber der Schule um ein
            Jahr hinausschieben. Diese Erklärung soll in der Regel bis zum 1. Mai
            abgegeben werden.
          </p>
        </section>

        <section>
          <h2>Kann mein Kind in Niedersachsen früher eingeschult werden?</h2>

          <p>
            Jüngere Kinder können auf Antrag der Erziehungsberechtigten eingeschult
            werden, wenn ihr Entwicklungsstand eine erfolgreiche Mitarbeit im
            ersten Schuljahrgang erwarten lässt. Die Entscheidung trifft die
            Schulleiterin oder der Schulleiter.
          </p>
        </section>

        <section>
          <h2>Wie läuft die Schulanmeldung in Niedersachsen ab?</h2>

          <p>
            Die zuständige Grundschule beziehungsweise der Schulträger informiert
            die Eltern über Anmeldung, Fristen und erforderliche Unterlagen.
            Verbindliche Details erhältst du bei der zuständigen Grundschule oder
            Schulbehörde in Niedersachsen.
          </p>
        </section>

        <section class="example-box">
          <h2>Beispiel: Geburtsdatum im August</h2>

          <p>
            Beispielhaft zeigt der Rechner: Wird ein Kind am 15. August 2020
            geboren, wird es am 15. August 2026 sechs Jahre alt. Da dieses Datum
            zwischen dem 1. Juli und dem 30. September liegt, fällt das Kind in
            Niedersachsen in den flexiblen Einschulungszeitraum für das Schuljahr
            2026/2027.
          </p>
        </section>

        <section>
          <h2>Häufige Fragen zur Einschulung in Niedersachsen</h2>

          <div class="faq-list">
            <article class="faq-item">
              <h3>Welcher Einschulungsstichtag gilt in Niedersachsen?</h3>
              <p>
                In Niedersachsen gilt der 30. September als Einschulungsstichtag.
                Kinder, die bis zu diesem Datum sechs Jahre alt werden, sind mit
                Beginn des neuen Schuljahres schulpflichtig. Nach offizieller
                Auslegung zählen dazu auch Kinder, die am 1. Oktober ihren sechsten
                Geburtstag haben.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wann ist die Einschulung in Niedersachsen 2026?</h3>
              <p>
                In Niedersachsen findet die Einschulung laut Ferienordnung am Sonnabend
                nach dem ersten Schultag statt – für 2026 also voraussichtlich
                Samstag, 15. August 2026. Der erste reguläre Schultag nach den
                Sommerferien ist voraussichtlich Donnerstag, 13. August 2026.
              </p>
            </article>

            <article class="faq-item">
              <h3>Was bedeutet Flexibilisierung in Niedersachsen?</h3>
              <p>
                Eltern von Kindern, die zwischen dem 1. Juli und dem 30. September
                sechs Jahre alt werden, können den Schulbesuch durch schriftliche
                Erklärung gegenüber der Schule um ein Jahr hinausschieben. Die
                Erklärung soll in der Regel bis zum 1. Mai abgegeben werden.
              </p>
            </article>

            <article class="faq-item">
              <h3>Kann mein Kind in Niedersachsen früher eingeschult werden?</h3>
              <p>
                Jüngere Kinder können auf Antrag der Erziehungsberechtigten
                eingeschult werden, wenn ihr Entwicklungsstand eine erfolgreiche
                Mitarbeit im ersten Schuljahrgang erwarten lässt. Die Entscheidung
                trifft die Schulleiterin oder der Schulleiter.
              </p>
            </article>

            <article class="faq-item">
              <h3>Wie läuft die Schulanmeldung in Niedersachsen ab?</h3>
              <p>
                Die zuständige Grundschule beziehungsweise der Schulträger informiert
                die Eltern über Anmeldung, Fristen und erforderliche Unterlagen.
                Verbindliche Details erhältst du bei der zuständigen Grundschule oder
                Schulbehörde in Niedersachsen.
              </p>
            </article>

            <article class="faq-item">
              <h3>Ist das Ergebnis zur Einschulung in Niedersachsen verbindlich?</h3>
              <p>
                Nein. Der Einschulungsrechner und diese Informationsseite dienen der
                Orientierung. Verbindliche Informationen erhältst du bei der zuständigen
                Grundschule, der Schulbehörde oder beim Niedersächsischen Kultusministerium.
              </p>
            </article>
          </div>
        </section>

        <section class="source-note">
          <h2>Quellen und Hinweise</h2>

          <p>
            Die folgenden offiziellen Quellen bilden die Grundlage dieser Übersicht
            zur Einschulung in Niedersachsen:
          </p>

          <div class="source-list" aria-label="Offizielle Quellen zur Einschulung in Niedersachsen">
            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 1</p>
              <a
                class="source-link"
                href="https://www.mk.niedersachsen.de/startseite/schule/unsere_schulen/allgemein_bildende_schulen/grundschule/vor_der_einschulung/vor-der-schule-149343.html"
                target="_blank"
                rel="noopener noreferrer"
              >
                Niedersächsisches Kultusministerium: Vor der Einschulung
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 2</p>
              <a
                class="source-link"
                href="https://www.mk.niedersachsen.de/startseite/leichte_sprache/ferien/ferien-223892.html"
                target="_blank"
                rel="noopener noreferrer"
              >
                Niedersächsisches Kultusministerium: Ferien 2026
              </a>
            </div>

            <div class="source-item">
              <p class="source-kicker">Offizielle Quelle 3</p>
              <a
                class="source-link"
                href="https://voris.wolterskluwer-online.de/browse/document/0b9ab58d-6701-3d0e-b79f-b7634b4f3531"
                target="_blank"
                rel="noopener noreferrer"
              >
                NI-VORIS: § 64 NSchG – Beginn der Schulpflicht (aktuelle Fassung)
              </a>
            </div>
          </div>

          <p>
            Hinweis: Bitte prüfe verbindliche Details immer bei der zuständigen
            Grundschule, der Schulbehörde oder beim Niedersächsischen
            Kultusministerium.
          </p>

          <p class="stand">Stand der Informationen: Mai 2026</p>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    color: #172033;
    background: #f6f3ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 208, 122, 0.32), transparent 32rem),
      linear-gradient(180deg, #fbf8f1 0%, #f2eee5 100%);
  }

  .state-page {
    min-height: 100vh;
    padding: 32px 20px 64px;
  }

  .back-link {
    display: block;
    max-width: 960px;
    margin: 0 auto 20px;
    color: #465266;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #172033;
    text-decoration: underline;
  }

  .state-card {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(30px, 4vw, 56px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 70px rgba(42, 35, 21, 0.08);
  }

  .state-kicker {
    margin: 0 0 14px;
    color: #816126;
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.095em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.25rem, 5vw, 4.05rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    font-weight: 500;
    line-height: 1.64;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 30px;
  }

  .quick-facts-master {
    margin-top: 34px;
  }

  :global(body.has-niedersachsen-calculator-result) .quick-facts-master .fact-card-highlight {
    display: none;
  }

  .fact-card {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 132px;
    padding: 22px 24px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.78);
  }

  .fact-card span {
    color: #816126;
    font-size: clamp(0.92rem, 1.1vw, 1.04rem);
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .fact-card strong {
    color: #172033;
    font-size: clamp(1.32rem, 1.85vw, 1.68rem);
    font-weight: 950;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .fact-card-highlight {
    border-color: rgba(129, 97, 38, 0.18);
    background: rgba(245, 210, 138, 0.1);
  }

  section {
    margin-top: 38px;
    padding-top: 34px;
    border-top: 1px solid rgba(42, 35, 21, 0.1);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.58rem, 2.35vw, 2.12rem);
    font-weight: 950;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  h3 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.06rem, 1.25vw, 1.18rem);
    font-weight: 900;
    line-height: 1.24;
    letter-spacing: -0.025em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.68;
  }

  .example-box,
  .source-note,
  .seo-explanation-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.16);
    border-radius: 22px;
    background: rgba(245, 210, 138, 0.12);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .faq-item {
    padding: 20px;
    border: 1px solid rgba(42, 35, 21, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-item p {
    margin-top: 12px;
    color: #465266;
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    font-weight: 500;
    line-height: 1.66;
  }

  .source-list {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

  .source-item {
    display: grid;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(129, 97, 38, 0.14);
  }

  .source-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .source-kicker {
    margin: 0;
    color: #816126;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.095em;
    line-height: 1.16;
    text-transform: uppercase;
  }

  .source-link {
    display: inline;
    color: #172033;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.42;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: #816126;
  }

  .stand {
    display: inline-flex;
    width: fit-content;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(129, 97, 38, 0.1);
    color: #816126;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
  }

  @media (max-width: 720px) {
    .quick-facts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .state-page {
      padding: 22px 14px 42px;
    }

    .state-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.7rem, 7.25vw, 2.18rem);
      line-height: 1.06;
      letter-spacing: -0.05em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .fact-card {
      min-height: 102px;
      padding: 18px 22px;
    }

    .fact-card span {
      font-size: clamp(0.82rem, 3.45vw, 0.96rem);
      letter-spacing: 0.095em;
    }

    .fact-card strong {
      font-size: clamp(1.12rem, 4.9vw, 1.36rem);
      line-height: 1.14;
    }


    section {
      margin-top: 30px;
      padding-top: 28px;
    }

    h2 {
      font-size: 1.62rem;
      line-height: 1.1;
    }

    p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .faq-item p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .example-box,
    .source-note,
    .seo-explanation-box {
      padding: 20px;
      border-radius: 20px;
    }

    .source-link {
      width: auto;
      font-size: 1rem;
      line-height: 1.42;
    }
  }

  @media (max-width: 390px) {
    h1 {
      font-size: clamp(1.58rem, 7vw, 1.95rem);
      line-height: 1.07;
      letter-spacing: -0.046em;
    }
  }
</style>
