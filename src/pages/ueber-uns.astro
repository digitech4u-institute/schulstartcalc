

---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Über uns: Einschulungsrechner.de";
const pageDescription =
  "Wer steckt hinter Einschulungsrechner.de? Erfahre, wie wir Informationen recherchieren, Quellen prüfen und Eltern beim Schulstart Orientierung geben.";
const canonical = "https://www.einschulungsrechner.de/ueber-uns/";

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  isPartOf: {
    "@type": "WebSite",
    name: "Einschulungsrechner.de",
    url: "https://www.einschulungsrechner.de/",
  },
  publisher: {
    "@type": "Organization",
    name: "DigiTech4U Institute",
  },
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} schema={webPageSchema}>
  <main class="about-page">
    <article class="about-card">
      <p class="kicker">Über uns</p>
      <h1>Wer steckt hinter Einschulungsrechner.de?</h1>

      <p class="lead">
        Einschulungsrechner.de ist ein kostenloses Orientierungsangebot des
        DigiTech4U Institute, einer gemeinnützigen Organisation (NPO) mit Sitz in Österreich.
        Das Projekt wird ehrenamtlich betrieben und soll Familien mit einfachen
        digitalen Mitteln eine erste Orientierung rund um Einschulung, Stichtag und
        Schulstart geben.
      </p>

      <section>
        <h2>Warum es diese Seite gibt</h2>
        <p>
          Die Einschulung ist für Familien ein wichtiger Übergang. Gleichzeitig sind
          Stichtage, Kann-Kind-Regelungen, Zurückstellung, Anmeldung und erste
          Schultage je nach Bundesland unterschiedlich geregelt. Genau hier setzt
          Einschulungsrechner.de an: Wir möchten Eltern eine erste, gut verständliche
          Orientierung geben.
        </p>
        <p>
          Ziel ist nicht, die Entscheidung der Schule oder Schulbehörde zu ersetzen.
          Ziel ist, Eltern dabei zu helfen, die wichtigsten Begriffe und nächsten
          Schritte besser einzuordnen.
        </p>
      </section>

      <section>
        <h2>Wie wir Informationen aufbereiten</h2>
        <p>
          Unsere Inhalte basieren auf öffentlich zugänglichen Informationen der
          Bundesländer, insbesondere Ministerien, Schulportalen, Schulgesetzen,
          Verordnungen und offiziellen Terminübersichten. Auf den Bundeslandseiten
          verlinken wir die jeweils genutzten Quellen transparent im Quellenbereich.
        </p>
        <p>
          Bei der Aufbereitung achten wir darauf, juristische oder behördliche
          Formulierungen in verständliche Alltagssprache zu übertragen. Wo Regeln
          komplex oder veränderlich sind, weisen wir ausdrücklich darauf hin und
          empfehlen die Rückfrage bei der zuständigen Grundschule oder Schulbehörde.
        </p>
      </section>

      <section>
        <h2>Wer für das Projekt verantwortlich ist</h2>
        <p>
          Betreiber und redaktionell verantwortlich für dieses Angebot ist das Präsidium
          des DigiTech4U Institute, eine gemeinnützige Organisation (NPO) mit Sitz in
          Österreich. Die Inhalte werden mit ehrenamtlichem Engagement aufbereitet.
          Unser Anspruch ist, offizielle Informationen verständlich und kostenlos
          zugänglich zu machen und Familien mit einfachen digitalen Mitteln bei der
          ersten Orientierung zu unterstützen.
        </p>
      </section>

      <section class="note-box">
        <h2>Wichtig: Orientierung statt verbindliche Auskunft</h2>
        <p>
          Der Einschulungsrechner und die Inhalte auf dieser Website dienen der
          allgemeinen Orientierung. Sie ersetzen keine verbindliche Auskunft durch
          Schule, Schulamt, Schulbehörde oder Ministerium. Für die tatsächliche
          Einschulung deines Kindes ist immer die zuständige Stelle vor Ort maßgeblich.
        </p>
      </section>

      <section id="kontakt" class="contact-box">
        <h2>Kontakt & Hinweise</h2>
        <p>
          Du hast einen Hinweis zu einer Quelle, eine Korrektur oder eine Frage zum
          Angebot? Dann kontaktiere uns gerne per E-Mail.
        </p>
        <p>
          E-Mail: <a href="mailto:info@digitech4u.org">info@digitech4u.org</a><br />
          Website: <a href="https://www.digitech4u.org/" target="_blank" rel="noopener noreferrer">www.digitech4u.org</a>
        </p>
        <p class="small-note">
          Bitte beachte: Wir können keine verbindliche Rechts- oder Schulberatung
          für Einzelfälle leisten. Wende dich dafür bitte an die zuständige
          Grundschule oder Schulbehörde.
        </p>
      </section>
    </article>
  </main>
</BaseLayout>

<style is:global>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    color: #172033;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background:
      radial-gradient(circle at top left, rgba(247, 218, 154, 0.32), transparent 34rem),
      linear-gradient(180deg, #fffaf0 0%, #f7efe1 100%);
  }

  .about-page {
    min-height: 100vh;
    padding: 52px 20px 64px;
    color: #172033;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  .about-page :where(h1, h2, p, a, li, strong, span) {
    font-family: inherit;
  }

  .about-card {
    width: min(960px, 100%);
    margin: 0 auto;
    padding: clamp(30px, 6vw, 54px);
    border: 1px solid rgba(42, 35, 21, 0.08);
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.76);
    box-shadow: 0 22px 60px rgba(42, 35, 21, 0.08);
  }

  .kicker {
    margin: 0 0 18px;
    color: #816126;
    font-size: 0.82rem;
    font-weight: 950;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: #172033;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 950;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .lead {
    max-width: 760px;
    margin: 24px 0 0;
    color: #465266;
    font-size: clamp(1.08rem, 2.3vw, 1.26rem);
    line-height: 1.68;
  }

  section {
    margin-top: 34px;
    padding-top: 32px;
    border-top: 1px solid rgba(42, 35, 21, 0.08);
  }

  h2 {
    margin: 0;
    color: #172033;
    font-size: clamp(1.55rem, 3.2vw, 2.15rem);
    font-weight: 920;
    line-height: 1.12;
    letter-spacing: -0.04em;
  }

  p {
    margin: 14px 0 0;
    color: #465266;
    font-size: 1.03rem;
    line-height: 1.7;
  }

  .note-box,
  .contact-box {
    padding: 24px;
    border: 1px solid rgba(129, 97, 38, 0.14);
    border-radius: 22px;
    background: rgba(255, 248, 236, 0.72);
  }

  .contact-box a {
    color: #816126;
    font-size: 1.05rem;
    font-weight: 850;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-box a:hover {
    color: #172033;
  }

  .small-note {
    font-size: 0.95rem;
    line-height: 1.58;
  }

  @media (max-width: 520px) {
    .about-page {
      padding: 28px 14px 46px;
    }

    .about-card {
      padding: 24px;
      border-radius: 24px;
    }

    h1 {
      font-size: clamp(1.72rem, 7vw, 2.16rem);
      line-height: 1.08;
      letter-spacing: -0.047em;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.58;
    }

    section {
      margin-top: 30px;
      padding-top: 28px;
    }

    h2 {
      font-size: 1.48rem;
      line-height: 1.14;
    }

    p {
      font-size: 0.96rem;
      line-height: 1.62;
    }

    .note-box,
    .contact-box {
      padding: 20px;
      border-radius: 20px;
    }
  }
</style>