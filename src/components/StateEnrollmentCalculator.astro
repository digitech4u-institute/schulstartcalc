
---
import { enrollmentRules } from "../data/enrollmentRules";
import { enrollmentDatesBySchoolYear } from "../data/enrollmentDatesBySchoolYear";
interface Props {
  stateName: string;
  stateSlug: string;
  calculatorKicker: string;
  resultKicker: string;
  headline: string;
  intro: string;
}

const {
  stateName,
  stateSlug,
  calculatorKicker,
  resultKicker,
  headline,
  intro,
} = Astro.props;

const normalizedSlug = stateSlug.toLowerCase();
const currentSchoolYear = "2026/2027";
const currentEnrollmentDates = enrollmentDatesBySchoolYear[currentSchoolYear];
const currentStateRule = enrollmentRules[normalizedSlug];
const currentStateDates = currentEnrollmentDates?.[normalizedSlug];
const calculatorStateRule = currentStateRule
  ? {
      name: stateName,
      cutoff: currentStateRule.cutoff,
      type:
        currentStateRule.type === "optional" ? "standard_with_optional" : currentStateRule.type,
      specialWindow: currentStateRule.specialWindow,
      label: `Stichtag ${currentStateRule.cutoffLabel}`,
    }
  : null;
const calculatorEnrollmentDatesBySchoolYear = Object.fromEntries(
  Object.entries(enrollmentDatesBySchoolYear).map(([schoolYear, datesByState]) => [
    schoolYear,
    datesByState?.[normalizedSlug]
      ? {
          enrollment: datesByState[normalizedSlug].enrollment,
          enrollmentQualifier: datesByState[normalizedSlug].enrollmentQualifier,
          firstSchoolDay: datesByState[normalizedSlug].firstSchoolDay,
          note: datesByState[normalizedSlug].note,
          hasConfirmedDate: datesByState[normalizedSlug].hasConfirmedDate,
          sourceStatus: datesByState[normalizedSlug].sourceStatus,
        }
      : null,
  ]),
);
const formId = `${normalizedSlug}CalculatorForm`;
const dayInputId = `${normalizedSlug}CalcDay`;
const monthInputId = `${normalizedSlug}CalcMonth`;
const yearInputId = `${normalizedSlug}CalcYear`;
const errorId = `${normalizedSlug}DateError`;
const buttonId = `${normalizedSlug}CalculateButton`;
const resultId = `${normalizedSlug}CalculatorResult`;
const inputNamePrefix = `${normalizedSlug}_calc_part`;
---

<section class="state-calculator-box" aria-label={`Einschulung ${stateName} berechnen`}>
  <p class="calculator-kicker">{calculatorKicker}</p>
  <h2>{headline}</h2>
  <p>{intro}</p>

  <form
    class="state-calculator-form"
    id={formId}
    autocomplete="off"
    data-lpignore="true"
    data-1p-ignore="true"
    data-form-type="other"
    data-state-name={stateName}
    data-state-slug={normalizedSlug}
    data-result-kicker={resultKicker}
  >
    <div class="form-group form-group-centered">
      <span class="form-label form-label-large">Geburtsdatum deines Kindes</span>

      <div class="date-input-group" aria-label="Geburtsdatum deines Kindes">
        <div class="date-field">
          <input
            id={dayInputId}
            name={`${inputNamePrefix}_a`}
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            maxlength="2"
            placeholder="TT"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-lpignore="true"
            data-1p-ignore="true"
            data-form-type="other"
            aria-label="Tag des Datums"
          />
          <span>Tag</span>
        </div>

        <div class="date-field">
          <input
            id={monthInputId}
            name={`${inputNamePrefix}_b`}
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            maxlength="2"
            placeholder="MM"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-lpignore="true"
            data-1p-ignore="true"
            data-form-type="other"
            aria-label="Monat des Datums"
          />
          <span>Monat</span>
        </div>

        <div class="date-field date-field-year">
          <input
            id={yearInputId}
            name={`${inputNamePrefix}_c`}
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            maxlength="4"
            placeholder="JJJJ"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-lpignore="true"
            data-1p-ignore="true"
            data-form-type="other"
            aria-label="Jahr des Datums"
          />
          <span>Jahr</span>
        </div>
      </div>

      <p id={errorId} class="field-error" aria-live="polite"></p>
    </div>

    <button id={buttonId} type="submit">Einschulung berechnen</button>
  </form>

  <div class="state-calculator-result" id={resultId} hidden></div>
</section>

<script define:vars={{
  normalizedSlug,
  stateName,
  resultKicker,
  calculatorStateRule,
  calculatorEnrollmentDatesBySchoolYear,
  currentSchoolYear,
}}>
  const stateRuleFromData = calculatorStateRule;
  const enrollmentDatesBySchoolYearFromData = calculatorEnrollmentDatesBySchoolYear;
  const referenceSchoolYear = currentSchoolYear;
  const form = document.getElementById(`${normalizedSlug}CalculatorForm`);
  const birthDayInput = document.getElementById(`${normalizedSlug}CalcDay`);
  const birthMonthInput = document.getElementById(`${normalizedSlug}CalcMonth`);
  const birthYearInput = document.getElementById(`${normalizedSlug}CalcYear`);
  const dateError = document.getElementById(`${normalizedSlug}DateError`);
  const calculateButton = document.getElementById(`${normalizedSlug}CalculateButton`);
  const resultBox = document.getElementById(`${normalizedSlug}CalculatorResult`);

  function onlyDigits(value) {
    return value.replace(/\D/g, "");
  }

  function setDateError(message) {
    if (!dateError) return;
    dateError.textContent = message || "";
  }

  function pad2(value) {
    return value.toString().padStart(2, "0");
  }

  function focusInput(input) {
    if (!input) return;
    input.focus();
  }

  function isRealDate(day, month, year) {
    const date = new Date(year, month - 1, day);

    return (
      date.getFullYear() === year &&
      date.getMonth() === month - 1 &&
      date.getDate() === day
    );
  }

  function buildBirthdateValueFromFields() {
    const dayValue = onlyDigits(birthDayInput?.value || "");
    const monthValue = onlyDigits(birthMonthInput?.value || "");
    const yearValue = onlyDigits(birthYearInput?.value || "");

    if (!dayValue || !monthValue || !yearValue) {
      return {
        value: "",
        error: "Bitte gib Tag, Monat und Jahr des Geburtsdatums ein.",
      };
    }

    const day = Number(dayValue);
    const month = Number(monthValue);
    const year = Number(yearValue);
    const currentYear = new Date().getFullYear();

    if (day < 1 || day > 31) {
      return {
        value: "",
        error: "Bitte prüfe den Tag. Der Wert muss zwischen 1 und 31 liegen.",
      };
    }

    if (month < 1 || month > 12) {
      return {
        value: "",
        error: "Bitte prüfe den Monat. Der Wert muss zwischen 1 und 12 liegen.",
      };
    }

    if (yearValue.length !== 4) {
      return {
        value: "",
        error: "Bitte gib das Geburtsjahr vierstellig ein, zum Beispiel 2020.",
      };
    }

    if (year > currentYear) {
      return {
        value: "",
        error: "Das Geburtsjahr liegt in der Zukunft. Bitte prüfe deine Eingabe.",
      };
    }

    if (year < currentYear - 12) {
      return {
        value: "",
        error:
          "Das Geburtsdatum wirkt für einen Einschulungsrechner ungewöhnlich. Bitte prüfe deine Eingabe.",
      };
    }

    if (!isRealDate(day, month, year)) {
      return {
        value: "",
        error: "Dieses Datum gibt es nicht. Bitte prüfe Tag und Monat.",
      };
    }

    return {
      value: `${year}-${pad2(month)}-${pad2(day)}`,
      error: "",
    };
  }

  function fillBirthdateFields(birthdateValue) {
    const [year, month, day] = birthdateValue.split("-");

    if (birthDayInput) birthDayInput.value = day || "";
    if (birthMonthInput) birthMonthInput.value = month || "";
    if (birthYearInput) birthYearInput.value = year || "";
  }

  function updateCalculateButtonState() {
    if (!calculateButton) return;

    const birthdateResult = buildBirthdateValueFromFields();

    if (birthdateResult.value) {
      calculateButton.classList.add("is-ready");
    } else {
      calculateButton.classList.remove("is-ready");
    }
  }

  function hasBirthdateUrlParam() {
    return new URLSearchParams(window.location.search).has("geburtsdatum");
  }

  function isPageReload() {
    const navigationEntry = performance.getEntriesByType("navigation")?.[0];

    if (navigationEntry?.type) {
      return navigationEntry.type === "reload";
    }

    return performance.navigation?.type === 1;
  }

  function clearBirthdateFieldsAfterReload() {
    if (!isPageReload() || hasBirthdateUrlParam()) return;

    form?.reset();

    if (birthDayInput) birthDayInput.value = "";
    if (birthMonthInput) birthMonthInput.value = "";
    if (birthYearInput) birthYearInput.value = "";

    setDateError("");
    updateCalculateButtonState();
  }

  window.addEventListener("pageshow", clearBirthdateFieldsAfterReload);

  function normalizeDateFieldOnBlur(input, maxValue) {
    if (!input) return;

    const value = onlyDigits(input.value);
    if (!value) return;

    const numberValue = Number(value);

    if (numberValue >= 1 && numberValue <= maxValue) {
      input.value = pad2(numberValue);
    }
  }

  function parseDateParts(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    return {
      birthdate,
      birthYear,
      sixthBirthdayYear,
      month,
      day,
    };
  }

  function createDateFromMMDD(year, mmdd) {
    const [month, day] = mmdd.split("-").map(Number);
    return new Date(year, month - 1, day, 12, 0, 0);
  }

  function formatDate(date) {
    return new Intl.DateTimeFormat("de-DE", {
      weekday: "long",
      day: "numeric",
      month: "long",
      year: "numeric",
    }).format(date);
  }

  function isDateBetweenMMDD(month, day, from, to) {
    const current = month * 100 + day;
    const [fromMonth, fromDay] = from.split("-").map(Number);
    const [toMonth, toDay] = to.split("-").map(Number);
    const fromValue = fromMonth * 100 + fromDay;
    const toValue = toMonth * 100 + toDay;

    if (fromValue <= toValue) {
      return current >= fromValue && current <= toValue;
    }

    return current >= fromValue || current <= toValue;
  }

  function buildGenericEnrollmentResult(birthdateValue, stateRule) {
    if (!stateRule) return null;

    const { sixthBirthdayYear, month, day } = parseDateParts(birthdateValue);
    const cutoffDate = createDateFromMMDD(sixthBirthdayYear, stateRule.cutoff);
    const sixthBirthdayDate = new Date(sixthBirthdayYear, month - 1, day, 12, 0, 0);
    const isBeforeOrOnCutoff = sixthBirthdayDate <= cutoffDate;
    let schoolStartYear = isBeforeOrOnCutoff ? sixthBirthdayYear : sixthBirthdayYear + 1;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline = `Dein Kind wird in ${stateRule.name} voraussichtlich im Schuljahr ${schoolStartYear}/${schoolStartYear + 1} regulär eingeschult.`;
    let explanation = `Dein Kind wird in ${stateRule.name} regulär schulpflichtig, weil es bis zum ${stateRule.label.replace("Stichtag ", "")} ${schoolStartYear} sechs Jahre alt wird.`;
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText = "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen und konkrete Termine.";

    if (!isBeforeOrOnCutoff && stateRule.type === "standard_with_optional") {
      statusLabel = "Regulär schulpflichtig";
      statusTone = "regular";
      explanation = `Dein Kind wird nach dem Stichtag in ${stateRule.name} sechs Jahre alt. Deshalb ist es voraussichtlich im Schuljahr ${schoolStartYear}/${schoolStartYear + 1} regulär schulpflichtig. Eine frühere Einschulung kann auf Antrag geprüft werden.`;
      nextStepText = `Wenn du eine Einschulung schon im Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1} prüfen möchtest, informiere dich frühzeitig bei der zuständigen Grundschule über Antrag, Voraussetzungen und Fristen.`;
    }

    if (stateRule.specialWindow && isDateBetweenMMDD(month, day, stateRule.specialWindow.from, stateRule.specialWindow.to)) {
      if (stateRule.type === "corridor") {
        statusLabel = "Einschulungskorridor";
        statusTone = "optional";
        schoolStartYear = sixthBirthdayYear;
        resultHeadline = "Dein Kind liegt im Einschulungskorridor.";
        explanation = `Dein Kind fällt in ${stateRule.name} in den Einschulungskorridor, weil es zwischen dem 1. Juli und dem 30. September sechs Jahre alt wird.`;
        nextStepTitle = "Wichtig für dich";
        nextStepText = "Prüfe die Fristen bei der zuständigen Grundschule. Unter bestimmten Voraussetzungen kann eine spätere Einschulung geklärt werden.";
      }

      if (stateRule.type === "karenzzeit") {
        statusLabel = "Karenzzeitkind";
        statusTone = "optional";
        schoolStartYear = sixthBirthdayYear;
        resultHeadline = `Dein Kind ist in ${stateRule.name} ein Karenzzeitkind.`;
        explanation = `Dein Kind wird nach dem regulären Stichtag sechs Jahre alt und liegt in ${stateRule.name} innerhalb der Karenzzeit.`;
        nextStepTitle = "Wichtig für dich";
        nextStepText = "Sprich die zuständige Grundschule direkt an. Dort erfährst du, wie Anmeldung, Fristen und die konkrete Einordnung geregelt sind.";
      }

      if (stateRule.type === "flexible_window") {
        statusLabel = "Flexibler Einschulungszeitraum";
        statusTone = "optional";
        schoolStartYear = sixthBirthdayYear;
        resultHeadline = `Dein Kind fällt in ${stateRule.name} in den flexiblen Einschulungszeitraum. Eine Einschulung zum Schuljahr ${schoolStartYear}/${schoolStartYear + 1} ist grundsätzlich möglich.`;
        explanation = `In ${stateRule.name} gilt der 30. September als Stichtag. Da dein Kind zwischen dem 1. Juli und dem 30. September sechs Jahre alt wird, ist es grundsätzlich schulpflichtig; zugleich gibt es eine besondere Flexibilisierung.`;
        nextStepTitle = "Wichtig für dich";
        nextStepText = "Informiere dich bei der zuständigen Grundschule, ob eine Verschiebung des Einschulungstermins in Frage kommt und welche Fristen dafür gelten.";
      }

      if (stateRule.type === "registration_window") {
        statusLabel = "Anmeldung möglich";
        statusTone = "optional";
        schoolStartYear = sixthBirthdayYear;
        resultHeadline = `Dein Kind liegt in ${stateRule.name} im erweiterten Anmeldezeitraum.`;
        explanation = `In ${stateRule.name} gilt der 30. Juni als regulärer Stichtag. Kinder, die bis zum 30. September sechs Jahre alt werden, können durch Anmeldung der Eltern ebenfalls schulpflichtig werden.`;
        nextStepTitle = "Wichtig für dich";
        nextStepText = "Informiere dich bei der zuständigen Grundschule, ob und wie die Anmeldung für eine Einschulung in diesem Schuljahr möglich ist.";
      }

      if (stateRule.type === "berlin_optional") {
        statusLabel = "Kann-Kind";
        statusTone = "optional";
        schoolStartYear = month <= 3 ? sixthBirthdayYear - 1 : sixthBirthdayYear;
        resultHeadline = `Dein Kind ist in ${stateRule.name} ein Kann-Kind.`;
        explanation = `Dein Kind liegt in ${stateRule.name} im Zeitraum der Kann-Kind-Regelung. Eine Einschulung im Schuljahr ${schoolStartYear}/${schoolStartYear + 1} kann auf Antrag der Erziehungsberechtigten geprüft werden.`;
        nextStepTitle = "Wichtig für dich";
        nextStepText = "Sprich frühzeitig mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung beantragen möchtest.";
      }

      if (stateRule.type === "brandenburg_optional") {
        statusLabel = "Kann-Kind auf Antrag";
        statusTone = "optional";
        schoolStartYear = sixthBirthdayYear;
        resultHeadline = `Dein Kind ist in ${stateRule.name} ein Kann-Kind für das Schuljahr ${schoolStartYear}/${schoolStartYear + 1}.`;
        explanation = `Dein Kind wird nach dem regulären Stichtag, aber bis zum 31. Dezember sechs Jahre alt. In ${stateRule.name} kann eine vorzeitige Einschulung für das Schuljahr ${schoolStartYear}/${schoolStartYear + 1} auf Antrag geprüft werden.`;
        nextStepTitle = "Wichtig für dich";
        nextStepText = "Sprich frühzeitig mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung für dieses Schuljahr prüfen lassen möchtest.";
      }
    }

    if (stateRule.type === "brandenburg_optional" && month <= 7) {
      schoolStartYear = sixthBirthdayYear - 1;
      statusLabel = "Aufnahme im Ausnahmefall möglich";
      statusTone = "optional";
      resultHeadline = `Dein Kind kann in ${stateRule.name} für das Schuljahr ${schoolStartYear}/${schoolStartYear + 1} nur im Ausnahmefall aufgenommen werden.`;
      explanation = `Dein Kind wird erst nach dem 31. Dezember und vor dem 1. August des Folgejahres sechs Jahre alt. In ${stateRule.name} kann eine Aufnahme in diesem Schuljahr nur in begründeten Ausnahmefällen geprüft werden.`;
      nextStepTitle = "Wichtig für dich";
      nextStepText = "Für diesen Sonderfall solltest du dich direkt an die zuständige Grundschule wenden.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate: Boolean(enrollmentDatesBySchoolYearFromData?.[schoolYear]),
    };
  }

  function getCalculatedSchoolYearTimeState(result) {
    if (!result?.schoolYear) {
      return {
        hasStarted: false,
        isActive: false,
        isCompleted: false,
      };
    }

    const startYear = Number(result.schoolYear.split("/")[0]);
    if (!Number.isFinite(startYear)) {
      return {
        hasStarted: false,
        isActive: false,
        isCompleted: false,
      };
    }

    const schoolYearStart = new Date(startYear, 7, 1, 0, 0, 0);
    const schoolYearEnd = new Date(startYear + 1, 7, 1, 0, 0, 0);
    const today = new Date();

    const isCompleted = today >= schoolYearEnd;
    const isActive = today >= schoolYearStart && today < schoolYearEnd;

    return {
      hasStarted: isActive || isCompleted,
      isActive,
      isCompleted,
    };
  }

  function updatePageResultState(result) {
    if (!result || !document?.body) return;

    document.body.classList.add("has-state-calculator-result");
    document.body.classList.add(`has-${normalizedSlug}-calculator-result`);
    document.body.dataset.calculatorStateSlug = normalizedSlug;
    document.body.dataset.calculatorSchoolYear = result.schoolYear;
    document.body.dataset.calculatorHasConfirmedDate = result.hasConfirmedDate ? "true" : "false";
  }

  function calculateSachsenEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline = "Dein Kind wird voraussichtlich<br class=\"regular-mobile-result-break\" /> regulär eingeschult.";
    let explanation =
      "Dein Kind wird in Sachsen regulär schulpflichtig, weil es bis zum 30. Juni sechs Jahre alt wird.";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen und konkrete Termine.";

    const afterJune = month > 6 || (month === 6 && day > 30);

    if (afterJune) {
      statusLabel = "Kann-Kind";
      statusTone = "optional";
      resultHeadline = `Dein Kind ist in Sachsen im Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1} ein Kann-Kind.`;
      explanation =
        "Dein Kind gilt in Sachsen als sogenanntes Kann-Kind: Es wird nach dem Stichtag 30. Juni sechs Jahre alt und ist deshalb nicht automatisch schulpflichtig. Eltern können eine vorzeitige Einschulung beantragen – die Schule prüft dann, ob das Kind den erforderlichen Entwicklungsstand für den Schulbesuch besitzt.";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich die zuständige Grundschule direkt an, wenn du eine vorzeitige Einschulung für dein Kind prüfen möchtest.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const hasConfirmedDate = schoolYear === "2026/2027";

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

  function calculateBayernEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline = "Dein Kind wird voraussichtlich<br class=\"regular-mobile-result-break\" /> regulär eingeschult.";
    let explanation =
      "Dein Kind wird in Bayern regulär schulpflichtig, weil es bis zum 30. September sechs Jahre alt wird.";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Schuleinschreibung, Unterlagen und konkrete Termine.";

    const inCorridor =
      (month > 6 || (month === 6 && day > 30)) &&
      (month < 10 || (month === 9 && day <= 30));

    if (inCorridor) {
      statusLabel = "Einschulungskorridor";
      statusTone = "optional";
      resultHeadline =
        `Dein Kind liegt in Bayern im Einschulungskorridor für das Schuljahr ${schoolStartYear}/${schoolStartYear + 1}.`;
      explanation =
        "Dein Kind wird zwischen dem 1. Juli und dem 30. September sechs Jahre alt. In Bayern ist die Einschulung grundsätzlich vorgesehen; Eltern können den Schulstart unter bestimmten Voraussetzungen aber um ein Jahr verschieben.";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich rechtzeitig mit der zuständigen Grundschule, wenn du den Einschulungskorridor nutzen oder eine spätere Einschulung prüfen möchtest.";
    }

    if (month > 9 || (month === 9 && day > 30)) {
      schoolStartYear = sixthBirthdayYear + 1;
      statusLabel = "Regulär schulpflichtig";
      statusTone = "regular";
      resultHeadline = "";
      explanation =
        "Dein Kind wird nach dem bayerischen Stichtag sechs Jahre alt. Deshalb ist es voraussichtlich im angezeigten Schuljahr regulär schulpflichtig.";
      nextStepTitle = "Nächster sinnvoller Schritt";
      nextStepText =
        "Prüfe die konkreten Termine zur Schuleinschreibung, sobald das relevante Schuljahr von Bayern veröffentlicht wurde.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const hasConfirmedDate = schoolYear === "2026/2027";

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

  function calculateBadenWuerttembergEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    const projectedSchoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const cutoffYear = schoolStartYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline =
