
---
interface Props {
  stateName: string;
  stateSlug: string;
  calculatorKicker: string;
  resultKicker: string;
  headline: string;
  intro: string;
}

const {
  stateName,
  stateSlug,
  calculatorKicker,
  resultKicker,
  headline,
  intro,
} = Astro.props;

const normalizedSlug = stateSlug.toLowerCase();
const formId = `${normalizedSlug}CalculatorForm`;
const dayInputId = `${normalizedSlug}CalcDay`;
const monthInputId = `${normalizedSlug}CalcMonth`;
const yearInputId = `${normalizedSlug}CalcYear`;
const errorId = `${normalizedSlug}DateError`;
const buttonId = `${normalizedSlug}CalculateButton`;
const resultId = `${normalizedSlug}CalculatorResult`;
const inputNamePrefix = `${normalizedSlug}_calc_part`;
---

<section class="state-calculator-box" aria-label={`Einschulung ${stateName} berechnen`}>
  <p class="calculator-kicker">{calculatorKicker}</p>
  <h2>{headline}</h2>
  <p>{intro}</p>

  <form
    class="state-calculator-form"
    id={formId}
    autocomplete="off"
    data-lpignore="true"
    data-1p-ignore="true"
    data-form-type="other"
    data-state-name={stateName}
    data-state-slug={normalizedSlug}
    data-result-kicker={resultKicker}
  >
    <div class="form-group form-group-centered">
      <span class="form-label form-label-large">Geburtsdatum deines Kindes</span>

      <div class="date-input-group" aria-label="Geburtsdatum deines Kindes">
        <div class="date-field">
          <input
            id={dayInputId}
            name={`${inputNamePrefix}_a`}
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            maxlength="2"
            placeholder="TT"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-lpignore="true"
            data-1p-ignore="true"
            data-form-type="other"
            aria-label="Tag des Datums"
          />
          <span>Tag</span>
        </div>

        <div class="date-field">
          <input
            id={monthInputId}
            name={`${inputNamePrefix}_b`}
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            maxlength="2"
            placeholder="MM"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-lpignore="true"
            data-1p-ignore="true"
            data-form-type="other"
            aria-label="Monat des Datums"
          />
          <span>Monat</span>
        </div>

        <div class="date-field date-field-year">
          <input
            id={yearInputId}
            name={`${inputNamePrefix}_c`}
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            maxlength="4"
            placeholder="JJJJ"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-lpignore="true"
            data-1p-ignore="true"
            data-form-type="other"
            aria-label="Jahr des Datums"
          />
          <span>Jahr</span>
        </div>
      </div>

      <p id={errorId} class="field-error" aria-live="polite"></p>
    </div>

    <button id={buttonId} type="submit">Einschulung berechnen</button>
  </form>

  <div class="state-calculator-result" id={resultId} hidden></div>
</section>

<script define:vars={{ normalizedSlug, stateName, resultKicker }}>
  const form = document.getElementById(`${normalizedSlug}CalculatorForm`);
  const birthDayInput = document.getElementById(`${normalizedSlug}CalcDay`);
  const birthMonthInput = document.getElementById(`${normalizedSlug}CalcMonth`);
  const birthYearInput = document.getElementById(`${normalizedSlug}CalcYear`);
  const dateError = document.getElementById(`${normalizedSlug}DateError`);
  const calculateButton = document.getElementById(`${normalizedSlug}CalculateButton`);
  const resultBox = document.getElementById(`${normalizedSlug}CalculatorResult`);

  function onlyDigits(value) {
    return value.replace(/\D/g, "");
  }

  function setDateError(message) {
    if (!dateError) return;
    dateError.textContent = message || "";
  }

  function pad2(value) {
    return value.toString().padStart(2, "0");
  }

  function focusInput(input) {
    if (!input) return;
    input.focus();
  }

  function isRealDate(day, month, year) {
    const date = new Date(year, month - 1, day);

    return (
      date.getFullYear() === year &&
      date.getMonth() === month - 1 &&
      date.getDate() === day
    );
  }

  function buildBirthdateValueFromFields() {
    const dayValue = onlyDigits(birthDayInput?.value || "");
    const monthValue = onlyDigits(birthMonthInput?.value || "");
    const yearValue = onlyDigits(birthYearInput?.value || "");

    if (!dayValue || !monthValue || !yearValue) {
      return {
        value: "",
        error: "Bitte gib Tag, Monat und Jahr des Geburtsdatums ein.",
      };
    }

    const day = Number(dayValue);
    const month = Number(monthValue);
    const year = Number(yearValue);
    const currentYear = new Date().getFullYear();

    if (day < 1 || day > 31) {
      return {
        value: "",
        error: "Bitte prüfe den Tag. Der Wert muss zwischen 1 und 31 liegen.",
      };
    }

    if (month < 1 || month > 12) {
      return {
        value: "",
        error: "Bitte prüfe den Monat. Der Wert muss zwischen 1 und 12 liegen.",
      };
    }

    if (yearValue.length !== 4) {
      return {
        value: "",
        error: "Bitte gib das Geburtsjahr vierstellig ein, zum Beispiel 2020.",
      };
    }

    if (year > currentYear) {
      return {
        value: "",
        error: "Das Geburtsjahr liegt in der Zukunft. Bitte prüfe deine Eingabe.",
      };
    }

    if (year < currentYear - 12) {
      return {
        value: "",
        error:
          "Das Geburtsdatum wirkt für einen Einschulungsrechner ungewöhnlich. Bitte prüfe deine Eingabe.",
      };
    }

    if (!isRealDate(day, month, year)) {
      return {
        value: "",
        error: "Dieses Datum gibt es nicht. Bitte prüfe Tag und Monat.",
      };
    }

    return {
      value: `${year}-${pad2(month)}-${pad2(day)}`,
      error: "",
    };
  }

  function fillBirthdateFields(birthdateValue) {
    const [year, month, day] = birthdateValue.split("-");

    if (birthDayInput) birthDayInput.value = day || "";
    if (birthMonthInput) birthMonthInput.value = month || "";
    if (birthYearInput) birthYearInput.value = year || "";
  }

  function updateCalculateButtonState() {
    if (!calculateButton) return;

    const birthdateResult = buildBirthdateValueFromFields();

    if (birthdateResult.value) {
      calculateButton.classList.add("is-ready");
    } else {
      calculateButton.classList.remove("is-ready");
    }
  }

  function normalizeDateFieldOnBlur(input, maxValue) {
    if (!input) return;

    const value = onlyDigits(input.value);
    if (!value) return;

    const numberValue = Number(value);

    if (numberValue >= 1 && numberValue <= maxValue) {
      input.value = pad2(numberValue);
    }
  }

  function hasCalculatedSchoolYearAlreadyStarted(result) {
    if (!result?.schoolYear) return false;

    const startYear = Number(result.schoolYear.split("/")[0]);
    if (!Number.isFinite(startYear)) return false;

    const schoolYearStart = new Date(startYear, 7, 1, 0, 0, 0);
    const today = new Date();

    return today >= schoolYearStart;
  }

  function updatePageResultState(result) {
    if (!result || !document?.body) return;

    document.body.classList.add("has-state-calculator-result");
    document.body.classList.add(`has-${normalizedSlug}-calculator-result`);
    document.body.dataset.calculatorStateSlug = normalizedSlug;
    document.body.dataset.calculatorSchoolYear = result.schoolYear;
    document.body.dataset.calculatorHasConfirmedDate = result.hasConfirmedDate ? "true" : "false";
  }

  function calculateSachsenEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline = "Dein Kind wird voraussichtlich<br class=\"regular-mobile-result-break\" /> regulär eingeschult.";
    let explanation =
      "Dein Kind wird in Sachsen regulär schulpflichtig, weil es bis zum 30. Juni sechs Jahre alt wird.";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen und konkrete Termine.";

    const afterJune = month > 6 || (month === 6 && day > 30);
    const bySeptember = month < 9 || (month === 9 && day <= 30);

    if (afterJune && bySeptember) {
      statusLabel = "Einschulung durch Anmeldung möglich";
      statusTone = "optional";
      resultHeadline = `Dein Kind liegt für das Schuljahr ${sixthBirthdayYear}/${sixthBirthdayYear + 1} im erweiterten Einschulungs&shy;zeitraum.`;
      explanation =
        "Dein Kind wird nach dem 30. Juni, aber bis zum 30. September sechs Jahre alt. In Sachsen kann es durch Anmeldung der Eltern ebenfalls als schulpflichtig gelten.";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich rechtzeitig mit der zuständigen Grundschule, wenn du eine Einschulung in diesem Schuljahr prüfen oder anmelden möchtest.";
    }

    if (month > 9 || (month === 9 && day > 30)) {
      schoolStartYear = sixthBirthdayYear + 1;
      statusLabel = "Regulär schulpflichtig";
      statusTone = "regular";
      resultHeadline = "";
      explanation =
        "Dein Kind wird nach dem sächsischen Stichtag sechs Jahre alt. Deshalb ist es voraussichtlich im angezeigten Schuljahr regulär schulpflichtig.";
      nextStepTitle = "Nächster sinnvoller Schritt";
      nextStepText =
        "Prüfe die konkreten Anmeldefristen und Termine, sobald das relevante Schuljahr von Sachsen veröffentlicht wurde.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const hasConfirmedDate = schoolYear === "2026/2027";

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

  function calculateBayernEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline = "Dein Kind wird voraussichtlich<br class=\"regular-mobile-result-break\" /> regulär eingeschult.";
    let explanation =
      "Dein Kind wird in Bayern regulär schulpflichtig, weil es bis zum 30. September sechs Jahre alt wird.";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Schuleinschreibung, Unterlagen und konkrete Termine.";

    const inCorridor =
      (month > 6 || (month === 6 && day > 30)) &&
      (month < 10 || (month === 9 && day <= 30));

    if (inCorridor) {
      statusLabel = "Einschulungskorridor";
      statusTone = "optional";
      resultHeadline = "Dein Kind liegt im Einschulungs&shy;korridor.";
      explanation =
        "Dein Kind wird zwischen dem 1. Juli und dem 30. September sechs Jahre alt. In Bayern ist die Einschulung grundsätzlich vorgesehen; Eltern können den Schulstart unter bestimmten Voraussetzungen aber um ein Jahr verschieben.";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich rechtzeitig mit der zuständigen Grundschule, wenn du den Einschulungskorridor nutzen oder eine spätere Einschulung prüfen möchtest.";
    }

    if (month > 9 || (month === 9 && day > 30)) {
      schoolStartYear = sixthBirthdayYear + 1;
      statusLabel = "Regulär schulpflichtig";
      statusTone = "regular";
      resultHeadline = "";
      explanation =
        "Dein Kind wird nach dem bayerischen Stichtag sechs Jahre alt. Deshalb ist es voraussichtlich im angezeigten Schuljahr regulär schulpflichtig.";
      nextStepTitle = "Nächster sinnvoller Schritt";
      nextStepText =
        "Prüfe die konkreten Termine zur Schuleinschreibung, sobald das relevante Schuljahr von Bayern veröffentlicht wurde.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const hasConfirmedDate = schoolYear === "2026/2027";

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

  function calculateBadenWuerttembergEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    const projectedSchoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const cutoffYear = schoolStartYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline =
      `Dein Kind wird in Baden-Württemberg voraussichtlich im Schuljahr ${projectedSchoolYear} regulär eingeschult.`;
    let explanation =
      `Dein Kind wird in Baden-Württemberg regulär schulpflichtig, weil es bis zum 30. Juni ${cutoffYear} sechs Jahre alt wird und damit für das Schuljahr ${projectedSchoolYear} schulpflichtig ist.`;
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen und konkrete Termine.";

    const afterJune = month > 6 || (month === 6 && day > 30);

    if (afterJune) {
      statusLabel = "Kann-Kind";
      statusTone = "optional";
      resultHeadline =
        `Dein Kind ist in Baden-Württemberg ein Kann-Kind. Eine Einschulung im Schuljahr ${projectedSchoolYear} ist durch Anmeldung an der Grundschule möglich.`;
      explanation =
        `Dein Kind wird nach dem 30. Juni ${cutoffYear} sechs Jahre alt. Es ist daher nicht automatisch regulär schulpflichtig, kann aber über die Stichtagsflexibilisierung für das Schuljahr ${projectedSchoolYear} angemeldet werden.`;
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        `Melde dich frühzeitig bei der zuständigen Grundschule. Dort wird geprüft, ob dein Kind schulbereit ist und für das Schuljahr ${projectedSchoolYear} eingeschult werden kann.`;
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const hasConfirmedDate = schoolYear === "2026/2027";

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

  function calculateNordrheinWestfalenEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline = "Dein Kind wird voraussichtlich<br class=\"regular-mobile-result-break\" /> regulär eingeschult.";
    let explanation =
      "Dein Kind wird in Nordrhein-Westfalen regulär schulpflichtig, weil es bis einschließlich 30. September sechs Jahre alt wird und damit ab dem 1. August desselben Jahres schulpflichtig ist.";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen und konkrete Termine.";

    const afterSeptember = month > 9 || (month === 9 && day >= 30);

    if (afterSeptember) {
      schoolStartYear = sixthBirthdayYear + 1;
      statusLabel = "Regulär schulpflichtig";
      statusTone = "regular";
      resultHeadline = "";
      explanation =
        "Dein Kind wird nach dem nordrhein-westfälischen Einschulungsstichtag sechs Jahre alt. Deshalb ist es voraussichtlich im angezeigten Schuljahr regulär schulpflichtig. Eine frühere Einschulung kann auf Antrag der Eltern geprüft werden.";
      nextStepTitle = "Nächster sinnvoller Schritt";
      nextStepText =
        "Sprich mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung prüfen möchtest.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const hasConfirmedDate = schoolYear === "2026/2027";

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

  function calculateNiedersachsenEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    const projectedSchoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const cutoffYear = schoolStartYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline =
      `Dein Kind wird in Niedersachsen voraussichtlich im Schuljahr ${projectedSchoolYear} regulär eingeschult.`;
    let explanation =
      `Dein Kind wird in Niedersachsen regulär schulpflichtig, weil es bis zum 1. Oktober ${cutoffYear} sechs Jahre alt wird und damit für das Schuljahr ${projectedSchoolYear} schulpflichtig ist.`;
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen, Sprachstandsfeststellung und konkrete Termine.";

    const afterOctoberFirst = month > 10 || (month === 10 && day > 1);

    if (afterOctoberFirst) {
      schoolStartYear = sixthBirthdayYear + 1;
      statusLabel = "Regulär schulpflichtig";
      statusTone = "regular";
      resultHeadline = "";
      explanation =
        "Dein Kind wird nach dem niedersächsischen Stichtag sechs Jahre alt. Deshalb ist es voraussichtlich im angezeigten Schuljahr regulär schulpflichtig. Eine vorzeitige Einschulung kann auf Antrag der Eltern geprüft werden.";
      nextStepTitle = "Nächster sinnvoller Schritt";
      nextStepText =
        "Sprich mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung prüfen möchtest.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const hasConfirmedDate = schoolYear === "2026/2027";

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };

  }

  function calculateHessenEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    const projectedSchoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const cutoffYear = schoolStartYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let resultHeadline =
      `Dein Kind wird in Hessen voraussichtlich im Schuljahr ${projectedSchoolYear} regulär eingeschult.`;
    let explanation =
      `Dein Kind wird in Hessen regulär schulpflichtig, weil es bis zum 30. Juni ${cutoffYear} das sechste Lebensjahr vollendet und damit zum 1. August ${cutoffYear} schulpflichtig wird.`;
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen, Sprachstandsfeststellung und konkrete Termine.";

    const afterOfficialCutoff = month > 7 || (month === 7 && day > 1);

    if (afterOfficialCutoff) {
      statusLabel = "Kann-Kind";
      statusTone = "optional";
      resultHeadline =
        `Dein Kind ist in Hessen ein Kann-Kind. Eine Einschulung im Schuljahr ${projectedSchoolYear} kann auf Antrag geprüft werden.`;
      explanation =
        `Dein Kind vollendet das sechste Lebensjahr nach dem hessischen Stichtag. Eine vorzeitige Einschulung für das Schuljahr ${projectedSchoolYear} kann auf schriftlichen Antrag der Eltern von der Schulleitung geprüft werden. Bei Kindern, die erst nach dem 31. Dezember das sechste Lebensjahr vollenden, kann zusätzlich eine schulpsychologische Überprüfung angeordnet werden.`;
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich frühzeitig mit der zuständigen Grundschule. Dort erfährst du, wie der Antrag gestellt wird und welche Einschätzungen für die Entscheidung berücksichtigt werden.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const hasConfirmedDate = schoolYear === "2026/2027";

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };

  }

  function calculateBerlinEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen, Einschulungsuntersuchung und konkrete Termine.";

    const bornOctoberToDecember = month >= 10;
    const bornJanuaryToMarch = month <= 3;

    if (bornOctoberToDecember) {
      statusLabel = "Kann-Kind";
      statusTone = "optional";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich frühzeitig mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung beantragen möchtest. Voraussetzung ist unter anderem, dass kein Sprachförderbedarf besteht.";
    }

    if (bornJanuaryToMarch) {
      schoolStartYear = sixthBirthdayYear - 1;
      statusLabel = "Kann-Kind";
      statusTone = "optional";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich frühzeitig mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung beantragen möchtest. Voraussetzung ist unter anderem, dass kein Sprachförderbedarf besteht.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const cutoffYear = schoolStartYear;
    const hasConfirmedDate = schoolYear === "2026/2027";

    let resultHeadline =
      `Dein Kind wird in Berlin voraussichtlich im Schuljahr ${schoolYear} regulär eingeschult.`;
    let explanation =
      `Dein Kind wird in Berlin regulär schulpflichtig, weil es bis zum 30. September ${cutoffYear} sechs Jahre alt wird und damit mit Beginn des Schuljahres ${schoolYear} schulpflichtig ist.`;

    if (statusTone === "optional") {
      resultHeadline =
        `Dein Kind ist in Berlin ein Kann-Kind. Eine Einschulung im Schuljahr ${schoolYear} kann auf Antrag geprüft werden.`;
      explanation =
        `Dein Kind vollendet das sechste Lebensjahr im Zeitraum der Berliner Kann-Kind-Regelung. Eine Einschulung im Schuljahr ${schoolYear} kann auf Antrag der Erziehungsberechtigten geprüft werden, wenn kein Sprachförderbedarf besteht.`;
    }

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

  function calculateHamburgEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen und konkrete Termine.";

    const afterJune = month > 6 || (month === 6 && day > 30);

    if (afterJune) {
      statusLabel = "Vorzeitige Einschulung auf Antrag möglich";
      statusTone = "optional";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich frühzeitig mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung für dieses Schuljahr prüfen lassen möchtest.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const cutoffYear = schoolStartYear;
    const hasConfirmedDate = schoolYear === "2026/2027";

    let resultHeadline =
      `Dein Kind wird in Hamburg voraussichtlich im Schuljahr ${schoolYear} regulär eingeschult.`;
    let explanation =
      `Dein Kind wird in Hamburg regulär schulpflichtig, weil es bis zum 30. Juni ${cutoffYear} sechs Jahre alt wird und damit für das Schuljahr ${schoolYear} schulpflichtig ist.`;

    if (afterJune) {
      resultHeadline =
        `Dein Kind ist in Hamburg nicht automatisch regulär schulpflichtig. Eine Einschulung im Schuljahr ${schoolYear} kann auf Antrag geprüft werden.`;
      explanation =
        `Dein Kind wird nach dem 30. Juni ${cutoffYear} sechs Jahre alt. Deshalb ist es in Hamburg für das Schuljahr ${schoolYear} nicht automatisch regulär schulpflichtig. Eine vorzeitige Einschulung kann auf Antrag der Sorgeberechtigten geprüft werden.`;
    }

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

  function calculateBrandenburgEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, Unterlagen, schulärztliche Untersuchung und konkrete Termine.";

    const octoberToDecember = month >= 10;
    const januaryToJuly = month <= 7;

    if (octoberToDecember) {
      statusLabel = "Kann-Kind auf Antrag";
      statusTone = "optional";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich frühzeitig mit der zuständigen Grundschule, wenn du eine vorzeitige Einschulung für dieses Schuljahr prüfen lassen möchtest.";
    }

    if (januaryToJuly) {
      schoolStartYear = sixthBirthdayYear - 1;
      statusLabel = "Aufnahme im Ausnahmefall möglich";
      statusTone = "optional";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Für Kinder, die erst nach dem 31. Dezember, aber noch vor dem 1. August des Folgejahres sechs Jahre alt werden, kann in begründeten Ausnahmefällen eine vorzeitige Aufnahme geprüft werden.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const cutoffYear = schoolStartYear;
    const hasConfirmedDate = schoolYear === "2026/2027";

    let resultHeadline =
      `Dein Kind wird in Brandenburg voraussichtlich im Schuljahr ${schoolYear} regulär eingeschult.`;
    let explanation =
      `Dein Kind wird in Brandenburg regulär schulpflichtig, weil es bis zum 30. September ${cutoffYear} sechs Jahre alt wird und damit ab dem 1. August ${cutoffYear} schulpflichtig ist.`;

    if (octoberToDecember) {
      resultHeadline =
        `Dein Kind ist in Brandenburg ein Kann-Kind. Eine Einschulung im Schuljahr ${schoolYear} kann auf Antrag geprüft werden.`;
      explanation =
        `Dein Kind wird nach dem 30. September ${cutoffYear}, aber bis zum 31. Dezember ${cutoffYear} sechs Jahre alt. In Brandenburg kann eine vorzeitige Einschulung für das Schuljahr ${schoolYear} auf Antrag der Eltern geprüft werden.`;
    }

    if (januaryToJuly) {
      resultHeadline =
        `Dein Kind kann in Brandenburg nur in begründeten Ausnahmefällen im Schuljahr ${schoolYear} aufgenommen werden.`;
      explanation =
        `Dein Kind wird erst nach dem 31. Dezember ${cutoffYear} und vor dem 1. August ${cutoffYear + 1} sechs Jahre alt. In Brandenburg kann eine Aufnahme in diesem Schuljahr nur in begründeten Ausnahmefällen geprüft werden.`;
    }

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

