  function calculateSaarlandEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, schul- oder amtsärztliche Untersuchung und konkrete Termine.";

    const afterJune = month > 6 || (month === 6 && day > 30);
    const januaryToDecember = month >= 1 && month <= 12;

    if (afterJune) {
      statusLabel = "Kann-Kind";
      statusTone = "optional";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich die zuständige Grundschule direkt an, wenn du eine vorzeitige Einschulung für dein Kind prüfen möchtest.";
    }

    if (!afterJune && januaryToDecember) {
      const previousSchoolStartYear = sixthBirthdayYear - 1;
      const today = new Date();
      const currentYear = today.getFullYear();
      const currentSchoolStartYear = today >= new Date(currentYear, 7, 1, 0, 0, 0)
        ? currentYear
        : currentYear - 1;
      const previousSchoolYearIsFuture = previousSchoolStartYear > currentSchoolStartYear;

      if (previousSchoolYearIsFuture) {
        schoolStartYear = previousSchoolStartYear;
        statusLabel = "Kann-Kind";
        statusTone = "optional";
        nextStepTitle = "Wichtig für dich";
        nextStepText =
          "Sprich die zuständige Grundschule direkt an, wenn du eine sehr frühe Einschulung für dein Kind prüfen möchtest. In diesem Fall können zusätzliche Einschätzungen erforderlich sein.";
      }
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const cutoffYear = schoolStartYear;
    const hasConfirmedDate = schoolYear === "2026/2027";
    let resultHeadline =
      `Dein Kind wird im Saarland voraussichtlich im Schuljahr ${schoolYear} regulär eingeschult.`;
    let explanation =
      `Dein Kind wird im Saarland regulär schulpflichtig, weil es bis zum 30. Juni ${cutoffYear} sechs Jahre alt wird und damit mit Beginn des Schuljahres ${schoolYear} schulpflichtig ist.`;

    if (statusTone === "optional" && schoolStartYear === sixthBirthdayYear) {
      resultHeadline =
        `Dein Kind ist im Saarland ein Kann-Kind. Eine Einschulung im Schuljahr ${schoolYear} kann auf Antrag geprüft werden.`;
      explanation =
        `Dein Kind vollendet das sechste Lebensjahr nach dem Stichtag 30. Juni ${cutoffYear} und ist deshalb nicht automatisch schulpflichtig. Eine vorzeitige Einschulung im Schuljahr ${schoolYear} kann auf Antrag der Erziehungsberechtigten geprüft werden.`;
    }

    if (statusTone === "optional" && schoolStartYear < sixthBirthdayYear) {
      resultHeadline =
        `Dein Kind kann im Saarland nur auf Antrag sehr früh im Schuljahr ${schoolYear} aufgenommen werden.`;
      explanation =
        `Dein Kind vollendet das sechste Lebensjahr erst im Kalenderjahr nach Beginn des Schuljahres ${schoolYear}. Im Saarland kann eine vorzeitige Aufnahme zu Anfang des Schuljahres auf Antrag geprüft werden; die Entscheidung trifft die Schulleitung auf Grundlage der vorgesehenen ärztlichen Untersuchung und Beratung.`;
    }

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

  function calculateBremenEnrollment(birthdateValue) {
    const birthdate = new Date(`${birthdateValue}T12:00:00`);
    const birthYear = birthdate.getFullYear();
    const sixthBirthdayYear = birthYear + 6;
    const month = birthdate.getMonth() + 1;
    const day = birthdate.getDate();

    let schoolStartYear = sixthBirthdayYear;
    let statusLabel = "Regulär schulpflichtig";
    let statusTone = "regular";
    let nextStepTitle = "Nächster sinnvoller Schritt";
    let nextStepText =
      "Informiere dich frühzeitig bei der zuständigen Grundschule über Anmeldung, schulische und gesundheitliche Einschätzungen sowie konkrete Termine.";

    const afterJune = month > 6 || (month === 6 && day > 30);
    const inKarenzzeit = afterJune && month <= 12;
    const inJanuaryEarlyAdmission = month === 1;

    if (inKarenzzeit) {
      statusLabel = "Karenzzeitkind";
      statusTone = "optional";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich die zuständige Grundschule direkt an. Die Anmeldung eines Karenzzeitkindes ist verbindlich; bei Geburtstagen ab Oktober kann zusätzlich eine Antragsprüfung erforderlich sein.";
    }

    if (inJanuaryEarlyAdmission) {
      schoolStartYear = sixthBirthdayYear - 1;
      statusLabel = "Vorzeitige Einschulung auf Antrag";
      statusTone = "optional";
      nextStepTitle = "Wichtig für dich";
      nextStepText =
        "Sprich die zuständige Grundschule direkt an, wenn du eine vorzeitige Einschulung für dein Kind prüfen möchtest. Maßgeblich sind unter anderem Schulreife und schulärztliche Einschätzung.";
    }

    const schoolYear = `${schoolStartYear}/${schoolStartYear + 1}`;
    const cutoffYear = schoolStartYear;
    const hasConfirmedDate = schoolYear === "2026/2027";

    let resultHeadline =
      `Dein Kind wird in Bremen voraussichtlich im Schuljahr ${schoolYear} regulär eingeschult.`;
    let explanation =
      `Dein Kind wird in Bremen regulär schulpflichtig, weil es bis zum 30. Juni ${cutoffYear} sechs Jahre alt wird und damit zum 1. August ${cutoffYear} schulpflichtig ist.`;

    if (statusLabel === "Karenzzeitkind") {
      resultHeadline =
        `Dein Kind ist in Bremen ein Karenzzeitkind. Eine Einschulung im Schuljahr ${schoolYear} ist innerhalb der Anmeldefrist möglich.`;
      explanation =
        `Dein Kind wird nach dem Stichtag 30. Juni ${cutoffYear}, aber bis zum 31. Dezember ${cutoffYear} sechs Jahre alt. Damit gilt es in Bremen als Karenzzeitkind. Die Anmeldung innerhalb der Anmeldefrist ist verbindlich; die zuständige Grundschule klärt die konkrete Einordnung.`;
    }

    if (statusLabel === "Vorzeitige Einschulung auf Antrag") {
      resultHeadline =
        `Dein Kind kann in Bremen nur auf Antrag vorzeitig im Schuljahr ${schoolYear} eingeschult werden.`;
      explanation =
        `Dein Kind vollendet das sechste Lebensjahr im Januar ${schoolStartYear + 1}. Für Kinder, die bis zum 31. Januar des Folgejahres sechs Jahre alt werden, kann in Bremen eine vorzeitige Aufnahme auf Antrag geprüft werden. Maßgeblich sind unter anderem Schulreife und schulärztliche Einschätzung.`;
    }

    return {
      schoolYear,
      statusLabel,
      statusTone,
      resultHeadline,
      explanation,
      nextStepTitle,
      nextStepText,
      hasConfirmedDate,
    };
  }

